{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "WebhookDeliveryWorker": {
    "Enabled": true,
    "PollIntervalSeconds": 15,
    "BatchSize": 10,
    "RequestTimeoutSeconds": 15,
    "RetryCooldownSeconds": 30,
    "MaxAttempts": 5
  },
  "ProviderCallbackWorker": {
    "Enabled": true,
    "PollIntervalSeconds": 10,
    "BatchSize": 20,
    "RetryCooldownSeconds": 15
  },
  "InactiveReminderWorker": {
    "MaxItemsPerRun": 200,
    "InactiveReminderPushGateway": ""
  }
}
