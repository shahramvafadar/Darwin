<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.LoginPage"
    x:DataType="vm:LoginViewModel"
    Title="{x:Static res:AppResources.LoginTitle}">

    <ScrollView x:Name="RootScrollView">
        <VerticalStackLayout Padding="24" Spacing="20">
            <Image Source="loyan_logo.png"
                   WidthRequest="120" HeightRequest="120"
                   HorizontalOptions="Center" />

            <Label Text="{x:Static res:AppResources.LoginTitle}"
                   Style="{StaticResource TitleLabelStyle}"
                   HorizontalOptions="Center" />

            <Label Text="{x:Static res:AppResources.EmailLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Email}"
                   Keyboard="Email"
                   Placeholder="{x:Static res:AppResources.LoginEmailPlaceholder}"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.PasswordLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Password}"
                   IsPassword="True"
                   Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Button Text="{x:Static res:AppResources.LoginButton}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding LoginCommand}" />

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="{x:Static res:AppResources.RegisterButton}"
                        Clicked="OnRegisterClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource BrandGold500}" />

                <Button Text="{x:Static res:AppResources.ForgotPasswordButton}"
                        Clicked="OnForgotPasswordClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource BrandGold500}" />
            </HorizontalStackLayout>

            <Button Text="{x:Static res:AppResources.RequestActivationEmailButton}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource BrandGold500}"
                    Command="{Binding RequestActivationEmailCommand}" />

            <Border Stroke="{StaticResource Neutral300}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.AuthLegalSectionTitle}"
                           FontAttributes="Bold"
                           FontSize="16" />

                    <Label Text="{x:Static res:AppResources.AuthLegalSectionSubtitle}"
                           FontSize="13"
                           LineBreakMode="WordWrap"
                           Opacity="0.85" />

                    <Button Text="{x:Static res:AppResources.LegalImpressumButton}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenImpressumCommand}" />

                    <Button Text="{x:Static res:AppResources.LegalPrivacyNoticeButton}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenPrivacyPolicyCommand}" />

                    <Button Text="{x:Static res:AppResources.LegalTermsButton}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenTermsCommand}" />

                    <Button Text="{x:Static res:AppResources.LegalHubTitle}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource BrandGold500}"
                            Clicked="OnLegalHubClicked" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding InfoMessage}"
                   TextColor="{StaticResource BrandGold500}"
                   IsVisible="{Binding HasInfo}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
