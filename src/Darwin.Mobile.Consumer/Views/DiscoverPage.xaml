<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:loyalty="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    x:Class="Darwin.Mobile.Consumer.Views.DiscoverPage"
    x:DataType="vm:DiscoverViewModel"
    Title="{x:Static res:AppResources.DiscoverTitle}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,28" Spacing="16">
                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.DiscoverTitle}" Style="{StaticResource TitleLabelStyle}" />
                        <Label Text="{x:Static res:AppResources.DiscoverExploreHeadline}" Style="{StaticResource BodyLabelStyle}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0" Text="{x:Static res:AppResources.DiscoverMyBusinessesTab}" Command="{Binding ShowJoinedTabCommand}" Style="{StaticResource OutlinedButtonStyle}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsJoinedTabSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource BrushPrimary}" />
                                        <Setter Property="TextColor" Value="{StaticResource BrushOnPrimary}" />
                                        <Setter Property="BorderWidth" Value="0" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Grid.Column="1" Text="{x:Static res:AppResources.DiscoverExploreTab}" Command="{Binding ShowExploreTabCommand}" Style="{StaticResource OutlinedButtonStyle}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsExploreTabSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource BrushPrimary}" />
                                        <Setter Property="TextColor" Value="{StaticResource BrushOnPrimary}" />
                                        <Setter Property="BorderWidth" Value="0" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout IsVisible="{Binding IsJoinedTabSelected}" Spacing="14">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding JoinedBusinessCount, StringFormat='{x:Static res:AppResources.DiscoverJoinedBusinessesCountFormat}'}" Style="{StaticResource CaptionLabelStyle}" />
                                <Label Text="{Binding JoinedBusinessCount}" Style="{StaticResource MetricValueLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding TotalJoinedPointsBalance, StringFormat='{x:Static res:AppResources.DiscoverTotalPointsFormat}'}" Style="{StaticResource CaptionLabelStyle}" />
                                <Label Text="{Binding TotalJoinedPointsBalance}" Style="{StaticResource MetricValueLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding TopJoinedBusinessName, StringFormat='{x:Static res:AppResources.DiscoverTopBalanceBusinessFormat}'}" Style="{StaticResource CaptionLabelStyle}" />
                                <Label Text="{Binding TopJoinedBusinessName}" FontAttributes="Bold" FontSize="15" LineBreakMode="TailTruncation" TextColor="{StaticResource BrushOnSurface}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label Text="{x:Static res:AppResources.DiscoverMyBusinessesEmpty}" Style="{StaticResource BodyLabelStyle}" IsVisible="{Binding HasJoinedAccounts, Converter={StaticResource InverseBoolConverter}}" />

                    <CollectionView x:Name="JoinedAccountsCollectionView" ItemsSource="{Binding JoinedAccounts}" SelectionMode="Single" SelectionChanged="OnJoinedBusinessSelected" IsVisible="{Binding HasJoinedAccounts}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="loyalty:LoyaltyAccountSummary">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,2">
                                    <VerticalStackLayout Spacing="10">
                                        <HorizontalStackLayout Spacing="10">
                                            <Border Style="{StaticResource MutedCardBorderStyle}" Padding="10,8">
                                                <Label Text="{Binding PointsBalance}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource BrushPrimaryPressed}" />
                                            </Border>
                                            <VerticalStackLayout Spacing="3" HorizontalOptions="FillAndExpand">
                                                <Label Text="{Binding BusinessName}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource BrushOnSurface}" />
                                                <Label Text="{Binding PointsBalance, StringFormat='{x:Static res:AppResources.PointsBalanceFormat}'}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Button Grid.Column="0" Text="{x:Static res:AppResources.DiscoverOpenQrButton}" Clicked="OnOpenQrClicked" CommandParameter="{Binding BusinessId}" Style="{StaticResource PrimaryButtonStyle}" />
                                            <Button Grid.Column="1" Text="{x:Static res:AppResources.DiscoverOpenRewardsButton}" Clicked="OnOpenRewardsClicked" CommandParameter="{Binding BusinessId}" Style="{StaticResource OutlinedButtonStyle}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsExploreTabSelected}" Spacing="14">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Border Style="{StaticResource FormFieldBorderStyle}">
                                <SearchBar Text="{Binding SearchQuery}" Placeholder="{x:Static res:AppResources.DiscoverSearchPlaceholder}" SearchCommand="{Binding SearchCommand}" />
                            </Border>
                            <Border Style="{StaticResource FormFieldBorderStyle}">
                                <Picker Title="{x:Static res:AppResources.DiscoverCategoryFilterLabel}" ItemsSource="{Binding CategoryKinds}" ItemDisplayBinding="{Binding DisplayName}" SelectedItem="{Binding SelectedCategory}" />
                            </Border>
                            <Border Style="{StaticResource MutedCardBorderStyle}">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{x:Static res:AppResources.DiscoverNearbyOnlyLabel}" FontAttributes="Bold" TextColor="{StaticResource BrushOnSurface}" />
                                            <Label Text="{x:Static res:AppResources.DiscoverNearbyRadiusLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                        </VerticalStackLayout>
                                        <Switch Grid.Column="1" IsToggled="{Binding IsNearbyOnly}" OnColor="{StaticResource BrandGold500}" />
                                    </Grid>
                                    <Picker ItemsSource="{Binding NearbyRadiusOptions}" SelectedItem="{Binding SelectedNearbyRadiusMeters}" IsVisible="{Binding IsNearbyOnly}">
                                        <Picker.ItemDisplayBinding>
                                            <Binding Path="." StringFormat="{x:Static res:AppResources.DiscoverNearbyRadiusMetersFormat}" />
                                        </Picker.ItemDisplayBinding>
                                    </Picker>
                                </VerticalStackLayout>
                            </Border>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="{x:Static res:AppResources.DiscoverSearchButton}" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Grid.Column="1" Text="{x:Static res:AppResources.DiscoverClearFiltersButton}" Command="{Binding ClearFiltersCommand}" Style="{StaticResource OutlinedButtonStyle}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="0" IsVisible="{Binding HasExploreResults}">
                        <maps:Map x:Name="ExploreMap" HeightRequest="220" IsVisible="{Binding HasExploreResults}" IsShowingUser="{Binding IsNearbyOnly}" MapType="Street" />
                    </Border>

                    <Label Text="{x:Static res:AppResources.DiscoverExploreEmpty}" Style="{StaticResource BodyLabelStyle}" IsVisible="{Binding HasExploreResults, Converter={StaticResource InverseBoolConverter}}" />

                    <CollectionView x:Name="ExploreBusinessesCollectionView" ItemsSource="{Binding ExploreBusinesses}" SelectionMode="Single" SelectionChanged="OnExploreBusinessSelected" IsVisible="{Binding HasExploreResults}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DiscoverExploreItem">
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,2">
                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Business.Name}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource BrushOnSurface}" />
                                                <Label Text="{Binding Business.Category, StringFormat='{x:Static res:AppResources.BusinessCategoryFormat}'}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding Business.Category, Converter={StaticResource InverseBoolConverter}}" />
                                                <Label Text="{Binding Business.City}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding Business.City, Converter={StaticResource NullCheckConverter}}" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}" Padding="10,8" IsVisible="{Binding IsJoined}">
                                                <Label Text="{x:Static res:AppResources.DiscoverAlreadyJoinedLabel}" FontSize="12" />
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
