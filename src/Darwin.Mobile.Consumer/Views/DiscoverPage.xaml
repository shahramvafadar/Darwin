<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:contracts="clr-namespace:Darwin.Contracts.Businesses;assembly=Darwin.Contracts"
    xmlns:loyalty="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    x:Class="Darwin.Mobile.Consumer.Views.DiscoverPage"
    x:DataType="vm:DiscoverViewModel"
    Title="{x:Static res:AppResources.DiscoverTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="{x:Static res:AppResources.DiscoverTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <!--
              Discover tab switcher:
              - My Businesses: joined memberships and quick actions.
              - Explore: searchable catalog for finding/joining new businesses.
            -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="{x:Static res:AppResources.DiscoverMyBusinessesTab}"
                        Command="{Binding ShowJoinedTabCommand}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.DiscoverExploreTab}"
                        Command="{Binding ShowExploreTabCommand}" />
            </Grid>

            <!-- Joined businesses section (quick access for frequent usage). -->
            <VerticalStackLayout IsVisible="{Binding IsJoinedTabSelected}" Spacing="12">
                <Label Text="{x:Static res:AppResources.DiscoverMyBusinessesHeadline}"
                       FontAttributes="Bold" />

                <Border Stroke="{StaticResource BrushGray300}"
                        StrokeThickness="1"
                        Padding="10"
                        IsVisible="{Binding HasJoinedAccounts}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding JoinedBusinessCount, StringFormat='{x:Static res:AppResources.DiscoverJoinedBusinessesCountFormat}'}" FontSize="13" />
                        <Label Text="{Binding TotalJoinedPointsBalance, StringFormat='{x:Static res:AppResources.DiscoverTotalPointsFormat}'}" FontSize="13" />
                        <Label Text="{Binding TopJoinedBusinessName, StringFormat='{x:Static res:AppResources.DiscoverTopBalanceBusinessFormat}'}" FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{x:Static res:AppResources.DiscoverMyBusinessesEmpty}"
                       IsVisible="{Binding HasJoinedAccounts, Converter={StaticResource InverseBoolConverter}}" />

                <CollectionView x:Name="JoinedAccountsCollectionView"
                                ItemsSource="{Binding JoinedAccounts}"
                                SelectionMode="Single"
                                SelectionChanged="OnJoinedBusinessSelected"
                                IsVisible="{Binding HasJoinedAccounts}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="loyalty:LoyaltyAccountSummary">
                            <Border Stroke="{StaticResource BrushPrimary}"
                                    StrokeThickness="1"
                                    Padding="12"
                                    Margin="4">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding BusinessName}"
                                           FontSize="16"
                                           FontAttributes="Bold" />

                                    <Label Text="{Binding PointsBalance,
                                                          StringFormat='{x:Static res:AppResources.PointsBalanceFormat}'}"
                                           FontSize="14" />

                                    <HorizontalStackLayout Spacing="10">
                                        <Button Text="{x:Static res:AppResources.DiscoverOpenQrButton}"
                                                Clicked="OnOpenQrClicked"
                                                CommandParameter="{Binding BusinessId}" />

                                        <Button Text="{x:Static res:AppResources.DiscoverOpenRewardsButton}"
                                                Clicked="OnOpenRewardsClicked"
                                                CommandParameter="{Binding BusinessId}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Explore section for name/address/category/nearby based discovery and joining. -->
            <VerticalStackLayout IsVisible="{Binding IsExploreTabSelected}" Spacing="12">
                <Label Text="{x:Static res:AppResources.DiscoverExploreHeadline}"
                       FontAttributes="Bold" />

                <SearchBar Text="{Binding SearchQuery}"
                           Placeholder="{x:Static res:AppResources.DiscoverSearchPlaceholder}"
                           SearchCommand="{Binding SearchCommand}" />

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Picker Grid.Column="0"
                            Title="{x:Static res:AppResources.DiscoverCategoryFilterLabel}"
                            ItemsSource="{Binding CategoryKinds}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedCategory}" />

                    <Button Grid.Column="1"
                            Text="{x:Static res:AppResources.DiscoverSearchButton}"
                            Command="{Binding SearchCommand}" />

                    <Button Grid.Column="2"
                            Text="{x:Static res:AppResources.DiscoverClearFiltersButton}"
                            Command="{Binding ClearFiltersCommand}" />
                </Grid>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.DiscoverNearbyOnlyLabel}" VerticalOptions="Center" />
                    <Switch IsToggled="{Binding IsNearbyOnly}" />
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding IsNearbyOnly}">
                    <Label Grid.Column="0"
                           Text="{x:Static res:AppResources.DiscoverNearbyRadiusLabel}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding NearbyRadiusOptions}"
                            SelectedItem="{Binding SelectedNearbyRadiusMeters}">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="." StringFormat="{x:Static res:AppResources.DiscoverNearbyRadiusMetersFormat}" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>


                <maps:Map x:Name="ExploreMap"
                          HeightRequest="260"
                          IsVisible="{Binding HasExploreResults}"
                          IsShowingUser="{Binding IsNearbyOnly}"
                          MapType="Street" />

                <Label Text="{x:Static res:AppResources.DiscoverExploreEmpty}"
                       IsVisible="{Binding HasExploreResults, Converter={StaticResource InverseBoolConverter}}" />

                <CollectionView x:Name="ExploreBusinessesCollectionView"
                                ItemsSource="{Binding ExploreBusinesses}"
                                SelectionMode="Single"
                                SelectionChanged="OnExploreBusinessSelected"
                                IsVisible="{Binding HasExploreResults}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiscoverExploreItem">
                            <Border Stroke="{StaticResource BrushGray300}"
                                    StrokeThickness="1"
                                    Padding="12"
                                    Margin="4">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding Business.Name}"
                                           FontSize="16"
                                           FontAttributes="Bold" />

                                    <Label Text="{Binding Business.Category,
                                                          StringFormat='{x:Static res:AppResources.BusinessCategoryFormat}'}"
                                           FontSize="14"
                                           IsVisible="{Binding Business.Category, Converter={StaticResource InverseBoolConverter}}" />

                                    <Label Text="{Binding Business.City}"
                                           FontSize="13"
                                           Opacity="0.8"
                                           IsVisible="{Binding Business.City, Converter={StaticResource NullCheckConverter}}" />

                                    <Label Text="{x:Static res:AppResources.DiscoverAlreadyJoinedLabel}"
                                           TextColor="Green"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           IsVisible="{Binding IsJoined}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="14"
                   IsVisible="{Binding HasError}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrushPrimary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
