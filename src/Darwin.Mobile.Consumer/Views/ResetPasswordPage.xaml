<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.ResetPasswordPage"
    x:DataType="vm:ResetPasswordViewModel"
    Title="{x:Static res:AppResources.ResetPasswordTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,32" Spacing="18">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ResetPasswordTitle}"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.ResetPasswordDescription}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.EmailLabel}"
                               Style="{StaticResource FormLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}">
                            <Entry Text="{Binding Email}"
                                   Keyboard="Email"
                                   Placeholder="{x:Static res:AppResources.EmailPlaceholder}"
                                   Style="{StaticResource FormEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.ResetPasswordTokenLabel}"
                               Style="{StaticResource FormLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}">
                            <Entry Text="{Binding Token}"
                                   Placeholder="{x:Static res:AppResources.ResetPasswordTokenPlaceholder}"
                                   Style="{StaticResource FormEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.NewPasswordLabel}"
                               Style="{StaticResource FormLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}">
                            <Entry Text="{Binding NewPassword}"
                                   IsPassword="True"
                                   Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                                   Style="{StaticResource FormEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.ConfirmNewPasswordLabel}"
                               Style="{StaticResource FormLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}">
                            <Entry Text="{Binding ConfirmNewPassword}"
                                   IsPassword="True"
                                   Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                                   Style="{StaticResource FormEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabelStyle}"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding SuccessMessage}"
                   Style="{StaticResource SuccessLabelStyle}"
                   IsVisible="{Binding HasSuccess}" />

            <Button Text="{x:Static res:AppResources.ResetPasswordActionButton}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ResetPasswordCommand}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
