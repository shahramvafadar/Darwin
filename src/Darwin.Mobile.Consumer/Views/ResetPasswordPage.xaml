<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.ResetPasswordPage"
    x:DataType="vm:ResetPasswordViewModel"
    Title="{x:Static res:AppResources.ResetPasswordTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{x:Static res:AppResources.ResetPasswordTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="{x:Static res:AppResources.ResetPasswordDescription}"
                   Style="{StaticResource BodyLabelStyle}" />

            <Label Text="{x:Static res:AppResources.EmailLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Email}"
                   Keyboard="Email"
                   Placeholder="user@example.com"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.ResetPasswordTokenLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Token}"
                   Placeholder="{x:Static res:AppResources.ResetPasswordTokenPlaceholder}"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.NewPasswordLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding NewPassword}"
                   IsPassword="True"
                   TextColor="{StaticResource Neutral900}" />

            <Label Text="{x:Static res:AppResources.ConfirmPasswordLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding ConfirmNewPassword}"
                   IsPassword="True"
                   TextColor="{StaticResource Neutral900}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding SuccessMessage}"
                   TextColor="Green"
                   IsVisible="{Binding HasSuccess}" />

            <Button Text="{x:Static res:AppResources.ResetPasswordActionButton}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ResetPasswordCommand}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
