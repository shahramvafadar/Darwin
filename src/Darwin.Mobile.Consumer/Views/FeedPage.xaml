<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:contracts="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    x:Class="Darwin.Mobile.Consumer.Views.FeedPage"
    x:Name="FeedRoot"
    x:DataType="vm:FeedViewModel"
    Title="{x:Static res:AppResources.FeedTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">

            <Label Text="{x:Static res:AppResources.FeedTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="{x:Static res:AppResources.FeedBusinessPickerLabel}"
                   IsVisible="{Binding HasAccounts}" />

            <Picker Title="{x:Static res:AppResources.FeedBusinessPickerLabel}"
                    ItemsSource="{Binding Accounts}"
                    ItemDisplayBinding="{Binding BusinessName}"
                    SelectedItem="{Binding SelectedAccount}"
                    IsVisible="{Binding HasAccounts}" />

            <Label Text="{Binding SelectedPointsText}"
                   IsVisible="{Binding CanNavigateWithSelection}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" IsVisible="{Binding CanNavigateWithSelection}">
                <Button Grid.Column="0"
                        Text="{x:Static res:AppResources.FeedOpenQrButton}"
                        Command="{Binding OpenQrCommand}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.FeedOpenRewardsButton}"
                        Command="{Binding OpenRewardsCommand}" />
            </Grid>

            <Button Text="{x:Static res:AppResources.FeedRefreshButton}"
                    Command="{Binding RefreshCommand}" />


            <Label Text="{x:Static res:AppResources.FeedPromotionsTitle}"
                   FontAttributes="Bold"
                   IsVisible="{Binding HasPromotions}" />

            <Label Text="{Binding PromotionScopeText}"
                   FontSize="12"
                   Opacity="0.8"
                   IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{x:Static res:AppResources.FeedPromotionDiagnosticsTitle}"
                   FontAttributes="Bold"
                   FontSize="13"
                   IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{Binding PromotionPolicyDiagnosticsSummaryText}"
                   FontSize="11"
                   Opacity="0.75"
                   IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{Binding PromotionDiagnosticsVisiblePromotionsPreview}"
                   FontSize="11"
                   Opacity="0.75"
                   IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{Binding PromotionDiagnosticsSnapshotAtText}"
                   FontSize="11"
                   Opacity="0.65"
                   IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{Binding PromotionDiagnosticsFreshnessText}"
                   FontSize="11"
                   Opacity="0.75"
                   TextColor="OrangeRed"
                   IsVisible="{Binding IsPromotionDiagnosticsSnapshotStale}" />

            <Label Text="{Binding PromotionDiagnosticsFreshnessText}"
                   FontSize="11"
                   Opacity="0.75"
                   TextColor="{StaticResource BrushPrimary}"
                   IsVisible="{Binding IsPromotionDiagnosticsSnapshotStale, Converter={StaticResource InverseBoolConverter}}" />

            <Button Text="{x:Static res:AppResources.FeedCopyPromotionDiagnosticsButton}"
                    FontSize="12"
                    Command="{Binding CopyPromotionDiagnosticsCommand}"
                    IsVisible="{Binding HasPromotionDiagnosticsSnapshotAt}" />

            <Label Text="{Binding PromotionDiagnosticsCopyStatus}"
                   FontSize="11"
                   Opacity="0.75"
                   TextColor="{StaticResource BrushPrimary}"
                   IsVisible="{Binding HasPromotionDiagnosticsCopyStatus}" />

            <Button Text="{x:Static res:AppResources.FeedPromotionDiagnosticsClearStatusButton}"
                    FontSize="11"
                    Command="{Binding ClearPromotionDiagnosticsStatusCommand}"
                    IsVisible="{Binding HasPromotionDiagnosticsCopyStatus}" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8"
                  IsVisible="{Binding HasAccounts}">
                <Button Grid.Column="0"
                        Text="{x:Static res:AppResources.FeedPromotionScopeSelectedBusinessButton}"
                        Command="{Binding ShowSelectedBusinessPromotionsCommand}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.FeedPromotionScopeAllBusinessesButton}"
                        Command="{Binding ShowAllBusinessesPromotionsCommand}" />
            </Grid>

            <CollectionView ItemsSource="{Binding PromotionItems}"
                            SelectionMode="None"
                            IsVisible="{Binding HasPromotions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:PromotionFeedItem">
                        <Border Stroke="{StaticResource BrushGray300}"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="2">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding BusinessName}" FontAttributes="Bold" />
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding Description}" />
                                <Button Text="{x:Static res:AppResources.FeedOpenPromotionButton}"
                                        Command="{Binding Source={x:Reference FeedRoot}, Path=BindingContext.OpenPromotionCommand}"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static res:AppResources.FeedEmptyMessage}"
                   IsVisible="{Binding HasItems, Converter={StaticResource InverseBoolConverter}}" />

            <CollectionView ItemsSource="{Binding Items}" IsVisible="{Binding HasItems}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:LoyaltyTimelineEntry">
                        <Border Stroke="{StaticResource BrushGray300}"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="2">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Kind}" FontAttributes="Bold" />
                                <Label Text="{Binding Note}" IsVisible="{Binding Note, Converter={StaticResource NullCheckConverter}}" />
                                <Label Text="{Binding PointsDelta, StringFormat='{0:+#;-#;0} pts'}"
                                       IsVisible="{Binding PointsDelta, Converter={StaticResource NullCheckConverter}}" />
                                <Label Text="{Binding PointsSpent, StringFormat='Spent: {0} pts'}"
                                       IsVisible="{Binding PointsSpent, Converter={StaticResource NullCheckConverter}}" />
                                <Label Text="{Binding OccurredAtUtc, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                       FontSize="12"
                                       Opacity="0.75" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="{x:Static res:AppResources.FeedLoadMoreButton}"
                    Command="{Binding LoadMoreCommand}"
                    IsVisible="{Binding HasMore}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrushPrimary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
