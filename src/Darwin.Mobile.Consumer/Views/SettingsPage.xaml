<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.SettingsPage"
    Title="{x:Static res:AppResources.SettingsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="18">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.SettingsTitle}"
                           Style="{StaticResource SectionEyebrowLabelStyle}" />

                    <Label Text="{x:Static res:AppResources.SettingsTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Label Text="{x:Static res:AppResources.SettingsSubtitle}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.SettingsProfileButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SettingsProfileButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnProfileClicked" />

                    <Button Text="{x:Static res:AppResources.SettingsOrdersAndInvoicesButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Clicked="OnMemberCommerceClicked" />

                    <Button Text="{x:Static res:AppResources.SettingsPreferencesButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Clicked="OnMemberPreferencesClicked" />

                    <Button Text="{x:Static res:AppResources.SettingsChangePasswordButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Clicked="OnChangePasswordClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                            Style="{StaticResource SoftButtonStyle}"
                            Clicked="OnLegalHubClicked" />

                    <Button Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                            Style="{StaticResource SoftButtonStyle}"
                            Clicked="OnAccountDeletionClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
