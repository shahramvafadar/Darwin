<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.RegisterPage"
    x:DataType="vm:RegisterViewModel"
    Title="{x:Static res:AppResources.RegisterTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{x:Static res:AppResources.RegisterTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="{x:Static res:AppResources.RegisterDescription}"
                   Style="{StaticResource BodyLabelStyle}" />

            <Label Text="{x:Static res:AppResources.FirstNameLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding FirstName}"
                   Placeholder="John"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.LastNameLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding LastName}"
                   Placeholder="Doe"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.EmailLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Email}"
                   Keyboard="Email"
                   Placeholder="user@example.com"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.PasswordLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding Password}"
                   IsPassword="True"
                   Placeholder="••••••••"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Label Text="{x:Static res:AppResources.ConfirmNewPasswordLabel}"
                   TextColor="{StaticResource Neutral900}" />
            <Entry Text="{Binding ConfirmPassword}"
                   IsPassword="True"
                   Placeholder="••••••••"
                   TextColor="{StaticResource Neutral900}"
                   PlaceholderColor="Gray" />

            <Border Stroke="{StaticResource Neutral300}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.RegisterAcknowledgementsTitle}"
                           FontAttributes="Bold"
                           FontSize="16" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox IsChecked="{Binding AcceptConsumerTerms}" VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="{x:Static res:AppResources.RegisterTermsAcknowledgementLabel}"
                                   LineBreakMode="WordWrap" />
                            <Button Text="{x:Static res:AppResources.LegalTermsButton}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource BrandGold500}"
                                    HorizontalOptions="Start"
                                    Command="{Binding OpenTermsCommand}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox IsChecked="{Binding AcknowledgePrivacyNotice}" VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="{x:Static res:AppResources.RegisterPrivacyAcknowledgementLabel}"
                                   LineBreakMode="WordWrap" />
                            <Button Text="{x:Static res:AppResources.LegalPrivacyNoticeButton}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource BrandGold500}"
                                    HorizontalOptions="Start"
                                    Command="{Binding OpenPrivacyPolicyCommand}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="{x:Static res:AppResources.LegalHubTitle}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource BrandGold500}"
                    HorizontalOptions="Start"
                    Clicked="OnLegalHubClicked" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Button Text="{x:Static res:AppResources.RegisterButton}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding RegisterCommand}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
