<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    x:Class="Darwin.Mobile.Consumer.Views.QrPage"
    x:DataType="vm:QrViewModel"
    Title="{x:Static res:AppResources.QrTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.QrTitle}" Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{Binding GuidanceMessage}" Style="{StaticResource BodyLabelStyle}" />
                    <Label Text="{Binding BusinessDisplayName, StringFormat='{x:Static res:AppResources.QrBusinessFormat}'}"
                           Style="{StaticResource SecondaryBodyLabelStyle}"
                           IsVisible="{Binding BusinessDisplayName, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding StatusMessage}"
                           Style="{StaticResource SuccessLabelStyle}"
                           IsVisible="{Binding StatusMessage, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Border Style="{StaticResource MutedCardBorderStyle}"
                            Padding="20"
                            HorizontalOptions="Center">
                        <Image Source="{Binding QrImage}"
                               HeightRequest="220"
                               WidthRequest="220"
                               HorizontalOptions="Center"
                               IsVisible="{Binding QrImage, Converter={StaticResource NullCheckConverter}}" />
                        <Label Text="{x:Static res:AppResources.QrEmptyStateMessage}"
                               Style="{StaticResource SecondaryBodyLabelStyle}"
                               HorizontalTextAlignment="Center"
                               IsVisible="False">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding QrImage}"
                                             Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <Label Text="{Binding ExpiresAtUtc, StringFormat='{x:Static res:AppResources.QrExpiresAtFormat}'}"
                           Style="{StaticResource BodyLabelStyle}"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding HasBusinessContext}" />
                    <Label Text="{Binding ExpiresInText}"
                           Style="{StaticResource SecondaryBodyLabelStyle}"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding HasBusinessContext}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="{x:Static res:AppResources.QrAccrualHelpText}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}" />
                            <buttons:SfButton Text="{x:Static res:AppResources.RefreshAccrualButton}"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Command="{Binding RefreshAccrualSessionCommand}"
                                              IsEnabled="{Binding HasBusinessContext}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <Label Text="{x:Static res:AppResources.QrRedemptionHelpText}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}" />
                            <buttons:SfButton Text="{x:Static res:AppResources.RefreshRedemptionButton}"
                                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                              Command="{Binding RefreshRedemptionSessionCommand}"
                                              IsEnabled="{Binding HasBusinessContext}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
