<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    x:Class="Darwin.Mobile.Consumer.Views.ForgotPasswordPage"
    x:DataType="vm:ForgotPasswordViewModel"
    NavigationPage.HasNavigationBar="False"
    Title="{x:Static res:AppResources.ForgotPasswordTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24,12,24,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ForgotPasswordTitle}"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.ForgotPasswordDescription}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding ForgotPasswordReadinessMessage}"
                           Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.EmailLabel}"
                                                   ContainerType="Outlined"
                                                   Stroke="{StaticResource Neutral100}"
                                                   ContainerBackground="{StaticResource Neutral0}"
                                                   OutlineCornerRadius="8"
                                                   FocusedStrokeThickness="2"
                                                   UnfocusedStrokeThickness="1"
                                                   InputViewPadding="14,6">
                        <Entry Text="{Binding Email}"
                               Keyboard="Email"
                               Placeholder="{x:Static res:AppResources.EmailPlaceholder}"
                               Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabelStyle}"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding SuccessMessage}"
                   Style="{StaticResource SuccessLabelStyle}"
                   IsVisible="{Binding HasSuccess}" />

            <buttons:SfButton Text="{x:Static res:AppResources.ForgotPasswordSendButton}"
                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                              Command="{Binding SendResetLinkCommand}"
                              IsEnabled="{Binding IsSendReady}" />

            <buttons:SfButton Text="{x:Static res:AppResources.ResetPasswordNavigateButton}"
                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                              Clicked="OnGoToResetPasswordClicked" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
