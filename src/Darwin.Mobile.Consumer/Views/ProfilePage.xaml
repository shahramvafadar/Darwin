<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    Title="{x:Static res:AppResources.ProfileTitle}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,22" Spacing="14">
                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.ProfileSectionTitle}"
                               Style="{StaticResource TitleLabelStyle}" />
                        <Label Text="{Binding Email}"
                               Style="{StaticResource BodyLabelStyle}" />
                        <Label Text="{Binding SuccessMessage}"
                               Style="{StaticResource SuccessLabelStyle}"
                               IsVisible="{Binding HasSuccess}" />
                        <Label Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorLabelStyle}"
                               IsVisible="{Binding HasError}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfileSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{x:Static res:AppResources.FirstNameLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding FirstName}" Style="{StaticResource FormEntryStyle}" /></Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{x:Static res:AppResources.LastNameLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding LastName}" Style="{StaticResource FormEntryStyle}" /></Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{x:Static res:AppResources.EmailLabel}" Style="{StaticResource CaptionLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding Email}" IsReadOnly="True" Style="{StaticResource FormEntryStyle}" /></Border>

                        <Label Text="{x:Static res:AppResources.PhoneLabel}" Style="{StaticResource CaptionLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding PhoneE164}" Placeholder="+49123456789" Keyboard="Telephone" Style="{StaticResource FormEntryStyle}" /></Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{x:Static res:AppResources.LocaleLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding Locale}" Placeholder="de-DE" Style="{StaticResource FormEntryStyle}" /></Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{x:Static res:AppResources.CurrencyLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding Currency}" Placeholder="EUR" Style="{StaticResource FormEntryStyle}" /></Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{x:Static res:AppResources.TimezoneLabel}" Style="{StaticResource CaptionLabelStyle}" />
                        <Border Style="{StaticResource FormFieldBorderStyle}"><Entry Text="{Binding Timezone}" Placeholder="Europe/Berlin" Style="{StaticResource FormEntryStyle}" /></Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="{x:Static res:AppResources.SaveProfileButton}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveProfileCommand}" />
                            <Button Grid.Column="1"
                                    Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Clicked="OnAccountDeletionClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfileAddressesSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding AddressCount, StringFormat='{x:Static res:AppResources.ProfileAddressCountFormat}'}"
                                           Style="{StaticResource CaptionLabelStyle}" />
                                    <Label Text="{Binding AddressCount}"
                                           Style="{StaticResource MetricValueLabelStyle}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{x:Static res:AppResources.ProfileManageAddressesButton}"
                                           Style="{StaticResource CaptionLabelStyle}" />
                                    <Label Text="{x:Static res:AppResources.ProfileManagePreferencesButton}"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource BrushOnSurface}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Label Text="{Binding DefaultBillingAddressSummary, StringFormat='{x:Static res:AppResources.ProfileDefaultBillingAddressFormat}'}"
                               Style="{StaticResource SecondaryBodyLabelStyle}"
                               LineBreakMode="WordWrap"
                               IsVisible="{Binding HasDefaultBillingAddress}" />

                        <Label Text="{Binding DefaultShippingAddressSummary, StringFormat='{x:Static res:AppResources.ProfileDefaultShippingAddressFormat}'}"
                               Style="{StaticResource SecondaryBodyLabelStyle}"
                               LineBreakMode="WordWrap"
                               IsVisible="{Binding HasDefaultShippingAddress}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="{x:Static res:AppResources.ProfileManageAddressesButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Clicked="OnManageAddressesClicked" />
                            <Button Grid.Column="1"
                                    Text="{x:Static res:AppResources.ProfileManagePreferencesButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Clicked="OnManagePreferencesClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfilePushRegistrationSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Border Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding PushRegistrationStatus}" Style="{StaticResource BodyLabelStyle}" />
                                <Label Text="{Binding LastPushSyncAtText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasLastPushSyncAt}" />
                                <Label Text="{Binding PushPermissionStateText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                <Label Text="{Binding PushTokenAvailabilityText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="{x:Static res:AppResources.ProfilePushRegistrationSyncButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Command="{Binding SyncPushRegistrationCommand}" />
                            <Button Grid.Column="1"
                                    Text="{x:Static res:AppResources.ProfilePushOpenSettingsButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Command="{Binding OpenNotificationSettingsCommand}" />
                        </Grid>

                        <Label Text="{x:Static res:AppResources.ProfilePushOpenSettingsHint}"
                               Style="{StaticResource SecondaryBodyLabelStyle}" />

                        <ActivityIndicator IsVisible="{Binding IsPushSyncBusy}"
                                           IsRunning="{Binding IsPushSyncBusy}"
                                           Color="{StaticResource BrandGold500}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfileCustomerContextSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Label Text="{x:Static res:AppResources.ProfileCustomerContextEmpty}"
                               Style="{StaticResource BodyLabelStyle}"
                               IsVisible="{Binding HasLinkedCustomerContext, Converter={StaticResource InverseBoolConverter}}" />

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding HasLinkedCustomerContext}">
                            <Label Text="{Binding LinkedCustomerDisplayName, StringFormat='{x:Static res:AppResources.ProfileCustomerDisplayNameFormat}'}"
                                   Style="{StaticResource BodyLabelStyle}" />
                            <Label Text="{Binding LinkedCustomerCompanyName, StringFormat='{x:Static res:AppResources.ProfileCustomerCompanyFormat}'}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   IsVisible="{Binding HasLinkedCustomerCompanyName}" />
                            <Label Text="{Binding LinkedCustomerSegmentsSummary, StringFormat='{x:Static res:AppResources.ProfileCustomerSegmentsFormat}'}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding HasLinkedCustomerSegments}" />
                            <Label Text="{Binding LinkedCustomerLastInteractionText}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   LineBreakMode="WordWrap" />
                            <Button Text="{x:Static res:AppResources.ProfileViewCustomerContextButton}"
                                    Style="{StaticResource OutlinedButtonStyle}"
                                    Clicked="OnViewCustomerContextClicked" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="#40FFFFFF"
              IsVisible="{Binding IsBusy}"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource BrushPrimary}" />
                <Label Text="{x:Static res:AppResources.ProfileTitle}"
                       Style="{StaticResource SecondaryBodyLabelStyle}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
