<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:contracts="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:chips="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    x:Class="Darwin.Mobile.Consumer.Views.RewardsPage"
    x:DataType="vm:RewardsViewModel"
    Title="{x:Static res:AppResources.RewardsTitle}">

    <Grid>
        <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                       IsRefreshing="{Binding IsBusy}"
                                       ProgressColor="{StaticResource BrandGold500}"
                                       ProgressBackground="{StaticResource Neutral0}">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <ScrollView>
                    <VerticalStackLayout Padding="20,16,20,22" Spacing="14">

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.RewardsTitle}"
                               Style="{StaticResource SectionEyebrowLabelStyle}" />

                        <Label Text="{x:Static res:AppResources.AccountSummaryLabel}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Label Text="{x:Static res:AppResources.RewardsCurrentPointsTitle}"
                               Style="{StaticResource CaptionLabelStyle}" />

                        <Label Text="{Binding PointsBalance}"
                               Style="{StaticResource MetricValueLabelStyle}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                              IsVisible="{Binding HasAccounts}">
                            <Border Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{x:Static res:AppResources.RewardsJoinedBusinessesTitle}"
                                           Style="{StaticResource CaptionLabelStyle}" />
                                    <Label Text="{Binding TotalJoinedBusinesses}"
                                           Style="{StaticResource MetricValueLabelStyle}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{x:Static res:AppResources.RewardsTotalPointsTitle}"
                                           Style="{StaticResource CaptionLabelStyle}" />
                                    <Label Text="{Binding TotalPointsAcrossBusinesses}"
                                           Style="{StaticResource MetricValueLabelStyle}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasAccounts}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.RewardsOverviewTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Label Text="{Binding TopBusinessByPoints, StringFormat='{x:Static res:AppResources.RewardsOverviewTopBusinessFormat}'}"
                               Style="{StaticResource BodyLabelStyle}" />

                        <buttons:SfButton Text="{x:Static res:AppResources.RewardsOpenSelectedBusinessQrButton}"
                                          Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                          Command="{Binding OpenSelectedBusinessQrCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource EmptyStateCardBorderStyle}"
                        IsVisible="{Binding HasAccounts, Converter={StaticResource InverseBoolConverter}}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.RewardsTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />
                        <Label Text="{x:Static res:AppResources.RewardsNoAccountsFound}"
                               Style="{StaticResource BodyLabelStyle}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout IsVisible="{Binding HasAccounts}" Spacing="14">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{x:Static res:AppResources.RewardsBusinessPickerLabel}"
                                   Style="{StaticResource SectionHeadingLabelStyle}" />

                            <chips:SfChipGroup ItemsSource="{Binding Accounts}"
                                               DisplayMemberPath="BusinessName"
                                               SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                               ChipType="Choice"
                                               ChoiceMode="Single"
                                               ChipCornerRadius="8"
                                               ChipBackground="{StaticResource BrushSurface}"
                                               ChipStroke="{StaticResource BrandGold50}"
                                               ChipStrokeThickness="1"
                                               ChipTextColor="{StaticResource Neutral900}"
                                               ChipTextSize="13"
                                               SelectedChipBackground="{StaticResource BrushPrimary}"
                                               SelectedChipTextColor="{StaticResource Neutral0}"
                                               SelectionIndicatorColor="{StaticResource BrandGold500}" />

                            <VerticalStackLayout Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding Accounts}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="contracts:LoyaltyAccountSummary">
                                        <Border Style="{StaticResource MutedCardBorderStyle}" Margin="0,0,0,2">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                    <Label Text="{Binding BusinessName}"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource BrushOnSurface}"
                                                           LineBreakMode="WordWrap" />
                                                    <Label Text="{Binding PointsBalance, StringFormat='{x:Static res:AppResources.PointsBalanceFormat}'}"
                                                           Style="{StaticResource SecondaryBodyLabelStyle}" />
                                                </VerticalStackLayout>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource CardBorderStyle}"
                                                        Padding="10,8">
                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="{x:Static res:AppResources.PointsLabel}"
                                                               Style="{StaticResource CaptionLabelStyle}"
                                                               HorizontalTextAlignment="Center" />
                                                        <Label Text="{Binding PointsBalance}"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource BrushPrimaryPressed}"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{x:Static res:AppResources.RewardsNextRewardSectionTitle}"
                                   Style="{StaticResource SectionHeadingLabelStyle}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{x:Static res:AppResources.RewardsConfiguredRewardsTitle}"
                                               Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding AvailableRewardsCount}"
                                               Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}" Padding="14,12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{x:Static res:AppResources.RewardsRedeemableRewardsTitle}"
                                               Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding RedeemableRewardsCount}"
                                               Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <VerticalStackLayout Spacing="6" IsVisible="{Binding HasNextRewardInsight}">
                                <Label Text="{Binding NextRewardTitle, StringFormat='{x:Static res:AppResources.RewardsNextRewardNameFormat}'}"
                                       Style="{StaticResource BodyLabelStyle}" />
                                <Label Text="{Binding PointsToNextReward, StringFormat='{x:Static res:AppResources.RewardsNextRewardRemainingFormat}'}"
                                       Style="{StaticResource SecondaryBodyLabelStyle}" />
                                <Label Text="{Binding NextRewardRequiredPoints, StringFormat='{x:Static res:AppResources.RewardsNextRewardThresholdFormat}'}"
                                       Style="{StaticResource SecondaryBodyLabelStyle}" />
                                <Label Text="{Binding NextRewardProgressPercent, StringFormat='{x:Static res:AppResources.RewardsNextRewardProgressFormat}'}"
                                       Style="{StaticResource SecondaryBodyLabelStyle}" />
                            </VerticalStackLayout>

                            <Label Text="{x:Static res:AppResources.RewardsAllRewardsUnlockedMessage}"
                                   Style="{StaticResource BodyLabelStyle}"
                                   IsVisible="{Binding HasUnlockedAllRewards}" />

                            <Border Style="{StaticResource MutedCardBorderStyle}" Padding="14">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding ExpiryStatusMessage}"
                                           Style="{StaticResource BodyLabelStyle}" />
                                    <Label Text="{Binding PointsExpiringSoon, StringFormat='{x:Static res:AppResources.RewardsPointsExpiringSoonFormat}'}"
                                           Style="{StaticResource SecondaryBodyLabelStyle}"
                                           IsVisible="{Binding HasExpiryInsight}" />
                                    <Label Text="{Binding NextPointsExpiryAtUtc, StringFormat='{x:Static res:AppResources.RewardsNextPointsExpiryFormat}'}"
                                           Style="{StaticResource SecondaryBodyLabelStyle}"
                                           IsVisible="{Binding HasExpiryInsight}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.RewardsAvailableRewardsLabel}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <VerticalStackLayout Spacing="12"
                                             BindableLayout.ItemsSource="{Binding AvailableRewards}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="contracts:LoyaltyRewardSummary">
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,2">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource BrushOnSurface}"
                                                       LineBreakMode="WordWrap" />
                                                <Label Text="{Binding RequiredPoints, StringFormat='{x:Static res:AppResources.RewardCostFormat}'}"
                                                       Style="{StaticResource SecondaryBodyLabelStyle}" />
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource MutedCardBorderStyle}"
                                                    Padding="10,8">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{x:Static res:AppResources.RewardsRequiredPointsBadgeLabel}"
                                                           Style="{StaticResource CaptionLabelStyle}"
                                                           HorizontalTextAlignment="Center" />
                                                    <Label Text="{Binding RequiredPoints}"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource BrushPrimaryPressed}"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.RewardsHistoryLabel}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Border Style="{StaticResource EmptyStateCardBorderStyle}"
                                IsVisible="{Binding HasHistory, Converter={StaticResource InverseBoolConverter}}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{x:Static res:AppResources.RewardsHistoryLabel}"
                                       Style="{StaticResource SectionHeadingLabelStyle}" />
                                <Label Text="{x:Static res:AppResources.RewardsNoHistoryMessage}"
                                       Style="{StaticResource BodyLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout Spacing="12"
                                             BindableLayout.ItemsSource="{Binding RewardHistory}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="contracts:PointsTransaction">
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,2">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="10"
                                              RowSpacing="6">
                                            <Border Grid.Column="0"
                                                    Grid.RowSpan="2"
                                                    Style="{StaticResource MutedCardBorderStyle}"
                                                    Padding="10,8">
                                                <Label Text="{Binding Type, Converter={StaticResource PointsTransactionTypeConverter}}"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource BrushPrimaryPressed}" />
                                            </Border>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Notes}"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource BrushOnSurface}"
                                                   LineBreakMode="WordWrap" />

                                            <VerticalStackLayout Grid.Column="2"
                                                                 Grid.RowSpan="2"
                                                                 Spacing="2"
                                                                 HorizontalOptions="End"
                                                                 WidthRequest="82">
                                                <Label Text="{x:Static res:AppResources.RewardsHistoryDeltaLabel}"
                                                       Style="{StaticResource CaptionLabelStyle}"
                                                       HorizontalTextAlignment="End" />
                                                <Label Text="{Binding Delta, StringFormat='{0:+#;-#;0}'}"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource BrushOnSurface}"
                                                       HorizontalTextAlignment="End" />
                                                <Label Text="{Binding Reference}"
                                                       Style="{StaticResource SecondaryBodyLabelStyle}"
                                                       HorizontalTextAlignment="End"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"
                                                       IsVisible="{Binding Reference, Converter={StaticResource NullCheckConverter}}" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="1"
                                                   Grid.Row="1"
                                                   Text="{Binding OccurredAtUtc, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                                   Style="{StaticResource SecondaryBodyLabelStyle}" />

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Border Style="{StaticResource MutedCardBorderStyle}"
                        IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Danger500}"
                           FontSize="14" />
                </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>

        <Grid BackgroundColor="{StaticResource BrushBusyOverlay}"
              IsVisible="{Binding IsBusy}"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource BrushPrimary}" />
                <Label Text="{x:Static res:AppResources.RewardsTitle}"
                       Style="{StaticResource SecondaryBodyLabelStyle}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
