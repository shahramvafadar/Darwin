<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:contracts="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    xmlns:biz="clr-namespace:Darwin.Contracts.Businesses;assembly=Darwin.Contracts"
    x:Class="Darwin.Mobile.Consumer.Views.BusinessDetailPage"
    x:DataType="vm:BusinessDetailViewModel"
    Title="{Binding Business.Name, FallbackValue={x:Static res:AppResources.BusinessDetailsTitle}}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Border StrokeThickness="0" BackgroundColor="{StaticResource Neutral100}" StrokeShape="RoundRectangle 16">
                <Grid HeightRequest="180">
                    <Image Source="{Binding Business.PrimaryImageUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding Business.PrimaryImageUrl, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.Name}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Neutral900}"
                           Margin="16"
                           VerticalOptions="End" />
                </Grid>
            </Border>

            <Label Text="{Binding Business.ShortDescription}"
                   FontSize="14"
                   TextColor="{StaticResource Neutral900}"
                   IsVisible="{Binding Business.ShortDescription, Converter={StaticResource NullCheckConverter}}" />

            <Border Stroke="{StaticResource BrushPrimary}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.BusinessEngagementTitle}" FontSize="18" FontAttributes="Bold" />

                    <Label Text="{Binding LikeCountText}" />
                    <Label Text="{Binding FavoriteCountText}" />
                    <Label Text="{Binding RatingAverageDisplayText}" />
                    <Label Text="{Binding RatingCountText}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="{x:Static res:AppResources.BusinessLikeButton}"
                                Command="{Binding ToggleLikeCommand}" />

                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.BusinessFavoriteButton}"
                                Command="{Binding ToggleFavoriteCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource BrushPrimary}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.BusinessMyReviewTitle}" FontSize="18" FontAttributes="Bold" />

                    <Label Text="{x:Static res:AppResources.BusinessMyReviewRatingLabel}" />
                    <Stepper Minimum="1" Maximum="5" Increment="1" Value="{Binding MyRating}" />
                    <Label Text="{Binding MyRatingText}" />

                    <Editor Text="{Binding MyReviewComment}"
                            Placeholder="{x:Static res:AppResources.BusinessMyReviewCommentPlaceholder}"
                            AutoSize="TextChanges"
                            HeightRequest="120" />

                    <Button Text="{x:Static res:AppResources.BusinessSaveReviewButton}"
                            Command="{Binding SaveReviewCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource BrushPrimary}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12"
                    IsVisible="{Binding HasReviews}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.BusinessRecentReviewsTitle}" FontSize="18" FontAttributes="Bold" />

                    <CollectionView ItemsSource="{Binding Reviews}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="biz:BusinessReviewItem">
                                <Border Stroke="{StaticResource Neutral300}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8" Margin="0,0,0,8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding AuthorName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Rating, StringFormat={x:Static res:AppResources.BusinessReviewRatingFormat}}" />
                                        <Label Text="{Binding Comment}"
                                               IsVisible="{Binding Comment, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding CreatedAtUtc, StringFormat='{0:yyyy-MM-dd HH:mm}'}"
                                               FontSize="12"
                                               Opacity="0.75" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource BrushPrimary}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.BusinessInformationTitle}" FontSize="18" FontAttributes="Bold" />

                    <Label Text="{Binding Business.Category, StringFormat={x:Static res:AppResources.BusinessCategoryFormat}}"
                           IsVisible="{Binding Business.Category, Converter={StaticResource NullCheckConverter}}" />

                    <Label Text="{Binding Business.City, StringFormat={x:Static res:AppResources.BusinessCityFormat}}"
                           IsVisible="{Binding Business.City, Converter={StaticResource NullCheckConverter}}" />

                    <Label Text="{Binding Business.WebsiteUrl, StringFormat={x:Static res:AppResources.BusinessWebsiteFormat}}"
                           IsVisible="{Binding Business.WebsiteUrl, Converter={StaticResource NullCheckConverter}}" />

                    <Label Text="{Binding Business.ContactPhoneE164, StringFormat={x:Static res:AppResources.BusinessPhoneFormat}}"
                           IsVisible="{Binding Business.ContactPhoneE164, Converter={StaticResource NullCheckConverter}}" />

                    <Label Text="{Binding Business.ContactEmail, StringFormat={x:Static res:AppResources.BusinessEmailFormat}}"
                           IsVisible="{Binding Business.ContactEmail, Converter={StaticResource NullCheckConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource BrushPrimary}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12"
                    IsVisible="{Binding Business.LoyaltyProgramPublic, Converter={StaticResource NullCheckConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.BusinessLoyaltyProgramTitle}" FontSize="18" FontAttributes="Bold" />

                    <Label Text="{Binding Business.LoyaltyProgramPublic.Name}"
                           FontAttributes="Bold"
                           FontSize="16" />

                    <Label Text="{Binding Business.LoyaltyProgramPublic.IsActive, StringFormat={x:Static res:AppResources.BusinessActiveFormat}}" />

                    <Label Text="{x:Static res:AppResources.BusinessRewardTiersTitle}" FontAttributes="Bold" />

                    <VerticalStackLayout
                        Spacing="8"
                        BindableLayout.ItemsSource="{Binding Business.LoyaltyProgramPublic.RewardTiers}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="contracts:LoyaltyRewardTierPublic">
                                <Border Stroke="{StaticResource Neutral300}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding PointsRequired, StringFormat={x:Static res:AppResources.BusinessPointsFormat}}"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding RewardType, StringFormat={x:Static res:AppResources.BusinessRewardTypeFormat}}" />
                                        <Label Text="{Binding RewardValue, StringFormat={x:Static res:AppResources.BusinessRewardValueFormat}}"
                                               IsVisible="{Binding RewardValue, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding Description}"
                                               IsVisible="{Binding Description, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding AllowSelfRedemption, StringFormat={x:Static res:AppResources.BusinessSelfRedemptionFormat}}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Button Text="{x:Static res:AppResources.JoinProgramButton}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding JoinCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrushPrimary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
