<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:contracts="clr-namespace:Darwin.Contracts.Loyalty;assembly=Darwin.Contracts"
    xmlns:biz="clr-namespace:Darwin.Contracts.Businesses;assembly=Darwin.Contracts"
    x:Class="Darwin.Mobile.Consumer.Views.BusinessDetailPage"
    x:DataType="vm:BusinessDetailViewModel"
    Title="{Binding Business.Name, FallbackValue={x:Static res:AppResources.BusinessDetailsTitle}}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Grid HeightRequest="184">
                    <Image Source="{Binding Business.PrimaryImageUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding Business.PrimaryImageUrl, Converter={StaticResource NullCheckConverter}}" />

                    <Grid BackgroundColor="#E6FFF8E7"
                          Padding="16"
                          VerticalOptions="End">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Business.Name}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BrushOnSurface}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding Business.ShortDescription}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   IsVisible="{Binding Business.ShortDescription, Converter={StaticResource NullCheckConverter}}" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding Business.LoyaltyProgramPublic.Name}"
                           Style="{StaticResource SectionHeadingLabelStyle}"
                           LineBreakMode="WordWrap"
                           IsVisible="{Binding Business.LoyaltyProgramPublic, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.LoyaltyProgramPublic.IsActive, Converter={StaticResource LocalizedBooleanConverter}, StringFormat={x:Static res:AppResources.BusinessActiveFormat}}"
                           Style="{StaticResource SecondaryBodyLabelStyle}"
                           IsVisible="{Binding Business.LoyaltyProgramPublic, Converter={StaticResource NullCheckConverter}}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="{x:Static res:AppResources.JoinProgramButton}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding JoinCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.BusinessSaveReviewButton}"
                                Style="{StaticResource OutlinedButtonStyle}"
                                Command="{Binding SaveReviewCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static res:AppResources.BusinessLikeButton}" Style="{StaticResource CaptionLabelStyle}" />
                        <Label Text="{Binding LikeCountText}" Style="{StaticResource MetricValueLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static res:AppResources.BusinessFavoriteButton}" Style="{StaticResource CaptionLabelStyle}" />
                        <Label Text="{Binding FavoriteCountText}" Style="{StaticResource MetricValueLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource MutedCardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static res:AppResources.BusinessMyReviewRatingLabel}" Style="{StaticResource CaptionLabelStyle}" />
                        <Label Text="{Binding RatingAverageDisplayText}" Style="{StaticResource MetricValueLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MutedCardBorderStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static res:AppResources.BusinessRecentReviewsTitle}" Style="{StaticResource CaptionLabelStyle}" />
                        <Label Text="{Binding RatingCountText}" Style="{StaticResource MetricValueLabelStyle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="{x:Static res:AppResources.BusinessLikeButton}"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Command="{Binding ToggleLikeCommand}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.BusinessFavoriteButton}"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Command="{Binding ToggleFavoriteCommand}" />
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.BusinessMyReviewTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{Binding MyRatingText}"
                           Style="{StaticResource BodyLabelStyle}" />
                    <Stepper Minimum="1"
                             Maximum="5"
                             Increment="1"
                             Value="{Binding MyRating}" />
                    <Border Style="{StaticResource FormFieldBorderStyle}" Padding="14,10">
                        <Editor Text="{Binding MyReviewComment}"
                                Placeholder="{x:Static res:AppResources.BusinessMyReviewCommentPlaceholder}"
                                HeightRequest="110"
                                Style="{StaticResource FormEditorStyle}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.BusinessInformationTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{Binding Business.Category, StringFormat={x:Static res:AppResources.BusinessCategoryFormat}}"
                           Style="{StaticResource BodyLabelStyle}"
                           IsVisible="{Binding Business.Category, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.City, StringFormat={x:Static res:AppResources.BusinessCityFormat}}"
                           Style="{StaticResource BodyLabelStyle}"
                           IsVisible="{Binding Business.City, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.WebsiteUrl, StringFormat={x:Static res:AppResources.BusinessWebsiteFormat}}"
                           Style="{StaticResource BodyLabelStyle}"
                           IsVisible="{Binding Business.WebsiteUrl, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.ContactPhoneE164, StringFormat={x:Static res:AppResources.BusinessPhoneFormat}}"
                           Style="{StaticResource BodyLabelStyle}"
                           IsVisible="{Binding Business.ContactPhoneE164, Converter={StaticResource NullCheckConverter}}" />
                    <Label Text="{Binding Business.ContactEmail, StringFormat={x:Static res:AppResources.BusinessEmailFormat}}"
                           Style="{StaticResource BodyLabelStyle}"
                           IsVisible="{Binding Business.ContactEmail, Converter={StaticResource NullCheckConverter}}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding Business.LoyaltyProgramPublic, Converter={StaticResource NullCheckConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.BusinessLoyaltyProgramTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding Business.LoyaltyProgramPublic.RewardTiers}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="contracts:LoyaltyRewardTierPublic">
                                <Border Style="{StaticResource MutedCardBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding PointsRequired, StringFormat={x:Static res:AppResources.BusinessPointsFormat}}"
                                               Style="{StaticResource BodyLabelStyle}" />
                                        <Label Text="{Binding RewardType, Converter={StaticResource BusinessRewardTypeConverter}, StringFormat={x:Static res:AppResources.BusinessRewardTypeFormat}}"
                                               Style="{StaticResource SecondaryBodyLabelStyle}" />
                                        <Label Text="{Binding RewardValue, StringFormat={x:Static res:AppResources.BusinessRewardValueFormat}}"
                                               Style="{StaticResource SecondaryBodyLabelStyle}"
                                               IsVisible="{Binding RewardValue, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding Description}"
                                               Style="{StaticResource SecondaryBodyLabelStyle}"
                                               IsVisible="{Binding Description, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding AllowSelfRedemption, Converter={StaticResource LocalizedBooleanConverter}, StringFormat={x:Static res:AppResources.BusinessSelfRedemptionFormat}}"
                                               Style="{StaticResource SecondaryBodyLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding HasReviews}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.BusinessRecentReviewsTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <CollectionView ItemsSource="{Binding Reviews}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="biz:BusinessReviewItem">
                                <Border Style="{StaticResource MutedCardBorderStyle}" Margin="0,0,0,10">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding AuthorName}" Style="{StaticResource BodyLabelStyle}" />
                                        <Label Text="{Binding Rating, StringFormat={x:Static res:AppResources.BusinessReviewRatingFormat}}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                        <Label Text="{Binding Comment}" Style="{StaticResource BodyLabelStyle}" IsVisible="{Binding Comment, Converter={StaticResource NullCheckConverter}}" />
                                        <Label Text="{Binding CreatedAtUtc, StringFormat='{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource CaptionLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabelStyle}"
                   IsVisible="{Binding HasError}" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
