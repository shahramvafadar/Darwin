<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.MemberPreferencesPage"
    x:DataType="vm:MemberPreferencesViewModel"
    Title="{x:Static res:AppResources.MemberPreferencesTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{x:Static res:AppResources.MemberPreferencesTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="{x:Static res:AppResources.MemberPreferencesSubtitle}"
                   FontSize="14"
                   Opacity="0.85" />

            <Label Text="{Binding SuccessMessage}"
                   TextColor="Green"
                   FontSize="14"
                   IsVisible="{Binding HasSuccess}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="14"
                   IsVisible="{Binding HasError}" />

            <Button Text="{x:Static res:AppResources.MemberPreferencesRefreshButton}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshCommand}" />

            <Border Stroke="{StaticResource Neutral300}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesMarketingConsentLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding MarketingConsent}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesEmailLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllowEmailMarketing}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesSmsLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllowSmsMarketing}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesWhatsAppLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllowWhatsAppMarketing}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesPromotionalPushLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllowPromotionalPushNotifications}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="{x:Static res:AppResources.MemberPreferencesAnalyticsLabel}"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllowOptionalAnalyticsTracking}" />
                    </Grid>

                    <Label Text="{Binding AcceptsTermsAtText}"
                           FontSize="13"
                           TextColor="{StaticResource Neutral600}"
                           IsVisible="{Binding HasAcceptsTermsAt}" />

                    <Button Text="{x:Static res:AppResources.MemberPreferencesSaveButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrandGold500}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
