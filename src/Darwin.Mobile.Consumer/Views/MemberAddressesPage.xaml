<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.MemberAddressesPage"
    x:DataType="vm:MemberAddressesViewModel"
    Title="{x:Static res:AppResources.MemberAddressesTitle}">

    <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                   IsRefreshing="{Binding IsBusy}"
                                   ProgressColor="{StaticResource BrandGold500}"
                                   ProgressBackground="{StaticResource Neutral0}">
        <pullToRefresh:SfPullToRefresh.PullableContent>
            <ScrollView>
                <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberAddressesTitle}" Style="{StaticResource TitleLabelStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <buttons:SfButton Grid.Column="0" Text="{x:Static res:AppResources.MemberAddressesRefreshButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding RefreshCommand}" />
                        <buttons:SfButton Grid.Column="1" Text="{x:Static res:AppResources.MemberAddressesCreateButton}" Style="{StaticResource SyncfusionPrimaryButtonStyle}" Command="{Binding StartCreateCommand}" />
                    </Grid>
                    <Label Text="{Binding SuccessMessage}" Style="{StaticResource SuccessLabelStyle}" IsVisible="{Binding HasSuccess}" />
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabelStyle}" IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberAddressesSavedSectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.MemberAddressesEmpty}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasAddresses, Converter={StaticResource InverseBoolConverter}}" />
                    <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Addresses}" IsVisible="{Binding HasAddresses}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemberAddressItemViewModel">
                                <Border Style="{StaticResource MutedCardBorderStyle}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding FullName}" FontAttributes="Bold" TextColor="{StaticResource BrushOnSurface}" />
                                        <Label Text="{Binding Summary}" Style="{StaticResource SecondaryBodyLabelStyle}" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding Company}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasCompany}" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{x:Static res:AppResources.MemberAddressesDefaultBillingBadge}" Style="{StaticResource CaptionLabelStyle}" IsVisible="{Binding IsDefaultBilling}" />
                                            <Label Text="{x:Static res:AppResources.MemberAddressesDefaultShippingBadge}" Style="{StaticResource CaptionLabelStyle}" IsVisible="{Binding IsDefaultShipping}" />
                                        </HorizontalStackLayout>
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                            <buttons:SfButton Grid.Row="0" Grid.Column="0" Text="{x:Static res:AppResources.MemberAddressesEditButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}" CommandParameter="{Binding .}" />
                                            <buttons:SfButton Grid.Row="0" Grid.Column="1" Text="{x:Static res:AppResources.MemberAddressesDeleteButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}" CommandParameter="{Binding .}" />
                                            <buttons:SfButton Grid.Row="1" Grid.Column="0" Text="{x:Static res:AppResources.MemberAddressesSetBillingButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetDefaultBillingCommand}" CommandParameter="{Binding .}" />
                                            <buttons:SfButton Grid.Row="1" Grid.Column="1" Text="{x:Static res:AppResources.MemberAddressesSetShippingButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetDefaultShippingCommand}" CommandParameter="{Binding .}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding EditorTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesFullNameLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding FullName}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesCompanyLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding Company}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="8">
                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesStreet1Label}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding Street1}" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesStreet2Label}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding Street2}" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesPostalCodeLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding PostalCode}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesCityLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding City}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesStateLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding State}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="8">
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesCountryCodeLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding CountryCode}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="8">
                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.MemberAddressesPhoneLabel}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding PhoneE164}" Keyboard="Telephone" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>
                    </VerticalStackLayout>

                    <Border Style="{StaticResource MutedCardBorderStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Text="{x:Static res:AppResources.MemberAddressesDefaultBillingSwitchLabel}" VerticalOptions="Center" LineBreakMode="WordWrap" Style="{StaticResource BodyLabelStyle}" />
                                <Switch Grid.Column="1" IsToggled="{Binding IsDefaultBilling}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Text="{x:Static res:AppResources.MemberAddressesDefaultShippingSwitchLabel}" VerticalOptions="Center" LineBreakMode="WordWrap" Style="{StaticResource BodyLabelStyle}" />
                                <Switch Grid.Column="1" IsToggled="{Binding IsDefaultShipping}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <buttons:SfButton Grid.Column="0" Text="{x:Static res:AppResources.MemberAddressesSaveButton}" Style="{StaticResource SyncfusionPrimaryButtonStyle}" Command="{Binding SaveCommand}" />
                        <buttons:SfButton Grid.Column="1" Text="{x:Static res:AppResources.MemberAddressesCancelButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding CancelEditCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </ScrollView>
        </pullToRefresh:SfPullToRefresh.PullableContent>
    </pullToRefresh:SfPullToRefresh>
</ContentPage>
