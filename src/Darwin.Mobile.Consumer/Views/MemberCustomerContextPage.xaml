<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.MemberCustomerContextPage"
    x:DataType="vm:MemberCustomerContextViewModel"
    Title="{x:Static res:AppResources.MemberCustomerContextTitle}">

    <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                   IsRefreshing="{Binding IsBusy}"
                                   ProgressColor="{StaticResource BrandGold500}"
                                   ProgressBackground="{StaticResource Neutral0}">
        <pullToRefresh:SfPullToRefresh.PullableContent>
            <ScrollView>
                <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextTitle}" Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextSubtitle}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <buttons:SfButton Text="{x:Static res:AppResources.MemberCustomerContextRefreshButton}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" Command="{Binding RefreshCommand}" />
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabelStyle}" IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{x:Static res:AppResources.MemberCustomerContextEmpty}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasContext, Converter={StaticResource InverseBoolConverter}}" />

            <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasContext}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextSummarySectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{Binding DisplayName}" Style="{StaticResource BodyLabelStyle}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                    <Label Text="{Binding EmailText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <Label Text="{Binding PhoneText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasPhone}" />
                    <Label Text="{Binding CompanyText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasCompany}" />
                    <Label Text="{Binding CreatedAtText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <Label Text="{Binding InteractionCountText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <Label Text="{Binding LastInteractionText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasLastInteraction}" />
                    <Label Text="{Binding NotesText}" Style="{StaticResource SecondaryBodyLabelStyle}" LineBreakMode="WordWrap" IsVisible="{Binding HasNotes}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasContext}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextSegmentsSectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextNoSegments}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasSegments, Converter={StaticResource InverseBoolConverter}}" />
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Segments}" IsVisible="{Binding HasSegments}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemberCustomerSegmentItemViewModel">
                                <Border Style="{StaticResource MutedCardBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyLabelStyle}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding Description}" Style="{StaticResource SecondaryBodyLabelStyle}" LineBreakMode="WordWrap" IsVisible="{Binding HasDescription}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasContext}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextConsentsSectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextNoConsents}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasConsents, Converter={StaticResource InverseBoolConverter}}" />
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Consents}" IsVisible="{Binding HasConsents}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemberCustomerConsentItemViewModel">
                                <Border Style="{StaticResource MutedCardBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Type}" Style="{StaticResource BodyLabelStyle}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding StatusText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                        <Label Text="{Binding GrantedAtText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                        <Label Text="{Binding RevokedAtText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasRevokedAt}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasContext}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextInteractionsSectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.MemberCustomerContextNoInteractions}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasRecentInteractions, Converter={StaticResource InverseBoolConverter}}" />
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding RecentInteractions}" IsVisible="{Binding HasRecentInteractions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemberCustomerInteractionItemViewModel">
                                <Border Style="{StaticResource MutedCardBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding TypeChannelText}" Style="{StaticResource BodyLabelStyle}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding SubjectText}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasSubject}" />
                                        <Label Text="{Binding CreatedAtText}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                        <Label Text="{Binding PreviewText}" Style="{StaticResource SecondaryBodyLabelStyle}" LineBreakMode="WordWrap" IsVisible="{Binding HasPreview}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </ScrollView>
        </pullToRefresh:SfPullToRefresh.PullableContent>
    </pullToRefresh:SfPullToRefresh>
</ContentPage>
