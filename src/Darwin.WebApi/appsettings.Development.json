{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "PostgreSql": ""
  },
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Email": {
    "Provider": "SMTP",
    "Brevo": {
      "BaseUrl": "https://api.brevo.com/v3/",
      "ApiKey": "",
      "SenderEmail": "no-reply@darwin.local",
      "SenderName": "Darwin Development",
      "ReplyToEmail": "",
      "ReplyToName": "",
      "WebhookUsername": "",
      "WebhookPassword": "",
      "SandboxMode": true,
      "TimeoutSeconds": 30,
      "DefaultTags": [
        "darwin",
        "development",
        "transactional"
      ]
    },
    "Smtp": {
      "Host": "localhost",
      "Port": 2525,
      "EnableSsl": false,
      "Username": "",
      "Password": "",
      "FromAddress": "no-reply@darwin.local",
      "FromDisplayName": "Darwin Development"
    }
  },
  "Jwt": {
    "Issuer": "Darwin.WebApi.Dev",
    "Audience": "Darwin.MobileClients.Dev",
    "Secret": ""
  },
  "StorefrontCheckout": {
    "FrontOfficeBaseUrl": "http://localhost:3000",
    "StripeCheckoutBaseUrl": "http://localhost:3000/mock-checkout"
  },
  "PushProviders": {
    "Fcm": {
      "Enabled": false,
      "ServerKey": "",
      "SenderId": ""
    },
    "Apns": {
      "Enabled": false,
      "TeamId": "",
      "KeyId": "",
      "AuthKeyFile": "",
      "BundleId": "com.loyan.darwin.mobile.consumer",
      "UseSandbox": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-dev-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Properties": {
      "Application": "Darwin.WebApi (Dev)"
    }
  },
  "DataProtection": {
    "KeysPath": "E:\\_Projects\\Darwin\\_shared_keys",
    "ApplicationName": "Darwin",
    "RequireKeyEncryption": false
  }
}
