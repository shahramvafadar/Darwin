{
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "buffered": true,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Darwin.WebApi"
    }
  },
  "DataProtection": {
    "KeysPath": "D:\\Darwin\\_shared_keys",
    "ApplicationName": "Darwin",
    "RequireKeyEncryption": true,
    "CertificateThumbprint": "",
    "CertificateStoreName": "My",
    "CertificateStoreLocation": "LocalMachine"
  },
  "Jwt": {
    "Issuer": "Darwin.WebApi",
    "Audience": "Darwin.MobileClients",
    "SigningKey": "",
    "ClockSkewSeconds": 60
  },
  "StorefrontCheckout": {
    "FrontOfficeBaseUrl": "https://storefront.example.com",
    "StripeCheckoutBaseUrl": "https://storefront.example.com/mock-checkout"
  },
  "BusinessOnboarding": {
    "InvitationMagicLink": {
      "BaseUrl": "darwin-business://InvitationAcceptance"
    }
  },
  "Email": {
    "Provider": "Brevo",
    "Brevo": {
      "BaseUrl": "https://api.brevo.com/v3/",
      "ApiKey": "",
      "SenderEmail": "",
      "SenderName": "Darwin",
      "ReplyToEmail": "",
      "ReplyToName": "Darwin Support",
      "WebhookUsername": "",
      "WebhookPassword": "",
      "SandboxMode": false,
      "TimeoutSeconds": 30,
      "DefaultTags": [
        "darwin",
        "transactional"
      ]
    },
    "Smtp": {
      "Host": "smtp.office365.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "",
      "FromDisplayName": "Darwin"
    }
  },
  "InactiveReminderWorker": {
    "Enabled": false,
    "Interval": "01:00:00",
    "InactiveThresholdDays": 14,
    "CooldownHours": 72,
    "MaxItemsPerRun": 200,
    "HighFailureRateWarningThresholdPercent": 30,
    "HighCooldownSuppressionWarningThresholdPercent": 60
  },
  "Notifications": {
    "InactiveReminderPushGateway": {
      "Enabled": false,
      "Endpoint": "/api/push/reminders/inactive",
      "BearerToken": "",
      "TitleTemplate": "We miss you at Loyan",
      "BodyTemplate": "It has been {inactiveDays} days since your last visit. Come back and discover new rewards.",
      "MaxAttempts": 3,
      "InitialBackoffMilliseconds": 300,
      "AndroidChannelId": "reengagement",
      "ApnsTopic": "com.loyan.darwin.mobile.consumer",
      "DeepLinkUrl": "loyan://feed",
      "CollapseKey": "inactive-reminder",
      "AnalyticsLabel": "inactive-reminder"
    }
  },
  "PushProviders": {
    "Fcm": {
      "Enabled": false,
      "ServerKey": "",
      "SenderId": ""
    },
    "Apns": {
      "Enabled": false,
      "TeamId": "",
      "KeyId": "",
      "AuthKeyFile": "",
      "BundleId": "com.loyan.darwin.mobile.consumer",
      "UseSandbox": true
    }
  }
}
