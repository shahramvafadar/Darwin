{
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "buffered": true,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Darwin.WebApi"
    }
  },
  "DataProtection": {
    "KeysPath": "D:\\Darwin\\_shared_keys"
  },
  "Jwt": {
    "Issuer": "Darwin.WebApi",
    "Audience": "Darwin.MobileClients",
    "SigningKey": "SET_STRONG_PRODUCTION_SECRET_KEY_VIA_USER_SECRETS_OR_ENV",
    "ClockSkewSeconds": 60
  },
  "StorefrontCheckout": {
    "FrontOfficeBaseUrl": "https://storefront.example.com",
    "StripeCheckoutBaseUrl": "https://storefront.example.com/mock-checkout"
  },
  "BusinessOnboarding": {
    "InvitationMagicLink": {
      "BaseUrl": "darwin-business://InvitationAcceptance"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.office365.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "darwin.test.sender@outlook.com",
      "Password": "SET_TEST_SMTP_PASSWORD_HERE",
      "FromAddress": "darwin.test.sender@outlook.com",
      "FromDisplayName": "Darwin Test"
    }
  },
  "InactiveReminderWorker": {
    "Enabled": false,
    "Interval": "01:00:00",
    "InactiveThresholdDays": 14,
    "CooldownHours": 72,
    "MaxItemsPerRun": 200,
    "HighFailureRateWarningThresholdPercent": 30,
    "HighCooldownSuppressionWarningThresholdPercent": 60
  },
  "Notifications": {
    "InactiveReminderPushGateway": {
      "Enabled": false,
      "Endpoint": "/api/push/reminders/inactive",
      "BearerToken": "",
      "TitleTemplate": "We miss you at Loyan",
      "BodyTemplate": "It has been {inactiveDays} days since your last visit. Come back and discover new rewards.",
      "MaxAttempts": 3,
      "InitialBackoffMilliseconds": 300,
      "AndroidChannelId": "reengagement",
      "ApnsTopic": "com.loyan.darwin.mobile.consumer",
      "DeepLinkUrl": "loyan://feed",
      "CollapseKey": "inactive-reminder",
      "AnalyticsLabel": "inactive-reminder"
    }
  },
  "PushProviders": {
    "Fcm": {
      "Enabled": true,
      "ServerKey": "SET_YOUR_FCM_SERVER_KEY",
      "SenderId": "SET_YOUR_FCM_SENDER_ID"
    },
    "Apns": {
      "Enabled": true,
      "TeamId": "YOUR_TEAM_ID",
      "KeyId": "YOUR_KEY_ID",
      "AuthKeyFile": "path/to/AuthKey.p8",
      "BundleId": "com.loyan.darwin.mobile.consumer",
      "UseSandbox": true
    }
  }
}
