@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Login");
    var returnUrl = (string?)ViewData["ReturnUrl"] ?? "";
    var antiBotToken = (string?)ViewData["AntiBotToken"] ?? "";
}

<h1 class="mb-3">@T.T("Login")</h1>

<form asp-action="LoginPost" asp-controller="Account" method="post" class="mb-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <input type="hidden" name="antiBotToken" value="@antiBotToken" />
    <div class="d-none" aria-hidden="true">
        <label for="antiBotHoneypot">Leave this field empty</label>
        <input id="antiBotHoneypot" name="antiBotHoneypot" type="text" value="" tabindex="-1" autocomplete="off" />
    </div>
    <div class="mb-3">
        <label for="email" class="form-label">@T.T("Email")</label>
        <input id="email" name="email" type="email" class="form-control" required />
        <span class="text-danger field-validation-valid" data-valmsg-for="email" data-valmsg-replace="true"></span>
    </div>
    <div class="mb-3">
        <label for="password" class="form-label">@T.T("Password")</label>
        <input id="password" name="password" type="password" class="form-control" required />
        <span class="text-danger field-validation-valid" data-valmsg-for="password" data-valmsg-replace="true"></span>
    </div>
    <div class="form-check mb-3">
        <input id="rememberMe" name="rememberMe" type="checkbox" class="form-check-input" />
        <label for="rememberMe" class="form-check-label">@T.T("RememberMe")</label>
    </div>
    <div class="text-end">
        <button class="btn btn-primary" type="submit">@T.T("Login")</button>
    </div>
</form>

<fieldset class="d-none">
    <form id="passkey-form" method="post" action="@Url.Action("WebAuthnFinishLogin", "Account")">
        @Html.AntiForgeryToken()
        <input type="hidden" name="challengeTokenId" id="challengeTokenId" />
        <input type="hidden" name="clientResponseJson" id="clientResponseJson" />
        <input type="hidden" name="userId" id="userId" />
        <input type="hidden" name="rememberMe" value="true" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
    </form>
    <button id="passkey-btn" class="btn btn-secondary mt-2" type="button" data-passkey-preparing-label="@T.T("PasskeyPreparing")">@T.T("LoginWithPasskey")</button>
</fieldset>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
