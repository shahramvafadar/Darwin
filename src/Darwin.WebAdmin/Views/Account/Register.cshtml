@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Register");
}

<h1 class="mb-3">@T.T("Register")</h1>

<form asp-action="RegisterPost" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label for="email" class="form-label">@T.T("Email")</label>
        <input id="email" name="email" type="email" class="form-control" required />
        <span class="text-danger field-validation-valid" data-valmsg-for="email" data-valmsg-replace="true"></span>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">@T.T("Password")</label>
        <input id="password" name="password" type="password" class="form-control" required autocomplete="new-password" />
        <span class="text-danger field-validation-valid" data-valmsg-for="password" data-valmsg-replace="true"></span>
    </div>

    <fieldset class="d-none">
        <div class="row">
            <div class="col-md-4 mb-3">
                <label for="locale" class="form-label">@T.T("Locale")</label>
                <select id="locale" name="locale" class="form-select">
                    <option value="de-DE" selected>@T.T("LocaleGermanGermany")</option>
                    <option value="en-US">@T.T("LocaleEnglishUnitedStates")</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label for="currency" class="form-label">@T.T("Currency")</label>
                <select id="currency" name="currency" class="form-select">
                    <option value="EUR" selected>@T.T("CurrencyEuro")</option>
                    <option value="USD">@T.T("CurrencyUsd")</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label for="timezone" class="form-label">@T.T("TimeZone")</label>
                <select id="timezone" name="timezone" class="form-select">
                    <option value="Europe/Berlin" selected>@T.T("TimeZoneEuropeBerlin")</option>
                    <option value="UTC">@T.T("Utc")</option>
                </select>
            </div>
        </div>
        <input type="hidden" name="supportedCulturesCsv" value="de-DE,en-US" />
    </fieldset>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">@T.T("CreateAccount")</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
