@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Register");
    var defaultCurrency = (string?)ViewData["DefaultCurrency"] ?? Darwin.Application.Settings.DTOs.SiteSettingDto.DefaultCurrencyDefault;
    var defaultLocale = (string?)ViewData["DefaultLocale"] ?? Darwin.WebAdmin.Localization.AdminCultureCatalog.DefaultCulture;
    var defaultTimeZone = (string?)ViewData["DefaultTimeZone"] ?? Darwin.Application.Settings.DTOs.SiteSettingDto.TimeZoneDefault;
    var supportedCulturesCsv = (string?)ViewData["SupportedCulturesCsv"] ?? Darwin.WebAdmin.Localization.AdminCultureCatalog.SupportedCulturesCsvDefault;
}

<h1 class="mb-3">@T.T("Register")</h1>

<form asp-action="RegisterPost" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label for="email" class="form-label">@T.T("Email")</label>
        <input id="email" name="email" type="email" class="form-control" required />
        <span class="text-danger field-validation-valid" data-valmsg-for="email" data-valmsg-replace="true"></span>
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">@T.T("Password")</label>
        <input id="password" name="password" type="password" class="form-control" required autocomplete="new-password" />
        <div class="form-text">@T.T("PasswordPolicyHelp")</div>
        <span class="text-danger field-validation-valid" data-valmsg-for="password" data-valmsg-replace="true"></span>
    </div>

    <fieldset class="d-none">
        <div class="row">
            <div class="col-md-4 mb-3">
                <label for="locale" class="form-label">@T.T("Locale")</label>
                <select id="locale" name="locale" class="form-select">
                    <option value="@Darwin.WebAdmin.Localization.AdminCultureCatalog.German" selected="@(defaultLocale == Darwin.WebAdmin.Localization.AdminCultureCatalog.German)">@T.T("LocaleGermanGermany")</option>
                    <option value="@Darwin.WebAdmin.Localization.AdminCultureCatalog.English" selected="@(defaultLocale == Darwin.WebAdmin.Localization.AdminCultureCatalog.English)">@T.T("LocaleEnglishUnitedStates")</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label for="currency" class="form-label">@T.T("Currency")</label>
                <select id="currency" name="currency" class="form-select">
                    <option value="@Darwin.Application.Settings.DTOs.SiteSettingDto.DefaultCurrencyDefault" selected="@(defaultCurrency == Darwin.Application.Settings.DTOs.SiteSettingDto.DefaultCurrencyDefault)">@T.T("CurrencyEuro")</option>
                    <option value="USD" selected="@(defaultCurrency == "USD")">@T.T("CurrencyUsd")</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label for="timezone" class="form-label">@T.T("TimeZone")</label>
                <select id="timezone" name="timezone" class="form-select">
                    <option value="@Darwin.Application.Settings.DTOs.SiteSettingDto.TimeZoneDefault" selected="@(defaultTimeZone == Darwin.Application.Settings.DTOs.SiteSettingDto.TimeZoneDefault)">@T.T("TimeZoneEuropeBerlin")</option>
                    <option value="UTC" selected="@(defaultTimeZone == "UTC")">@T.T("Utc")</option>
                </select>
            </div>
        </div>
        <input type="hidden" name="supportedCulturesCsv" value="@supportedCulturesCsv" />
    </fieldset>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">@T.T("CreateAccount")</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
