@model Darwin.WebAdmin.ViewModels.Mobile.MobileOperationsVm
@using System.Globalization
@{
    ViewData["Title"] = T.T("MobileOperationsTitle");
    var readyText = T.T("Ready");
    var missingText = T.T("Missing");
    string LocalizeMobilePlatform(object? platform) => platform is null ? "-" : T.T(platform.ToString() ?? string.Empty);

    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivationMembers"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("LockedMembers"),
        _ => T.T("Members")
    };

    string BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApprovalBusinesses"),
        _ => T.T("BusinessesTitle")
    };

    string CommunicationChannelLabel(string channel) => channel switch
    {
        "Sms" => T.T("Sms"),
        "WhatsApp" => T.T("WhatsApp"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };

    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        _ => T.T("Invitations")
    };
    string InvitationDebtSummaryLabel(int pendingInvitationCount) => pendingInvitationCount > 0
        ? T.T("BusinessSupportPendingInvitationsLabel")
        : InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open);
    int InvitationDebtCount(int pendingInvitationCount, int openInvitationCount) => pendingInvitationCount > 0
        ? pendingInvitationCount
        : openInvitationCount;
    string DeviceRemediationState(Darwin.WebAdmin.ViewModels.Mobile.MobileDeviceOpsListItemVm item) => !item.HasPushToken
        ? "missing-push"
        : !item.NotificationsEnabled
            ? "notifications-disabled"
            : item.BusinessMembershipCount > 0
                ? "business-members"
                : string.Empty;
    string DeviceRemediationLabel(Darwin.WebAdmin.ViewModels.Mobile.MobileDeviceOpsListItemVm item) => !item.HasPushToken
        ? T.T("MobileMissingPushToken")
        : !item.NotificationsEnabled
            ? T.T("MobileNotificationsDisabled")
            : item.BusinessMembershipCount > 0
                ? T.T("BusinessMemberDevices")
                : T.T("UsersFilterMobileLinked");
    string DeviceRemediationBadgeClass(Darwin.WebAdmin.ViewModels.Mobile.MobileDeviceOpsListItemVm item) => !item.HasPushToken || !item.NotificationsEnabled
        ? "badge bg-warning-subtle text-warning-emphasis"
        : item.BusinessMembershipCount > 0
            ? "badge bg-info-subtle text-info-emphasis"
            : "badge bg-success-subtle text-success-emphasis";
    string MobileOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string MobileOpsHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string MobileSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-mobile" }) ?? string.Empty;
    string BusinessAppSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-business-app" }) ?? string.Empty;
    string ScopedSupportQueueUrl() => Url.Action("SupportQueue", "Businesses", new { businessId = Model.BusinessId }) ?? string.Empty;
    string LoyaltyAccountsIndexUrl() => Url.Action("Accounts", "Loyalty") ?? string.Empty;
    string LoyaltyAccountsUrl(string q) => Url.Action("Accounts", "Loyalty", new { q }) ?? string.Empty;
    string LoyaltyRedemptionsUrl() => Url.Action("Redemptions", "Loyalty") ?? string.Empty;
    string LoyaltyCampaignsUrl() => Url.Action("Campaigns", "Loyalty") ?? string.Empty;
    string LoyaltyProgramsUrl() => Url.Action("Programs", "Loyalty") ?? string.Empty;
    string LoyaltyScanSessionsIndexUrl() => Url.Action("ScanSessions", "Loyalty") ?? string.Empty;
    string LoyaltyScanSessionsUrl(string q) => Url.Action("ScanSessions", "Loyalty", new { q }) ?? string.Empty;
    string UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter) => Url.Action("Index", "Users", new { filter }) ?? string.Empty;
    string UserEditUrl(Guid id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string ProviderReviewChannelAuditsUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { providerReviewOnly = true }) ?? string.Empty;
    string MobileOperationsIndexUrl() => Url.Action("Index", "MobileOperations", new { businessId = Model.BusinessId }) ?? string.Empty;
    string MobileOperationsUrl(string state) => Url.Action("Index", "MobileOperations", new { businessId = Model.BusinessId, state }) ?? string.Empty;
    string MobileOperationsItemUrl(Darwin.WebAdmin.ViewModels.Mobile.MobileDeviceOpsListItemVm item) => Url.Action("Index", "MobileOperations", new { businessId = Model.BusinessId, state = DeviceRemediationState(item) }) ?? string.Empty;
    string DeactivateStaleDevicesUrl() => Url.Action("DeactivateStaleDevices", "MobileOperations") ?? string.Empty;
    string ClearNotificationsDisabledPushTokensUrl() => Url.Action("ClearNotificationsDisabledPushTokens", "MobileOperations") ?? string.Empty;
    var bootstrapAttentionCount =
        (Model.JwtEnabled ? 0 : 1)
        + (Model.JwtRequireDeviceBinding ? 0 : 1)
        + (Model.BusinessManagementWebsiteConfigured ? 0 : 1)
        + (Model.AccountDeletionConfigured ? 0 : 1);
    var onboardingAttentionCount = Model.AttentionBusinessCount
        + Model.PendingApprovalBusinessCount
        + InvitationDebtCount(Model.PendingInvitationCount, Model.OpenInvitationCount)
        + Model.PendingActivationMemberCount
        + Model.LockedMemberCount
        + Model.BusinessesRequiringEmailSetupCount;
    var transportAttentionCount =
        (Model.EmailTransportConfigured ? 0 : 1)
        + (Model.SmsTransportConfigured ? 0 : 1)
        + (Model.WhatsAppTransportConfigured ? 0 : 1)
        + (Model.AdminAlertRoutingConfigured ? 0 : 1);
    var deviceAttentionCount = Model.StaleDevicesCount + Model.DevicesMissingPushTokenCount + Model.NotificationsDisabledCount;
}

<div id="mobile-operations-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("MobileOperationsTitle")</h1>
        <p class="text-muted mb-0">@T.T("MobileOperationsIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-mobile" class="btn btn-outline-secondary"
           hx-get="@MobileSettingsUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SiteSettings")</a>
        <a asp-controller="Businesses" asp-action="SupportQueue" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@ScopedSupportQueueUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SupportQueue")</a>
        <a asp-controller="Loyalty" asp-action="ScanSessions" class="btn btn-outline-secondary"
               hx-get="@LoyaltyScanSessionsIndexUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("LoyaltyScanSessionsTitle")</a>
        <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-outline-secondary"
           hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
</div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("MobileOperationsTitle")</h2>
                <p class="text-muted mb-0">@T.T("MobileOperationsIntro")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Businesses" asp-action="SupportQueue" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                   hx-get="@ScopedSupportQueueUrl()"
                   hx-target="#mobile-operations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-mobile" class="btn btn-sm btn-outline-primary"
                   hx-get="@MobileSettingsUrl()"
                   hx-target="#mobile-operations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenMobileBootstrap")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("MobileBootstrapTitle")</div>
                        <span class="@MobileOpsHealthBadgeClass(bootstrapAttentionCount == 0)">@MobileOpsHealthBadgeText(bootstrapAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@bootstrapAttentionCount</div>
                    <div class="small text-muted">@T.T("MobileBootstrapDeviceBindingRequired")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-mobile" class="btn btn-sm btn-outline-secondary"
                           hx-get="@MobileSettingsUrl()"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenMobileBootstrap")</a>
                        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-business-app" class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessAppSettingsUrl()"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenBusinessAppSettings")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("MobileOnboardingDependenciesTitle")</div>
                        <span class="@MobileOpsHealthBadgeClass(onboardingAttentionCount == 0)">@MobileOpsHealthBadgeText(onboardingAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@onboardingAttentionCount</div>
                    <div class="small text-muted">@InvitationDebtSummaryLabel(Model.PendingInvitationCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="Businesses" asp-action="SupportQueue" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@ScopedSupportQueueUrl()"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("SupportQueue")</a>
                        <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-sm btn-outline-secondary"
                           hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("TransportReadiness")</div>
                        <span class="@MobileOpsHealthBadgeClass(transportAttentionCount == 0)">@MobileOpsHealthBadgeText(transportAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@transportAttentionCount</div>
                    <div class="small text-muted">@T.T("MobileOperationsSnapshotNote")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalBusinessCommunicationsUrl()"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenCommunicationsWorkspace")</a>
                        <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-providerReviewOnly="true" class="btn btn-sm btn-outline-secondary"
                           hx-get="@ProviderReviewChannelAuditsUrl()"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReviewProviderLane")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("DeviceFleetSnapshotTitle")</div>
                        <span class="@MobileOpsHealthBadgeClass(deviceAttentionCount == 0)">@MobileOpsHealthBadgeText(deviceAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@deviceAttentionCount</div>
                    <div class="small text-muted">@T.T("MobileMissingPushToken") / @T.T("MobileNotificationsDisabled")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="stale" class="btn btn-sm btn-outline-warning"
                           hx-get="@MobileOperationsUrl("stale")"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MobileStaleDevices")</a>
                        <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="missing-push" class="btn btn-sm btn-outline-warning"
                           hx-get="@MobileOperationsUrl("missing-push")"
                           hx-target="#mobile-operations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MobileMissingPushToken")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("LoyaltyMobileFollowUp")</div>
    <div class="card-body d-flex gap-2 flex-wrap">
        <a asp-controller="Loyalty" asp-action="Accounts" class="btn btn-sm btn-outline-primary"
                           hx-get="@LoyaltyAccountsIndexUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("LoyaltyAccountsTitle")</a>
        <a asp-controller="Loyalty" asp-action="Redemptions" class="btn btn-sm btn-outline-secondary"
           hx-get="@LoyaltyRedemptionsUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Redemptions")</a>
        <a asp-controller="Loyalty" asp-action="Campaigns" class="btn btn-sm btn-outline-secondary"
           hx-get="@LoyaltyCampaignsUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Campaigns")</a>
        <a asp-controller="Loyalty" asp-action="Programs" class="btn btn-sm btn-outline-secondary"
           hx-get="@LoyaltyProgramsUrl()"
           hx-target="#mobile-operations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Programs")</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("MobileBootstrapTitle")</div>
            <div class="card-body">
                <div class="mb-2">@T.T("MobileBootstrapJwtEnabled"): <strong>@(Model.JwtEnabled ? readyText : missingText)</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapSingleDeviceOnly"): <strong>@(Model.JwtSingleDeviceOnly ? readyText : missingText)</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapDeviceBindingRequired"): <strong>@(Model.JwtRequireDeviceBinding ? readyText : missingText)</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapAccessTokenMinutes"): <strong>@Model.JwtAccessTokenMinutes</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapRefreshTokenDays"): <strong>@Model.JwtRefreshTokenDays</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapQrRefreshSeconds"): <strong>@Model.MobileQrTokenRefreshSeconds</strong></div>
                <div class="mb-2">@T.T("MobileBootstrapMaxOutboxItems"): <strong>@Model.MobileMaxOutboxItems</strong></div>
                <div class="mb-2">@T.T("DefaultCulture"): <strong>@Model.DefaultCulture</strong></div>
                <div>@T.T("TimeZone"): <strong>@Model.TimeZone</strong></div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("MobileBusinessAppHandoffsTitle")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("SubscriptionWebsite")</div><div class="fs-6 fw-semibold">@(Model.BusinessManagementWebsiteConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("AccountDeletion")</div><div class="fs-6 fw-semibold">@(Model.AccountDeletionConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("Impressum")</div><div class="fs-6 fw-semibold">@(Model.ImpressumConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("Privacy")</div><div class="fs-6 fw-semibold">@(Model.PrivacyPolicyConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("BusinessTerms")</div><div class="fs-6 fw-semibold">@(Model.BusinessTermsConfigured ? readyText : missingText)</div></div></div>
                </div>
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-business-app" class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessAppSettingsUrl()"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenBusinessAppSettings")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-mobile" class="btn btn-sm btn-outline-secondary"
                       hx-get="@MobileSettingsUrl()"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenMobileBootstrap")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("MobileOnboardingDependenciesTitle")</div>
            <div class="card-body">
                <div class="mb-2">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention): <strong>@Model.AttentionBusinessCount</strong></div>
                <div class="mb-2">@BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval): <strong>@Model.PendingApprovalBusinessCount</strong></div>
                <div class="mb-2">@InvitationDebtSummaryLabel(Model.PendingInvitationCount): <strong>@InvitationDebtCount(Model.PendingInvitationCount, Model.OpenInvitationCount)</strong></div>
                <div class="mb-2">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation): <strong>@Model.PendingActivationMemberCount</strong></div>
                <div class="mb-2">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked): <strong>@Model.LockedMemberCount</strong></div>
                <div>@T.T("BusinessesRequiringEmailSetup"): <strong>@Model.BusinessesRequiringEmailSetupCount</strong></div>
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-controller="Businesses" asp-action="SupportQueue" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                       hx-get="@ScopedSupportQueueUrl()"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("SupportQueue")</a>
                    <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed" class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed)"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
                    <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked" class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
                    <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("DeviceFleetSnapshotTitle")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("ActiveDevices")</div><div class="fs-5">@Model.TotalActiveDevices</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("BusinessMemberDevices")</div><div class="fs-5">@Model.BusinessMemberDevicesCount</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("MobileStaleDevices")</div><div class="fs-5">@Model.StaleDevicesCount</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("MobileMissingPushToken")</div><div class="fs-5">@Model.DevicesMissingPushTokenCount</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-3"><div class="text-muted small">@T.T("MobileNotificationsDisabled")</div><div class="fs-5">@Model.NotificationsDisabledCount</div></div></div>
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Android")</div><div class="fs-5">@Model.AndroidDevicesCount</div></div></div>
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("iOS")</div><div class="fs-5">@Model.IosDevicesCount</div></div></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("RecentAppVersions")</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead><tr><th>@T.T("Platform")</th><th>@T.T("Version")</th><th>@T.T("Devices")</th><th>@T.T("LastSeen")</th></tr></thead>
                    <tbody>
                    @if (Model.RecentVersions.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">@T.T("NoDeviceVersionData")</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentVersions)
                        {
                            <tr>
                                <td>@LocalizeMobilePlatform(item.Platform)</td>
                                <td>@item.AppVersion</td>
                                <td>@item.DeviceCount</td>
                        <td>@(item.LastSeenAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? "-")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">@T.T("TransportReadiness")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Email")</div><div class="fs-5">@(Model.EmailTransportConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@CommunicationChannelLabel("Sms")</div><div class="fs-5">@(Model.SmsTransportConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@CommunicationChannelLabel("WhatsApp")</div><div class="fs-5">@(Model.WhatsAppTransportConfigured ? readyText : missingText)</div></div></div>
                    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("AdminAlerts")</div><div class="fs-5">@(Model.AdminAlertRoutingConfigured ? readyText : missingText)</div></div></div>
                </div>
                <div class="alert alert-secondary mt-3 mb-0">@T.T("MobileOperationsSnapshotNote")</div>
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-providerReviewOnly="true"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@ProviderReviewChannelAuditsUrl()"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("ReviewProviderLane")</a>
                    <a asp-controller="BusinessCommunications" asp-action="Index"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@GlobalBusinessCommunicationsUrl()"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenCommunicationsWorkspace")</a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <details class="admin-playbook mb-4">
        <summary>@T.T("MobileOperationsPlaybooks")</summary>
        <div class="admin-playbook-body p-0">
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead><tr><th>@T.T("Playbook")</th><th>@T.T("WhenItApplies")</th><th>@T.T("OperatorAction")</th></tr></thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#mobile-operations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.Title</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#mobile-operations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.ScopeNote</a>
                        </td>
                        <td>
                            <div>
                                <a href="@playbook.QueueActionUrl"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#mobile-operations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.OperatorAction</a>
                            </div>
                            <div class="d-flex gap-2 flex-wrap mt-2">
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#mobile-operations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#mobile-operations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        </div>
    </details>
}

<div class="card mb-4">
    <div class="card-header">@T.T("NeedsAttention")</div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("DeviceFleetSnapshotTitle")</div>
                <div class="text-muted small">@T.T("RecentMobileDevices")</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (string.Equals(Model.StateFilter, "stale", StringComparison.OrdinalIgnoreCase) && Model.StaleDevicesCount > 0)
                {
                    <form asp-action="DeactivateStaleDevices" method="post" class="d-inline" hx-post="@DeactivateStaleDevicesUrl()" hx-target="#mobile-operations-workspace-shell" hx-swap="outerHTML">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="q" value="@Model.Query" />
                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                        <input type="hidden" name="platform" value="@Model.PlatformFilter" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("MobileDeactivateStaleBatch")</button>
                    </form>
                }
                @if (string.Equals(Model.StateFilter, "notifications-disabled", StringComparison.OrdinalIgnoreCase) && Model.NotificationsDisabledCount > 0)
                {
                    <form asp-action="ClearNotificationsDisabledPushTokens" method="post" class="d-inline" hx-post="@ClearNotificationsDisabledPushTokensUrl()" hx-target="#mobile-operations-workspace-shell" hx-swap="outerHTML">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="q" value="@Model.Query" />
                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                        <input type="hidden" name="platform" value="@Model.PlatformFilter" />
                        <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("MobileClearDisabledPushBatch")</button>
                    </form>
                }
                <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="business-members" class="btn btn-sm btn-outline-secondary"
                   hx-get="@MobileOperationsUrl("business-members")"
                   hx-target="#mobile-operations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessMemberDevices")</a>
                <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-sm btn-outline-secondary"
                   hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)"
                   hx-target="#mobile-operations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="text-muted small">@T.T("MobileStaleDevices")</div>
                    <div class="fs-4 fw-semibold">@Model.StaleDevicesCount</div>
                    <div class="small text-muted">@T.T("LastSeen")</div>
                    <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="stale" class="btn btn-sm btn-outline-warning mt-auto"
                       hx-get="@MobileOperationsUrl("stale")"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MobileStaleDevices")</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="text-muted small">@T.T("MobileMissingPushToken")</div>
                    <div class="fs-4 fw-semibold">@Model.DevicesMissingPushTokenCount</div>
                    <div class="small text-muted">@T.T("ClearPush")</div>
                    <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="missing-push" class="btn btn-sm btn-outline-warning mt-auto"
                       hx-get="@MobileOperationsUrl("missing-push")"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MobileMissingPushToken")</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="text-muted small">@T.T("MobileNotificationsDisabled")</div>
                    <div class="fs-4 fw-semibold">@Model.NotificationsDisabledCount</div>
                    <div class="small text-muted">@T.T("ProviderReview")</div>
                    <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="notifications-disabled" class="btn btn-sm btn-outline-warning mt-auto"
                       hx-get="@MobileOperationsUrl("notifications-disabled")"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MobileNotificationsDisabled")</a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="text-muted small">@T.T("BusinessMemberDevices")</div>
                    <div class="fs-4 fw-semibold">@Model.BusinessMemberDevicesCount</div>
                    <div class="small text-muted">@T.T("SupportQueue")</div>
                    <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="business-members" class="btn btn-sm btn-outline-secondary mt-auto"
                       hx-get="@MobileOperationsUrl("business-members")"
                       hx-target="#mobile-operations-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessMemberDevices")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
        <div class="card-header">@T.T("RecentMobileDevices")</div>
    <div class="card-body border-bottom">
        <form asp-action="Index" method="get" class="row g-2"
                           hx-get="@MobileOperationsIndexUrl()"
              hx-target="#mobile-operations-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <input type="hidden" name="businessId" value="@Model.BusinessId" />
            <div class="col-md-4">
                <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("MobileSearchUserDeviceVersion")" />
            </div>
            <div class="col-md-3">
                <select name="platform" asp-items="Model.PlatformItems" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <select name="state" asp-items="Model.StateItems" class="form-select"></select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary">@T.T("Filter")</button>
                <a asp-action="Index" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
                           hx-get="@MobileOperationsIndexUrl()"
                   hx-target="#mobile-operations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Reset")</a>
            </div>
        </form>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle mb-0">
            <thead><tr><th>@T.T("User")</th><th>@T.T("Platform")</th><th>@T.T("Version")</th><th>@T.T("Device")</th><th>@T.T("Push")</th><th>@T.T("Membership")</th><th>@T.T("LastSeen")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (Model.Devices.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-3">@T.T("NoDevicesMatchCurrentFilters")</td></tr>
            }
            else
            {
                foreach (var item in Model.Devices)
                {
                    <tr>
                        <td>
                            <div>@item.UserDisplayName</div>
                            <div class="small text-muted">@item.UserEmail</div>
                        </td>
                        <td>@LocalizeMobilePlatform(item.Platform)</td>
                        <td>
                            <div>@(item.AppVersion ?? "-")</div>
                            <div class="small text-muted">@(item.DeviceModel ?? T.T("UnknownDevice"))</div>
                        </td>
                        <td><code>@item.DeviceId</code></td>
                        <td>
                            <div>@(item.HasPushToken ? T.T("MobilePushTokenPresent") : T.T("MobilePushTokenMissing"))</div>
                            <div class="small text-muted">@(item.NotificationsEnabled ? T.T("MobileNotificationsOn") : T.T("MobileNotificationsOff"))</div>
                            <div class="mt-1"><span class="@DeviceRemediationBadgeClass(item)">@DeviceRemediationLabel(item)</span></div>
                        </td>
                        <td>
                            <div>@(item.BusinessMembershipCount > 0 ? string.Format(T.T("MobileBusinessMemberships"), item.BusinessMembershipCount) : T.T("MobileConsumerOnly"))</div>
                            @if (item.BusinessMembershipCount > 0)
                            {
                                <div class="small mt-1">
                                    <a asp-controller="Businesses" asp-action="SupportQueue" asp-route-businessId="@Model.BusinessId"
                                       hx-get="@ScopedSupportQueueUrl()"
                                       hx-target="#mobile-operations-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("SupportQueue")</a>
                                </div>
                            }
                        </td>
                        <td>@(item.LastSeenAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? T.T("Never"))</td>
                        <td class="text-end">
                            <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary"
                               hx-get="@UserEditUrl(item.UserId)"
                               hx-target="#mobile-operations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("User")</a>
                            <a asp-controller="Loyalty" asp-action="Accounts" class="btn btn-sm btn-outline-secondary"
                               hx-get="@LoyaltyAccountsUrl(item.UserEmail)"
                               hx-target="#mobile-operations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Loyalty")</a>
                            @if (item.BusinessMembershipCount > 0)
                            {
                                <a asp-controller="Loyalty" asp-action="ScanSessions" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@LoyaltyScanSessionsUrl(item.UserEmail)"
                                   hx-target="#mobile-operations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("LoyaltyScanSessionsTitle")</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(DeviceRemediationState(item)))
                            {
                                <a asp-action="Index" asp-route-businessId="@Model.BusinessId" asp-route-state="@DeviceRemediationState(item)" class="btn btn-sm btn-outline-secondary"
                                           hx-get="@MobileOperationsItemUrl(item)"
                                   hx-target="#mobile-operations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@DeviceRemediationLabel(item)</a>
                            }
                            <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-providerReviewOnly="true" class="btn btn-sm btn-outline-secondary"
                               hx-get="@ProviderReviewChannelAuditsUrl()"
                               hx-target="#mobile-operations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("ProviderReview")</a>
                            @if (item.HasPushToken)
                            {
                                <form asp-action="ClearPushToken" method="post" class="d-inline"
                                      hx-post="@Url.Action("ClearPushToken", "MobileOperations")"
                                      hx-target="#mobile-operations-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                    <input type="hidden" name="platform" value="@Model.PlatformFilter" />
                                    <input type="hidden" name="state" value="@Model.StateFilter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("ClearPush")</button>
                                </form>
                            }
                            @if (item.IsActive)
                            {
                                <form asp-action="DeactivateDevice" method="post" class="d-inline"
                                      hx-post="@Url.Action("DeactivateDevice", "MobileOperations")"
                                      hx-target="#mobile-operations-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                    <input type="hidden" name="platform" value="@Model.PlatformFilter" />
                                    <input type="hidden" name="state" value="@Model.StateFilter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Deactivate")</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="MobileOperations"
       asp-action="Index"
       asp-route-q="@Model.Query"
       asp-route-businessId="@Model.BusinessId"
       asp-route-platform="@Model.PlatformFilter"
       asp-route-state="@Model.StateFilter"
       hx-target="#mobile-operations-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"></pager>
</div>
