@model Darwin.WebAdmin.ViewModels.Identity.UserRolesEditVm
@{
    ViewData["Title"] = "Edit User Roles";
}

<div id="user-roles-editor-shell">
    <h1 class="mb-3"><i class="fa fa-users-cog"></i> Roles - @Model.UserEmail</h1>

    <div id="alerts-container">
        <partial name="~/Views/Shared/_Alerts.cshtml" />
    </div>

    <form asp-action="Roles"
          method="post"
          class="row g-3"
          hx-post="@Url.Action("Roles", "Users")"
          hx-target="#user-roles-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="UserEmail" />
        <input type="hidden" asp-for="UserDisplay" />

        <div class="col-12">
            <div class="card">
                <div class="card-header">Assign roles to user</div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="alert alert-info">
                        <strong>Delegated support role:</strong> the built-in <code>business-support-admins</code> role is intended for invitation and business-member support actions only. Approval, suspension, owner overrides, and business lifecycle changes remain FullAdmin-only.
                    </div>
                    @if (Model.AllRoles.Count > 0)
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-2">
                            @foreach (var r in Model.AllRoles)
                            {
                                var isChecked = Model.SelectedRoleIds.Contains(r.Id);
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedRoleIds"
                                               value="@r.Id"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label">
                                            <strong>@r.DisplayName</strong>
                                            @if (string.Equals(r.Key, "business-support-admins", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="badge bg-info text-dark ms-2">Delegated support</span>
                                            }
                                            <small class="text-muted d-block">@r.Key - @r.Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No roles found.</div>
                    }
                </div>
                <div class="card-footer text-end">
                    <a asp-controller="Users" asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left"></i> Back
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-check"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
