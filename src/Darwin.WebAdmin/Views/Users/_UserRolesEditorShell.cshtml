@model Darwin.WebAdmin.ViewModels.Identity.UserRolesEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditUserRolesTitle");
}

<div id="user-roles-editor-shell">
    <h1 class="mb-3"><i class="fa fa-users-cog"></i> @T.T("EditUserRolesTitle") - @Model.UserEmail</h1>

    <div id="alerts-container">
        <partial name="~/Views/Shared/_Alerts.cshtml" />
    </div>

    <form asp-action="Roles"
          method="post"
          class="row g-3"
          hx-post="@Url.Action("Roles", "Users")"
          hx-target="#user-roles-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="UserEmail" />
        <input type="hidden" asp-for="UserDisplay" />
        <input type="hidden" asp-for="ReturnToIndex" />
        <input type="hidden" asp-for="Query" />
        <input type="hidden" asp-for="Filter" />
        <input type="hidden" asp-for="Page" />
        <input type="hidden" asp-for="PageSize" />

        <div class="col-12">
            <div class="card">
                <div class="card-header">@T.T("AssignRolesToUserTitle")</div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a asp-controller="Users"
                           asp-action="Index"
                           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                           asp-route-q="@Model.UserEmail"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed, q = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-user-check"></i> @T.T("UsersFilterUnconfirmed")
                        </a>
                        <a asp-controller="Users"
                           asp-action="Index"
                           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                           asp-route-q="@Model.UserEmail"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Locked, q = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-lock"></i> @T.T("UsersFilterLocked")
                        </a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-status="Failed"
                           asp-route-flowKey="AccountActivation"
                           asp-route-recipientEmail="@Model.UserEmail"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation", recipientEmail = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-envelope-circle-check"></i> @T.T("OpenFailedActivationEmails")
                        </a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-status="Failed"
                           asp-route-flowKey="PasswordReset"
                           asp-route-recipientEmail="@Model.UserEmail"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset", recipientEmail = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-triangle-exclamation"></i> @T.T("OpenFailedPasswordResets")
                        </a>
                        <a asp-controller="MobileOperations"
                           asp-action="Index"
                           asp-route-q="@Model.UserEmail"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "MobileOperations", new { q = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                        </a>
                        <a asp-controller="Loyalty"
                           asp-action="Accounts"
                           asp-route-q="@Model.UserEmail"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Accounts", "Loyalty", new { q = Model.UserEmail })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-star"></i> @T.T("Loyalty")
                        </a>
                    </div>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="alert alert-info">
                        <strong>@T.T("DelegatedSupportRoleTitle")</strong> @T.T("DelegatedSupportRoleNote")
                    </div>
                    @if (Model.AllRoles.Count > 0)
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-2">
                            @foreach (var r in Model.AllRoles)
                            {
                                var isChecked = Model.SelectedRoleIds.Contains(r.Id);
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedRoleIds"
                                               value="@r.Id"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label">
                                            <strong>@r.DisplayName</strong>
                                            @if (string.Equals(r.Key, "business-support-admins", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="badge bg-info text-dark ms-2">@T.T("DelegatedSupportBadge")</span>
                                            }
                                            <small class="text-muted d-block">@r.Key - @r.Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">@T.T("NoRolesFound")</div>
                    }
                </div>
                <div class="card-footer text-end">
                    @if (Model.ReturnToIndex)
                    {
                        <a asp-controller="Users"
                           asp-action="Index"
                           asp-route-q="@Model.Query"
                           asp-route-filter="@Model.Filter"
                           asp-route-page="@Model.Page"
                           asp-route-pageSize="@Model.PageSize"
                           class="btn btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Users", new { q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML">
                            <i class="fa fa-arrow-left"></i> @T.T("Back")
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Users"
                           asp-action="Edit"
                           asp-route-id="@Model.UserId"
                           class="btn btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "Users", new { id = Model.UserId })"
                           hx-target="#user-roles-editor-shell"
                           hx-swap="outerHTML">
                            <i class="fa fa-arrow-left"></i> @T.T("Back")
                        </a>
                    }
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-check"></i> @T.T("Save")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
