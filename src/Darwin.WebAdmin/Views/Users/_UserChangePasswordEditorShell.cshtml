@model Darwin.WebAdmin.ViewModels.Identity.UserChangePasswordVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("ChangePassword");
}

<div id="user-change-password-editor-shell">
    <h1 class="mb-3"><i class="fa fa-key"></i> @T.T("ChangePassword")</h1>

    <form asp-action="ChangePassword"
          method="post"
          class="needs-validation"
          novalidate
          hx-post="@Url.Action("ChangePassword", "Users")"
          hx-target="#user-change-password-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="ReturnToIndex" />
        <input type="hidden" asp-for="Query" />
        <input type="hidden" asp-for="Filter" />
        <input type="hidden" asp-for="Page" />
        <input type="hidden" asp-for="PageSize" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <a asp-controller="MobileOperations"
                       asp-action="Index"
                       asp-route-q="@Model.Email"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "MobileOperations", new { q = Model.Email })"
                       hx-target="#user-change-password-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                    </a>
                    <a asp-controller="Loyalty"
                       asp-action="Accounts"
                       asp-route-q="@Model.Email"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Accounts", "Loyalty", new { q = Model.Email })"
                       hx-target="#user-change-password-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa fa-star"></i> @T.T("Loyalty")
                    </a>
                </div>
                <div class="mb-3">
                    <label class="form-label">@T.T("User")</label>
                    <div class="form-text">
                        <strong>@Model.Email</strong> <span class="text-muted">(@T.T("Id"): @Model.Id)</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <field-help title="@T.T("NewPassword")" content="@T.T("PasswordPolicyHelp")" placement="right"></field-help>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <div class="form-text">@T.T("PasswordPolicyHelp")</div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmNewPassword" class="form-label"></label>
                    <field-help title="@T.T("ConfirmNewPassword")" content="@T.T("MustMatchNewPassword")" placement="right"></field-help>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="card-footer text-end">
                @if (Model.ReturnToIndex)
                {
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-q="@Model.Query"
                       asp-route-filter="@Model.Filter"
                       asp-route-page="@Model.Page"
                       asp-route-pageSize="@Model.PageSize"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Users", new { q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize })"
                       hx-target="#user-change-password-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa fa-arrow-left"></i> @T.T("Back")
                    </a>
                }
                else
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "Users", new { id = Model.Id })"
                       hx-target="#user-change-password-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa fa-arrow-left"></i> @T.T("Back")
                    </a>
                }
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-check"></i> @T.T("Save")
                </button>
            </div>
        </div>
    </form>
</div>
