@model Darwin.WebAdmin.ViewModels.Identity.UsersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("UsersPageTitle");
}

<div id="users-workspace-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">@T.T("UsersPageTitle")</h2>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Unconfirmed" class="btn btn-outline-warning btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Unconfirmed" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterUnconfirmed")</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Locked" class="btn btn-outline-danger btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Locked" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterLocked")</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Inactive" class="btn btn-outline-secondary btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Inactive" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterInactive")</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="MobileLinked" class="btn btn-outline-info btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterMobileLinked")</a>
            <a asp-controller="Users"
               asp-action="Create"
               class="btn btn-primary"
               hx-get="@Url.Action("Create", "Users")"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">
                <i class="fa fa-plus"></i> @T.T("UsersCreateAction")
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("UsersSummaryTotal")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                <div class="mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="All"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Users", new { filter = "All" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersPageTitle")</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("UsersSummaryUnconfirmed")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.UnconfirmedCount</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="Unconfirmed"
                       class="btn btn-sm btn-outline-warning"
                       hx-get="@Url.Action("Index", "Users", new { filter = "Unconfirmed" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="AccountActivation"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("UsersSummaryLocked")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.LockedCount</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="Locked"
                       class="btn btn-sm btn-outline-danger"
                       hx-get="@Url.Action("Index", "Users", new { filter = "Locked" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterLocked")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="PasswordReset"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("UsersSummaryInactive")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div>
                <div class="mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="Inactive"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Users", new { filter = "Inactive" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterInactive")</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("UsersSummaryMobileLinked")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.MobileLinkedCount</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="MobileLinked"
                       class="btn btn-sm btn-outline-info"
                       hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                    <a asp-controller="MobileOperations"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "MobileOperations")"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">@T.T("UsersPlaybooksTitle")</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("UsersPlaybooksQueueColumn")</th>
                            <th>@T.T("UsersPlaybooksScopeColumn")</th>
                            <th>@T.T("UsersPlaybooksActionColumn")</th>
                            <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Title</td>
                            <td>@item.ScopeNote</td>
                            <td>@item.OperatorAction</td>
                            <td>@item.FollowUp</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <form method="get"
          class="row g-2 mb-3"
          hx-get="@Url.Action("Index", "Users")"
          hx-target="#users-workspace-shell"
          hx-swap="outerHTML">
        <div class="col-auto">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("UsersSearchPlaceholder")">
        </div>
        <div class="col-auto">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <select name="pageSize" class="form-select">
                @foreach (var s in Model.PageSizeItems)
                {
                    <option value="@s.Value" selected="@s.Selected">@s.Text</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("UsersSearchAction")</button>
            <a asp-controller="Users"
               asp-action="Index"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Index", "Users")"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">@T.T("UsersResetAction")</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>@T.T("UsersEmailColumn")</th>
                    <th>@T.T("UsersNameColumn")</th>
                    <th>@T.T("UsersLifecycleColumn")</th>
                    <th class="text-center">@T.T("UsersActiveColumn")</th>
                    <th class="text-end" style="width:410px">@T.T("UsersActionsColumn")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@u.Email</td>
                        <td>@($"{u.FirstName} {u.LastName}".Trim())</td>
                        <td>
                            @if (!u.EmailConfirmed)
                            {
                                <div>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="AccountActivation"
                                       asp-route-recipientEmail="@u.Email"
                                       class="badge text-bg-warning text-decoration-none"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation", recipientEmail = u.Email })"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("UsersLifecycleUnconfirmedBadge")</a>
                                </div>
                            }
                            @if (u.IsLockedOut)
                            {
                                <div>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="PasswordReset"
                                       asp-route-recipientEmail="@u.Email"
                                       class="badge text-bg-danger text-decoration-none"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset", recipientEmail = u.Email })"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("UsersLifecycleLockedBadge")</a>
                                </div>
                                <div class="small text-muted">@u.LockoutEndUtc?.ToString("yyyy-MM-dd HH:mm")</div>
                            }
                            @if (u.MobileDeviceCount > 0)
                            {
                                <div>
                                    <a asp-controller="MobileOperations"
                                       asp-action="Index"
                                       asp-route-q="@u.Email"
                                       class="badge text-bg-info text-decoration-none"
                                       hx-get="@Url.Action("Index", "MobileOperations", new { q = u.Email })"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@string.Format(T.T("UsersLifecycleMobileBadge"), u.MobileDeviceCount)</a>
                                </div>
                            }
                        </td>
                        <td class="text-center">
                            @if (u.IsActive)
                            {
                                <span class="badge text-bg-success">@T.T("UsersYes")</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">@T.T("UsersNo")</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Edit", "Users", new { id = u.Id })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-pen"></i> @T.T("UsersEditAction")
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangeEmail"
                               asp-route-id="@u.Id"
                               asp-route-currentEmail="@u.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("ChangeEmail", "Users", new { id = u.Id, currentEmail = u.Email })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-envelope"></i> @T.T("UsersEmailAction")
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangePassword"
                               asp-route-id="@u.Id"
                               asp-route-email="@u.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("ChangePassword", "Users", new { id = u.Id, email = u.Email })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-key"></i> @T.T("UsersPasswordAction")
                            </a>

                            <a asp-controller="Users" asp-action="Roles" asp-route-id="@u.Id"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Roles", "Users", new { id = u.Id, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-users-cog"></i> @T.T("UsersRolesAction")
                            </a>

                            @if (u.MobileDeviceCount > 0)
                            {
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-q="@u.Email"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "MobileOperations", new { q = u.Email })"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                                </a>

                                <a asp-controller="Loyalty"
                                   asp-action="Accounts"
                                   asp-route-q="@u.Email"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Accounts", "Loyalty", new { q = u.Email })"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa fa-star"></i> @T.T("Loyalty")
                                </a>
                            }

                            @if (!u.EmailConfirmed)
                            {
                                <form asp-controller="Users"
                                      asp-action="SendActivationEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("SendActivationEmail", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="fa fa-paper-plane"></i> @T.T("UsersActivationAction")
                                    </button>
                                </form>
                            }

                            @if (u.IsLockedOut)
                            {
                                <form asp-controller="Users"
                                      asp-action="Unlock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Unlock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa fa-unlock"></i> @T.T("UsersUnlockAction")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Users"
                                      asp-action="Lock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Lock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        <i class="fa fa-lock"></i> @T.T("UsersLockAction")
                                    </button>
                                </form>
                            }

                            @if (!u.IsSystem)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("Delete", "Users")"
                                        data-id="@u.Id"
                                        data-name="@u.Email"
                                        data-rowversion="@Convert.ToBase64String(u.RowVersion)"
                                        data-hx-target="#users-workspace-shell"
                                        data-hx-swap="outerHTML"
                                        data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                                    <i class="fa fa-trash"></i> @T.T("UsersDeleteAction")
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Users"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#users-workspace-shell"
           hx-swap="outerHTML">
    </pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
