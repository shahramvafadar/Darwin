@model Darwin.WebAdmin.ViewModels.Identity.UsersListVm
@{
    ViewData["Title"] = "Users";
}

<div id="users-workspace-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Users</h2>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Unconfirmed" class="btn btn-outline-warning btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Unconfirmed" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">Unconfirmed</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Locked" class="btn btn-outline-danger btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Locked" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">Locked</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="Inactive" class="btn btn-outline-secondary btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "Inactive" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">Inactive</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="MobileLinked" class="btn btn-outline-info btn-sm"
               hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })" hx-target="#users-workspace-shell" hx-swap="outerHTML">Mobile-linked</a>
            <a asp-controller="Users"
               asp-action="Create"
               class="btn btn-primary"
               hx-get="@Url.Action("Create", "Users")"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">
                <i class="fa fa-plus"></i> Create
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Unconfirmed</div>
                <div class="fs-4 fw-semibold">@Model.Summary.UnconfirmedCount</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Locked</div>
                <div class="fs-4 fw-semibold">@Model.Summary.LockedCount</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Inactive</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Mobile-linked</div>
                <div class="fs-4 fw-semibold">@Model.Summary.MobileLinkedCount</div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Identity Support Playbooks</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Queue</th>
                            <th>Scope</th>
                            <th>Operator Action</th>
                            <th>Follow-up</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Title</td>
                            <td>@item.ScopeNote</td>
                            <td>@item.OperatorAction</td>
                            <td>@item.FollowUp</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <form method="get"
          class="row g-2 mb-3"
          hx-get="@Url.Action("Index", "Users")"
          hx-target="#users-workspace-shell"
          hx-swap="outerHTML">
        <div class="col-auto">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search by email/name">
        </div>
        <div class="col-auto">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <select name="pageSize" class="form-select">
                @foreach (var s in Model.PageSizeItems)
                {
                    <option value="@s.Value" selected="@s.Selected">@s.Text</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> Search</button>
            <a asp-controller="Users"
               asp-action="Index"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Index", "Users")"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">Reset</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Name</th>
                    <th>Lifecycle</th>
                    <th class="text-center">Active</th>
                    <th class="text-end" style="width:410px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>@u.Email</td>
                        <td>@($"{u.FirstName} {u.LastName}".Trim())</td>
                        <td>
                            @if (!u.EmailConfirmed)
                            {
                                <div><span class="badge text-bg-warning">Unconfirmed</span></div>
                            }
                            @if (u.IsLockedOut)
                            {
                                <div><span class="badge text-bg-danger">Locked</span></div>
                                <div class="small text-muted">@u.LockoutEndUtc?.ToString("yyyy-MM-dd HH:mm")</div>
                            }
                            @if (u.MobileDeviceCount > 0)
                            {
                                <div><span class="badge text-bg-info">Mobile @u.MobileDeviceCount</span></div>
                            }
                        </td>
                        <td class="text-center">
                            @if (u.IsActive)
                            {
                                <span class="badge text-bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">No</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@u.Id"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Edit", "Users", new { id = u.Id })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-pen"></i> Edit
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangeEmail"
                               asp-route-id="@u.Id"
                               asp-route-currentEmail="@u.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("ChangeEmail", "Users", new { id = u.Id, currentEmail = u.Email })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-envelope"></i> Email
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangePassword"
                               asp-route-id="@u.Id"
                               asp-route-email="@u.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("ChangePassword", "Users", new { id = u.Id, email = u.Email })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-key"></i> Password
                            </a>

                            <a asp-controller="Users" asp-action="Roles" asp-route-id="@u.Id"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Roles", "Users", new { id = u.Id, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize })"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-users-cog"></i> Roles
                            </a>

                            @if (!u.EmailConfirmed)
                            {
                                <form asp-controller="Users"
                                      asp-action="SendActivationEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("SendActivationEmail", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="fa fa-paper-plane"></i> Activation
                                    </button>
                                </form>
                            }

                            @if (u.IsLockedOut)
                            {
                                <form asp-controller="Users"
                                      asp-action="Unlock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Unlock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa fa-unlock"></i> Unlock
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Users"
                                      asp-action="Lock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Lock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        <i class="fa fa-lock"></i> Lock
                                    </button>
                                </form>
                            }

                            @if (!u.IsSystem)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("Delete", "Users")"
                                        data-id="@u.Id"
                                        data-name="@u.Email"
                                        data-rowversion="@Convert.ToBase64String(u.RowVersion)">
                                    <i class="fa fa-trash"></i> Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Users"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter">
    </pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
