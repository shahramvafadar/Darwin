@model Darwin.WebAdmin.ViewModels.Identity.UsersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("UsersPageTitle");
    string GlobalMobileOperationsUrl() => Url.Action("Index", "MobileOperations") ?? string.Empty;
    string GlobalUsersUrl() => Url.Action("Index", "Users") ?? string.Empty;
    string UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter) => Url.Action("Index", "Users", new { filter }) ?? string.Empty;
    string CreateUserUrl() => Url.Action("Create", "Users") ?? string.Empty;
    string UserEditUrl(object? id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string UserEditReturnUrl(object? id) => Url.Action("Edit", "Users", new { id, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string ChangeEmailUrl(object? id, string? currentEmail) => Url.Action("ChangeEmail", "Users", new { id, currentEmail, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string ChangePasswordUrl(object? id, string? email) => Url.Action("ChangePassword", "Users", new { id, email, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string UserRolesUrl(object? id) => Url.Action("Roles", "Users", new { id, returnToIndex = true, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string EmailAuditsUrl(string flowKey, string status = "Failed", string? recipientEmail = null) => Url.Action("EmailAudits", "BusinessCommunications", new { status, flowKey, recipientEmail }) ?? string.Empty;
    string MobileOperationsUrl(string? q = null) => Url.Action("Index", "MobileOperations", new { q }) ?? string.Empty;
    string LoyaltyAccountsUrl(string? q = null) => Url.Action("Accounts", "Loyalty", new { q }) ?? string.Empty;
}

<div id="users-workspace-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">@T.T("UsersPageTitle")</h2>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed" class="btn btn-outline-warning btn-sm"
               hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed)" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterUnconfirmed")</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked" class="btn btn-outline-danger btn-sm"
               hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterLocked")</a>
            <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive" class="btn btn-outline-secondary btn-sm"
               hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive)" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterInactive")</a>
        <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-outline-info btn-sm"
           hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)" hx-target="#users-workspace-shell" hx-swap="outerHTML">@T.T("UsersFilterMobileLinked")</a>
            <a asp-controller="Users"
               asp-action="Create"
               class="btn btn-primary"
               hx-get="@CreateUserUrl()"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">
                <i class="fa fa-plus"></i> @T.T("UsersCreateAction")
            </a>
        </div>
    </div>

    <div class="admin-kpi-row mb-3">
        <div class="admin-kpi-item">
                <div class="text-muted small">@T.T("UsersSummaryTotal")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                <div class="mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.All"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.All)"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersPageTitle")</a>
                </div>
        </div>
        <div class="admin-kpi-item">
                <div class="text-muted small">@T.T("UsersSummaryUnconfirmed")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.UnconfirmedCount</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                       class="btn btn-sm btn-outline-warning"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed)"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="AccountActivation"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl("AccountActivation")"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                </div>
        </div>
        <div class="admin-kpi-item">
                <div class="text-muted small">@T.T("UsersSummaryLocked")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.LockedCount</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                       class="btn btn-sm btn-outline-danger"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterLocked")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="PasswordReset"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl("PasswordReset")"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                </div>
        </div>
        <div class="admin-kpi-item">
                <div class="text-muted small">@T.T("UsersSummaryInactive")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div>
                <div class="mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive)"
                       hx-target="#users-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("UsersFilterInactive")</a>
                </div>
        </div>
        <div class="admin-kpi-item">
                <div class="text-muted small">@T.T("UsersSummaryMobileLinked")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.MobileLinkedCount</div>
        </div>
    </div>

    <details class="admin-playbook mb-3">
        <summary>@T.T("UsersPlaybooksTitle")</summary>
        <div class="admin-playbook-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("UsersPlaybooksQueueColumn")</th>
                            <th>@T.T("UsersPlaybooksScopeColumn")</th>
                            <th>@T.T("UsersPlaybooksActionColumn")</th>
                            <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Title</td>
                            <td>@item.ScopeNote</td>
                            <td>
                                <div class="mb-2">@item.OperatorAction</div>
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-filter="@item.QueueFilter"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@UsersQueueUrl(item.QueueFilter)"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@item.Title</a>
                            </td>
                            <td>
                                <div class="mb-2">@item.FollowUp</div>
                                @if (!string.IsNullOrWhiteSpace(item.AuditFlowKey))
                                {
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="@item.AuditFlowKey"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@EmailAuditsUrl(item.AuditFlowKey)"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@(item.AuditFlowKey == "AccountActivation" ? T.T("OpenFailedActivationEmails") : T.T("OpenFailedPasswordResets"))</a>
                                }
                                else if (item.OpensMobileOperations)
                                {
                                    <a asp-controller="MobileOperations"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@GlobalMobileOperationsUrl()"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </details>

    <form method="get"
          class="row g-2 mb-3"
          hx-get="@GlobalUsersUrl()"
          hx-target="#users-workspace-shell"
          hx-swap="outerHTML">
        <div class="col-auto">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("UsersSearchPlaceholder")">
        </div>
        <div class="col-auto">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <select name="pageSize" class="form-select">
                @foreach (var s in Model.PageSizeItems)
                {
                    <option value="@s.Value" selected="@s.Selected">@s.Text</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("UsersSearchAction")</button>
            <a asp-controller="Users"
               asp-action="Index"
               class="btn btn-outline-secondary"
               hx-get="@GlobalUsersUrl()"
               hx-target="#users-workspace-shell"
               hx-swap="outerHTML">@T.T("UsersResetAction")</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead>
                <tr>
                    <th>@T.T("UsersEmailColumn")</th>
                    <th>@T.T("UsersNameColumn")</th>
                    <th>@T.T("UsersLifecycleColumn")</th>
                    <th class="text-center">@T.T("UsersActiveColumn")</th>
                    <th class="text-end admin-w-410">@T.T("UsersActionsColumn")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td>
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@u.Id"
                               class="text-decoration-none"
                               hx-get="@UserEditUrl(u.Id)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@u.Email</a>
                        </td>
                        <td>
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@u.Id"
                               class="text-decoration-none"
                               hx-get="@UserEditUrl(u.Id)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@($"{u.FirstName} {u.LastName}".Trim())</a>
                        </td>
                        <td>
                            @if (!u.EmailConfirmed)
                            {
                                <div>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="AccountActivation"
                                       asp-route-recipientEmail="@u.Email"
                                       class="badge text-bg-warning text-decoration-none"
                                       hx-get="@EmailAuditsUrl("AccountActivation", recipientEmail: u.Email)"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("UsersLifecycleUnconfirmedBadge")</a>
                                </div>
                            }
                            @if (u.IsLockedOut)
                            {
                                <div>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="PasswordReset"
                                       asp-route-recipientEmail="@u.Email"
                                       class="badge text-bg-danger text-decoration-none"
                                       hx-get="@EmailAuditsUrl("PasswordReset", recipientEmail: u.Email)"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("UsersLifecycleLockedBadge")</a>
                                </div>
                                <div class="small text-muted">@u.LockoutEndUtc?.ToLocalTime().ToString(System.Globalization.CultureInfo.CurrentCulture)</div>
                            }
                            @if (u.MobileDeviceCount > 0)
                            {
                                <div>
                                    <a asp-controller="MobileOperations"
                                       asp-action="Index"
                                       asp-route-q="@u.Email"
                                       class="badge text-bg-info text-decoration-none"
                                       hx-get="@MobileOperationsUrl(u.Email)"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@string.Format(T.T("UsersLifecycleMobileBadge"), u.MobileDeviceCount)</a>
                                </div>
                            }
                            @if (!u.IsActive)
                            {
                                <div>
                                    <a asp-controller="Users"
                                       asp-action="Edit"
                                       asp-route-id="@u.Id"
                                       asp-route-returnToIndex="true"
                                       asp-route-q="@Model.Query"
                                       asp-route-filter="@Model.Filter"
                                       asp-route-page="@Model.Page"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="badge text-bg-secondary text-decoration-none"
                                       hx-get="@UserEditReturnUrl(u.Id)"
                                       hx-target="#users-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("UsersLifecycleInactiveBadge")</a>
                                </div>
                            }
                        </td>
                        <td class="text-center">
                            @if (u.IsActive)
                            {
                                <a asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@u.Id"
                                   class="badge text-bg-success text-decoration-none"
                                   hx-get="@UserEditUrl(u.Id)"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("UsersYes")</a>
                            }
                            else
                            {
                                <a asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@u.Id"
                                   class="badge text-bg-secondary text-decoration-none"
                                   hx-get="@UserEditUrl(u.Id)"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("UsersNo")</a>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@u.Id"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@UserEditReturnUrl(u.Id)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-pen"></i> @T.T("UsersEditAction")
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangeEmail"
                               asp-route-id="@u.Id"
                               asp-route-currentEmail="@u.Email"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@ChangeEmailUrl(u.Id, u.Email)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-envelope"></i> @T.T("UsersEmailAction")
                            </a>

                            <a
                               asp-controller="Users"
                               asp-action="ChangePassword"
                               asp-route-id="@u.Id"
                               asp-route-email="@u.Email"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@ChangePasswordUrl(u.Id, u.Email)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-key"></i> @T.T("UsersPasswordAction")
                            </a>

                            <a asp-controller="Users" asp-action="Roles" asp-route-id="@u.Id"
                               asp-route-returnToIndex="true"
                               asp-route-q="@Model.Query"
                               asp-route-filter="@Model.Filter"
                               asp-route-page="@Model.Page"
                               asp-route-pageSize="@Model.PageSize"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@UserRolesUrl(u.Id)"
                               hx-target="#users-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa fa-users-cog"></i> @T.T("UsersRolesAction")
                            </a>

                            @if (u.MobileDeviceCount > 0)
                            {
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-q="@u.Email"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(u.Email)"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                                </a>

                                <a asp-controller="Loyalty"
                                   asp-action="Accounts"
                                   asp-route-q="@u.Email"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@LoyaltyAccountsUrl(u.Email)"
                                   hx-target="#users-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa fa-star"></i> @T.T("Loyalty")
                                </a>
                            }

                            @if (!u.EmailConfirmed)
                            {
                                <form asp-controller="Users"
                                      asp-action="SendActivationEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("SendActivationEmail", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="fa fa-paper-plane"></i> @T.T("UsersActivationAction")
                                    </button>
                                </form>
                                <form asp-controller="Users"
                                      asp-action="ConfirmEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("ConfirmEmail", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa fa-check-circle"></i> @T.T("UsersConfirmEmailAction")
                                    </button>
                                </form>
                            }

                            <form asp-controller="Users"
                                  asp-action="SendPasswordReset"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("SendPasswordReset", "Users")"
                                  hx-target="#users-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <input type="hidden" name="returnToIndex" value="true" />
                                <input type="hidden" name="q" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    <i class="fa fa-paper-plane"></i> @T.T("UserSendResetEmailAction")
                                </button>
                            </form>

                            @if (u.IsLockedOut)
                            {
                                <form asp-controller="Users"
                                      asp-action="Unlock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Unlock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa fa-unlock"></i> @T.T("UsersUnlockAction")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Users"
                                      asp-action="Lock"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Lock", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        <i class="fa fa-lock"></i> @T.T("UsersLockAction")
                                    </button>
                                </form>
                            }

                            @if (u.IsActive)
                            {
                                <form asp-controller="Users"
                                      asp-action="Deactivate"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Deactivate", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        <i class="fa fa-user-slash"></i> @T.T("UsersDeactivateAction")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Users"
                                      asp-action="Activate"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("Activate", "Users")"
                                      hx-target="#users-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="returnToIndex" value="true" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa fa-user-check"></i> @T.T("UsersActivateAction")
                                    </button>
                                </form>
                            }

                            @if (!u.IsSystem)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("Delete", "Users")"
                                        data-id="@u.Id"
                                        data-name="@u.Email"
                                        data-rowversion="@Convert.ToBase64String(u.RowVersion)"
                                        data-hx-target="#users-workspace-shell"
                                        data-hx-swap="outerHTML"
                                   >
                                    <i class="fa fa-trash"></i> @T.T("UsersDeleteAction")
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Users"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#users-workspace-shell"
           hx-swap="outerHTML">
    </pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
