@model Darwin.WebAdmin.ViewModels.Identity.UserEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditUserTitle");
    var addressesSection = ViewBag.AddressesSection as Darwin.WebAdmin.ViewModels.Identity.UserAddressesSectionVm;
    var needsActivationFollowUp = !Model.EmailConfirmed;
    var needsPasswordResetFollowUp = Model.IsLockedOut;
    var needsInactiveFollowUp = !Model.IsActive;
    string GlobalUsersUrl() => Url.Action("Index", "Users") ?? string.Empty;
    string UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter, string? q = null) => Url.Action("Index", "Users", new { filter, q }) ?? string.Empty;
    string UsersReturnUrl() => Url.Action("Index", "Users", new { q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string EmailAuditsUrl(string flowKey) => Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey, recipientEmail = Model.Email }) ?? string.Empty;
    string ChangeEmailUrl() => Url.Action("ChangeEmail", "Users", new { id = Model.Id, currentEmail = Model.Email, returnToIndex = Model.ReturnToIndex, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string ChangePasswordUrl() => Url.Action("ChangePassword", "Users", new { id = Model.Id, email = Model.Email, returnToIndex = Model.ReturnToIndex, q = Model.Query, filter = Model.Filter, page = Model.Page, pageSize = Model.PageSize }) ?? string.Empty;
    string UserRolesUrl() => Url.Action("Roles", "Users", new { id = Model.Id }) ?? string.Empty;
    string MobileOperationsUrl() => Url.Action("Index", "MobileOperations", new { q = Model.Email }) ?? string.Empty;
    string LoyaltyAccountsUrl() => Url.Action("Accounts", "Loyalty", new { q = Model.Email }) ?? string.Empty;
    string FormatTimestamp(DateTime? timestampUtc) => timestampUtc?.ToLocalTime().ToString(System.Globalization.CultureInfo.CurrentCulture) ?? "-";
}

<div id="user-edit-editor-shell"
     data-add-address-title="@T.T("AddAddress")"
     data-edit-address-title="@T.T("EditAddress")">
    <h2>@T.T("EditUserTitle")</h2>

    <div class="card mb-4">
        <div class="card-header">@T.T("UsersLifecycleColumn")</div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                @if (needsActivationFollowUp)
                {
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                       asp-route-q="@Model.Email"
                       class="btn btn-sm btn-outline-warning"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed, Model.Email)"
                       hx-target="#user-edit-editor-shell"
                       hx-swap="outerHTML">@T.T("UsersFilterUnconfirmed")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="AccountActivation"
                       asp-route-recipientEmail="@Model.Email"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl("AccountActivation")"
                       hx-target="#user-edit-editor-shell"
                       hx-swap="outerHTML">@T.T("OpenFailedActivationEmails")</a>
                }
                @if (needsPasswordResetFollowUp)
                {
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                       asp-route-q="@Model.Email"
                       class="btn btn-sm btn-outline-danger"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked, Model.Email)"
                       hx-target="#user-edit-editor-shell"
                       hx-swap="outerHTML">@T.T("UsersFilterLocked")</a>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-status="Failed"
                       asp-route-flowKey="PasswordReset"
                       asp-route-recipientEmail="@Model.Email"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl("PasswordReset")"
                       hx-target="#user-edit-editor-shell"
                       hx-swap="outerHTML">@T.T("OpenFailedPasswordResets")</a>
                }
                @if (needsInactiveFollowUp)
                {
                    <a asp-controller="Users"
                       asp-action="Index"
                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive"
                       asp-route-q="@Model.Email"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Inactive, Model.Email)"
                       hx-target="#user-edit-editor-shell"
                       hx-swap="outerHTML">@T.T("UsersFilterInactive")</a>
                }
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("UserAdministrativeActionsTitle")</div>
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="me-auto text-muted">@Model.Email</span>
                @if (Model.EmailConfirmed)
                {
                    <span class="badge text-bg-success">@T.T("UserEmailConfirmedBadge")</span>
                }
                else
                {
                    <span class="badge text-bg-warning">@T.T("UserEmailUnconfirmedBadge")</span>
                }

                @if (Model.IsLockedOut)
                {
                    <span class="badge text-bg-danger">@T.T("UsersLifecycleLockedBadge")</span>
                }
                else
                {
                    <span class="badge text-bg-success">@T.T("UserUnlockedBadge")</span>
                }
            </div>

            @if (Model.IsLockedOut && Model.LockoutEndUtc.HasValue)
            {
                <p class="small text-muted mb-3">
                    @T.T("UserLockoutEndsLabel"): @FormatTimestamp(Model.LockoutEndUtc)
                </p>
            }

            <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Users"
               asp-action="ChangeEmail"
               asp-route-id="@Model.Id"
               asp-route-currentEmail="@Model.Email"
               asp-route-returnToIndex="@Model.ReturnToIndex"
               asp-route-q="@Model.Query"
               asp-route-filter="@Model.Filter"
               asp-route-page="@Model.Page"
               asp-route-pageSize="@Model.PageSize"
               class="btn btn-outline-secondary"
               hx-get="@ChangeEmailUrl()"
               hx-target="#user-edit-editor-shell"
               hx-swap="outerHTML">
                <i class="fa fa-envelope"></i> @T.T("ChangeEmail")
            </a>
            <a asp-controller="Users"
               asp-action="ChangePassword"
               asp-route-id="@Model.Id"
               asp-route-email="@Model.Email"
               asp-route-returnToIndex="@Model.ReturnToIndex"
               asp-route-q="@Model.Query"
               asp-route-filter="@Model.Filter"
               asp-route-page="@Model.Page"
               asp-route-pageSize="@Model.PageSize"
               class="btn btn-outline-secondary"
               hx-get="@ChangePasswordUrl()"
               hx-target="#user-edit-editor-shell"
               hx-swap="outerHTML">
                <i class="fa fa-key"></i> @T.T("ChangePassword")
            </a>
            <a asp-controller="Users"
               asp-action="Roles"
               asp-route-id="@Model.Id"
               class="btn btn-outline-primary"
               hx-get="@UserRolesUrl()"
               hx-target="#user-edit-editor-shell"
               hx-swap="outerHTML">
                <i class="fa fa-users-cog"></i> @T.T("ManageRolesAction")
            </a>
            <a asp-controller="MobileOperations"
               asp-action="Index"
               asp-route-q="@Model.Email"
               class="btn btn-outline-secondary"
               hx-get="@MobileOperationsUrl()"
               hx-target="#user-edit-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
            </a>
            <a asp-controller="Loyalty"
               asp-action="Accounts"
               asp-route-q="@Model.Email"
               class="btn btn-outline-secondary"
               hx-get="@LoyaltyAccountsUrl()"
               hx-target="#user-edit-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa fa-star"></i> @T.T("Loyalty")
            </a>
            @if (!Model.EmailConfirmed)
            {
                <form asp-controller="Users"
                      asp-action="SendActivationEmail"
                      method="post"
                      hx-post="@Url.Action("SendActivationEmail", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fa fa-paper-plane"></i> @T.T("UserSendActivationEmailAction")
                    </button>
                </form>
                <form asp-controller="Users"
                      asp-action="ConfirmEmail"
                      method="post"
                      hx-post="@Url.Action("ConfirmEmail", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-success">
                        <i class="fa fa-check-circle"></i> @T.T("BusinessMemberConfirmEmailAction")
                    </button>
                </form>
            }
            <form asp-controller="Users"
                  asp-action="SendPasswordReset"
                  method="post"
                  hx-post="@Url.Action("SendPasswordReset", "Users")"
                  hx-target="#user-edit-editor-shell"
                  hx-swap="outerHTML"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                <input type="hidden" name="q" value="@Model.Query" />
                <input type="hidden" name="filter" value="@Model.Filter" />
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <button type="submit" class="btn btn-outline-warning">
                    <i class="fa fa-paper-plane"></i> @T.T("UserSendResetEmailAction")
                </button>
            </form>
            @if (Model.IsLockedOut)
            {
                <form asp-controller="Users"
                      asp-action="Unlock"
                      method="post"
                      hx-post="@Url.Action("Unlock", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-success">
                        <i class="fa fa-lock-open"></i> @T.T("UserUnlockAccountAction")
                    </button>
                </form>
            }
            else
            {
                <form asp-controller="Users"
                      asp-action="Lock"
                      method="post"
                      hx-post="@Url.Action("Lock", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="fa fa-lock"></i> @T.T("UserLockAccountAction")
                    </button>
                </form>
            }
            @if (Model.IsActive)
            {
                <form asp-controller="Users"
                      asp-action="Deactivate"
                      method="post"
                      hx-post="@Url.Action("Deactivate", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="fa fa-user-slash"></i> @T.T("UsersDeactivateAction")
                    </button>
                </form>
            }
            else
            {
                <form asp-controller="Users"
                      asp-action="Activate"
                      method="post"
                      hx-post="@Url.Action("Activate", "Users")"
                      hx-target="#user-edit-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnToIndex" value="@Model.ReturnToIndex" />
                    <input type="hidden" name="q" value="@Model.Query" />
                    <input type="hidden" name="filter" value="@Model.Filter" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <button type="submit" class="btn btn-outline-success">
                        <i class="fa fa-user-check"></i> @T.T("UsersActivateAction")
                    </button>
                </form>
            }
            </div>
        </div>
    </div>

    <form asp-controller="Users"
          asp-action="Edit"
          method="post"
          class="row g-3"
          hx-post="@Url.Action("Edit", "Users")"
          hx-target="#user-edit-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="ReturnToIndex" />
        <input type="hidden" asp-for="Query" />
        <input type="hidden" asp-for="Filter" />
        <input type="hidden" asp-for="Page" />
        <input type="hidden" asp-for="PageSize" />
        <div asp-validation-summary="ModelOnly" class="text-danger col-12"></div>

        <partial name="_UserProfileFields" model="Model" />

        <div class="col-md-3">
            <div class="form-check mt-4 pt-2">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-12">
            <button class="btn btn-primary" type="submit"><i class="fa fa-save"></i> @T.T("Save")</button>
            @if (Model.ReturnToIndex)
            {
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-q="@Model.Query"
                   asp-route-filter="@Model.Filter"
                   asp-route-page="@Model.Page"
                   asp-route-pageSize="@Model.PageSize"
                   class="btn btn-outline-secondary"
                   hx-get="@UsersReturnUrl()"
                   hx-target="#user-edit-editor-shell"
                   hx-swap="outerHTML">@T.T("Back")</a>
            }
            else
            {
                <a asp-controller="Users"
                   asp-action="Index"
                   class="btn btn-outline-secondary"
                   hx-get="@GlobalUsersUrl()"
                   hx-target="#user-edit-editor-shell"
                   hx-swap="outerHTML">@T.T("Back")</a>
            }
        </div>
    </form>

    <hr />
    <h3 class="mt-4">@T.T("AddressesTitle")</h3>

    <div id="addresses-section">
        @await Html.PartialAsync("~/Views/Users/_AddressesSection.cshtml", addressesSection)
    </div>

    @await Html.PartialAsync("~/Views/Users/_AddressEditModal.cshtml", new Darwin.WebAdmin.ViewModels.Identity.UserAddressEditVm())
    <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
