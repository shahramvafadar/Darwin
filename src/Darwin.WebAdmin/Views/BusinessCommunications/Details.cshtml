                <div class="mb-2">@T.T("BusinessCommunicationHighSeverityLabel"): <strong>@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "High", StringComparison.OrdinalIgnoreCase))</strong></div>
                <div>@T.T("BusinessCommunicationSlowDeliveriesLabel"): <strong>@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "Slow", StringComparison.OrdinalIgnoreCase))</strong></div>
                <div class="mt-2">@T.T("CommunicationRetriedDeliveryChainsLabel"): <strong>@Model.RecentEmailAudits.Count(x => x.PriorAttemptCount > 0)</strong></div>
                <div>@T.T("CommunicationPriorSuccessContextLabel"): <strong>@Model.RecentEmailAudits.Count(x => x.LastSuccessfulAttemptAtUtc.HasValue)</strong></div>
