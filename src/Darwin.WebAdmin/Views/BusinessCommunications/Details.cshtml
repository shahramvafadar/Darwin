@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationProfileVm
@{
    ViewData["Title"] = "Business Communication Profile";
}

<div id="business-communication-profile-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open me-2"></i>@Model.Name</h1>
        <p class="text-muted mb-0">Business-level communication readiness, current policy flags, and phase-1 operational implications.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Back to Communications</a>
        <a asp-action="ChannelAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">SMS / WhatsApp Audits</a>
        <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Email Audits</a>
        <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.Id" class="btn btn-outline-primary"
           hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Open Setup</a>
        <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Members</a>
        <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Invitations</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Business Profile</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Legal Name</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.LegalName) ? "Missing" : Model.LegalName)</dd>
                    <dt class="col-sm-4">Contact Email</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ContactEmail) ? "Missing" : Model.ContactEmail)</dd>
                    <dt class="col-sm-4">Culture</dt>
                    <dd class="col-sm-8">@Model.DefaultCulture</dd>
                    <dt class="col-sm-4">Time Zone</dt>
                    <dd class="col-sm-8">@Model.DefaultTimeZoneId</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge text-bg-secondary">@Model.OperationalStatus</span>
                        @if (!Model.IsActive)
                        {
                            <span class="badge text-bg-warning ms-1">Inactive</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Sender Defaults</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Support</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.SupportEmail) ? "Missing" : Model.SupportEmail)</dd>
                    <dt class="col-sm-4">Sender</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.CommunicationSenderName) ? "Missing" : Model.CommunicationSenderName)</dd>
                    <dt class="col-sm-4">Reply-To</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.CommunicationReplyToEmail) ? "Missing" : Model.CommunicationReplyToEmail)</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Support Signals</div>
            <div class="card-body">
                <div class="mb-2">Open Invitations: <strong>@Model.OpenInvitationCount</strong></div>
                <div class="mb-2">Pending Activation Members: <strong>@Model.PendingActivationMemberCount</strong></div>
                <div>Locked Members: <strong>@Model.LockedMemberCount</strong></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Policy Flags</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge @(Model.CustomerEmailNotificationsEnabled ? "text-bg-primary" : "text-bg-light")">Transactional Email</span>
                    <span class="badge @(Model.CustomerMarketingEmailsEnabled ? "text-bg-info" : "text-bg-light")">Marketing Email</span>
                    <span class="badge @(Model.OperationalAlertEmailsEnabled ? "text-bg-secondary" : "text-bg-light")">Operational Alerts</span>
                </div>
                <div class="small text-muted mt-3">
                    These toggles reflect business intent only. They still depend on global transport and alert-routing readiness.
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Global Dependency Readiness</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge @(Model.EmailTransportConfigured ? "text-bg-success" : "text-bg-warning")">SMTP @(Model.EmailTransportConfigured ? "Ready" : "Missing")</span>
                    <span class="badge @(Model.SmsTransportConfigured ? "text-bg-success" : "text-bg-warning")">SMS @(Model.SmsTransportConfigured ? "Ready" : "Missing")</span>
                    <span class="badge @(Model.WhatsAppTransportConfigured ? "text-bg-success" : "text-bg-warning")">WhatsApp @(Model.WhatsAppTransportConfigured ? "Ready" : "Missing")</span>
                    <span class="badge @(Model.AdminAlertRoutingConfigured ? "text-bg-success" : "text-bg-warning")">Admin Alerts @(Model.AdminAlertRoutingConfigured ? "Ready" : "Missing")</span>
                </div>
                <div class="mt-3">
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-smtp" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">SMTP</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">SMS</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">WhatsApp</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">Admin Alerts</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Transactional Communication Policy</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Subject Prefix</dt>
                    <dd class="col-sm-8">@(Model.TransactionalSubjectPrefixConfigured ? Model.TransactionalSubjectPrefix : "No prefix configured")</dd>
                    <dt class="col-sm-4">Test Inbox</dt>
                    <dd class="col-sm-8">@(Model.TestInboxConfigured ? Model.TestInboxEmail : "Not rerouting")</dd>
                </dl>
                <div class="small text-muted mt-3">
                    Current invitation, activation, password-reset, and phone-verification flows depend on this policy surface and its test targets.
                </div>
                <div class="mt-3">
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">Open Communication Policy</a>
                    @if (Model.CanSendTestEmail)
                    {
                        <form asp-action="SendTestEmail" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">Send Test Email</button>
                        </form>
                    }
                    @if (Model.CanSendTestSms)
                    {
                        <form asp-action="SendTestSms" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">Send Test SMS</button>
                        </form>
                    }
                    @if (Model.CanSendTestWhatsApp)
                    {
                        <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">Send Test WhatsApp</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Phase-1 Policy Implications</div>
            <div class="card-body">
                <ul class="mb-0">
                    <li>Subject prefix applies to current SMTP-based invitation, activation, and password-reset subjects.</li>
                    <li>Test inbox reroute redirects those emails for controlled validation and prepends the original recipient to the body.</li>
                    <li>SMS and WhatsApp test targets are transport-validation controls, while phone verification now uses customizable text templates.</li>
                    <li>This is an operational control, not a reusable template-engine or retry-queue replacement.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Readiness Issues</div>
            <div class="card-body">
                @if (Model.ReadinessIssues.Count == 0)
                {
                    <div class="alert alert-success mb-0">No immediate communication readiness issues are visible for this business.</div>
                }
                else
                {
                    <ul class="mb-0">
                    @foreach (var issue in Model.ReadinessIssues)
                    {
                        <li>@issue</li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Currently Relevant Phase-1 Flows</div>
            <div class="card-body">
                @if (Model.ActiveFlowNames.Count == 0)
                {
                    <div class="text-muted">No currently relevant built-in flows were inferred for this business.</div>
                }
                else
                {
                    <ul class="mb-0">
                    @foreach (var flow in Model.ActiveFlowNames)
                    {
                        <li>@flow</li>
                    }
                    </ul>
                }
                <div class="small text-muted mt-3">
                    This is an operational implication view only. It does not claim a reusable template engine or full Communication Core delivery policy yet.
                </div>
                @if (Model.OpenInvitationCount > 0)
                {
                    <div class="mt-3">
                    <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" asp-route-flowKey="BusinessInvitation" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, flowKey = "BusinessInvitation" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        View Invitation Email Audits
                    </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Recommended Next Actions</div>
            <div class="card-body">
                <ul class="mb-0">
                @foreach (var action in Model.RecommendedActions)
                {
                    <li>@action</li>
                }
                </ul>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">Open Setup</a>
                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id, filter = "Attention" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">Open Member Support</a>
                    <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id, filter = "Open" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">Open Invitations</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Recent Business Email Activity</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>When (UTC)</th>
                                <th>Flow</th>
                                <th>Recipient</th>
                                <th>Status</th>
                                <th>Delivery Context</th>
                                <th>Follow-up</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.RecentEmailAudits.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center text-muted py-3">No recent business-scoped email activity.</td></tr>
                        }
                        else
                        {
                            foreach (var item in Model.RecentEmailAudits)
                            {
                                <tr>
                                    <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                                    <td>@item.RecipientEmail</td>
                                    <td>
                                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-success">Sent</span>
                                        }
                                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">Failed</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">High</span>
                                        }
                                        else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-warning">Medium</span>
                                        }
                                        else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-secondary">Watch</span>
                                        }
                                        else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-info">Slow</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-light">Normal</span>
                                        }
                                        <div class="small text-muted mt-1">Open for @item.AttemptAgeMinutes min</div>
                                        @if (item.CompletionLatencySeconds.HasValue)
                                        {
                                            <div class="small text-muted">Latency @item.CompletionLatencySeconds.Value s</div>
                                        }
                                        @if (item.PriorAttemptCount > 0)
                                        {
                                            <div class="small text-muted">Prior attempts @item.PriorAttemptCount</div>
                                        }
                                        @if (item.PriorFailureCount > 0)
                                        {
                                            <div class="small text-muted">Prior failures @item.PriorFailureCount</div>
                                        }
                                        @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                                        {
                                            <div class="small text-muted">Last success @item.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="small">@item.RecommendedAction</div>
                                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                        {
                                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                                        }
                                        <div class="mt-2 d-flex flex-wrap gap-2">
                                            @if (string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-query="@item.RecipientEmail" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id, query = item.RecipientEmail, filter = "Open" })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">Search Invitation</a>
                                            }
                                            else if (string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase) || string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-query="@item.RecipientEmail" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id, query = item.RecipientEmail, filter = "Attention" })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">Member Support</a>
                                                <a asp-controller="Users" asp-action="Index" asp-route-q="@item.RecipientEmail" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">Open Users</a>
                                            }
                                            else if (string.Equals(item.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestEmail)
                                            {
                                                <form asp-action="SendTestEmail" method="post" class="d-inline"
                                                      hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                                                      hx-target="#business-communication-profile-shell"
                                                      hx-swap="outerHTML">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Rerun Test</button>
                                                </form>
                                            }
                                            <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" asp-route-status="Failed" asp-route-flowKey="@item.FlowKey" class="btn btn-sm btn-outline-dark"
                                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, status = "Failed", flowKey = item.FlowKey })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">Failed Audits</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">Open Business Email Audits</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">SMS / WhatsApp Activity Snapshot</div>
            <div class="card-body">
                <div class="mb-2">Attempts (24h): <strong>@Model.ChannelAuditSummary.Recent24HourCount</strong></div>
                <div class="mb-2">SMS / WhatsApp: <strong>@Model.ChannelAuditSummary.SmsCount / @Model.ChannelAuditSummary.WhatsAppCount</strong></div>
                <div class="mb-2">Phone Verification: <strong>@Model.ChannelAuditSummary.PhoneVerificationCount</strong></div>
                <div>Failures: <strong>@Model.ChannelAuditSummary.FailedCount</strong></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Delivery Backlog Snapshot</div>
            <div class="card-body">
                <div class="mb-2">Needs Follow-up: <strong>@Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp)</strong></div>
                <div class="mb-2">High Severity: <strong>@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "High", StringComparison.OrdinalIgnoreCase))</strong></div>
                <div>Slow Deliveries: <strong>@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "Slow", StringComparison.OrdinalIgnoreCase))</strong></div>
                <div class="mt-2">Retried Chains: <strong>@Model.RecentEmailAudits.Count(x => x.PriorAttemptCount > 0)</strong></div>
                <div>Prior Success Context: <strong>@Model.RecentEmailAudits.Count(x => x.LastSuccessfulAttemptAtUtc.HasValue)</strong></div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">Recent SMS / WhatsApp Activity</div>
    <div class="card-body">
        <div class="small text-muted mb-3">
            This keeps non-email delivery visible while investigating one business. It is intentionally scoped to current live SMS and WhatsApp families, especially phone verification and operator transport tests.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>When (UTC)</th>
                        <th>Channel</th>
                        <th>Flow</th>
                        <th>Recipient</th>
                        <th>Status</th>
                        <th>Preview</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentChannelAudits.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No recent SMS or WhatsApp activity for this business scope.</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentChannelAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge text-bg-light">@item.Channel</span> <span class="small text-muted">@item.Provider</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                            <td>@item.RecipientAddress</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">Sent</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">Failed</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                <div class="small">@item.MessagePreview</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-1">@item.FailureMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">Channel Truth Snapshot</div>
    <div class="card-body">
        <div class="small text-muted mb-3">
            This snapshot keeps channel reality visible while troubleshooting one business. It shows what is live today and where operators should stop before treating SMS or WhatsApp like a generic delivery bus.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Channel</th>
                        <th>Current State</th>
                        <th>Live Flows</th>
                        <th>Safe Operator Actions</th>
                        <th>Risk Boundary</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.ChannelOperations)
                {
                    <tr>
                        <td class="fw-semibold">@item.Channel</td>
                        <td>@item.CurrentState</td>
                        <td>@item.LiveFlows</td>
                        <td>@item.SafeOperatorActions</td>
                        <td>@item.RiskBoundary</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Template Inventory Snapshot</div>
            <div class="card-body">
                <div class="small text-muted mb-3">
                    This is the current template truth for phase-1 communication flows. It shows what is hard-coded today and what operators can really influence.
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Flow</th>
                                <th>Template Surface</th>
                                <th>Current Template Preview</th>
                                <th>Supported Tokens</th>
                                <th>Operator Control</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.TemplateInventory)
                        {
                            <tr>
                                <td class="fw-semibold">@item.FlowName</td>
                                <td>@item.TemplateSurface</td>
                                <td>
                                    <div class="small"><strong>Subject:</strong> @item.CurrentSubjectTemplate</div>
                                    <div class="small text-muted mt-1"><strong>Body:</strong> @item.CurrentBodyTemplate</div>
                                </td>
                                <td><code>@item.SupportedTokens</code></td>
                                <td>@item.OperatorControl</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        @if (!string.IsNullOrWhiteSpace(item.AuditFlowKey))
                                        {
                                            <a asp-action="EmailAudits"
                                               asp-route-businessId="@Model.Id"
                                               asp-route-status="Failed"
                                               asp-route-flowKey="@item.AuditFlowKey"
                                               class="btn btn-sm btn-outline-secondary"
                                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, status = "Failed", flowKey = item.AuditFlowKey })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">Failed Audits</a>
                                        }
                                        @if (item.OperatorActionTarget == "Invitations")
                                        {
                                            <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                                               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "Users")
                                        {
                                            <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                                               hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "EmailAudits")
                                        {
                                            <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "AdminAlerts")
                                        {
                                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-primary"
                                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        @if (item.OperatorActionTarget != "AdminAlerts")
                                        {
                                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">Open Policy</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
