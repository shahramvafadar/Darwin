                                            <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-filter="@invitationWorkspaceFilter" class="btn btn-sm btn-outline-primary"
                                               hx-get="@BusinessInvitationsUrl(Model.Id, invitationWorkspaceFilter)"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "Users")
                                        {
                                            <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-filter="@memberWorkspaceFilter" class="btn btn-sm btn-outline-primary"
                                               hx-get="@BusinessMembersUrl(Model.Id, memberWorkspaceFilter)"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "EmailAudits")
                                        {
                                            <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                                               hx-get="@EmailAuditsUrl(Model.Id)"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                        else if (item.OperatorActionTarget == "AdminAlerts")
                                        {
                                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-primary"
                                               hx-get="@SiteSettingsUrl("site-settings-admin-routing")"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
