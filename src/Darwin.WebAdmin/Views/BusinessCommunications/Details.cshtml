@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationProfileVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessCommunicationProfileTitle");
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string ChannelAuditsUrl(
        Guid businessId,
        bool? phoneVerificationOnly = null,
        bool? providerReviewOnly = null,
        bool? actionBlockedOnly = null,
        bool? escalationCandidatesOnly = null,
        bool? adminTestOnly = null,
        string? channel = null) => Url.Action("ChannelAudits", "BusinessCommunications", new
        {
            businessId,
            phoneVerificationOnly,
            providerReviewOnly,
            actionBlockedOnly,
            escalationCandidatesOnly,
            adminTestOnly,
            channel
        }) ?? string.Empty;
    string EmailAuditsUrl(
        Guid businessId,
        string? status = null,
        string? flowKey = null,
        bool? retryReadyOnly = null,
        bool? retryBlockedOnly = null,
        bool? chainFollowUpOnly = null) => Url.Action("EmailAudits", "BusinessCommunications", new
        {
            businessId,
            status,
            flowKey,
            retryReadyOnly,
            retryBlockedOnly,
            chainFollowUpOnly
        }) ?? string.Empty;
    string BusinessSetupUrl(Guid id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string MerchantReadinessUrl(Guid businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null, string? query = null) => Url.Action("Members", "Businesses", new { businessId, query, filter }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null, string? query = null) => Url.Action("Invitations", "Businesses", new { businessId, query, filter }) ?? string.Empty;
    string SiteSettingsUrl(string? fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string MobileOperationsUrl(Guid businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string UsersUrl(string? q = null) => Url.Action("Index", "Users", new { q }) ?? string.Empty;
    string UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter) => Url.Action("Index", "Users", new { filter }) ?? string.Empty;

    string FlowLabel(string? flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string OperationalStatusLabel(string? operationalStatus) => operationalStatus switch
    {
        "PendingApproval" => T.T("PendingApproval"),
        "Approved" => T.T("Approved"),
        "Suspended" => T.T("Suspended"),
        _ => string.IsNullOrWhiteSpace(operationalStatus) ? T.T("CommonUnclassified") : T.T(operationalStatus)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string ChannelLabel(string? channel) => channel switch
    {
        "SMS" => T.T("BusinessCommunicationSmsShort"),
        "WhatsApp" => T.T("BusinessCommunicationWhatsAppShort"),
        "Email" => T.T("CommunicationBuiltInFlowEmailChannel"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };

    string MemberWorkspaceLabel() => T.T("Members");
    string InvitationWorkspaceLabel() => T.T("Invitations");
    var memberWorkspaceFilter = Model.PendingActivationMemberCount > 0
        ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation
        : Model.LockedMemberCount > 0
            ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked
            : (Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter?)null;
    var invitationWorkspaceFilter = Model.PendingInvitationCount > 0
        ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending
        : Model.OpenInvitationCount > 0
            ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open
            : (Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter?)null;
    string MemberWorkspaceActionLabel() => memberWorkspaceFilter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        _ => T.T("BusinessCommunicationOpenMemberSupportAction")
    };
    string InvitationDebtSummaryLabel() => Model.PendingInvitationCount > 0
        ? T.T("BusinessSupportPendingInvitationsLabel")
        : T.T("BusinessCommunicationOpenInvitationsLabel");
    int InvitationDebtCount() => Model.PendingInvitationCount > 0
        ? Model.PendingInvitationCount
        : Model.OpenInvitationCount;
    string InvitationWorkspaceActionLabel() => invitationWorkspaceFilter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        _ => T.T("BusinessCommunicationOpenInvitationsAction")
    };
    string InvitationAuditActionLabel() => invitationWorkspaceFilter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        _ => T.T("BusinessCommunicationViewInvitationAuditsAction")
    };
    string ValueOrMissing(string? value) => string.IsNullOrWhiteSpace(value)
        ? T.T("CommonMissingBadge")
        : value;
    string DependencyBadgeStatusLabel(bool configured) => configured
        ? T.T("CommonReadyBadge")
        : T.T("CommonMissingBadge");
    string ProfileHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string ProfileHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    var setupGapCount = (Model.MissingSupportEmail ? 1 : 0) + (Model.MissingSenderIdentity ? 1 : 0);
    var memberAndInviteAttentionCount = InvitationDebtCount() + Model.PendingActivationMemberCount + Model.LockedMemberCount;
    var emailEscalationCount = Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp) + Model.RecentEmailAudits.Count(x => x.PriorFailureCount > 0);
    var emailRetryBlockedCount = Model.RecentEmailAudits.Count(x => !x.CanRetryNow && !string.IsNullOrWhiteSpace(x.RetryPolicyState));
    var emailChainFollowUpCount = Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp || x.PriorFailureCount > 0 || x.RecentAttemptCount24h > 1);
    var channelEscalationCount = Model.ChannelAuditSummary.FailedCount + Model.ChannelAuditSummary.ProviderReviewCount + Model.ChannelAuditSummary.ActionBlockedCount;
    var channelActionBlockedCount = Model.ChannelAuditSummary.ActionBlockedCount;
    var channelEscalationFollowUpCount = Model.ChannelAuditSummary.EscalationCandidateCount + Model.ChannelAuditSummary.RepeatedFailureCount;
    var communicationPolicyAttentionCount = (Model.CustomerEmailNotificationsEnabled ? 0 : 1)
        + (Model.EmailTransportConfigured ? 0 : 1)
        + (Model.AdminAlertRoutingConfigured ? 0 : 1);
    var communicationDeliveryVisibilityAttentionCount = emailRetryBlockedCount
        + channelActionBlockedCount
        + channelEscalationFollowUpCount;
    var failedInvitationAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase));
    var failedActivationAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase));
    var failedAdminTestAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase));
    var failedPasswordResetAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase));
    var communicationRuntimeExecutionAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && (string.Equals(x.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase)));
    var invitationFamilyAttentionCount = InvitationDebtCount();
    var passwordResetFamilyAttentionCount = Model.LockedMemberCount;
    var phoneVerificationFamilyAttentionCount = Model.ChannelAuditSummary.PhoneVerificationCount;
    var communicationFamilyAttentionCount = invitationFamilyAttentionCount
        + passwordResetFamilyAttentionCount
        + phoneVerificationFamilyAttentionCount;
}

<div id="business-communication-profile-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open me-2"></i>@Model.Name</h1>
        <p class="text-muted mb-0">@T.T("BusinessCommunicationProfileIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
       hx-get="@GlobalBusinessCommunicationsUrl()"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
        <a asp-action="ChannelAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@ChannelAuditsUrl(Model.Id)"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
        <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@EmailAuditsUrl(Model.Id)"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("EmailAudits")</a>
        <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.Id" class="btn btn-outline-primary"
           hx-get="@BusinessSetupUrl(Model.Id)"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenSetup")</a>
        <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-filter="@memberWorkspaceFilter" class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Id, memberWorkspaceFilter)"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberWorkspaceLabel()</a>
        <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-filter="@invitationWorkspaceFilter" class="btn btn-outline-secondary"
           hx-get="@BusinessInvitationsUrl(Model.Id, invitationWorkspaceFilter)"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@InvitationWorkspaceLabel()</a>
</div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("BusinessCommunicationProfileTitle")</h2>
                <p class="text-muted mb-0">@T.T("BusinessCommunicationProfileIntro")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessSupportQueueUrl(Model.Id)"
                   hx-target="#business-communication-profile-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-communications-policy"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                   hx-target="#business-communication-profile-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenPolicyAction")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("BusinessCommunicationNeedsSetupOnlyLabel")</div>
                        <span class="@ProfileHealthBadgeClass(setupGapCount == 0)">@ProfileHealthBadgeText(setupGapCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@setupGapCount</div>
                    <div class="small text-muted">@T.T("BusinessCommunicationProfileSupportSignalsTitle")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="Businesses"
                           asp-action="Setup"
                           asp-route-id="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSetupUrl(Model.Id)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenSetup")</a>
                        <a asp-controller="Businesses"
                           asp-action="MerchantReadiness"
                           asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@MerchantReadinessUrl(Model.Id)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@MemberWorkspaceLabel()</div>
                        <span class="@ProfileHealthBadgeClass(memberAndInviteAttentionCount == 0)">@ProfileHealthBadgeText(memberAndInviteAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@memberAndInviteAttentionCount</div>
                    <div class="small text-muted">@InvitationDebtSummaryLabel()</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="Businesses"
                           asp-action="Members"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@memberWorkspaceFilter"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMembersUrl(Model.Id, memberWorkspaceFilter)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@MemberWorkspaceActionLabel()</a>
                        <a asp-controller="Businesses"
                           asp-action="Invitations"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@invitationWorkspaceFilter"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessInvitationsUrl(Model.Id, invitationWorkspaceFilter)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@InvitationWorkspaceActionLabel()</a>
                        <a asp-controller="Businesses"
                           asp-action="Members"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMembersUrl(Model.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-status="Failed"
                           asp-route-flowKey="AccountActivation"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(Model.Id, status: "Failed", flowKey: "AccountActivation")"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                        <a asp-controller="Businesses"
                           asp-action="Members"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMembersUrl(Model.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PasswordReset")</a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="ChannelAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-phoneVerificationOnly="true"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ChannelAuditsUrl(Model.Id, phoneVerificationOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PhoneVerification")</a>
                        <a asp-controller="MobileOperations"
                           asp-action="Index"
                           asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@MobileOperationsUrl(Model.Id)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("EmailAudits")</div>
                        <span class="@ProfileHealthBadgeClass(emailEscalationCount == 0)">@ProfileHealthBadgeText(emailEscalationCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@emailEscalationCount</div>
                    <div class="small text-muted">@T.T("BusinessCommunicationFollowUpBacklogNote")</div>
                    <div class="small text-muted">@T.T("RetryBlocked"): <strong>@emailRetryBlockedCount</strong></div>
                    <div class="small text-muted">@T.T("HeavyChains"): <strong>@emailChainFollowUpCount</strong></div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-status="Failed"
                           asp-route-flowKey="AdminCommunicationTest"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(Model.Id, status: "Failed", flowKey: "AdminCommunicationTest")"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FailedAdminTests")</a>
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(Model.Id)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("EmailAudits")</a>
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-retryReadyOnly="true"
                           class="btn btn-sm btn-outline-success"
                           hx-get="@EmailAuditsUrl(Model.Id, retryReadyOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RetryReady")</a>
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-retryBlockedOnly="true"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@EmailAuditsUrl(Model.Id, retryBlockedOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RetryBlocked")</a>
                        <a asp-action="EmailAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-chainFollowUpOnly="true"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@EmailAuditsUrl(Model.Id, chainFollowUpOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("HeavyChains")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("SmsWhatsAppAuditsTitle")</div>
                        <span class="@ProfileHealthBadgeClass(channelEscalationCount == 0)">@ProfileHealthBadgeText(channelEscalationCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@channelEscalationCount</div>
                    <div class="small text-muted">@T.T("ProviderReview")</div>
                    <div class="small text-muted">@T.T("ActionBlocked"): <strong>@channelActionBlockedCount</strong></div>
                    <div class="small text-muted">@T.T("EscalationCandidates"): <strong>@channelEscalationFollowUpCount</strong></div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="ChannelAudits"
                           asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ChannelAuditsUrl(Model.Id)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-providerReviewOnly="true"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@ChannelAuditsUrl(Model.Id, providerReviewOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ProviderReview")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-actionBlockedOnly="true"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ChannelAuditsUrl(Model.Id, actionBlockedOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ActionBlocked")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-businessId="@Model.Id"
                           asp-route-escalationCandidatesOnly="true"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@ChannelAuditsUrl(Model.Id, escalationCandidatesOnly: true)"
                           hx-target="#business-communication-profile-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("EscalationCandidates")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("CommunicationPolicy")</div>
            <div class="card-body d-flex flex-column gap-2">
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <div class="text-muted small">@T.T("OpenPolicyAction")</div>
                    <span class="@ProfileHealthBadgeClass(communicationPolicyAttentionCount == 0)">@ProfileHealthBadgeText(communicationPolicyAttentionCount == 0)</span>
                </div>
                <div class="fs-4 fw-semibold">@communicationPolicyAttentionCount</div>
                <div class="small text-muted">@T.T("BusinessCommunicationTransactionalEmailLabel"): <strong>@DependencyBadgeStatusLabel(Model.CustomerEmailNotificationsEnabled)</strong></div>
                <div class="small text-muted">@T.T("SMTP"): <strong>@DependencyBadgeStatusLabel(Model.EmailTransportConfigured)</strong></div>
