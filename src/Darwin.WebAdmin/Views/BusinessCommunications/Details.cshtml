<div class="card mt-4">
            <div class="card-header">@T.T("RecentSmsWhatsAppActivity")</div>
    <div class="card-body">
        <div class="small text-muted mb-3">
            @T.T("BusinessCommunicationProfileChannelActivityNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("WhenUtc")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Recipient")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Preview")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentChannelAudits.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">@T.T("BusinessCommunicationNoRecentChannelActivity")</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentChannelAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge text-bg-light">@item.Channel</span> <span class="small text-muted">@item.Provider</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("Unclassified") : item.FlowKey)</td>
                            <td>@item.RecipientAddress</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@T.T("Sent")</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("Failed")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                <div class="small">@item.MessagePreview</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-1">@item.FailureMessage</div>
                                }
                                @if (string.Equals(item.FlowKey, "PhoneVerification", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="mt-2 d-flex flex-wrap gap-2">
                                        <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-sm btn-outline-secondary"
                                           hx-get="@Url.Action("Index", "MobileOperations")"
                                           hx-target="#business-communication-profile-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                        <a asp-controller="Users" asp-action="Index" asp-route-filter="MobileLinked" class="btn btn-sm btn-outline-secondary"
                                           hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })"
                                           hx-target="#business-communication-profile-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">@T.T("BusinessCommunicationLiveChannelFamiliesTitle")</div>
    <div class="card-body">
        <div class="small text-muted mb-3">
            @T.T("BusinessCommunicationLiveChannelFamiliesNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Family")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("ChannelAuditCurrentTemplateColumn")</th>
                        <th>@T.T("ChannelAuditRenderedPreviewColumn")</th>
                        <th>@T.T("Tokens")</th>
                        <th>@T.T("ChannelAuditTargetPolicyColumn")</th>
                        <th>@T.T("ChannelAuditUsageGuidanceColumn")</th>
                        <th>@T.T("Action")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ChannelTemplateFamilies.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">@T.T("BusinessCommunicationNoLiveChannelFamilies")</td></tr>
                }
                else
                {
                    foreach (var family in Model.ChannelTemplateFamilies)
                    {
                        <tr>
                            <td class="fw-semibold">@family.FamilyName</td>
                            <td><span class="badge text-bg-light">@family.Channel</span></td>
                            <td><div class="small">@family.CurrentTemplate</div></td>
                            <td><div class="small text-body-secondary">@family.ExamplePreview</div></td>
                            <td><code>@family.SupportedTokens</code></td>
                            <td>
                                <div class="small">@family.TargetSurface</div>
                                <div class="small text-muted mt-1">@family.PolicyNote</div>
                            </td>
                            <td>
                                <div class="small">@family.SafeUsageNote</div>
                                <div class="small text-muted mt-1">@family.RolloutBoundary</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="@family.ActionFragment"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = family.ActionFragment })"
                                       hx-target="#business-communication-profile-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@family.ActionLabel</a>
                                    @if (string.Equals(family.FamilyName, "Phone Verification", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-businessId="@Model.Id"
                                           asp-route-phoneVerificationOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id, phoneVerificationOnly = true, channel = family.Channel })"
                                           hx-target="#business-communication-profile-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenVerificationAuditsAction")</a>
                                    }
                                    else if (string.Equals(family.FamilyName, "Admin Communication Test", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-businessId="@Model.Id"
                                           asp-route-adminTestOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id, adminTestOnly = true, channel = family.Channel })"
                                           hx-target="#business-communication-profile-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenTestAuditsAction")</a>
                                        @if (string.Equals(family.Channel, "SMS", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestSms)
                                        {
                                            <form asp-action="SendTestSms" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                                                  hx-target="#business-communication-profile-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunSmsTestAction")</button>
                                            </form>
                                        }
                                        else if (string.Equals(family.Channel, "WhatsApp", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestWhatsApp)
                                        {
                                            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                                                  hx-target="#business-communication-profile-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunWhatsAppTestAction")</button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

