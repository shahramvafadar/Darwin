@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationProfileVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessCommunicationProfileTitle");
}

<div id="business-communication-profile-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open me-2"></i>@Model.Name</h1>
        <p class="text-muted mb-0">@T.T("BusinessCommunicationProfileIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
        <a asp-action="ChannelAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
        <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("EmailAudits")</a>
        <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.Id" class="btn btn-outline-primary"
           hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenSetup")</a>
        <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Members")</a>
        <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
           hx-target="#business-communication-profile-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Invitations")</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationProfileBusinessProfileTitle")</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">@T.T("CommonLegalName")</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.LegalName) ? T.T("CommonMissingBadge") : Model.LegalName)</dd>
                    <dt class="col-sm-4">@T.T("CommonContactEmail")</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ContactEmail) ? T.T("CommonMissingBadge") : Model.ContactEmail)</dd>
                    <dt class="col-sm-4">@T.T("CommonCulture")</dt>
                    <dd class="col-sm-8">@Model.DefaultCulture</dd>
                    <dt class="col-sm-4">@T.T("CommonTimeZone")</dt>
                    <dd class="col-sm-8">@Model.DefaultTimeZoneId</dd>
                    <dt class="col-sm-4">@T.T("CommonStatus")</dt>
                    <dd class="col-sm-8">
                        <span class="badge text-bg-secondary">@Model.OperationalStatus</span>
                        @if (!Model.IsActive)
                        {
                            <span class="badge text-bg-warning ms-1">@T.T("CommonInactiveBadge")</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationProfileSenderDefaultsTitle")</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">@T.T("BusinessCommunicationSupportShort")</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.SupportEmail) ? T.T("CommonMissingBadge") : Model.SupportEmail)</dd>
                    <dt class="col-sm-4">@T.T("BusinessCommunicationSenderShort")</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.CommunicationSenderName) ? T.T("CommonMissingBadge") : Model.CommunicationSenderName)</dd>
                    <dt class="col-sm-4">@T.T("BusinessCommunicationReplyToShort")</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.CommunicationReplyToEmail) ? T.T("CommonMissingBadge") : Model.CommunicationReplyToEmail)</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationProfileSupportSignalsTitle")</div>
            <div class="card-body">
                <div class="mb-2">@T.T("BusinessCommunicationOpenInvitationsLabel"): <strong>@Model.OpenInvitationCount</strong></div>
                <div class="mb-2">@T.T("BusinessCommunicationPendingActivationMembersLabel"): <strong>@Model.PendingActivationMemberCount</strong></div>
                <div>@T.T("BusinessCommunicationLockedMembersLabel"): <strong>@Model.LockedMemberCount</strong></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationPolicyFlagsTitle")</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge @(Model.CustomerEmailNotificationsEnabled ? "text-bg-primary" : "text-bg-light")">@T.T("BusinessCommunicationTransactionalEmailLabel")</span>
                    <span class="badge @(Model.CustomerMarketingEmailsEnabled ? "text-bg-info" : "text-bg-light")">@T.T("BusinessCommunicationMarketingEmailLabel")</span>
                    <span class="badge @(Model.OperationalAlertEmailsEnabled ? "text-bg-secondary" : "text-bg-light")">@T.T("BusinessCommunicationOperationalAlertsLabel")</span>
                </div>
                <div class="small text-muted mt-3">
                    @T.T("BusinessCommunicationPolicyFlagsHelp")
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationGlobalDependencyReadinessTitle")</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge @(Model.EmailTransportConfigured ? "text-bg-success" : "text-bg-warning")">SMTP @(Model.EmailTransportConfigured ? T.T("CommonReadyBadge") : T.T("CommonMissingBadge"))</span>
                    <span class="badge @(Model.SmsTransportConfigured ? "text-bg-success" : "text-bg-warning")">SMS @(Model.SmsTransportConfigured ? T.T("CommonReadyBadge") : T.T("CommonMissingBadge"))</span>
                    <span class="badge @(Model.WhatsAppTransportConfigured ? "text-bg-success" : "text-bg-warning")">WhatsApp @(Model.WhatsAppTransportConfigured ? T.T("CommonReadyBadge") : T.T("CommonMissingBadge"))</span>
                    <span class="badge @(Model.AdminAlertRoutingConfigured ? "text-bg-success" : "text-bg-warning")">@T.T("BusinessCommunicationAdminAlertsShort") @(Model.AdminAlertRoutingConfigured ? T.T("CommonReadyBadge") : T.T("CommonMissingBadge"))</span>
                </div>
                <div class="mt-3">
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-smtp" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationSmtpShort")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationSmsShort")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationWhatsAppShort")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationAdminAlertsShort")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationTransactionalPolicyTitle")</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">@T.T("BusinessCommunicationSubjectPrefixLabel")</dt>
                    <dd class="col-sm-8">@(Model.TransactionalSubjectPrefixConfigured ? Model.TransactionalSubjectPrefix : T.T("BusinessCommunicationNoPrefixConfigured"))</dd>
                    <dt class="col-sm-4">@T.T("BusinessCommunicationTestInboxLabel")</dt>
                    <dd class="col-sm-8">@(Model.TestInboxConfigured ? Model.TestInboxEmail : T.T("BusinessCommunicationNoRerouteConfigured"))</dd>
                </dl>
                <div class="small text-muted mt-3">
                    @T.T("BusinessCommunicationTransactionalPolicyNote")
                </div>
                <div class="mt-3">
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationOpenPolicyAction")</a>
                    <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "MobileOperations")"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                    @if (Model.CanSendTestEmail)
                    {
                        <form asp-action="SendTestEmail" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("SendTestEmail")</button>
                        </form>
                    }
                    @if (Model.CanSendTestSms)
                    {
                        <form asp-action="SendTestSms" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("SendTestSms")</button>
                        </form>
                    }
                    @if (Model.CanSendTestWhatsApp)
                    {
                        <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                              hx-target="#business-communication-profile-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("SendTestWhatsApp")</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationPhaseOneImplicationsTitle")</div>
            <div class="card-body">
                <ul class="mb-0">
                    <li>@T.T("BusinessCommunicationPhaseOneImplicationSubjectPrefix")</li>
                    <li>@T.T("BusinessCommunicationPhaseOneImplicationTestInbox")</li>
                    <li>@T.T("BusinessCommunicationPhaseOneImplicationVerificationTargets")</li>
                    <li>@T.T("BusinessCommunicationPhaseOneImplicationOperationalControl")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationReadinessIssuesTitle")</div>
            <div class="card-body">
                @if (Model.ReadinessIssues.Count == 0)
                {
                    <div class="alert alert-success mb-0">@T.T("BusinessCommunicationNoReadinessIssues")</div>
                }
                else
                {
                    <ul class="mb-0">
                    @foreach (var issue in Model.ReadinessIssues)
                    {
                        <li>@issue</li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationCurrentFlowsTitle")</div>
            <div class="card-body">
                @if (Model.ActiveFlowNames.Count == 0)
                {
                    <div class="text-muted">@T.T("BusinessCommunicationNoCurrentFlows")</div>
                }
                else
                {
                    <ul class="mb-0">
                    @foreach (var flow in Model.ActiveFlowNames)
                    {
                        <li>@flow</li>
                    }
                    </ul>
                }
                <div class="small text-muted mt-3">
                    @T.T("BusinessCommunicationCurrentFlowsNote")
                </div>
                @if (Model.OpenInvitationCount > 0)
                {
                    <div class="mt-3">
                    <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" asp-route-flowKey="BusinessInvitation" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, flowKey = "BusinessInvitation" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @T.T("BusinessCommunicationViewInvitationAuditsAction")
                    </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationRecommendedNextActionsTitle")</div>
            <div class="card-body">
                <ul class="mb-0">
                @foreach (var action in Model.RecommendedActions)
                {
                    <li>@action</li>
                }
                </ul>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">@T.T("CommonOpenSetupAction")</a>
                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id, filter = "Attention" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">@T.T("BusinessCommunicationOpenMemberSupportAction")</a>
                    <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id, filter = "Open" })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML">@T.T("BusinessCommunicationOpenInvitationsAction")</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">@T.T("BusinessCommunicationRecentBusinessEmailActivityTitle")</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@T.T("WhenUtc")</th>
                                <th>@T.T("Flow")</th>
                                <th>@T.T("Recipient")</th>
                                <th>@T.T("Status")</th>
                                <th>@T.T("EmailAuditsDeliveryContextColumn")</th>
                                <th>@T.T("FollowUp")</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.RecentEmailAudits.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center text-muted py-3">@T.T("BusinessCommunicationNoRecentBusinessEmailActivity")</td></tr>
                        }
                        else
                        {
                            foreach (var item in Model.RecentEmailAudits)
                            {
                                <tr>
                                    <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("CommonUnclassified") : item.FlowKey)</td>
                                    <td>@item.RecipientEmail</td>
                                    <td>
                                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-success">@T.T("CommonSentBadge")</span>
                                        }
                                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">@T.T("CommonFailedBadge")</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">@T.T("CommonHighBadge")</span>
                                        }
                                        else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-warning">@T.T("CommonMediumBadge")</span>
                                        }
                                        else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-secondary">@T.T("CommonWatchBadge")</span>
                                        }
                                        else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-info">@T.T("CommonSlowBadge")</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-light">@T.T("CommonNormalBadge")</span>
                                        }
                                        <div class="small text-muted mt-1">@string.Format(T.T("CommonOpenForMinutes"), item.AttemptAgeMinutes)</div>
                                        @if (item.CompletionLatencySeconds.HasValue)
                                        {
                                            <div class="small text-muted">@string.Format(T.T("CommonLatencySeconds"), item.CompletionLatencySeconds.Value)</div>
                                        }
                                        @if (item.PriorAttemptCount > 0)
                                        {
                                            <div class="small text-muted">@string.Format(T.T("CommonPriorAttempts"), item.PriorAttemptCount)</div>
                                        }
                                        @if (item.PriorFailureCount > 0)
                                        {
                                            <div class="small text-muted">@string.Format(T.T("CommonPriorFailures"), item.PriorFailureCount)</div>
                                        }
                                        @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                                        {
                                            <div class="small text-muted">@string.Format(T.T("CommonLastSuccessAt"), item.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm"))</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="small">@item.RecommendedAction</div>
                                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                        {
                                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                                        }
                                        <div class="mt-2 d-flex flex-wrap gap-2">
                                            @if (string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.Id" asp-route-query="@item.RecipientEmail" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id, query = item.RecipientEmail, filter = "Open" })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">@T.T("BusinessCommunicationSearchInvitationAction")</a>
                                            }
                                            else if (string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase) || string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.Id" asp-route-query="@item.RecipientEmail" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id, query = item.RecipientEmail, filter = "Attention" })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">@T.T("BusinessCommunicationMemberSupportAction")</a>
                                                <a asp-controller="Users" asp-action="Index" asp-route-q="@item.RecipientEmail" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML">@T.T("BusinessCommunicationOpenUsersAction")</a>
                                                <a asp-controller="MobileOperations" asp-action="Index" asp-route-q="@item.RecipientEmail" class="btn btn-sm btn-outline-secondary"
                                                   hx-get="@Url.Action("Index", "MobileOperations", new { q = item.RecipientEmail })"
                                                   hx-target="#business-communication-profile-shell"
                                                   hx-swap="outerHTML"
                                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                            }
                                            else if (string.Equals(item.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestEmail)
                                            {
                                                <form asp-action="SendTestEmail" method="post" class="d-inline"
                                                      hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                                                      hx-target="#business-communication-profile-shell"
                                                      hx-swap="outerHTML">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("CommonRerunTestAction")</button>
                                                </form>
                                            }
                                            <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" asp-route-status="Failed" asp-route-flowKey="@item.FlowKey" class="btn btn-sm btn-outline-dark"
                                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, status = "Failed", flowKey = item.FlowKey })"
                                               hx-target="#business-communication-profile-shell"
                                               hx-swap="outerHTML">@T.T("FailedAuditsAction")</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a asp-action="EmailAudits" asp-route-businessId="@Model.Id" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id })"
                       hx-target="#business-communication-profile-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessCommunicationOpenBusinessEmailAuditsAction")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@T.T("SmsWhatsAppActivitySnapshotTitle")</div>
            <div class="card-body">
