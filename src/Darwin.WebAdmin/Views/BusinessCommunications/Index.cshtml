                                   hx-get="@BusinessFailedInvitationAuditsUrl(item.Id)"
                               hx-target="#business-communications-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
                            <a asp-action="ChannelAudits"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessChannelAuditsUrl(item.Id)"
                               hx-target="#business-communications-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("SmsWhatsAppAudits")</a>
                            <a asp-controller="Businesses"
                               asp-action="Invitations"
                               asp-route-businessId="@item.Id"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                               class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessPendingInvitationsUrl(item.Id)"
                               hx-target="#business-communications-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Pending")</a>
                            <a asp-controller="Businesses"
                               asp-action="Members"
                               asp-route-businessId="@item.Id"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                               class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                               hx-target="#business-communications-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                            <a asp-controller="Businesses"
                               asp-action="Members"
                               asp-route-businessId="@item.Id"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                               class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)"
                               hx-target="#business-communications-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("UsersFilterLocked")</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-setupOnly="@Model.SetupOnly"
       asp-route-filter="@Model.Filter"
       hx-target="#business-communications-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
