<div class="card mb-4">
    <div class="card-header">@T.T("CommunicationRecentEmailDeliveryActivityTitle")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("CommunicationRecentEmailDeliveryActivityNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("WhenUtc")</th>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Recipient")</th>
                        <th>@T.T("SubjectLabel")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("EmailAuditsDeliveryContextColumn")</th>
                        <th>@T.T("Details")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentEmailAudits.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">@T.T("CommunicationNoEmailDeliveryActivity")</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentEmailAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("Unclassified") : item.FlowKey)</td>
                            <td>@item.RecipientEmail</td>
                            <td>@item.Subject</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@T.T("Sent")</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("Failed")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("High")</span>
                                }
                                else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-warning">@T.T("Medium")</span>
                                }
                                else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-secondary">@T.T("Watch")</span>
                                }
                                else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-info">@T.T("Slow")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-light">@T.T("Normal")</span>
                                }
                                <div class="small text-muted mt-1">@string.Format(T.T("CommunicationOpenForMinutes"), item.AttemptAgeMinutes)</div>
                                @if (item.CompletionLatencySeconds.HasValue)
                                {
                                    <div class="small text-muted">@string.Format(T.T("CommunicationLatencySeconds"), item.CompletionLatencySeconds.Value)</div>
                                }
                                @if (item.PriorAttemptCount > 0)
                                {
                                    <div class="small text-muted">@string.Format(T.T("CommunicationPriorAttempts"), item.PriorAttemptCount)</div>
                                }
                                @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                                {
                                    <div class="small text-muted">@string.Format(T.T("CommunicationLastSuccessAt"), item.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm"))</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger">@item.FailureMessage</div>
                                }
                                else if (item.CompletedAtUtc.HasValue)
                                {
                                    <div class="small text-muted">@string.Format(T.T("CommunicationCompletedAt"), item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm"))</div>
                                }
                                else
                                {
                                    <div class="small text-muted">@T.T("CommunicationAttemptRecorded")</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <a asp-action="EmailAudits" class="btn btn-sm btn-outline-primary"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
               hx-target="#business-communications-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessCommunicationOpenFullEmailAuditLogAction")</a>
        </div>
    </div>
</div>

