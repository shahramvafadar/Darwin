@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationOpsVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CommunicationOpsTitle");
}

<div id="business-communications-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-circle-check me-2"></i>@T.T("CommunicationOpsTitle")</h1>
        <p class="text-muted mb-0">@T.T("CommunicationOpsIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ChannelAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SmsWhatsAppAudits")</a>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("EmailAudits")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-smtp" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">SMTP</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">SMS</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">WhatsApp</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Admin Alerts</a>
        @if (Model.Transport.CanSendTestEmail)
        {
            <form asp-action="SendTestEmail" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestEmail")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestSms)
        {
            <form asp-action="SendTestSms" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestSms")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestWhatsApp)
        {
            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestWhatsApp")</button>
            </form>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("EmailTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.EmailTransportConfigured ? T.T("Ready") : T.T("NeedsSetup"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("SmsTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.SmsTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("WhatsAppTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.WhatsAppTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("AdminAlertRouting")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.AdminAlertRoutingConfigured ? T.T("Configured") : T.T("Missing"))</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("TransactionalSubjectPrefix")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.TransactionalSubjectPrefixConfigured ? Model.Transport.TransactionalSubjectPrefix : T.T("NoPrefixConfigured"))</div>
            <div class="small text-muted mt-2">Applied to the current invitation, activation, and password-reset email subjects.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommunicationTestInbox")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.TestInboxConfigured ? Model.Transport.TestInboxEmail : T.T("NotRerouting"))</div>
            <div class="small text-muted mt-2">When configured, current transactional emails are redirected here and include the original recipient in the body.</div>
            @if (Model.Transport.CanSendTestEmail)
            {
                <div class="small text-success mt-2">A test email can be sent safely from this workspace because SMTP and the test inbox are both configured.</div>
            }
            else
            {
                <div class="small text-muted mt-2">Configure both SMTP and the communication test inbox to enable a safe operator-side test email action.</div>
            }
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("SmsTestTarget")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.SmsTestRecipientConfigured ? Model.Transport.TestSmsRecipientE164 : T.T("NotConfigured"))</div>
            <div class="small text-muted mt-2">Used for operator-side SMS transport tests before live rollout.</div>
            @if (Model.Transport.CanSendTestSms)
            {
                <div class="small text-success mt-2">A safe operator-side SMS test is available because transport and test target are configured.</div>
            }
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("WhatsAppTestTarget")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.WhatsAppTestRecipientConfigured ? Model.Transport.TestWhatsAppRecipientE164 : T.T("NotConfigured"))</div>
            <div class="small text-muted mt-2">Used for operator-side WhatsApp transport tests before live rollout.</div>
            @if (Model.Transport.CanSendTestWhatsApp)
            {
                <div class="small text-success mt-2">A safe operator-side WhatsApp test is available because transport and test target are configured.</div>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Businesses Requiring Email Setup</div>
            <div class="fs-4 fw-semibold">@Model.Summary.BusinessesRequiringEmailSetupCount</div>
            <div class="small text-muted mt-2">Businesses with email-related toggles enabled but missing support or sender defaults.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Support Email</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingSupportEmailCount</div>
            <div class="small text-muted mt-2">Counts businesses that still have no business-level support mailbox configured.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Sender Identity</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingSenderIdentityCount</div>
            <div class="small text-muted mt-2">Counts businesses missing sender name or reply-to defaults.</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Channel Attempts (24h)</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.Recent24HourCount</div>
            <div class="small text-muted mt-2">Recent SMS and WhatsApp sends for verification and operator diagnostics.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">SMS / WhatsApp</div>
            <div class="fw-semibold mt-1">@Model.ChannelAuditSummary.SmsCount / @Model.ChannelAuditSummary.WhatsAppCount</div>
            <div class="small text-muted mt-2">Cross-channel activity mix for currently live non-email flows.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Phone Verification</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.PhoneVerificationCount</div>
            <div class="small text-muted mt-2">Delivery attempts generated by the canonical mobile-number verification flow.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Channel Failures</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.FailedCount</div>
            <div class="small text-muted mt-2">Operator-visible non-email delivery failures that need transport or policy review.</div>
        </div>
    </div>
</div>

<div class="card mb-4">
        <div class="card-header">@T.T("RecentSmsWhatsAppActivity")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This is the current multi-channel audit baseline. It covers the live SMS and WhatsApp families we already use for phone verification and operator diagnostics, without pretending a full outbox or generic notification bus exists yet.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("WhenUtc")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Recipient")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Preview")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentChannelAudits.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">@T.T("NoSmsWhatsAppActivityYet")</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentChannelAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge text-bg-light">@item.Channel</span> <span class="small text-muted">@item.Provider</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("Unclassified") : item.FlowKey)</td>
                            <td>@item.RecipientAddress</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@T.T("Sent")</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("Failed")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                <div class="small">@item.MessagePreview</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-1">@item.FailureMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <a asp-action="ChannelAudits" class="btn btn-sm btn-outline-primary"
               hx-get="@Url.Action("ChannelAudits", "BusinessCommunications")"
               hx-target="#business-communications-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">Open Full SMS / WhatsApp Audit Log</a>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Live SMS / WhatsApp Message Families</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            These are the current live non-email message families. Operators can see the effective template, token surface, target path, and policy boundary without waiting for one exact-chain incident to reconstruct that context.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Family</th>
                        <th>Channel</th>
                        <th>Current Template</th>
                        <th>Rendered Preview</th>
                        <th>Tokens</th>
                        <th>Target / Policy</th>
                        <th>Usage Guidance</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ChannelTemplateFamilies.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">No live SMS or WhatsApp message families are currently exposed.</td></tr>
                }
                else
                {
                    foreach (var family in Model.ChannelTemplateFamilies)
                    {
                        <tr>
                            <td class="fw-semibold">@family.FamilyName</td>
                            <td><span class="badge text-bg-light">@family.Channel</span></td>
                            <td><div class="small">@family.CurrentTemplate</div></td>
                            <td><div class="small text-body-secondary">@family.ExamplePreview</div></td>
                            <td><code>@family.SupportedTokens</code></td>
                            <td>
                                <div class="small">@family.TargetSurface</div>
                                <div class="small text-muted mt-1">@family.PolicyNote</div>
                            </td>
                            <td>
                                <div class="small">@family.SafeUsageNote</div>
                                <div class="small text-muted mt-1">@family.RolloutBoundary</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="@family.ActionFragment"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = family.ActionFragment })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@family.ActionLabel</a>
                                    @if (string.Equals(family.FamilyName, "Phone Verification", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-phoneVerificationOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true, channel = family.Channel })"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">Open Verification Audits</a>
                                    }
                                    else if (string.Equals(family.FamilyName, "Admin Communication Test", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-adminTestOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { adminTestOnly = true, channel = family.Channel })"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">Open Test Audits</a>
                                        @if (string.Equals(family.Channel, "SMS", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestSms)
                                        {
                                            <form asp-action="SendTestSms" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Rerun SMS Test</button>
                                            </form>
                                        }
                                        else if (string.Equals(family.Channel, "WhatsApp", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestWhatsApp)
                                        {
                                            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Rerun WhatsApp Test</button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Retried Delivery Chains</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.PriorAttemptCount > 0)</div>
            <div class="small text-muted mt-2">Recent audit rows that are part of a repeated delivery chain for the same flow and recipient.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Prior Success Context</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.LastSuccessfulAttemptAtUtc.HasValue)</div>
            <div class="small text-muted mt-2">Recent audit rows where the same flow/recipient already had a successful delivery before.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Repeated Failure Chains</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.PriorFailureCount > 0 && x.NeedsOperatorFollowUp)</div>
            <div class="small text-muted mt-2">Recent follow-up rows that are not first-time failures and likely need deeper operator review.</div>
        </div>
    </div>
</div>

<div class="small text-muted mb-3">
    Transactional email enabled: <strong>@Model.Summary.TransactionalEmailBusinessesCount</strong>
    <span class="mx-2">|</span>
    Marketing email enabled: <strong>@Model.Summary.MarketingEmailBusinessesCount</strong>
    <span class="mx-2">|</span>
    Operational alerts enabled: <strong>@Model.Summary.OperationalAlertBusinessesCount</strong>
</div>

<div class="card mb-4">
    <div class="card-header">Current Transactional Communication Flows</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This is a phase-1 visibility catalog. These flows are operational, but they still use direct transactional composition and do not yet provide a full template engine, delivery log, retry queue, or reusable Communication Core workflow.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Flow</th>
                        <th>Channel</th>
                        <th>Trigger</th>
                        <th>Delivery Path</th>
                        <th>Current Status</th>
                        <th>Next Step</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var flow in Model.BuiltInFlows)
                {
                    <tr>
                        <td class="fw-semibold">@flow.Name</td>
                        <td>@flow.Channel</td>
                        <td>@flow.Trigger</td>
                        <td>@flow.DeliveryPath</td>
                        <td>@flow.CurrentImplementationStatus</td>
                        <td>@flow.NextStep</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Template Inventory and Operator Control</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This inventory shows what is actually configurable today. It does not pretend a reusable template engine exists where only hard-coded transactional composition exists.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Flow</th>
                        <th>Template Surface</th>
                        <th>Subject Source</th>
                        <th>Body Source</th>
                        <th>Current Template Preview</th>
                        <th>Supported Tokens</th>
                        <th>Operator Control</th>
                        <th>Actions</th>
                        <th>Next Step</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.TemplateInventory)
                {
                    <tr>
                        <td class="fw-semibold">@item.FlowName</td>
                        <td>@item.TemplateSurface</td>
                        <td>@item.SubjectSource</td>
                        <td>@item.BodySource</td>
                        <td>
                            <div class="small"><strong>Subject:</strong> @item.CurrentSubjectTemplate</div>
                            <div class="small text-muted mt-1"><strong>Body:</strong> @item.CurrentBodyTemplate</div>
                        </td>
                        <td><code>@item.SupportedTokens</code></td>
                        <td>@item.OperatorControl</td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrWhiteSpace(item.AuditFlowKey))
                                {
                                    <a asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="@item.AuditFlowKey"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = item.AuditFlowKey })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">Failed Audits</a>
                                }
                                @if (item.OperatorActionTarget == "Invitations")
                                {
                                    <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "Users")
                                {
                                    <a asp-controller="Users" asp-action="Index" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("Index", "Users")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "EmailAudits")
                                {
                                    <a asp-action="EmailAudits" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "AdminAlerts")
                                {
                                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.OperatorActionLabel</a>
                                }
                                @if (item.OperatorActionTarget != "AdminAlerts")
                                {
                                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">Open Policy</a>
                                }
                            </div>
                        </td>
                        <td>@item.NextStep</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Capability Coverage and Retry Visibility</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This matrix is intentionally operational, not aspirational. It shows what operators can already inspect today and where Communication Core work is still missing.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Capability</th>
                        <th>Current State</th>
                        <th>Operator Visibility</th>
                        <th>Next Step</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.CapabilityCoverage)
                {
                    <tr>
                        <td class="fw-semibold">@item.Capability</td>
                        <td>@item.CurrentState</td>
                        <td>@item.OperatorVisibility</td>
                        <td>@item.NextStep</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Channel Truth and Safe Live Actions</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This table defines what is actually live per channel. It is here to stop two common operator mistakes: assuming WhatsApp is only a future concept, or assuming SMS/WhatsApp are already a generic notification platform.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Channel</th>
                        <th>Current State</th>
                        <th>Live Flows</th>
                        <th>Safe Operator Actions</th>
                        <th>Risk Boundary</th>
                        <th>Next Step</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.ChannelOperations)
                {
                    <tr>
                        <td class="fw-semibold">@item.Channel</td>
                        <td>@item.CurrentState</td>
                        <td>@item.LiveFlows</td>
                        <td>@item.SafeOperatorActions</td>
                        <td>@item.RiskBoundary</td>
                        <td>@item.NextStep</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Resend and Retry Policy Matrix</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            Operators should use only the safe entry points listed here. Failed audit rows are for triage visibility; they are not a generic replay button.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Flow</th>
                        <th>Current Safe Action</th>
                        <th>Generic Retry Status</th>
                        <th>Operator Entry Point</th>
                        <th>Actions</th>
                        <th>Escalation Rule</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.ResendPolicies)
                {
                    <tr>
                        <td class="fw-semibold">@item.FlowName</td>
                        <td>@item.CurrentSafeAction</td>
                        <td>@item.GenericRetryStatus</td>
                        <td>@item.OperatorEntryPoint</td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrWhiteSpace(item.AuditFlowKey))
                                {
                                    <a asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="@item.AuditFlowKey"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = item.AuditFlowKey })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">Failed Audits</a>
                                }
                                @if (item.OperatorActionTarget == "Invitations")
                                {
                                    <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "Users")
                                {
                                    <a asp-controller="Users" asp-action="Index" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("Index", "Users")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "EmailAudits")
                                {
                                    <a asp-action="EmailAudits" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.OperatorActionLabel</a>
                                }
                                else if (item.OperatorActionTarget == "AdminAlerts")
                                {
                                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-primary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.OperatorActionLabel</a>
                                }
                            </div>
                        </td>
                        <td>@item.EscalationRule</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Recent Email Delivery Activity</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This is a phase-1 email audit trail. It captures delivery attempts and failures for current SMTP-based transactional emails, but it is not yet a full Communication Core delivery-log/search/retry system.
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>When (UTC)</th>
                        <th>Flow</th>
                        <th>Recipient</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Delivery Context</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentEmailAudits.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No email delivery activity has been recorded yet.</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentEmailAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                            <td>@item.RecipientEmail</td>
                            <td>@item.Subject</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">Sent</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">Failed</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">High</span>
                                }
                                else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-warning">Medium</span>
                                }
                                else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-secondary">Watch</span>
                                }
                                else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-info">Slow</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-light">Normal</span>
                                }
                                <div class="small text-muted mt-1">Open for @item.AttemptAgeMinutes min</div>
                                @if (item.CompletionLatencySeconds.HasValue)
                                {
                                    <div class="small text-muted">Latency @item.CompletionLatencySeconds.Value s</div>
                                }
                                @if (item.PriorAttemptCount > 0)
                                {
                                    <div class="small text-muted">Prior attempts @item.PriorAttemptCount</div>
                                }
                                @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                                {
                                    <div class="small text-muted">Last success @item.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger">@item.FailureMessage</div>
                                }
                                else if (item.CompletedAtUtc.HasValue)
                                {
                                    <div class="small text-muted">Completed @item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                }
                                else
                                {
                                    <div class="small text-muted">Attempt recorded</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <a asp-action="EmailAudits" class="btn btn-sm btn-outline-primary"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
               hx-target="#business-communications-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">Open Full Email Audit Log</a>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Follow-up Backlog</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp)</div>
            <div class="small text-muted mt-2">Recent failed or stale-pending rows that still need operator follow-up.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">High Severity Rows</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "High", StringComparison.OrdinalIgnoreCase))</div>
            <div class="small text-muted mt-2">Business-linked failures and stale pending rows that deserve first-pass triage.</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Slow Deliveries</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => string.Equals(x.Severity, "Slow", StringComparison.OrdinalIgnoreCase))</div>
            <div class="small text-muted mt-2">Completed deliveries that took longer than the current operator threshold.</div>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "BusinessCommunications")"
      hx-target="#business-communications-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by business, legal name, support email, or sender" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check mt-2">
            <input type="checkbox" name="setupOnly" value="true" class="form-check-input" id="setupOnly" checked="@(Model.SetupOnly ? "checked" : null)" />
            <label class="form-check-label" for="setupOnly">Needs setup only</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>Business</th>
                <th>Support Email</th>
                <th>Sender Identity</th>
                <th>Enabled Policies</th>
                <th>Gaps</th>
                <th class="text-end" style="width:220px">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">No businesses matched the communication filters.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        @if (!string.IsNullOrWhiteSpace(item.LegalName))
                        {
                            <div class="small text-muted">@item.LegalName</div>
                        }
                    </td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.SupportEmail))
                        {
                            <span class="badge text-bg-warning">Missing</span>
                        }
                        else
                        {
                            <span>@item.SupportEmail</span>
                        }
                    </td>
                    <td>
                        <div>@(string.IsNullOrWhiteSpace(item.CommunicationSenderName) ? "Missing sender name" : item.CommunicationSenderName)</div>
                        <div class="small text-muted">@(string.IsNullOrWhiteSpace(item.CommunicationReplyToEmail) ? "Missing reply-to" : item.CommunicationReplyToEmail)</div>
                    </td>
                    <td>
                        @if (item.CustomerEmailNotificationsEnabled)
                        {
                            <span class="badge text-bg-primary">Transactional</span>
                        }
                        @if (item.CustomerMarketingEmailsEnabled)
                        {
                            <span class="badge text-bg-info">Marketing</span>
                        }
                        @if (item.OperationalAlertEmailsEnabled)
                        {
                            <span class="badge text-bg-secondary">Alerts</span>
                        }
                    </td>
                    <td>
                        @if (item.MissingSupportEmail)
                        {
                            <div class="small text-muted">Support email missing</div>
                        }
                        @if (item.MissingSenderIdentity)
                        {
                            <div class="small text-muted">Sender identity incomplete</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-businessId="@item.Id" class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-circle-info"></i> Inspect
                        </a>
                        <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("Setup", "Businesses", new { id = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-sliders"></i> Open Setup
                        </a>
                        <a asp-controller="Businesses" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-setupOnly="@Model.SetupOnly"
       asp-route-filter="@Model.Filter"
       hx-target="#business-communications-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
