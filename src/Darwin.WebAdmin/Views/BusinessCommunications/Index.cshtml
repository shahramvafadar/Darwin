@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationOpsVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CommunicationOpsTitle");
}

<div id="business-communications-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-circle-check me-2"></i>@T.T("CommunicationOpsTitle")</h1>
        <p class="text-muted mb-0">@T.T("CommunicationOpsIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ChannelAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SmsWhatsAppAudits")</a>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("EmailAudits")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-smtp" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SMTP")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SMS")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("WhatsApp")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("AdminAlerts")</a>
        @if (Model.Transport.CanSendTestEmail)
        {
            <form asp-action="SendTestEmail" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestEmail")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestSms)
        {
            <form asp-action="SendTestSms" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestSms")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestWhatsApp)
        {
            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestWhatsApp")</button>
            </form>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("EmailTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.EmailTransportConfigured ? T.T("Ready") : T.T("NeedsSetup"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("SmsTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.SmsTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("WhatsAppTransport")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.WhatsAppTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("AdminAlertRouting")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.AdminAlertRoutingConfigured ? T.T("Configured") : T.T("Missing"))</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("TransactionalSubjectPrefix")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.TransactionalSubjectPrefixConfigured ? Model.Transport.TransactionalSubjectPrefix : T.T("NoPrefixConfigured"))</div>
            <div class="small text-muted mt-2">@T.T("CommunicationSubjectPrefixNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommunicationTestInbox")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.TestInboxConfigured ? Model.Transport.TestInboxEmail : T.T("NotRerouting"))</div>
            <div class="small text-muted mt-2">@T.T("CommunicationTestInboxNote")</div>
            @if (Model.Transport.CanSendTestEmail)
            {
                <div class="small text-success mt-2">@T.T("CommunicationTestEmailReadyNote")</div>
            }
            else
            {
                <div class="small text-muted mt-2">@T.T("CommunicationTestEmailBlockedNote")</div>
            }
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("SmsTestTarget")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.SmsTestRecipientConfigured ? Model.Transport.TestSmsRecipientE164 : T.T("NotConfigured"))</div>
            <div class="small text-muted mt-2">@T.T("CommunicationTestSmsTargetNote")</div>
            @if (Model.Transport.CanSendTestSms)
            {
                <div class="small text-success mt-2">@T.T("CommunicationTestSmsReadyNote")</div>
            }
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("WhatsAppTestTarget")</div>
            <div class="fw-semibold mt-1">@(Model.Transport.WhatsAppTestRecipientConfigured ? Model.Transport.TestWhatsAppRecipientE164 : T.T("NotConfigured"))</div>
            <div class="small text-muted mt-2">@T.T("CommunicationTestWhatsAppTargetNote")</div>
            @if (Model.Transport.CanSendTestWhatsApp)
            {
                <div class="small text-success mt-2">@T.T("CommunicationTestWhatsAppReadyNote")</div>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("BusinessesRequiringEmailSetup")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.BusinessesRequiringEmailSetupCount</div>
            <div class="small text-muted mt-2">@T.T("BusinessesRequiringEmailSetupNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingSupportEmail")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingSupportEmailCount</div>
            <div class="small text-muted mt-2">@T.T("MissingSupportEmailNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingSenderIdentity")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingSenderIdentityCount</div>
            <div class="small text-muted mt-2">@T.T("MissingSenderIdentityNote")</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ChannelAttempts24h")</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.Recent24HourCount</div>
            <div class="small text-muted mt-2">@T.T("ChannelAttempts24hNote")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("SmsWhatsAppMix")</div>
            <div class="fw-semibold mt-1">@Model.ChannelAuditSummary.SmsCount / @Model.ChannelAuditSummary.WhatsAppCount</div>
            <div class="small text-muted mt-2">@T.T("SmsWhatsAppMixNote")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("PhoneVerification")</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.PhoneVerificationCount</div>
            <div class="small text-muted mt-2">@T.T("PhoneVerificationActivityNote")</div>
            <div class="d-flex gap-2 flex-wrap mt-3">
                <a asp-action="ChannelAudits"
                   asp-route-phoneVerificationOnly="true"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true })"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("PhoneVerification")</a>
                <a asp-controller="MobileOperations"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "MobileOperations")"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="MobileLinked"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ChannelFailures")</div>
            <div class="fs-4 fw-semibold">@Model.ChannelAuditSummary.FailedCount</div>
            <div class="small text-muted mt-2">@T.T("ChannelFailuresNote")</div>
        </div>
    </div>
</div>

<div class="card mb-4">
        <div class="card-header">@T.T("RecentSmsWhatsAppActivity")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("ChannelAuditBaselineNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("WhenUtc")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Recipient")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Preview")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentChannelAudits.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">@T.T("NoSmsWhatsAppActivityYet")</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentChannelAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge text-bg-light">@item.Channel</span> <span class="small text-muted">@item.Provider</span></td>
                            <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("Unclassified") : item.FlowKey)</td>
                            <td>@item.RecipientAddress</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@T.T("Sent")</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("Failed")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                <div class="small">@item.MessagePreview</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-1">@item.FailureMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <a asp-action="ChannelAudits" class="btn btn-sm btn-outline-primary"
               hx-get="@Url.Action("ChannelAudits", "BusinessCommunications")"
               hx-target="#business-communications-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessCommunicationOpenFullChannelAuditLogAction")</a>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("BusinessCommunicationLiveChannelFamiliesTitle")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("BusinessCommunicationLiveChannelFamiliesNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("BusinessCommunicationFamilyColumn")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("BusinessCommunicationCurrentTemplateColumn")</th>
                        <th>@T.T("BusinessCommunicationRenderedPreviewColumn")</th>
                        <th>@T.T("BusinessCommunicationTokensColumn")</th>
                        <th>@T.T("BusinessCommunicationTargetPolicyColumn")</th>
                        <th>@T.T("BusinessCommunicationUsageGuidanceColumn")</th>
                        <th>@T.T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ChannelTemplateFamilies.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">@T.T("BusinessCommunicationNoLiveChannelFamilies")</td></tr>
                }
                else
                {
                    foreach (var family in Model.ChannelTemplateFamilies)
                    {
                        <tr>
                            <td class="fw-semibold">@family.FamilyName</td>
                            <td><span class="badge text-bg-light">@family.Channel</span></td>
                            <td><div class="small">@family.CurrentTemplate</div></td>
                            <td><div class="small text-body-secondary">@family.ExamplePreview</div></td>
                            <td><code>@family.SupportedTokens</code></td>
                            <td>
                                <div class="small">@family.TargetSurface</div>
                                <div class="small text-muted mt-1">@family.PolicyNote</div>
                            </td>
                            <td>
                                <div class="small">@family.SafeUsageNote</div>
                                <div class="small text-muted mt-1">@family.RolloutBoundary</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="@family.ActionFragment"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = family.ActionFragment })"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@family.ActionLabel</a>
                                    @if (string.Equals(family.FamilyName, "Phone Verification", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-phoneVerificationOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true, channel = family.Channel })"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenVerificationAuditsAction")</a>
                                        <a asp-controller="MobileOperations"
                                           asp-action="Index"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("Index", "MobileOperations")"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                        <a asp-controller="Users"
                                           asp-action="Index"
                                           asp-route-filter="MobileLinked"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("Index", "Users", new { filter = "MobileLinked" })"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                                    }
                                    else if (string.Equals(family.FamilyName, "Admin Communication Test", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-adminTestOnly="true"
                                           asp-route-channel="@family.Channel"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { adminTestOnly = true, channel = family.Channel })"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenTestAuditsAction")</a>
                                        @if (string.Equals(family.Channel, "SMS", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestSms)
                                        {
                                            <form asp-action="SendTestSms" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunSmsTestAction")</button>
                                            </form>
                                        }
                                        else if (string.Equals(family.Channel, "WhatsApp", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestWhatsApp)
                                        {
                                            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunWhatsAppTestAction")</button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommunicationRetriedDeliveryChainsLabel")</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.PriorAttemptCount > 0)</div>
            <div class="small text-muted mt-2">@T.T("CommunicationRetriedDeliveryChainsNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommunicationPriorSuccessContextLabel")</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.LastSuccessfulAttemptAtUtc.HasValue)</div>
            <div class="small text-muted mt-2">@T.T("CommunicationPriorSuccessContextNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommunicationRepeatedFailureChainsLabel")</div>
            <div class="fs-4 fw-semibold">@Model.RecentEmailAudits.Count(x => x.PriorFailureCount > 0 && x.NeedsOperatorFollowUp)</div>
            <div class="small text-muted mt-2">@T.T("CommunicationRepeatedFailureChainsNote")</div>
        </div>
    </div>
</div>

<div class="small text-muted mb-3">
    @T.T("CommunicationTransactionalEmailEnabledLabel"): <strong>@Model.Summary.TransactionalEmailBusinessesCount</strong>
    <span class="mx-2">|</span>
    @T.T("CommunicationMarketingEmailEnabledLabel"): <strong>@Model.Summary.MarketingEmailBusinessesCount</strong>
    <span class="mx-2">|</span>
    @T.T("CommunicationOperationalAlertsEnabledLabel"): <strong>@Model.Summary.OperationalAlertBusinessesCount</strong>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("CommunicationCurrentTransactionalFlowsTitle")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("CommunicationCurrentTransactionalFlowsNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("Trigger")</th>
                        <th>@T.T("CommunicationDeliveryPathColumn")</th>
                        <th>@T.T("CurrentStatus")</th>
                        <th>@T.T("NextStep")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var flow in Model.BuiltInFlows)
                {
                    <tr>
                        <td class="fw-semibold">@flow.Name</td>
                        <td>@flow.Channel</td>
                        <td>@flow.Trigger</td>
                        <td>@flow.DeliveryPath</td>
                        <td>@flow.CurrentImplementationStatus</td>
                        <td>@flow.NextStep</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("CommunicationTemplateInventoryTitle")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("CommunicationTemplateInventoryNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("CommunicationTemplateSurfaceColumn")</th>
                        <th>@T.T("CommunicationSubjectSourceColumn")</th>
                        <th>@T.T("CommunicationBodySourceColumn")</th>
                        <th>@T.T("CommunicationCurrentTemplatePreviewColumn")</th>
                        <th>@T.T("SupportedTokens")</th>
                        <th>@T.T("CommunicationOperatorControlColumn")</th>
                        <th>@T.T("Actions")</th>
                        <th>@T.T("NextStep")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.TemplateInventory)
                {
                    <tr>
                        <td class="fw-semibold">@item.FlowName</td>
                        <td>@item.TemplateSurface</td>
                        <td>@item.SubjectSource</td>
                        <td>@item.BodySource</td>
