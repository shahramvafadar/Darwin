@model Darwin.WebAdmin.ViewModels.Businesses.BusinessCommunicationOpsVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CommunicationOpsTitle");

    string GlobalBusinessSupportQueueUrl() => Url.Action("SupportQueue", "Businesses") ?? string.Empty;
    string GlobalMerchantReadinessUrl() => Url.Action("MerchantReadiness", "Businesses") ?? string.Empty;
    string GlobalMobileOperationsUrl() => Url.Action("Index", "MobileOperations") ?? string.Empty;
    string GlobalUsersUrl() => Url.Action("Index", "Users") ?? string.Empty;
    string GlobalEmailAuditsUrl() => Url.Action("EmailAudits", "BusinessCommunications") ?? string.Empty;
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string GlobalChannelAuditsUrl() => Url.Action("ChannelAudits", "BusinessCommunications") ?? string.Empty;
    string GlobalTemplatePreviewsUrl() => Url.Action("TemplatePreviews", "BusinessCommunications") ?? string.Empty;
    string GlobalProviderCallbacksUrl() => Url.Action("ProviderCallbacks", "BusinessCommunications") ?? string.Empty;
    string BrevoProviderCallbacksUrl(string? status = null, bool? failedOnly = null, bool? stalePendingOnly = null) => Url.Action("ProviderCallbacks", "BusinessCommunications", new { provider = "Brevo", status, failedOnly, stalePendingOnly }) ?? string.Empty;
    string TemplatePreviewFlowUrl(string flowKey) => Url.Action("TemplatePreviews", "BusinessCommunications", new { flowKey }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string BusinessCommunicationsSetupUrl() => Url.Action("Index", "BusinessCommunications", new { setupOnly = true }) ?? string.Empty;
    string PendingInvitationsUrl() => Url.Action("Invitations", "Businesses", new { filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending }) ?? string.Empty;
    string UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter) => Url.Action("Index", "Users", new { filter }) ?? string.Empty;
    string EmailAuditsFlowUrl(string flowKey, string status) => Url.Action("EmailAudits", "BusinessCommunications", new { flowKey, status }) ?? string.Empty;
    string FailedAuditFlowUrl(string flowKey) => Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey }) ?? string.Empty;
    string EmailAuditsRetryReadyUrl() => Url.Action("EmailAudits", "BusinessCommunications", new { retryReadyOnly = true }) ?? string.Empty;
    string EmailAuditsRetryBlockedUrl() => Url.Action("EmailAudits", "BusinessCommunications", new { retryBlockedOnly = true }) ?? string.Empty;
    string EmailAuditsHighChainVolumeUrl() => Url.Action("EmailAudits", "BusinessCommunications", new { highChainVolumeOnly = true }) ?? string.Empty;
    string ChannelAuditsProviderReviewUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { providerReviewOnly = true }) ?? string.Empty;
    string ChannelAuditsActionReadyUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { actionReadyOnly = true }) ?? string.Empty;
    string ChannelAuditsActionBlockedUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { actionBlockedOnly = true }) ?? string.Empty;
    string ChannelAuditsEscalationCandidatesUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { escalationCandidatesOnly = true }) ?? string.Empty;
    string ChannelAuditsPhoneVerificationUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true }) ?? string.Empty;
    string ChannelAuditsPhoneVerificationByChannelUrl(string? channel) => Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true, channel }) ?? string.Empty;
    string ChannelAuditsAdminTestByChannelUrl(string? channel) => Url.Action("ChannelAudits", "BusinessCommunications", new { adminTestOnly = true, channel }) ?? string.Empty;
    string CommunicationDetailsUrl(Guid businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string BusinessSetupUrl(Guid id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessEditUrl(Guid id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessEmailAuditsUrl(Guid businessId) => Url.Action("EmailAudits", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string BusinessFailedInvitationAuditsUrl(Guid businessId) => Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status = "Failed", flowKey = "BusinessInvitation" }) ?? string.Empty;
    string BusinessChannelAuditsUrl(Guid businessId) => Url.Action("ChannelAudits", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string BusinessPendingInvitationsUrl(Guid businessId) => Url.Action("Invitations", "Businesses", new { businessId, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending }) ?? string.Empty;
    string BusinessMembersUrl(Guid businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;

    string FlowLabel(string? flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string SeverityLabel(string? severity) => severity switch
    {
        "High" => T.T("High"),
        "Medium" => T.T("Medium"),
        "Watch" => T.T("Watch"),
        "Slow" => T.T("Slow"),
        "Normal" => T.T("Normal"),
        _ => string.IsNullOrWhiteSpace(severity) ? T.T("CommonUnclassified") : T.T(severity)
    };

    string ChannelLabel(string? channel) => channel switch
    {
        "SMS" => T.T("BusinessCommunicationSmsShort"),
        "WhatsApp" => T.T("BusinessCommunicationWhatsAppShort"),
        "Email" => T.T("CommunicationBuiltInFlowEmailChannel"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };
    string ValueOrLabel(string? value, string missingLabel) => string.IsNullOrWhiteSpace(value)
        ? T.T(missingLabel)
        : value;
    string SupportEmailBadgeClass(string? supportEmail) => string.IsNullOrWhiteSpace(supportEmail)
        ? "badge text-bg-warning"
        : string.Empty;
    string SupportEmailLabel(string? supportEmail) => string.IsNullOrWhiteSpace(supportEmail)
        ? T.T("CommonMissingBadge")
        : supportEmail;
    string DependencyStatusLabel(bool configured, string configuredLabel, string missingLabel) => configured
        ? T.T(configuredLabel)
        : T.T(missingLabel);
    string CommunicationHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string CommunicationHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    var transportAttentionCount =
        (Model.Transport.EmailTransportConfigured ? 0 : 1)
        + (Model.Transport.SmsTransportConfigured ? 0 : 1)
        + (Model.Transport.WhatsAppTransportConfigured ? 0 : 1)
        + (Model.Transport.AdminAlertRoutingConfigured ? 0 : 1);
    var setupGapCount = Model.Summary.BusinessesRequiringEmailSetupCount
        + Model.Summary.MissingSupportEmailCount
        + Model.Summary.MissingSenderIdentityCount;
    var communicationPolicyAttentionCount = transportAttentionCount + setupGapCount;
    var emailEscalationCount = Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp)
        + Model.RecentEmailAudits.Count(x => x.PriorFailureCount > 0 && x.NeedsOperatorFollowUp);
    var emailRetryBlockedCount = Model.RecentEmailAudits.Count(x => !x.CanRetryNow && !string.IsNullOrWhiteSpace(x.RetryPolicyState));
    var emailChainFollowUpCount = Model.RecentEmailAudits.Count(x => x.NeedsOperatorFollowUp || x.PriorFailureCount > 0 || x.RecentAttemptCount24h > 1);
    var failedInvitationAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase));
    var failedActivationAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase));
    var failedAdminTestAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase));
    var failedPasswordResetAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && string.Equals(x.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase));
    var communicationRuntimeExecutionAttentionCount = Model.RecentEmailAudits.Count(x =>
        string.Equals(x.Status, "Failed", StringComparison.OrdinalIgnoreCase)
        && (string.Equals(x.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase)));
    var brevoProviderAttentionCount = Model.ProviderCallbackSummary.BrevoFailedCount
        + Model.ProviderCallbackSummary.BrevoStalePendingCount
        + Model.ProviderCallbackSummary.BrevoDeliveryFailureEventCount;
    var channelEscalationCount = Model.ChannelAuditSummary.FailedCount + Model.ChannelAuditSummary.PhoneVerificationCount;
    var channelActionBlockedCount = Model.ChannelAuditSummary.ActionBlockedCount;
    var channelEscalationFollowUpCount = Model.ChannelAuditSummary.EscalationCandidateCount + Model.ChannelAuditSummary.RepeatedFailureCount;
}

<div id="business-communications-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-circle-check me-2"></i>@T.T("CommunicationOpsTitle")</h1>
        <p class="text-muted mb-0">@T.T("CommunicationOpsIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ChannelAudits" class="btn btn-outline-secondary"
                           hx-get="@GlobalChannelAuditsUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SmsWhatsAppAudits")</a>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary"
           hx-get="@GlobalEmailAuditsUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("EmailAudits")</a>
        <a asp-action="TemplatePreviews" class="btn btn-outline-secondary"
           hx-get="@GlobalTemplatePreviewsUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommunicationTemplatePreviewsTitle")</a>
        <a asp-action="ProviderCallbacks" class="btn btn-outline-secondary"
           hx-get="@GlobalProviderCallbacksUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("ProviderCallbackInboxTitle")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-outline-secondary"
           hx-get="@SiteSettingsUrl("site-settings-smtp")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("SMTP")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-outline-secondary"
           hx-get="@SiteSettingsUrl("site-settings-sms")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@ChannelLabel("SMS")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-outline-secondary"
           hx-get="@SiteSettingsUrl("site-settings-whatsapp")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@ChannelLabel("WhatsApp")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-outline-secondary"
           hx-get="@SiteSettingsUrl("site-settings-admin-routing")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("AdminAlerts")</a>
        @if (Model.Transport.CanSendTestEmail)
        {
            <form asp-action="SendTestEmail" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestEmail")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestSms)
        {
            <form asp-action="SendTestSms" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestSms")</button>
            </form>
        }
        @if (Model.Transport.CanSendTestWhatsApp)
        {
            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                  hx-target="#business-communications-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">@T.T("SendTestWhatsApp")</button>
            </form>
        }
</div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("CommunicationOpsTitle")</h2>
                <p class="text-muted mb-0">@T.T("BusinessSetupCommunicationsDependencyNote")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@GlobalBusinessSupportQueueUrl()"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-communications-policy"
                   class="btn btn-sm btn-outline-primary"
                       hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenPolicyAction")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("CommunicationPolicy")</div>
                        <span class="@CommunicationHealthBadgeClass(communicationPolicyAttentionCount == 0)">@CommunicationHealthBadgeText(communicationPolicyAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@communicationPolicyAttentionCount</div>
                    <div class="small text-muted">@T.T("CommunicationOpsIntro")</div>
                    <div class="small text-muted">@T.T("BusinessCommunicationNeedsSetupOnlyLabel"): <strong>@setupGapCount</strong></div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-smtp"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@SiteSettingsUrl("site-settings-smtp")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("SMTP")</a>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-sms"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@SiteSettingsUrl("site-settings-sms")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@ChannelLabel("SMS")</a>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-whatsapp"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@SiteSettingsUrl("site-settings-whatsapp")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@ChannelLabel("WhatsApp")</a>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-communications-policy"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenPolicyAction")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("BusinessCommunicationNeedsSetupOnlyLabel")</div>
                        <span class="@CommunicationHealthBadgeClass(setupGapCount == 0)">@CommunicationHealthBadgeText(setupGapCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@setupGapCount</div>
                    <div class="small text-muted">@string.Format("{0} | {1} | {2}", Model.Summary.BusinessesRequiringEmailSetupCount, Model.Summary.MissingSupportEmailCount, Model.Summary.MissingSenderIdentityCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Index"
                           asp-route-setupOnly="true"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessCommunicationsSetupUrl()"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessCommunicationNeedsSetupOnlyLabel")</a>
                        <a asp-controller="Businesses"
                           asp-action="SupportQueue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalBusinessSupportQueueUrl()"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("SupportQueue")</a>
                        <a asp-controller="Businesses"
                           asp-action="MerchantReadiness"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalMerchantReadinessUrl()"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("EmailAudits")</div>
                        <span class="@CommunicationHealthBadgeClass(emailEscalationCount == 0 && communicationRuntimeExecutionAttentionCount == 0)">@CommunicationHealthBadgeText(emailEscalationCount == 0 && communicationRuntimeExecutionAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@(emailEscalationCount + communicationRuntimeExecutionAttentionCount)</div>
                    <div class="small text-muted">@T.T("CommunicationRepeatedFailureChainsNote")</div>
                    <div class="small text-muted">@T.T("Communications"): <strong>@emailRetryBlockedCount</strong></div>
                    <div class="small text-muted">@T.T("CommunicationTemplateInventoryTitle"): <strong>@emailChainFollowUpCount</strong></div>
                    <div class="small text-muted">@T.T("RuntimeExecution"): <strong>@communicationRuntimeExecutionAttentionCount</strong> (@T.T("OpenFailedInvitationEmails"): @failedInvitationAttentionCount / @T.T("UsersFilterUnconfirmed") / @T.T("OpenFailedActivationEmails"): @failedActivationAttentionCount / @T.T("FailedAdminTests"): @failedAdminTestAttentionCount / @T.T("OpenFailedPasswordResets"): @failedPasswordResetAttentionCount)</div>
                    <div class="small text-muted">@T.T("BrevoProviderCallbacks"): <strong>@brevoProviderAttentionCount</strong> (@T.T("Pending"): @Model.ProviderCallbackSummary.BrevoPendingCount / @T.T("Failed"): @Model.ProviderCallbackSummary.BrevoFailedCount / @T.T("BrevoDeliveryFailureEvents"): @Model.ProviderCallbackSummary.BrevoDeliveryFailureEventCount / @T.T("Recent24Hours"): @Model.ProviderCallbackSummary.BrevoRecent24HourCount)</div>
                    <div class="small text-muted">@T.T("RetryBlocked"): <strong>@emailRetryBlockedCount</strong></div>
                    <div class="small text-muted">@T.T("HeavyChains"): <strong>@emailChainFollowUpCount</strong></div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="Businesses"
                           asp-action="Invitations"
                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@PendingInvitationsUrl()"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Pending")</a>
                        <a asp-action="EmailAudits"
                           asp-route-flowKey="BusinessInvitation"
                           asp-route-status="Failed"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsFlowUrl("BusinessInvitation", "Failed")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
                        <a asp-controller="Users"
                           asp-action="Index"
                           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed)"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                        <a asp-controller="Users"
                           asp-action="Index"
                           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("UsersFilterLocked")</a>
                        <a asp-action="EmailAudits"
                           asp-route-flowKey="AccountActivation"
                           asp-route-status="Failed"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsFlowUrl("AccountActivation", "Failed")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                        <a asp-action="EmailAudits"
                           asp-route-flowKey="AdminCommunicationTest"
                           asp-route-status="Failed"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsFlowUrl("AdminCommunicationTest", "Failed")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FailedAdminTests")</a>
                        <a asp-action="EmailAudits"
                           asp-route-flowKey="PasswordReset"
                           asp-route-status="Failed"
                           class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsFlowUrl("PasswordReset", "Failed")"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                        <a asp-action="EmailAudits"
                           asp-route-retryReadyOnly="true"
                           class="btn btn-sm btn-outline-success"
                       hx-get="@EmailAuditsRetryReadyUrl()"
                            hx-target="#business-communications-workspace-shell"
                            hx-swap="outerHTML"
                            hx-push-url="true">@T.T("RetryReady")</a>
                        <a asp-action="ProviderCallbacks"
                           asp-route-provider="Brevo"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@BrevoProviderCallbacksUrl()"
