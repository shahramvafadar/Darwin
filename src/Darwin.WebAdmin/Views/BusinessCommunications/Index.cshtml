<div class="card mb-4">
        <div class="card-header">@T.T("RecentSmsWhatsAppActivity")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("ChannelAuditBaselineNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("WhenUtc")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("Flow")</th>
                        <th>@T.T("Recipient")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Preview")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentChannelAudits.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">@T.T("NoSmsWhatsAppActivityYet")</td></tr>
                }
                else
                {
                    foreach (var item in Model.RecentChannelAudits)
                    {
                        <tr>
                            <td>@item.AttemptedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                            <td><span class="badge text-bg-light">@ChannelLabel(item.Channel)</span> <span class="small text-muted">@item.Provider</span></td>
                            <td>@FlowLabel(item.FlowKey)</td>
                            <td>@item.RecipientAddress</td>
                            <td>
                                @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@DeliveryStatusLabel("Sent")</span>
                                }
                                else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@DeliveryStatusLabel("Failed")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@DeliveryStatusLabel(item.Status)</span>
                                }
                            </td>
                            <td>
                                <div class="small">@item.MessagePreview</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-1">@item.FailureMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="mt-3">
            <a asp-action="ChannelAudits" class="btn btn-sm btn-outline-primary"
                           hx-get="@GlobalChannelAuditsUrl()"
               hx-target="#business-communications-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessCommunicationOpenFullChannelAuditLogAction")</a>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("BusinessCommunicationLiveChannelFamiliesTitle")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("BusinessCommunicationLiveChannelFamiliesNote")
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("BusinessCommunicationFamilyColumn")</th>
                        <th>@T.T("Channel")</th>
                        <th>@T.T("BusinessCommunicationCurrentTemplateColumn")</th>
                        <th>@T.T("BusinessCommunicationRenderedPreviewColumn")</th>
                        <th>@T.T("BusinessCommunicationTokensColumn")</th>
                        <th>@T.T("BusinessCommunicationTargetPolicyColumn")</th>
                        <th>@T.T("BusinessCommunicationUsageGuidanceColumn")</th>
                        <th>@T.T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ChannelTemplateFamilies.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">@T.T("BusinessCommunicationNoLiveChannelFamilies")</td></tr>
                }
                else
                {
                    foreach (var family in Model.ChannelTemplateFamilies)
                    {
                        <tr>
                            <td class="fw-semibold">@family.FamilyName</td>
                            <td><span class="badge text-bg-light">@ChannelLabel(family.Channel)</span></td>
                            <td><div class="small">@family.CurrentTemplate</div></td>
                            <td><div class="small text-body-secondary">@family.ExamplePreview</div></td>
                            <td><code>@family.SupportedTokens</code></td>
                            <td>
                                <div class="small">@family.TargetSurface</div>
                                <div class="small text-muted mt-1">@family.PolicyNote</div>
                            </td>
                            <td>
                                <div class="small">@family.SafeUsageNote</div>
                                <div class="small text-muted mt-1">@family.RolloutBoundary</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="@family.ActionFragment"
                                       class="btn btn-sm btn-outline-secondary"
                                           hx-get="@SiteSettingsUrl(family.ActionFragment)"
                                       hx-target="#business-communications-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@family.ActionLabel</a>
                                    @if (string.Equals(family.FamilyKey, "PhoneVerification", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-phoneVerificationOnly="true"
                                           asp-route-channel="@family.ChannelValue"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@ChannelAuditsPhoneVerificationByChannelUrl(family.ChannelValue)"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenVerificationAuditsAction")</a>
                                        <a asp-controller="MobileOperations"
                                           asp-action="Index"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@GlobalMobileOperationsUrl()"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                        <a asp-controller="Users"
                                           asp-action="Index"
                                           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked)"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("UsersFilterMobileLinked")</a>
                                    }
                                    else if (string.Equals(family.FamilyKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="ChannelAudits"
                                           asp-route-adminTestOnly="true"
                                           asp-route-channel="@family.ChannelValue"
                                           class="btn btn-sm btn-outline-dark"
                                           hx-get="@ChannelAuditsAdminTestByChannelUrl(family.ChannelValue)"
                                           hx-target="#business-communications-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("BusinessCommunicationOpenTestAuditsAction")</a>
                                        @if (string.Equals(family.ChannelValue, "SMS", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestSms)
                                        {
                                            <form asp-action="SendTestSms" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunSmsTestAction")</button>
                                            </form>
                                        }
                                        else if (string.Equals(family.ChannelValue, "WhatsApp", StringComparison.OrdinalIgnoreCase) && Model.Transport.CanSendTestWhatsApp)
                                        {
                                            <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                                                  hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                                                  hx-target="#business-communications-workspace-shell"
                                                  hx-swap="outerHTML">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunWhatsAppTestAction")</button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

