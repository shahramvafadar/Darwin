<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "BusinessCommunications")"
      hx-target="#business-communications-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessCommunicationSearchPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check mt-2">
            <input type="checkbox" name="setupOnly" value="true" class="form-check-input" id="setupOnly" checked="@(Model.SetupOnly ? "checked" : null)" />
            <label class="form-check-label" for="setupOnly">@T.T("BusinessCommunicationNeedsSetupOnlyLabel")</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Business")</th>
                <th>@T.T("BusinessCommunicationSupportEmailColumn")</th>
                <th>@T.T("BusinessCommunicationSenderIdentityColumn")</th>
                <th>@T.T("BusinessCommunicationEnabledPoliciesColumn")</th>
                <th>@T.T("BusinessCommunicationGapsColumn")</th>
                <th class="text-end" style="width:220px">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">@T.T("BusinessCommunicationEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        @if (!string.IsNullOrWhiteSpace(item.LegalName))
                        {
                            <div class="small text-muted">@item.LegalName</div>
                        }
                    </td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.SupportEmail))
                        {
                            <span class="badge text-bg-warning">Missing</span>
                        }
                        else
                        {
                            <span>@item.SupportEmail</span>
                        }
                    </td>
                    <td>
                        <div>@(string.IsNullOrWhiteSpace(item.CommunicationSenderName) ? "Missing sender name" : item.CommunicationSenderName)</div>
                        <div class="small text-muted">@(string.IsNullOrWhiteSpace(item.CommunicationReplyToEmail) ? "Missing reply-to" : item.CommunicationReplyToEmail)</div>
                    </td>
                    <td>
                        @if (item.CustomerEmailNotificationsEnabled)
                        {
                            <span class="badge text-bg-primary">Transactional</span>
                        }
                        @if (item.CustomerMarketingEmailsEnabled)
                        {
                            <span class="badge text-bg-info">Marketing</span>
                        }
                        @if (item.OperationalAlertEmailsEnabled)
                        {
                            <span class="badge text-bg-secondary">Alerts</span>
                        }
                    </td>
                    <td>
                        @if (item.MissingSupportEmail)
                        {
                            <div class="small text-muted">Support email missing</div>
                        }
                        @if (item.MissingSenderIdentity)
                        {
                            <div class="small text-muted">Sender identity incomplete</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-businessId="@item.Id" class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-circle-info"></i> Inspect
                        </a>
                        <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("Setup", "Businesses", new { id = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-sliders"></i> Open Setup
                        </a>
                        <a asp-controller="Businesses" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                           hx-target="#business-communications-workspace-shell"
                           hx-swap="outerHTML">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-setupOnly="@Model.SetupOnly"
       asp-route-filter="@Model.Filter"
       hx-target="#business-communications-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
