@model Darwin.WebAdmin.ViewModels.Businesses.ChannelDispatchAuditsListVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@using Darwin.Application.Businesses.Queries
@{
    ViewData["Title"] = T.T("SmsWhatsAppAuditsTitle");
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string GlobalChannelAuditsUrl() => Url.Action("ChannelAudits", "BusinessCommunications") ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string SiteSettingsUrl(string? fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string SettingsActionUrl(string? controller, string? fragment) => Url.Action("Edit", controller, new { fragment }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string UsersQueueUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter, string? query = null) => Url.Action("Index", "Users", new { filter, query }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter) => Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string CommunicationDetailsUrl(Guid? businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string ChannelAuditsUrl(
        string? query = null,
        string? recipientAddress = null,
        string? channel = null,
        string? flowKey = null,
        string? status = null,
        bool? failedOnly = null,
        bool? phoneVerificationOnly = null,
        bool? adminTestOnly = null,
        bool? repeatedFailuresOnly = null,
        bool? priorSuccessOnly = null,
        bool? actionReadyOnly = null,
        bool? actionBlockedOnly = null,
        bool? escalationCandidatesOnly = null,
        bool? heavyChainsOnly = null,
        bool? providerReviewOnly = null,
        string? provider = null,
        bool? chainFollowUpOnly = null,
        bool? chainResolvedOnly = null,
        Guid? businessId = null) => Url.Action("ChannelAudits", "BusinessCommunications", new
        {
            query,
            recipientAddress,
            channel,
            flowKey,
            status,
            failedOnly,
            phoneVerificationOnly,
            adminTestOnly,
            repeatedFailuresOnly,
            priorSuccessOnly,
            actionReadyOnly,
            actionBlockedOnly,
            escalationCandidatesOnly,
            heavyChainsOnly,
            providerReviewOnly,
            provider,
            chainFollowUpOnly,
            chainResolvedOnly,
            businessId
        }) ?? string.Empty;

    string FlowLabel(string? flowKey) => flowKey switch
    {
        ChannelDispatchAuditVocabulary.FlowKeys.PhoneVerification => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        ChannelDispatchAuditVocabulary.FlowKeys.AdminCommunicationTest => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string ProviderPressureLabel(string? pressureState) => pressureState switch
    {
        ChannelDispatchAuditVocabulary.PressureStates.Elevated => T.T("CommunicationProviderPressureElevated"),
        ChannelDispatchAuditVocabulary.PressureStates.Recovering => T.T("CommunicationProviderPressureRecovering"),
        ChannelDispatchAuditVocabulary.PressureStates.Stable => T.T("CommunicationProviderPressureStable"),
        _ => string.IsNullOrWhiteSpace(pressureState) ? T.T("CommonUnclassified") : T.T(pressureState)
    };

    string ProviderRecoveryLabel(string? recoveryState) => recoveryState switch
    {
        ChannelDispatchAuditVocabulary.RecoveryStates.Recovered => T.T("CommunicationProviderRecoveryRecovered"),
        ChannelDispatchAuditVocabulary.RecoveryStates.StableSuccess => T.T("CommunicationProviderRecoveryStableSuccess"),
        ChannelDispatchAuditVocabulary.RecoveryStates.NoneYet => T.T("CommunicationProviderRecoveryNoneYet"),
        _ => string.IsNullOrWhiteSpace(recoveryState) ? T.T("CommonUnclassified") : T.T(recoveryState)
    };

    string ChainStatusMixLabel(string? statusMix) => statusMix switch
    {
        ChannelDispatchAuditVocabulary.ChainStatusMixes.Mixed => T.T("CommunicationChainStatusMixed"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.OpenFailure => T.T("CommunicationChainStatusOpenFailure"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.FailureOnly => T.T("CommunicationChainStatusFailureOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.PendingOnly => T.T("CommunicationChainStatusPendingOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.SuccessOnly => T.T("CommunicationChainStatusSuccessOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.SingleAttempt => T.T("CommunicationChainStatusSingleAttempt"),
        _ => string.IsNullOrWhiteSpace(statusMix) ? T.T("CommonUnclassified") : T.T(statusMix)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string QueueStateLabel(Darwin.WebAdmin.ViewModels.Businesses.ChannelDispatchAuditListItemVm item) =>
        string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase)
            ? T.T("CommunicationChannelWorkerFailed")
            : T.T("CommunicationChannelAwaitingWorker");

    string ChannelLabel(string? channel) => channel switch
    {
        "SMS" => T.T("BusinessCommunicationSmsShort"),
        "WhatsApp" => T.T("BusinessCommunicationWhatsAppShort"),
        "Email" => T.T("CommunicationBuiltInFlowEmailChannel"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };

    string LogicalRecipientAddress(Darwin.WebAdmin.ViewModels.Businesses.ChannelDispatchAuditListItemVm item) =>
        string.IsNullOrWhiteSpace(item.IntendedRecipientAddress) ? item.RecipientAddress : item.IntendedRecipientAddress!;

    bool HasRecipientOverride(Darwin.WebAdmin.ViewModels.Businesses.ChannelDispatchAuditListItemVm item) =>
        !string.IsNullOrWhiteSpace(item.IntendedRecipientAddress) &&
        !string.Equals(item.IntendedRecipientAddress, item.RecipientAddress, StringComparison.OrdinalIgnoreCase);
    string ChannelAuditHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string ChannelAuditHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    var actionBacklogCount = Model.Summary.ActionReadyCount + Model.Summary.ActionBlockedCount;
    var escalationBacklogCount = Model.Summary.EscalationCandidateCount + Model.Summary.RepeatedFailureCount;
    var providerLaneCount = Model.Summary.ProviderReviewCount + Model.Summary.ProviderRecoveredCount;
    var chainAttentionCount = Model.Summary.HeavyChainCount + Model.Summary.PendingCount;
    var exactChainActive = !string.IsNullOrWhiteSpace(Model.RecipientAddress);
    var providerReviewActive = !string.IsNullOrWhiteSpace(Model.Provider);
}

<div id="business-communication-channel-audits-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-message me-2"></i>@T.T("SmsWhatsAppAuditsTitle")</h1>
        <p class="text-muted mb-0">@T.T("NonEmailDeliveryHistory")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
                           hx-get="@GlobalBusinessCommunicationsUrl()"
           hx-target="#business-communication-channel-audits-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
</div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("SmsWhatsAppAuditsTitle")</h2>
                <p class="text-muted mb-0">@T.T("NonEmailDeliveryHistory")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
                   hx-target="#business-communication-channel-audits-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-communications-policy"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                   hx-target="#business-communication-channel-audits-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenPolicyAction")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("ActionReady")</div>
                        <span class="@ChannelAuditHealthBadgeClass(Model.Summary.ActionReadyCount == 0)">@ChannelAuditHealthBadgeText(Model.Summary.ActionReadyCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@actionBacklogCount</div>
                    <div class="small text-muted">@string.Format("{0} / {1}", Model.Summary.ActionReadyCount, Model.Summary.ActionBlockedCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="ChannelAudits"
                           asp-route-actionReadyOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-success"
                           hx-get="@ChannelAuditsUrl(actionReadyOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ActionReady")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-actionBlockedOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@ChannelAuditsUrl(actionBlockedOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ActionBlocked")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("EscalationCandidates")</div>
                        <span class="@ChannelAuditHealthBadgeClass(escalationBacklogCount == 0)">@ChannelAuditHealthBadgeText(escalationBacklogCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@escalationBacklogCount</div>
                    <div class="small text-muted">@T.T("HeavyChains")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="ChannelAudits"
                           asp-route-escalationCandidatesOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@ChannelAuditsUrl(escalationCandidatesOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("EscalationCandidates")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-repeatedFailuresOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ChannelAuditsUrl(repeatedFailuresOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RepeatedFailures")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("ProviderReview")</div>
                        <span class="@ChannelAuditHealthBadgeClass(providerLaneCount == 0)">@ChannelAuditHealthBadgeText(providerLaneCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@providerLaneCount</div>
                    <div class="small text-muted">@(providerReviewActive ? Model.Provider : T.T("LeaveProviderReview"))</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="ChannelAudits"
                           asp-route-providerReviewOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@ChannelAuditsUrl(providerReviewOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ProviderReview")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-priorSuccessOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@ChannelAuditsUrl(priorSuccessOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PriorSuccessContext")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("ExactChainMode")</div>
                        <span class="@ChannelAuditHealthBadgeClass(!exactChainActive)">@ChannelAuditHealthBadgeText(!exactChainActive)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@chainAttentionCount</div>
                    <div class="small text-muted">@(exactChainActive ? Model.RecipientAddress : T.T("LeaveExactChain"))</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="ChannelAudits"
                           asp-route-heavyChainsOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ChannelAuditsUrl(heavyChainsOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("HeavyChains")</a>
                        <a asp-action="ChannelAudits"
                           asp-route-recipientAddress="@Model.RecipientAddress"
                           asp-route-flowKey="@Model.FlowKey"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ChannelAuditsUrl(recipientAddress: Model.RecipientAddress, flowKey: Model.FlowKey, businessId: Model.BusinessId)"
                           hx-target="#business-communication-channel-audits-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("WholeChain")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="ChannelAudits" asp-route-failedOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-danger"
       hx-get="@ChannelAuditsUrl(failedOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("FailedOnly")</a>
    <a asp-action="ChannelAudits" asp-route-phoneVerificationOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
       hx-get="@ChannelAuditsUrl(phoneVerificationOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("PhoneVerification")</a>
    <a asp-action="ChannelAudits" asp-route-adminTestOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@ChannelAuditsUrl(adminTestOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("AdminTests")</a>
    <a asp-action="ChannelAudits" asp-route-repeatedFailuresOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-warning"
       hx-get="@ChannelAuditsUrl(repeatedFailuresOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("RepeatedFailures")</a>
    <a asp-action="ChannelAudits" asp-route-priorSuccessOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-info"
       hx-get="@ChannelAuditsUrl(priorSuccessOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("PriorSuccessContext")</a>
    <a asp-action="ChannelAudits" asp-route-actionReadyOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-success"
       hx-get="@ChannelAuditsUrl(actionReadyOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ActionReady")</a>
    <a asp-action="ChannelAudits" asp-route-actionBlockedOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-dark"
       hx-get="@ChannelAuditsUrl(actionBlockedOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ActionBlocked")</a>
    <a asp-action="ChannelAudits" asp-route-escalationCandidatesOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-danger"
       hx-get="@ChannelAuditsUrl(escalationCandidatesOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("EscalationCandidates")</a>
    <a asp-action="ChannelAudits" asp-route-heavyChainsOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-warning"
       hx-get="@ChannelAuditsUrl(heavyChainsOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("HeavyChains")</a>
    <a asp-action="ChannelAudits" asp-route-providerReviewOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-info"
       hx-get="@ChannelAuditsUrl(providerReviewOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ProviderReview")</a>
    <a asp-action="ChannelAudits" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-dark"
       hx-get="@ChannelAuditsUrl(businessId: Model.BusinessId)"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Reset")</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Provider))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>@T.T("ProviderReviewMode"):</strong> @T.T("ShowingProviderLaneFor") <code>@Model.Provider</code>
            @if (!string.IsNullOrWhiteSpace(Model.Channel))
            {
                <span> @T.T("OnChannel") <code>@ChannelLabel(Model.Channel)</code></span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.FlowKey))
            {
                <span> @T.T("InFlow") <code>@FlowLabel(Model.FlowKey)</code></span>
            }
        </div>
        <a asp-action="ChannelAudits"
           asp-route-query="@Model.Query"
           asp-route-recipientAddress="@Model.RecipientAddress"
           asp-route-channel="@Model.Channel"
           asp-route-flowKey="@Model.FlowKey"
           asp-route-status="@Model.Status"
           asp-route-failedOnly="@Model.FailedOnly"
           asp-route-phoneVerificationOnly="@Model.PhoneVerificationOnly"
           asp-route-adminTestOnly="@Model.AdminTestOnly"
           asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
           asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
           asp-route-actionReadyOnly="@Model.ActionReadyOnly"
           asp-route-actionBlockedOnly="@Model.ActionBlockedOnly"
           asp-route-escalationCandidatesOnly="@Model.EscalationCandidatesOnly"
           asp-route-heavyChainsOnly="@Model.HeavyChainsOnly"
           asp-route-providerReviewOnly="@Model.ProviderReviewOnly"
           asp-route-provider=""
           asp-route-chainFollowUpOnly="@Model.ChainFollowUpOnly"
           asp-route-chainResolvedOnly="@Model.ChainResolvedOnly"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
               hx-get="@ChannelAuditsUrl(query: Model.Query, recipientAddress: Model.RecipientAddress, channel: Model.Channel, flowKey: Model.FlowKey, status: Model.Status, failedOnly: Model.FailedOnly, phoneVerificationOnly: Model.PhoneVerificationOnly, adminTestOnly: Model.AdminTestOnly, repeatedFailuresOnly: Model.RepeatedFailuresOnly, priorSuccessOnly: Model.PriorSuccessOnly, actionReadyOnly: Model.ActionReadyOnly, actionBlockedOnly: Model.ActionBlockedOnly, escalationCandidatesOnly: Model.EscalationCandidatesOnly, heavyChainsOnly: Model.HeavyChainsOnly, providerReviewOnly: Model.ProviderReviewOnly, provider: string.Empty, chainFollowUpOnly: Model.ChainFollowUpOnly, chainResolvedOnly: Model.ChainResolvedOnly, businessId: Model.BusinessId)"
           hx-target="#business-communication-channel-audits-shell"
           hx-swap="outerHTML">@T.T("LeaveProviderReview")</a>
    </div>

    @if (Model.ProviderSummary is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Attempts24h")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.RecentAttemptCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Failed")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.FailureCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Sent")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.SentCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Pending")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.PendingCount24h</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PressureState")</div>
                    <div class="fw-semibold mt-1">@ProviderPressureLabel(Model.ProviderSummary.PressureState)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RecoveryState")</div>
                    <div class="fw-semibold mt-1">@ProviderRecoveryLabel(Model.ProviderSummary.RecoveryState)</div>
                    @if (Model.ProviderSummary.LastSuccessfulAttemptAtUtc.HasValue)
                    {
                        <div class="small text-muted mt-2">@string.Format(T.T("CommonLastSuccessAtUtc"), Model.ProviderSummary.LastSuccessfulAttemptAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                    }
                </div>
            </div>
        </div>
        <div class="alert alert-secondary mb-4">
            <div class="small text-muted">@T.T("RecommendedNextStep")</div>
            <div class="fw-semibold">@Model.ProviderSummary.RecommendedAction</div>
            <div class="mt-2">
