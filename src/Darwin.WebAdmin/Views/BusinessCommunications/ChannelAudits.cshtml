@model Darwin.WebAdmin.ViewModels.Businesses.ChannelDispatchAuditsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@using Darwin.Application.Businesses.Queries
@{
    ViewData["Title"] = T.T("SmsWhatsAppAuditsTitle");

    string FlowLabel(string? flowKey) => flowKey switch
    {
        ChannelDispatchAuditVocabulary.FlowKeys.PhoneVerification => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        ChannelDispatchAuditVocabulary.FlowKeys.AdminCommunicationTest => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string ProviderPressureLabel(string? pressureState) => pressureState switch
    {
        ChannelDispatchAuditVocabulary.PressureStates.Elevated => T.T("CommunicationProviderPressureElevated"),
        ChannelDispatchAuditVocabulary.PressureStates.Recovering => T.T("CommunicationProviderPressureRecovering"),
        ChannelDispatchAuditVocabulary.PressureStates.Stable => T.T("CommunicationProviderPressureStable"),
        _ => string.IsNullOrWhiteSpace(pressureState) ? T.T("CommonUnclassified") : T.T(pressureState)
    };

    string ProviderRecoveryLabel(string? recoveryState) => recoveryState switch
    {
        ChannelDispatchAuditVocabulary.RecoveryStates.Recovered => T.T("CommunicationProviderRecoveryRecovered"),
        ChannelDispatchAuditVocabulary.RecoveryStates.StableSuccess => T.T("CommunicationProviderRecoveryStableSuccess"),
        ChannelDispatchAuditVocabulary.RecoveryStates.NoneYet => T.T("CommunicationProviderRecoveryNoneYet"),
        _ => string.IsNullOrWhiteSpace(recoveryState) ? T.T("CommonUnclassified") : T.T(recoveryState)
    };

    string ChainStatusMixLabel(string? statusMix) => statusMix switch
    {
        ChannelDispatchAuditVocabulary.ChainStatusMixes.Mixed => T.T("CommunicationChainStatusMixed"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.OpenFailure => T.T("CommunicationChainStatusOpenFailure"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.FailureOnly => T.T("CommunicationChainStatusFailureOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.PendingOnly => T.T("CommunicationChainStatusPendingOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.SuccessOnly => T.T("CommunicationChainStatusSuccessOnly"),
        ChannelDispatchAuditVocabulary.ChainStatusMixes.SingleAttempt => T.T("CommunicationChainStatusSingleAttempt"),
        _ => string.IsNullOrWhiteSpace(statusMix) ? T.T("CommonUnclassified") : T.T(statusMix)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string ChannelLabel(string? channel) => channel switch
    {
        "SMS" => T.T("BusinessCommunicationSmsShort"),
        "WhatsApp" => T.T("BusinessCommunicationWhatsAppShort"),
        "Email" => T.T("CommunicationBuiltInFlowEmailChannel"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };
}

<div id="business-communication-channel-audits-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-message me-2"></i>@T.T("SmsWhatsAppAuditsTitle")</h1>
        <p class="text-muted mb-0">@T.T("NonEmailDeliveryHistory")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communication-channel-audits-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="ChannelAudits" asp-route-failedOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-danger"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { failedOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("FailedOnly")</a>
    <a asp-action="ChannelAudits" asp-route-phoneVerificationOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("PhoneVerification")</a>
    <a asp-action="ChannelAudits" asp-route-adminTestOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { adminTestOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("AdminTests")</a>
    <a asp-action="ChannelAudits" asp-route-repeatedFailuresOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-warning"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { repeatedFailuresOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("RepeatedFailures")</a>
    <a asp-action="ChannelAudits" asp-route-priorSuccessOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-info"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { priorSuccessOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("PriorSuccessContext")</a>
    <a asp-action="ChannelAudits" asp-route-actionReadyOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-success"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { actionReadyOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ActionReady")</a>
    <a asp-action="ChannelAudits" asp-route-actionBlockedOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-dark"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { actionBlockedOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ActionBlocked")</a>
    <a asp-action="ChannelAudits" asp-route-escalationCandidatesOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-danger"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { escalationCandidatesOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("EscalationCandidates")</a>
    <a asp-action="ChannelAudits" asp-route-heavyChainsOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-warning"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { heavyChainsOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("HeavyChains")</a>
    <a asp-action="ChannelAudits" asp-route-providerReviewOnly="true" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-info"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { providerReviewOnly = true, businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ProviderReview")</a>
    <a asp-action="ChannelAudits" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-dark"
       hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.BusinessId })"
       hx-target="#business-communication-channel-audits-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Reset")</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Provider))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>@T.T("ProviderReviewMode"):</strong> @T.T("ShowingProviderLaneFor") <code>@Model.Provider</code>
            @if (!string.IsNullOrWhiteSpace(Model.Channel))
            {
                <span> @T.T("OnChannel") <code>@ChannelLabel(Model.Channel)</code></span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.FlowKey))
            {
                <span> @T.T("InFlow") <code>@FlowLabel(Model.FlowKey)</code></span>
            }
        </div>
        <a asp-action="ChannelAudits"
           asp-route-query="@Model.Query"
           asp-route-recipientAddress="@Model.RecipientAddress"
           asp-route-channel="@Model.Channel"
           asp-route-flowKey="@Model.FlowKey"
           asp-route-status="@Model.Status"
           asp-route-failedOnly="@Model.FailedOnly"
           asp-route-phoneVerificationOnly="@Model.PhoneVerificationOnly"
           asp-route-adminTestOnly="@Model.AdminTestOnly"
           asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
           asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
           asp-route-actionReadyOnly="@Model.ActionReadyOnly"
           asp-route-actionBlockedOnly="@Model.ActionBlockedOnly"
           asp-route-escalationCandidatesOnly="@Model.EscalationCandidatesOnly"
           asp-route-heavyChainsOnly="@Model.HeavyChainsOnly"
           asp-route-providerReviewOnly="@Model.ProviderReviewOnly"
           asp-route-provider=""
           asp-route-chainFollowUpOnly="@Model.ChainFollowUpOnly"
           asp-route-chainResolvedOnly="@Model.ChainResolvedOnly"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { query = Model.Query, recipientAddress = Model.RecipientAddress, channel = Model.Channel, flowKey = Model.FlowKey, status = Model.Status, failedOnly = Model.FailedOnly, phoneVerificationOnly = Model.PhoneVerificationOnly, adminTestOnly = Model.AdminTestOnly, repeatedFailuresOnly = Model.RepeatedFailuresOnly, priorSuccessOnly = Model.PriorSuccessOnly, actionReadyOnly = Model.ActionReadyOnly, actionBlockedOnly = Model.ActionBlockedOnly, escalationCandidatesOnly = Model.EscalationCandidatesOnly, heavyChainsOnly = Model.HeavyChainsOnly, providerReviewOnly = Model.ProviderReviewOnly, provider = string.Empty, chainFollowUpOnly = Model.ChainFollowUpOnly, chainResolvedOnly = Model.ChainResolvedOnly, businessId = Model.BusinessId })"
           hx-target="#business-communication-channel-audits-shell"
           hx-swap="outerHTML">@T.T("LeaveProviderReview")</a>
    </div>

    @if (Model.ProviderSummary is not null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Attempts24h")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.RecentAttemptCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Failed")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.FailureCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Sent")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.SentCount24h</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@DeliveryStatusLabel("Pending")</div>
                    <div class="fs-4 fw-semibold">@Model.ProviderSummary.PendingCount24h</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PressureState")</div>
                    <div class="fw-semibold mt-1">@ProviderPressureLabel(Model.ProviderSummary.PressureState)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RecoveryState")</div>
                    <div class="fw-semibold mt-1">@ProviderRecoveryLabel(Model.ProviderSummary.RecoveryState)</div>
                    @if (Model.ProviderSummary.LastSuccessfulAttemptAtUtc.HasValue)
                    {
                        <div class="small text-muted mt-2">@string.Format(T.T("CommonLastSuccessAtUtc"), Model.ProviderSummary.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm"))</div>
                    }
                </div>
            </div>
        </div>
        <div class="alert alert-secondary mb-4">
            <div class="small text-muted">@T.T("RecommendedNextStep")</div>
            <div class="fw-semibold">@Model.ProviderSummary.RecommendedAction</div>
            <div class="mt-2">
                <div class="small text-muted">@T.T("EscalationRule")</div>
                <div class="small">@Model.ProviderSummary.EscalationHint</div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
                @if (string.Equals(Model.FlowKey, "PhoneVerification", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                       hx-target="#business-communication-channel-audits-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenVerificationPolicy")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
                       hx-target="#business-communication-channel-audits-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("SmsSettings")</a>
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
                       hx-target="#business-communication-channel-audits-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("WhatsAppSettings")</a>
                }
                else if (string.Equals(Model.FlowKey, ChannelDispatchAuditVocabulary.FlowKeys.AdminCommunicationTest, StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                       hx-target="#business-communication-channel-audits-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("TestTargets")</a>
                        @if (string.Equals(Model.Channel, "SMS", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestSms)
                    {
                        <form asp-action="SendTestSms" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestSms", "BusinessCommunications")"
                              hx-target="#business-communication-channel-audits-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnToChannelAudits" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="provider" value="@Model.Provider" />
                            <input type="hidden" name="recipientAddress" value="@Model.RecipientAddress" />
                            <input type="hidden" name="channel" value="@Model.Channel" />
                            <input type="hidden" name="flowKey" value="@Model.FlowKey" />
                            <input type="hidden" name="status" value="@Model.Status" />
                            <input type="hidden" name="failedOnly" value="@Model.FailedOnly" />
                            <input type="hidden" name="phoneVerificationOnly" value="@Model.PhoneVerificationOnly" />
                            <input type="hidden" name="adminTestOnly" value="@Model.AdminTestOnly" />
                            <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
                            <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
                            <input type="hidden" name="actionReadyOnly" value="@Model.ActionReadyOnly" />
                            <input type="hidden" name="actionBlockedOnly" value="@Model.ActionBlockedOnly" />
                            <input type="hidden" name="escalationCandidatesOnly" value="@Model.EscalationCandidatesOnly" />
                            <input type="hidden" name="heavyChainsOnly" value="@Model.HeavyChainsOnly" />
                            <input type="hidden" name="providerReviewOnly" value="@Model.ProviderReviewOnly" />
                            <input type="hidden" name="chainFollowUpOnly" value="@Model.ChainFollowUpOnly" />
                            <input type="hidden" name="chainResolvedOnly" value="@Model.ChainResolvedOnly" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("RerunTestSms")</button>
                        </form>
                    }
                    @if (string.Equals(Model.Channel, "WhatsApp", StringComparison.OrdinalIgnoreCase) && Model.CanSendTestWhatsApp)
                    {
                        <form asp-action="SendTestWhatsApp" method="post" class="d-inline"
                              hx-post="@Url.Action("SendTestWhatsApp", "BusinessCommunications")"
                              hx-target="#business-communication-channel-audits-shell"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnToChannelAudits" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="provider" value="@Model.Provider" />
                            <input type="hidden" name="recipientAddress" value="@Model.RecipientAddress" />
                            <input type="hidden" name="channel" value="@Model.Channel" />
                            <input type="hidden" name="flowKey" value="@Model.FlowKey" />
                            <input type="hidden" name="status" value="@Model.Status" />
                            <input type="hidden" name="failedOnly" value="@Model.FailedOnly" />
                            <input type="hidden" name="phoneVerificationOnly" value="@Model.PhoneVerificationOnly" />
                            <input type="hidden" name="adminTestOnly" value="@Model.AdminTestOnly" />
                            <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
                            <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
                            <input type="hidden" name="actionReadyOnly" value="@Model.ActionReadyOnly" />
                            <input type="hidden" name="actionBlockedOnly" value="@Model.ActionBlockedOnly" />
                            <input type="hidden" name="escalationCandidatesOnly" value="@Model.EscalationCandidatesOnly" />
                            <input type="hidden" name="heavyChainsOnly" value="@Model.HeavyChainsOnly" />
                            <input type="hidden" name="providerReviewOnly" value="@Model.ProviderReviewOnly" />
                            <input type="hidden" name="chainFollowUpOnly" value="@Model.ChainFollowUpOnly" />
                            <input type="hidden" name="chainResolvedOnly" value="@Model.ChainResolvedOnly" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("RerunTestWhatsApp")</button>
                        </form>
                    }
                }
            </div>
        </div>
    }
}

@if (!string.IsNullOrWhiteSpace(Model.RecipientAddress))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>@T.T("ExactChainMode"):</strong> @T.T("ShowingDeliveryChainFor") <code>@Model.RecipientAddress</code>
            @if (!string.IsNullOrWhiteSpace(Model.FlowKey))
            {
                <span> @T.T("InFlow") <code>@FlowLabel(Model.FlowKey)</code></span>
            }
        </div>
        <a asp-action="ChannelAudits"
           asp-route-query="@Model.Query"
           asp-route-channel="@Model.Channel"
           asp-route-flowKey="@Model.FlowKey"
           asp-route-status="@Model.Status"
           asp-route-failedOnly="@Model.FailedOnly"
           asp-route-phoneVerificationOnly="@Model.PhoneVerificationOnly"
           asp-route-adminTestOnly="@Model.AdminTestOnly"
           asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
           asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
           asp-route-actionReadyOnly="@Model.ActionReadyOnly"
           asp-route-actionBlockedOnly="@Model.ActionBlockedOnly"
           asp-route-escalationCandidatesOnly="@Model.EscalationCandidatesOnly"
           asp-route-heavyChainsOnly="@Model.HeavyChainsOnly"
           asp-route-providerReviewOnly="@Model.ProviderReviewOnly"
           asp-route-chainFollowUpOnly="false"
           asp-route-chainResolvedOnly="false"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { query = Model.Query, channel = Model.Channel, flowKey = Model.FlowKey, status = Model.Status, failedOnly = Model.FailedOnly, phoneVerificationOnly = Model.PhoneVerificationOnly, adminTestOnly = Model.AdminTestOnly, repeatedFailuresOnly = Model.RepeatedFailuresOnly, priorSuccessOnly = Model.PriorSuccessOnly, actionReadyOnly = Model.ActionReadyOnly, actionBlockedOnly = Model.ActionBlockedOnly, escalationCandidatesOnly = Model.EscalationCandidatesOnly, heavyChainsOnly = Model.HeavyChainsOnly, providerReviewOnly = Model.ProviderReviewOnly, chainFollowUpOnly = false, chainResolvedOnly = false, businessId = Model.BusinessId })"
           hx-target="#business-communication-channel-audits-shell"
           hx-swap="outerHTML">@T.T("LeaveExactChain")</a>
    </div>

    @if (Model.ChainSummary is not null)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            <a asp-action="ChannelAudits"
               asp-route-recipientAddress="@Model.RecipientAddress"
               asp-route-flowKey="@Model.FlowKey"
               asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
               asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
               asp-route-actionReadyOnly="@Model.ActionReadyOnly"
               asp-route-actionBlockedOnly="@Model.ActionBlockedOnly"
               asp-route-escalationCandidatesOnly="@Model.EscalationCandidatesOnly"
               asp-route-heavyChainsOnly="@Model.HeavyChainsOnly"
               asp-route-providerReviewOnly="@Model.ProviderReviewOnly"
               asp-route-chainFollowUpOnly="false"
               asp-route-chainResolvedOnly="false"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm @((Model.ChainFollowUpOnly || Model.ChainResolvedOnly) ? "btn-outline-secondary" : "btn-dark")"
               hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { recipientAddress = Model.RecipientAddress, flowKey = Model.FlowKey, repeatedFailuresOnly = Model.RepeatedFailuresOnly, priorSuccessOnly = Model.PriorSuccessOnly, actionReadyOnly = Model.ActionReadyOnly, actionBlockedOnly = Model.ActionBlockedOnly, escalationCandidatesOnly = Model.EscalationCandidatesOnly, heavyChainsOnly = Model.HeavyChainsOnly, providerReviewOnly = Model.ProviderReviewOnly, chainFollowUpOnly = false, chainResolvedOnly = false, businessId = Model.BusinessId })"
               hx-target="#business-communication-channel-audits-shell"
               hx-swap="outerHTML">@T.T("ChannelAuditWholeChainAction")</a>
            <a asp-action="ChannelAudits"
               asp-route-recipientAddress="@Model.RecipientAddress"
               asp-route-flowKey="@Model.FlowKey"
               asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
               asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
               asp-route-actionReadyOnly="@Model.ActionReadyOnly"
               asp-route-actionBlockedOnly="@Model.ActionBlockedOnly"
               asp-route-escalationCandidatesOnly="@Model.EscalationCandidatesOnly"
               asp-route-heavyChainsOnly="@Model.HeavyChainsOnly"
               asp-route-providerReviewOnly="@Model.ProviderReviewOnly"
               asp-route-chainFollowUpOnly="true"
               asp-route-chainResolvedOnly="false"
               asp-route-businessId="@Model.BusinessId"
