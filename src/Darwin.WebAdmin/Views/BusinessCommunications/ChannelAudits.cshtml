<form method="get" class="row g-2 mb-3"
          hx-get="@GlobalChannelAuditsUrl()"
      hx-target="#business-communication-channel-audits-shell"
      hx-swap="outerHTML">
    <input type="hidden" name="businessId" value="@Model.BusinessId" />
    <input type="hidden" name="recipientAddress" value="@Model.RecipientAddress" />
    <input type="hidden" name="failedOnly" value="@Model.FailedOnly" />
    <input type="hidden" name="phoneVerificationOnly" value="@Model.PhoneVerificationOnly" />
    <input type="hidden" name="adminTestOnly" value="@Model.AdminTestOnly" />
    <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
    <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
    <input type="hidden" name="actionReadyOnly" value="@Model.ActionReadyOnly" />
    <input type="hidden" name="actionBlockedOnly" value="@Model.ActionBlockedOnly" />
    <input type="hidden" name="escalationCandidatesOnly" value="@Model.EscalationCandidatesOnly" />
    <input type="hidden" name="heavyChainsOnly" value="@Model.HeavyChainsOnly" />
    <input type="hidden" name="providerReviewOnly" value="@Model.ProviderReviewOnly" />
    <input type="hidden" name="chainFollowUpOnly" value="@Model.ChainFollowUpOnly" />
    <input type="hidden" name="chainResolvedOnly" value="@Model.ChainResolvedOnly" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("ChannelAuditsSearchPlaceholder")" />
    </div>
    <div class="col-md-2">
        <select name="provider" asp-items="Model.ProviderItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="channel" asp-items="Model.ChannelItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="flowKey" asp-items="Model.FlowItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">@T.T("Search")</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>@T.T("WhenUtc")</th>
                <th>@T.T("Channel")</th>
                <th>@T.T("Flow")</th>
                <th>@T.T("Recipient")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("ChannelAuditPreviewDetailsColumn")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">@T.T("ChannelAuditNoResults")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var needsActionBlockedFollowUp = !item.CanRerunNow && !string.IsNullOrWhiteSpace(item.ActionPolicyState);
                var needsChainFollowUp = item.NeedsOperatorFollowUp || item.PriorFailureCount > 0 || item.ChainAttemptCount > 1;
                var needsProviderLaneFollowUp = !item.IsQueueOperation && (item.NeedsEscalationReview || item.ProviderFailureCount24h > 0);
                var needsBusinessSupportFollowUp = item.BusinessId.HasValue && (item.NeedsOperatorFollowUp || item.NeedsEscalationReview);
                <tr>
                    <td>@item.AttemptedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                    <td><span class="badge text-bg-light">@ChannelLabel(item.Channel)</span> <span class="small text-muted">@item.Provider</span></td>
                    <td>@FlowLabel(item.FlowKey)</td>
                    <td>
                        <div>@LogicalRecipientAddress(item)</div>
                        @if (HasRecipientOverride(item))
                        {
                            <div class="small text-muted mt-1">@T.T("EffectiveRecipient"): <code>@item.RecipientAddress</code></div>
                        }
                    </td>
                    <td>
                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">@DeliveryStatusLabel("Sent")</span>
                        }
                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-danger">@DeliveryStatusLabel("Failed")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@DeliveryStatusLabel(item.Status)</span>
                        }
                    </td>
                    <td>
                        <div class="small">@item.MessagePreview</div>
                        @if (item.IsQueueOperation)
                        {
                            <div class="small text-muted mt-1">@T.T("CommunicationQueuedDispatchOperationLabel"): <code>@QueueStateLabel(item)</code></div>
                            <div class="small text-muted">@string.Format(T.T("CommunicationQueuedDispatchAttempts"), item.QueueAttemptCount)</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.TemplateKey))
                        {
                            <div class="small text-muted mt-1">@T.T("TemplateKey"): <code>@item.TemplateKey</code></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CorrelationKey))
                        {
                            <div class="small text-muted">@T.T("Correlation"): <code>@item.CorrelationKey</code></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ProviderMessageId))
                        {
                            <div class="small text-muted">@T.T("ProviderMessageId"): <code>@item.ProviderMessageId</code></div>
                        }
                        @if (item.PriorAttemptCount > 0 || item.LastSuccessfulAttemptAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">
                                @T.T("ChannelAuditChainContextLabel"):
                                @T.T("ChannelAuditTotalAttemptsInlineLabel") <code>@item.ChainAttemptCount</code>,
                                @T.T("ChannelAuditProfileInlineLabel") <code>@ChainStatusMixLabel(item.ChainStatusMix)</code>,
                                @T.T("ChannelAuditPriorAttemptsInlineLabel") <code>@item.PriorAttemptCount</code>,
                                @T.T("ChannelAuditPriorFailuresInlineLabel") <code>@item.PriorFailureCount</code>
                                @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                                {
                                    <span>, @T.T("ChannelAuditLastSuccessInlineLabel") <code>@item.LastSuccessfulAttemptAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</code></span>
                                }
                            </div>
                        }
                        @if (!item.IsQueueOperation)
                        {
                            <div class="small text-muted mt-1">
                                @T.T("ChannelAuditProviderLaneLabel"):
                                <code>@ProviderPressureLabel(item.ProviderPressureState)</code>,
                                @T.T("ChannelAuditRecoveryInlineLabel") <code>@ProviderRecoveryLabel(item.ProviderRecoveryState)</code>,
                                @T.T("ChannelAuditAttempts24hInlineLabel") <code>@item.ProviderRecentAttemptCount24h</code>,
                                @T.T("ChannelAuditFailures24hInlineLabel") <code>@item.ProviderFailureCount24h</code>
                                @if (item.ProviderLastSuccessfulAttemptAtUtc.HasValue)
                                {
                                    <span>, @T.T("ChannelAuditLastSuccessInlineLabel") <code>@item.ProviderLastSuccessfulAttemptAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</code></span>
                                }
                            </div>
                            <div class="small mt-1">
                                @if (item.CanRerunNow)
                                {
                                    <span class="badge text-bg-success">@item.ActionPolicyState</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.ActionPolicyState</span>
                                    @if (!string.IsNullOrWhiteSpace(item.ActionBlockedReason))
                                    {
                                        <span class="text-muted ms-1">@item.ActionBlockedReason</span>
                                    }
                                    @if (item.ActionAvailableAtUtc.HasValue)
                                    {
                                        <span class="text-muted ms-1">@string.Format(T.T("ChannelAuditAvailableAtUtc"), item.ActionAvailableAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</span>
                                    }
                                }
                            </div>
                            @if (item.NeedsEscalationReview)
                            {
                                <div class="small text-danger mt-1">
                                    <strong>@T.T("ChannelAuditEscalationCandidateLabel"):</strong> @item.EscalationReason
                                </div>
                            }
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                        }
                        else if (item.CompletedAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">@string.Format(T.T("CommunicationCompletedAt"), item.CompletedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                        }
                        @if (item.IsQueueOperation)
                        {
                            <div class="mt-2">
                                <form asp-action="CancelChannelDispatchOperation" method="post" class="d-inline"
                                      hx-post="@Url.Action("CancelChannelDispatchOperation", "BusinessCommunications")"
