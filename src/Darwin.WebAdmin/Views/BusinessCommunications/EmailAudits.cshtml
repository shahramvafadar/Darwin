            <code>@Model.ChainSummary.FirstAttemptAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture)</code>,
            @T.T("ChannelAuditLatestAttemptLabel")
            <code>@Model.ChainSummary.LastAttemptAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture)</code>
