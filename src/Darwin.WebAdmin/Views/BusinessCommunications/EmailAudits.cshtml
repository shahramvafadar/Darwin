<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>@T.T("WhenUtc")</th>
                <th>@T.T("Recipient")</th>
                <th>@T.T("Subject")</th>
                <th>@T.T("Flow")</th>
                <th>@T.T("Business")</th>
                <th>@T.T("Provider")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("EmailAuditsDeliveryContextColumn")</th>
                <th>@T.T("EmailAuditsOperatorResponseColumn")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted py-4">@T.T("EmailAuditsEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var needsRetryBlockedFollowUp = !item.CanRetryNow && !string.IsNullOrWhiteSpace(item.RetryPolicyState);
                var needsChainFollowUp = item.NeedsOperatorFollowUp || item.PriorFailureCount > 0 || item.RecentAttemptCount24h > 1;
                var needsBusinessSupportFollowUp = item.BusinessId.HasValue && (item.NeedsOperatorFollowUp || string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase));
                <tr>
                    <td>@item.AttemptedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                    <td>
                        <div>@LogicalRecipientEmail(item)</div>
                        @if (HasRecipientOverride(item))
                        {
                            <div class="small text-muted mt-1">@T.T("EffectiveRecipient"): <code>@item.RecipientEmail</code></div>
                        }
                    </td>
                    <td>@item.Subject</td>
                    <td>@FlowLabel(item.FlowKey)</td>
                    <td>
                        @if (item.BusinessId.HasValue)
                        {
                            <a asp-action="Details" asp-route-businessId="@item.BusinessId"
                               hx-get="@CommunicationDetailsUrl(item.BusinessId)"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">@BusinessDisplayName(item)</a>
                        }
                        else
                        {
                            <span class="text-muted">@T.T("NotApplicable")</span>
                        }
                    </td>
                    <td>@item.Provider</td>
                    <td>
                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">@DeliveryStatusLabel("Sent")</span>
                        }
                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-danger">@DeliveryStatusLabel("Failed")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@DeliveryStatusLabel(item.Status)</span>
                        }
                    </td>
                    <td>
                        <div class="small">
                            @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-danger">@T.T("CommonHighBadge")</span>
                            }
                            else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-warning">@T.T("CommonMediumBadge")</span>
                            }
                            else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-secondary">@T.T("CommonWatchBadge")</span>
                            }
                            else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-info">@T.T("CommonSlowBadge")</span>
                            }
                            else
                            {
                                <span class="badge text-bg-light">@T.T("CommonNormalBadge")</span>
                            }
                        </div>
                        <div class="small text-muted mt-1">@string.Format(T.T("CommonOpenForMinutes"), item.AttemptAgeMinutes)</div>
                        @if (item.CompletionLatencySeconds.HasValue)
                        {
                            <div class="small text-muted">@string.Format(T.T("CommonLatencySeconds"), item.CompletionLatencySeconds.Value)</div>
                        }
                        @if (item.NeedsOperatorFollowUp)
                        {
                            <div class="small text-danger mt-1">@T.T("CommonNeedsOperatorFollowUp")</div>
                        }
                        @if (item.PriorAttemptCount > 0)
                        {
                            <div class="small text-muted mt-1">@string.Format(T.T("CommonPriorAttemptsColon"), item.PriorAttemptCount)</div>
                        }
                        @if (item.PriorFailureCount > 0)
                        {
                            <div class="small text-muted">@string.Format(T.T("EmailAuditsPriorFailures"), item.PriorFailureCount)</div>
                        }
                        @if (item.RecentAttemptCount24h > 0)
                        {
                            <div class="small text-muted">@string.Format(T.T("EmailAuditsRecentChainAttempts24h"), item.RecentAttemptCount24h)</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ChainStatusMix))
                        {
                            <div class="small text-muted">@string.Format(T.T("EmailAuditsChainProfile"), ChainStatusMixLabel(item.ChainStatusMix))</div>
                        }
                        @if (item.ChainSpanHours.HasValue)
                        {
                            <div class="small text-muted">@string.Format(T.T("EmailAuditsChainSpanHours"), item.ChainSpanHours.Value)</div>
                        }
                        @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                        {
                            <div class="small text-muted">@string.Format(T.T("CommunicationLastSuccessAt"), item.LastSuccessfulAttemptAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.RetryPolicyState))
                        {
                            <div class="small mt-1">
                                @if (string.Equals(item.RetryPolicyState, "Ready", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">@T.T("EmailAuditsRetryReadyLabel")</span>
                                }
                                else if (string.Equals(item.RetryPolicyState, "Cooldown", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-warning">@T.T("EmailAuditsRetryCooldownLabel")</span>
                                }
                                else if (string.Equals(item.RetryPolicyState, "RateLimited", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">@T.T("EmailAuditsRetryRateLimitedLabel")</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@RetryPolicyStateLabel(item.RetryPolicyState)</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.TemplateKey))
                        {
                            <div class="small text-muted mt-1">@T.T("TemplateKey"): <code>@item.TemplateKey</code></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CorrelationKey))
                        {
                            <div class="small text-muted">@T.T("Correlation"): <code>@item.CorrelationKey</code></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ProviderMessageId))
                        {
                            <div class="small text-muted">@T.T("ProviderMessageId"): <code>@item.ProviderMessageId</code></div>
                            @if (string.Equals(item.Provider, "Brevo", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="small mt-1">
                                    <a asp-action="ProviderCallbacks"
                                       asp-route-query="@item.ProviderMessageId"
                                       asp-route-provider="Brevo"
                                       class="text-decoration-none"
                                       hx-get="@ProviderCallbacksUrl(item.ProviderMessageId, "Brevo")"
                                       hx-target="#business-communication-audits-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("BrevoWebhookEvents")</a>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.LatestProviderCallbackEvent))
                                {
                                    <div class="small text-muted mt-1">
                                        <span class="badge text-bg-info">@item.LatestProviderCallbackEvent</span>
                                        @if (item.LatestProviderCallbackOccurredAtUtc.HasValue)
                                        {
                                            <span>@string.Format(T.T("BrevoLatestWebhookAt"), item.LatestProviderCallbackOccurredAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(item.LatestProviderCallbackStatus))
                                        {
                                            <span>@string.Format(T.T("BrevoLatestWebhookStatus"), item.LatestProviderCallbackStatus)</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.LatestProviderCallbackReason))
                                    {
                                        <div class="small text-muted">@string.Format(T.T("BrevoLatestWebhookReason"), item.LatestProviderCallbackReason)</div>
                                    }
                                }
                            }
                        }
                    </td>
                    <td>
                        <div class="small">@item.RecommendedAction</div>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                        }
                        else if (item.CompletedAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">@string.Format(T.T("CommunicationCompletedAt"), item.CompletedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                        }
                        else
                        {
                            <div class="small text-muted mt-1">@T.T("CommunicationAttemptRecorded")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.RetryBlockedReason))
                        {
                            <div class="small text-warning mt-1">@item.RetryBlockedReason</div>
                        }
                        @if (item.RetryAvailableAtUtc.HasValue)
                        {
                            <div class="small text-muted">@string.Format(T.T("EmailAuditsRetryAvailableAtUtc"), item.RetryAvailableAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                        }
                        @if (item.IsQueueOperation)
                        {
                            <div class="mt-2">
                                <form asp-action="CancelEmailDispatchOperation" method="post" class="d-inline"
                                      hx-post="@Url.Action("CancelEmailDispatchOperation", "BusinessCommunications")"
                                      hx-target="#business-communication-audits-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="query" value="@Model.Query" />
                                    <input type="hidden" name="recipientEmail" value="@Model.RecipientEmail" />
                                    <input type="hidden" name="status" value="@Model.Status" />
                                    <input type="hidden" name="flowKey" value="@Model.FlowKey" />
                                    <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly" />
                                    <input type="hidden" name="businessLinkedFailuresOnly" value="@Model.BusinessLinkedFailuresOnly" />
                                    <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
                                    <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
                                    <input type="hidden" name="retryReadyOnly" value="@Model.RetryReadyOnly" />
                                    <input type="hidden" name="retryBlockedOnly" value="@Model.RetryBlockedOnly" />
                                    <input type="hidden" name="highChainVolumeOnly" value="@Model.HighChainVolumeOnly" />
                                    <input type="hidden" name="chainFollowUpOnly" value="@Model.ChainFollowUpOnly" />
                                    <input type="hidden" name="chainResolvedOnly" value="@Model.ChainResolvedOnly" />
                                    @if (Model.BusinessId.HasValue)
                                    {
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                    }
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("CancelQueuedDispatch")</button>
                                </form>
                            </div>
                        }
                        @if (item.CanRetryNow)
                        {
                            <div class="mt-2">
                                <form asp-action="RetryEmailAudit" method="post" class="d-inline"
                                      hx-post="@Url.Action("RetryEmailAudit", "BusinessCommunications")"
                                      hx-target="#business-communication-audits-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="query" value="@Model.Query" />
                                    <input type="hidden" name="recipientEmail" value="@Model.RecipientEmail" />
                                    <input type="hidden" name="status" value="@Model.Status" />
                                    <input type="hidden" name="flowKey" value="@Model.FlowKey" />
                                    <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly" />
                                    <input type="hidden" name="businessLinkedFailuresOnly" value="@Model.BusinessLinkedFailuresOnly" />
                                    <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
                                    <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
                                    <input type="hidden" name="retryReadyOnly" value="@Model.RetryReadyOnly" />
                                    <input type="hidden" name="retryBlockedOnly" value="@Model.RetryBlockedOnly" />
                                    <input type="hidden" name="highChainVolumeOnly" value="@Model.HighChainVolumeOnly" />
                                    <input type="hidden" name="chainFollowUpOnly" value="@Model.ChainFollowUpOnly" />
                                    <input type="hidden" name="chainResolvedOnly" value="@Model.ChainResolvedOnly" />
                                    @if (Model.BusinessId.HasValue)
                                    {
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                    }
                                    <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("RetryNowAction")</button>
                                </form>
                            </div>
                        }
                        else if (needsRetryBlockedFollowUp)
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="EmailAudits"
                                   asp-route-retryBlockedOnly="true"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@EmailAuditsUrl(retryBlockedOnly: true, businessId: item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("RetryBlocked")</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenPolicyAction")</a>
                                @if (string.Equals(item.FlowKey, "PhoneVerification", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a asp-action="ChannelAudits"
                                       asp-route-businessId="@item.BusinessId"
                                       asp-route-phoneVerificationOnly="true"
                                       class="btn btn-sm btn-outline-dark"
                                       hx-get="@ChannelAuditsUrl(item.BusinessId, phoneVerificationOnly: true)"
                                       hx-target="#business-communication-audits-workspace-shell"
                                       hx-swap="outerHTML">@T.T("PhoneVerification")</a>
                                }
                            </div>
                        }
                        @if (needsChainFollowUp)
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="EmailAudits"
                                   asp-route-chainFollowUpOnly="true"
                                   asp-route-recipientEmail="@LogicalRecipientEmail(item)"
                                   asp-route-flowKey="@item.FlowKey"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@EmailAuditsUrl(chainFollowUpOnly: true, recipientEmail: LogicalRecipientEmail(item), flowKey: item.FlowKey, businessId: item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("NeedsFollowUp")</a>
                                <a asp-action="EmailAudits"
                                   asp-route-repeatedFailuresOnly="true"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(repeatedFailuresOnly: true, businessId: item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("RepeatedFailures")</a>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FlowKey))
                        {
                            <div class="mt-2">
                                <a asp-action="EmailAudits"
                                   asp-route-recipientEmail="@LogicalRecipientEmail(item)"
                                   asp-route-flowKey="@item.FlowKey"
                                   asp-route-status=""
                                   asp-route-stalePendingOnly="false"
                                   asp-route-businessLinkedFailuresOnly="false"
                                   asp-route-repeatedFailuresOnly="false"
                                   asp-route-priorSuccessOnly="false"
                                   asp-route-retryReadyOnly="false"
                                   asp-route-retryBlockedOnly="false"
                                   asp-route-highChainVolumeOnly="false"
                                   asp-route-chainFollowUpOnly="@Model.ChainFollowUpOnly"
                                   asp-route-chainResolvedOnly="@Model.ChainResolvedOnly"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                           hx-get="@EmailAuditsUrl(recipientEmail: LogicalRecipientEmail(item), flowKey: item.FlowKey, status: string.Empty, stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, retryReadyOnly: false, retryBlockedOnly: false, highChainVolumeOnly: false, chainFollowUpOnly: Model.ChainFollowUpOnly, chainResolvedOnly: Model.ChainResolvedOnly, businessId: item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenExactChain")</a>
                            </div>
                        }
                        @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                        {
                            var invitationWorkspaceFilter = InvitationWorkspaceFilter(item);
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@item.BusinessId" asp-route-query="@LogicalRecipientEmail(item)" asp-route-filter="@invitationWorkspaceFilter" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessInvitationsUrl(item.BusinessId, invitationWorkspaceFilter, LogicalRecipientEmail(item))"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("BusinessCommunicationSearchInvitationAction")</a>
                                <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary"
                                   asp-route-businessId="@item.BusinessId"
                                   hx-get="@BusinessSupportQueueUrl(item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("SupportQueue")</a>
                                <a asp-action="Details" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-dark"
                                   hx-get="@CommunicationDetailsUrl(item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("BusinessCommunicationInspectBusinessAction")</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase) || string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                        {
                            var memberWorkspaceFilter = MemberWorkspaceFilter(item);
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Users" asp-action="Index" asp-route-q="@LogicalRecipientEmail(item)" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@UsersUrl(LogicalRecipientEmail(item))"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("BusinessCommunicationOpenUsersAction")</a>
                                <a asp-controller="MobileOperations" asp-action="Index" asp-route-businessId="@item.BusinessId" asp-route-q="@LogicalRecipientEmail(item)" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(item.BusinessId, LogicalRecipientEmail(item))"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                @if (item.BusinessId.HasValue)
                                {
                                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@item.BusinessId" asp-route-query="@LogicalRecipientEmail(item)" asp-route-filter="@memberWorkspaceFilter" class="btn btn-sm btn-outline-secondary"
                                       hx-get="@BusinessMembersUrl(item.BusinessId, memberWorkspaceFilter, LogicalRecipientEmail(item))"
                                       hx-target="#business-communication-audits-workspace-shell"
                                       hx-swap="outerHTML">@T.T("CommunicationOpenMemberSupportAction")</a>
                                }
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenPolicyAction")</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "PhoneVerification", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-phoneVerificationOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ChannelAuditsUrl(item.BusinessId, phoneVerificationOnly: true)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("PhoneVerification")</a>
                                <a asp-controller="MobileOperations" asp-action="Index" asp-route-businessId="@item.BusinessId" asp-route-q="@LogicalRecipientEmail(item)" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(item.BusinessId, LogicalRecipientEmail(item))"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenPolicyAction")</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"
       hx-get="@GlobalBusinessCommunicationsUrl()"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenWorkspaceAction")</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("OpenPolicyAction")</a>
                                @if (Model.CanSendTestEmail)
                                {
                                    <form asp-action="SendTestEmail" method="post" class="d-inline"
                                          hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                                          hx-target="#business-communication-audits-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("BusinessCommunicationRerunEmailTestAction")</button>
                                    </form>
                                }
                            </div>
                        }
                        else if (needsBusinessSupportFollowUp)
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary"
                                   asp-route-businessId="@item.BusinessId"
                                   hx-get="@BusinessSupportQueueUrl(item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("SupportQueue")</a>
                                <a asp-action="Details" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-dark"
                                   hx-get="@CommunicationDetailsUrl(item.BusinessId)"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">@T.T("BusinessCommunicationInspectBusinessAction")</a>
                            </div>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="EmailAudits"
       asp-route-query="@Model.Query"
       asp-route-recipientEmail="@Model.RecipientEmail"
       asp-route-status="@Model.Status"
       asp-route-flowKey="@Model.FlowKey"
       asp-route-stalePendingOnly="@Model.StalePendingOnly"
       asp-route-businessLinkedFailuresOnly="@Model.BusinessLinkedFailuresOnly"
       asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
       asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
       asp-route-retryReadyOnly="@Model.RetryReadyOnly"
       asp-route-retryBlockedOnly="@Model.RetryBlockedOnly"
       asp-route-highChainVolumeOnly="@Model.HighChainVolumeOnly"
       asp-route-businessId="@Model.BusinessId"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
