@if (!string.IsNullOrWhiteSpace(Model.RecipientEmail))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>@T.T("ExactChainMode"):</strong> @T.T("ShowingDeliveryChainFor") <code>@Model.RecipientEmail</code>
            @if (!string.IsNullOrWhiteSpace(Model.FlowKey))
            {
                <span> @T.T("InFlow") <code>@FlowLabel(Model.FlowKey)</code></span>
            }
        </div>
        <a asp-action="EmailAudits"
           asp-route-query="@Model.Query"
           asp-route-status="@Model.Status"
           asp-route-flowKey="@Model.FlowKey"
           asp-route-stalePendingOnly="@Model.StalePendingOnly"
           asp-route-businessLinkedFailuresOnly="@Model.BusinessLinkedFailuresOnly"
           asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
           asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
           asp-route-retryReadyOnly="@Model.RetryReadyOnly"
           asp-route-retryBlockedOnly="@Model.RetryBlockedOnly"
           asp-route-highChainVolumeOnly="@Model.HighChainVolumeOnly"
           asp-route-chainFollowUpOnly="false"
           asp-route-chainResolvedOnly="false"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { query = Model.Query, status = Model.Status, flowKey = Model.FlowKey, stalePendingOnly = Model.StalePendingOnly, businessLinkedFailuresOnly = Model.BusinessLinkedFailuresOnly, repeatedFailuresOnly = Model.RepeatedFailuresOnly, priorSuccessOnly = Model.PriorSuccessOnly, retryReadyOnly = Model.RetryReadyOnly, retryBlockedOnly = Model.RetryBlockedOnly, highChainVolumeOnly = Model.HighChainVolumeOnly, chainFollowUpOnly = false, chainResolvedOnly = false, businessId = Model.BusinessId })"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML">@T.T("LeaveExactChain")</a>
    </div>

    @if (Model.ChainSummary is not null)
    {
        <div class="d-flex gap-2 flex-wrap mb-3">
            <a asp-action="EmailAudits"
               asp-route-recipientEmail="@Model.RecipientEmail"
               asp-route-flowKey="@Model.FlowKey"
               asp-route-chainFollowUpOnly="false"
               asp-route-chainResolvedOnly="false"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm @(Model.ChainFollowUpOnly || Model.ChainResolvedOnly ? "btn-outline-secondary" : "btn-dark")"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { recipientEmail = Model.RecipientEmail, flowKey = Model.FlowKey, chainFollowUpOnly = false, chainResolvedOnly = false, businessId = Model.BusinessId })"
               hx-target="#business-communication-audits-workspace-shell"
               hx-swap="outerHTML">@T.T("WholeChain")</a>
            <a asp-action="EmailAudits"
               asp-route-recipientEmail="@Model.RecipientEmail"
               asp-route-flowKey="@Model.FlowKey"
               asp-route-chainFollowUpOnly="true"
               asp-route-chainResolvedOnly="false"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm @(Model.ChainFollowUpOnly ? "btn-warning" : "btn-outline-warning")"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { recipientEmail = Model.RecipientEmail, flowKey = Model.FlowKey, chainFollowUpOnly = true, chainResolvedOnly = false, businessId = Model.BusinessId })"
               hx-target="#business-communication-audits-workspace-shell"
               hx-swap="outerHTML">@T.T("NeedsFollowUp")</a>
            <a asp-action="EmailAudits"
               asp-route-recipientEmail="@Model.RecipientEmail"
               asp-route-flowKey="@Model.FlowKey"
               asp-route-chainFollowUpOnly="false"
               asp-route-chainResolvedOnly="true"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm @(Model.ChainResolvedOnly ? "btn-success" : "btn-outline-success")"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { recipientEmail = Model.RecipientEmail, flowKey = Model.FlowKey, chainFollowUpOnly = false, chainResolvedOnly = true, businessId = Model.BusinessId })"
               hx-target="#business-communication-audits-workspace-shell"
               hx-swap="outerHTML">@T.T("ResolvedHistory")</a>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ChainAttempts")</div>
                    <div class="fs-4 fw-semibold">@Model.ChainSummary.TotalAttempts</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ChainFailed")</div>
                    <div class="fs-4 fw-semibold">@Model.ChainSummary.FailedCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ChainSent")</div>
                    <div class="fs-4 fw-semibold">@Model.ChainSummary.SentCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ChainPending")</div>
                    <div class="fs-4 fw-semibold">@Model.ChainSummary.PendingCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("NeedsFollowUp")</div>
                    <div class="fs-4 fw-semibold">@Model.ChainSummary.NeedsOperatorFollowUpCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ChainProfile")</div>
                    <div class="fw-semibold mt-1">@ChainStatusMixLabel(Model.ChainSummary.StatusMix)</div>
                </div>
            </div>
        </div>
        <div class="alert alert-secondary mb-4">
            <strong>@T.T("EmailAuditChainTimelineLabel"):</strong>
            @T.T("ChannelAuditFirstAttemptLabel")
            <code>@Model.ChainSummary.FirstAttemptAtUtc?.ToString("yyyy-MM-dd HH:mm")</code>,
            @T.T("ChannelAuditLatestAttemptLabel")
            <code>@Model.ChainSummary.LastAttemptAtUtc?.ToString("yyyy-MM-dd HH:mm")</code>
            @if (Model.ChainSummary.LastSuccessfulAttemptAtUtc.HasValue)
            {
                <span>, @T.T("EmailAuditLastSuccessLabel") <code>@Model.ChainSummary.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</code></span>
            }
            else
            {
                <span>, @T.T("EmailAuditNoSuccessfulDeliveryYet")</span>
            }
            <div class="small text-muted mt-2">
                @T.T("EmailAuditExactChainNote")
            </div>
        </div>

        @if (Model.ChainSummary.RecentHistory.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">@T.T("ChannelAuditRecentExactChainHistoryTitle")</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>@T.T("WhenUtc")</th>
                                    <th>@T.T("Status")</th>
                                    <th>@T.T("Provider")</th>
                                    <th>@T.T("SubjectLabel")</th>
                                    <th>@T.T("Outcome")</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var history in Model.ChainSummary.RecentHistory)
                            {
                                <tr>
                                    <td>@history.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (string.Equals(history.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-success">@DeliveryStatusLabel("Sent")</span>
                                        }
                                        else if (string.Equals(history.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">@DeliveryStatusLabel("Failed")</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">@DeliveryStatusLabel(history.Status)</span>
                                        }
                                    </td>
                                    <td>@history.Provider</td>
                                    <td>@history.Subject</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(history.FailureMessage))
                                        {
                                            <span class="text-danger small">@history.FailureMessage</span>
                                        }
                                        else if (history.CompletedAtUtc.HasValue)
                                        {
                                            <span class="text-muted small">@string.Format(T.T("CommunicationCompletedAt"), history.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm"))</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@T.T("CommunicationAttemptRecorded")</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
}

