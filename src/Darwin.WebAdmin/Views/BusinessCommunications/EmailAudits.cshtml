@model Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EmailDeliveryAudits");

    string FlowLabel(string? flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string RetryPolicyStateLabel(string? retryPolicyState) => retryPolicyState switch
    {
        "Ready" => T.T("EmailAuditsRetryReadyLabel"),
        "Cooldown" => T.T("EmailAuditsRetryCooldownLabel"),
        "RateLimited" => T.T("EmailAuditsRetryRateLimitedLabel"),
        "Unsupported" => T.T("CommunicationEmailRetryPolicyUnsupported"),
        "Closed" => T.T("CommunicationEmailRetryPolicyClosed"),
        _ => string.IsNullOrWhiteSpace(retryPolicyState) ? T.T("CommonUnclassified") : T.T(retryPolicyState)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string ChainStatusMixLabel(string? statusMix) => statusMix switch
    {
        "Mixed success/failure" => T.T("CommunicationChainStatusMixed"),
        "Open failure chain" => T.T("CommunicationChainStatusOpenFailure"),
        "Failure-only chain" => T.T("CommunicationChainStatusFailureOnly"),
        "Pending-only chain" => T.T("CommunicationChainStatusPendingOnly"),
        "Success-only chain" => T.T("CommunicationChainStatusSuccessOnly"),
        "Single attempt" => T.T("CommunicationChainStatusSingleAttempt"),
        _ => string.IsNullOrWhiteSpace(statusMix) ? T.T("CommonUnclassified") : T.T(statusMix)
    };

    string LogicalRecipientEmail(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        string.IsNullOrWhiteSpace(item.IntendedRecipientEmail) ? item.RecipientEmail : item.IntendedRecipientEmail!;

    bool HasRecipientOverride(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        !string.IsNullOrWhiteSpace(item.IntendedRecipientEmail) &&
        !string.Equals(item.IntendedRecipientEmail, item.RecipientEmail, StringComparison.OrdinalIgnoreCase);
}

<div id="business-communication-audits-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open-text me-2"></i>@T.T("EmailDeliveryAudits")</h1>
        <p class="text-muted mb-0">@T.T("RecentSmtpAttempts")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("OperatorPlaybooksByFlow")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("CommunicationEmailAuditsPlaybookIntro")
        </div>
        <div class="row g-3">
            @foreach (var playbook in Model.Playbooks)
            {
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@playbook.Title</div>
                            <a asp-action="EmailAudits"
                               asp-route-status="Failed"
                               asp-route-flowKey="@playbook.FlowKey"
                               asp-route-businessId="@Model.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = playbook.FlowKey, businessId = Model.BusinessId })"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">@T.T("OpenFailed")</a>
                        </div>
                        <div class="small text-muted mb-2">@playbook.ScopeNote</div>
                        <div class="small"><strong>@T.T("AllowedAction"):</strong> @playbook.AllowedAction</div>
                        <div class="small text-muted mt-2"><strong>@T.T("Escalation"):</strong> @playbook.EscalationRule</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

