       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="true"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", stalePendingOnly = false, businessLinkedFailuresOnly = false, repeatedFailuresOnly = true, priorSuccessOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Repeated Failures</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="true"
       asp-route-retryReadyOnly="false"
       asp-route-retryBlockedOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { stalePendingOnly = false, businessLinkedFailuresOnly = false, repeatedFailuresOnly = false, priorSuccessOnly = true, retryReadyOnly = false, retryBlockedOnly = false, businessId = Model.BusinessId })"
