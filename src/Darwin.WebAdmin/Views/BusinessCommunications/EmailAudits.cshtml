@model Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditsListVm
@{
    ViewData["Title"] = "Email Delivery Audits";
}

<div id="business-communication-audits-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open-text me-2"></i>Email Delivery Audits</h1>
        <p class="text-muted mb-0">Recent SMTP-based transactional delivery attempts and failures.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML">Back to Communications</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Operator Playbooks by Flow</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            This is a response-planning surface, not a shared retry queue. Use the flow-specific actions below instead of treating failed emails as generic resend jobs.
        </div>
        <div class="row g-3">
            @foreach (var playbook in Model.Playbooks)
            {
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@playbook.Title</div>
                            <a asp-action="EmailAudits"
                               asp-route-status="Failed"
                               asp-route-flowKey="@playbook.FlowKey"
                               asp-route-businessId="@Model.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = playbook.FlowKey, businessId = Model.BusinessId })"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">Open Failed</a>
                        </div>
                        <div class="small text-muted mb-2">@playbook.ScopeNote</div>
                        <div class="small"><strong>Allowed action:</strong> @playbook.AllowedAction</div>
                        <div class="small text-muted mt-2"><strong>Escalation:</strong> @playbook.EscalationRule</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-danger"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", stalePendingOnly = false, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Failed Only</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="true"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-warning"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { stalePendingOnly = true, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Stale Pending</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-businessLinkedFailuresOnly="true"
       asp-route-stalePendingOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", businessLinkedFailuresOnly = true, stalePendingOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Business-linked Failures</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="BusinessInvitation"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "BusinessInvitation", stalePendingOnly = false, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Failed Invitations</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="AccountActivation"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation", stalePendingOnly = false, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Failed Activations</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="PasswordReset"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset", stalePendingOnly = false, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Failed Password Resets</a>
    <a asp-action="EmailAudits"
       asp-route-flowKey="AdminCommunicationTest"
       asp-route-status="Failed"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { flowKey = "AdminCommunicationTest", status = "Failed", stalePendingOnly = false, businessLinkedFailuresOnly = false, businessId = Model.BusinessId })"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">Failed Admin Tests</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Sent</div>
            <div class="fs-4 fw-semibold">@Model.Summary.SentCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Pending</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Stale Pending</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StalePendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Last 24 h</div>
            <div class="fs-4 fw-semibold">@Model.Summary.Recent24HourCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Business-linked Failures</div>
            <div class="fs-4 fw-semibold">@Model.Summary.BusinessLinkedFailureCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed Invitations</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedInvitationCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed Activations</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedActivationCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed Password Resets</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedPasswordResetCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed Admin Tests</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedAdminTestCount</div>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
      hx-target="#business-communication-audits-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by recipient, subject, provider, flow, or business" />
    </div>
    <div class="col-md-3">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <select name="flowKey" asp-items="Model.FlowItems" class="form-select"></select>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="stalePendingOnly" value="true" checked="@Model.StalePendingOnly" id="stalePendingOnly" />
            <label class="form-check-label" for="stalePendingOnly">Stale pending only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="businessLinkedFailuresOnly" value="true" checked="@Model.BusinessLinkedFailuresOnly" id="businessLinkedFailuresOnly" />
            <label class="form-check-label" for="businessLinkedFailuresOnly">Business-linked failures only</label>
        </div>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    @if (Model.BusinessId.HasValue)
    {
        <input type="hidden" name="businessId" value="@Model.BusinessId" />
    }
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>When (UTC)</th>
                <th>Recipient</th>
                <th>Subject</th>
                <th>Flow</th>
                <th>Business</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Operator Response</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted py-4">No email audits matched the selected filters.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.RecipientEmail</td>
                    <td>@item.Subject</td>
                    <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                    <td>
                        @if (item.BusinessId.HasValue)
                        {
                            <a asp-action="Details" asp-route-businessId="@item.BusinessId"
                               hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">@(!string.IsNullOrWhiteSpace(item.BusinessName) ? item.BusinessName : item.BusinessId.ToString())</a>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>@item.Provider</td>
                    <td>
                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Sent</span>
                        }
                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-danger">Failed</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>
                        <div class="small">@item.RecommendedAction</div>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                        }
                        else if (item.CompletedAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">Completed @item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        else
                        {
                            <div class="small text-muted mt-1">Attempt recorded</div>
                        }
                        @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.BusinessId })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Open Invitations</a>
                                <a asp-action="Details" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Inspect Business</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase) || string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Users" asp-action="Index" asp-route-q="@item.RecipientEmail" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Open Users</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Communication Policy</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "BusinessCommunications")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Communication Workspace</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Policy Settings</a>
                                @if (Model.CanSendTestEmail)
                                {
                                    <form asp-action="SendTestEmail" method="post" class="d-inline"
                                          hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                                          hx-target="#business-communication-audits-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Rerun Test</button>
                                    </form>
                                }
                            </div>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="EmailAudits"
       asp-route-query="@Model.Query"
       asp-route-status="@Model.Status"
       asp-route-flowKey="@Model.FlowKey"
       asp-route-stalePendingOnly="@Model.StalePendingOnly"
       asp-route-businessLinkedFailuresOnly="@Model.BusinessLinkedFailuresOnly"
       asp-route-businessId="@Model.BusinessId"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
