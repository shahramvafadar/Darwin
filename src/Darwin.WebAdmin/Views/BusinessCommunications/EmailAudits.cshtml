        @if (Model.ChainSummary.RecentHistory.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-header">@T.T("ChannelAuditRecentExactChainHistoryTitle")</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>@T.T("WhenUtc")</th>
                                    <th>@T.T("Status")</th>
                                    <th>@T.T("Provider")</th>
                                    <th>@T.T("SubjectLabel")</th>
                                    <th>@T.T("Outcome")</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var history in Model.ChainSummary.RecentHistory)
                            {
                                <tr>
                                    <td>@history.AttemptedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                                    <td>
                                        @if (string.Equals(history.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-success">@DeliveryStatusLabel("Sent")</span>
                                        }
                                        else if (string.Equals(history.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge text-bg-danger">@DeliveryStatusLabel("Failed")</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">@DeliveryStatusLabel(history.Status)</span>
                                        }
                                    </td>
                                    <td>@history.Provider</td>
                                    <td>@history.Subject</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(history.FailureMessage))
                                        {
                                            <span class="text-danger small">@history.FailureMessage</span>
                                        }
                                        else if (history.CompletedAtUtc.HasValue)
                                        {
                                            <span class="text-muted small">@string.Format(T.T("CommunicationCompletedAt"), history.CompletedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@T.T("CommunicationAttemptRecorded")</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
}

