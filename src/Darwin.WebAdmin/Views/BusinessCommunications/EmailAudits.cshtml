<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
      hx-target="#business-communication-audits-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by recipient, subject, provider, flow, or business" />
    </div>
    <div class="col-md-3">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <select name="flowKey" asp-items="Model.FlowItems" class="form-select"></select>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="stalePendingOnly" value="true" checked="@Model.StalePendingOnly" id="stalePendingOnly" />
            <label class="form-check-label" for="stalePendingOnly">Stale pending only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="businessLinkedFailuresOnly" value="true" checked="@Model.BusinessLinkedFailuresOnly" id="businessLinkedFailuresOnly" />
            <label class="form-check-label" for="businessLinkedFailuresOnly">Business-linked failures only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="repeatedFailuresOnly" value="true" checked="@Model.RepeatedFailuresOnly" id="repeatedFailuresOnly" />
            <label class="form-check-label" for="repeatedFailuresOnly">Repeated failures only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="priorSuccessOnly" value="true" checked="@Model.PriorSuccessOnly" id="priorSuccessOnly" />
            <label class="form-check-label" for="priorSuccessOnly">Prior success context only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="retryReadyOnly" value="true" checked="@Model.RetryReadyOnly" id="retryReadyOnly" />
            <label class="form-check-label" for="retryReadyOnly">Retry ready only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="retryBlockedOnly" value="true" checked="@Model.RetryBlockedOnly" id="retryBlockedOnly" />
            <label class="form-check-label" for="retryBlockedOnly">Retry blocked only</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="highChainVolumeOnly" value="true" checked="@Model.HighChainVolumeOnly" id="highChainVolumeOnly" />
            <label class="form-check-label" for="highChainVolumeOnly">Heavy chains only</label>
        </div>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    @if (Model.BusinessId.HasValue)
    {
        <input type="hidden" name="businessId" value="@Model.BusinessId" />
    }
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications")"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>When (UTC)</th>
                <th>Recipient</th>
                <th>Subject</th>
                <th>Flow</th>
                <th>Business</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Delivery Context</th>
                <th>Operator Response</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted py-4">No email audits matched the selected filters.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.RecipientEmail</td>
                    <td>@item.Subject</td>
                    <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                    <td>
                        @if (item.BusinessId.HasValue)
                        {
                            <a asp-action="Details" asp-route-businessId="@item.BusinessId"
                               hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">@(!string.IsNullOrWhiteSpace(item.BusinessName) ? item.BusinessName : item.BusinessId.ToString())</a>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>@item.Provider</td>
                    <td>
                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Sent</span>
                        }
                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-danger">Failed</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>
                        <div class="small">
                            @if (string.Equals(item.Severity, "High", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-danger">High</span>
                            }
                            else if (string.Equals(item.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-warning">Medium</span>
                            }
                            else if (string.Equals(item.Severity, "Watch", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-secondary">Watch</span>
                            }
                            else if (string.Equals(item.Severity, "Slow", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge text-bg-info">Slow</span>
                            }
                            else
                            {
                                <span class="badge text-bg-light">Normal</span>
                            }
                        </div>
                        <div class="small text-muted mt-1">Open for @item.AttemptAgeMinutes min</div>
                        @if (item.CompletionLatencySeconds.HasValue)
                        {
                            <div class="small text-muted">Latency @item.CompletionLatencySeconds.Value s</div>
                        }
                        @if (item.NeedsOperatorFollowUp)
                        {
                            <div class="small text-danger mt-1">Needs operator follow-up</div>
                        }
                        @if (item.PriorAttemptCount > 0)
                        {
                            <div class="small text-muted mt-1">Prior attempts: @item.PriorAttemptCount</div>
                        }
                        @if (item.PriorFailureCount > 0)
                        {
                            <div class="small text-muted">Prior failures: @item.PriorFailureCount</div>
                        }
                        @if (item.RecentAttemptCount24h > 0)
                        {
                            <div class="small text-muted">Recent chain attempts (24 h): @item.RecentAttemptCount24h</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ChainStatusMix))
                        {
                            <div class="small text-muted">Chain profile: @item.ChainStatusMix</div>
                        }
                        @if (item.ChainSpanHours.HasValue)
                        {
                            <div class="small text-muted">Chain span: @item.ChainSpanHours.Value h</div>
                        }
                        @if (item.LastSuccessfulAttemptAtUtc.HasValue)
                        {
                            <div class="small text-muted">Last success @item.LastSuccessfulAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.RetryPolicyState))
                        {
                            <div class="small mt-1">
                                @if (string.Equals(item.RetryPolicyState, "Ready", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-success">Retry ready</span>
                                }
                                else if (string.Equals(item.RetryPolicyState, "Cooldown", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-warning">Retry cooldown</span>
                                }
                                else if (string.Equals(item.RetryPolicyState, "RateLimited", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge text-bg-danger">Retry rate-limited</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@item.RetryPolicyState</span>
                                }
                            </div>
                        }
                    </td>
                    <td>
                        <div class="small">@item.RecommendedAction</div>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-1">@item.FailureMessage</div>
                        }
                        else if (item.CompletedAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">Completed @item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        else
                        {
                            <div class="small text-muted mt-1">Attempt recorded</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.RetryBlockedReason))
                        {
                            <div class="small text-warning mt-1">@item.RetryBlockedReason</div>
                        }
                        @if (item.RetryAvailableAtUtc.HasValue)
                        {
                            <div class="small text-muted">Retry available @item.RetryAvailableAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</div>
                        }
                        @if (item.CanRetryNow)
                        {
                            <div class="mt-2">
                                <form asp-action="RetryEmailAudit" method="post" class="d-inline"
                                      hx-post="@Url.Action("RetryEmailAudit", "BusinessCommunications")"
                                      hx-target="#business-communication-audits-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="query" value="@Model.Query" />
                                    <input type="hidden" name="status" value="@Model.Status" />
                                    <input type="hidden" name="flowKey" value="@Model.FlowKey" />
                                    <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly" />
                                    <input type="hidden" name="businessLinkedFailuresOnly" value="@Model.BusinessLinkedFailuresOnly" />
                                    <input type="hidden" name="repeatedFailuresOnly" value="@Model.RepeatedFailuresOnly" />
                                    <input type="hidden" name="priorSuccessOnly" value="@Model.PriorSuccessOnly" />
                                    <input type="hidden" name="retryReadyOnly" value="@Model.RetryReadyOnly" />
                                    <input type="hidden" name="retryBlockedOnly" value="@Model.RetryBlockedOnly" />
                                    <input type="hidden" name="highChainVolumeOnly" value="@Model.HighChainVolumeOnly" />
                                    @if (Model.BusinessId.HasValue)
                                    {
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                    }
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Retry Now</button>
                                </form>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FlowKey))
                        {
                            <div class="mt-2">
                                <a asp-action="EmailAudits"
                                   asp-route-query="@item.RecipientEmail"
                                   asp-route-flowKey="@item.FlowKey"
                                   asp-route-status="@Model.Status"
                                   asp-route-stalePendingOnly="false"
                                   asp-route-businessLinkedFailuresOnly="false"
                                   asp-route-repeatedFailuresOnly="false"
                                   asp-route-priorSuccessOnly="false"
                                   asp-route-retryReadyOnly="false"
                                   asp-route-retryBlockedOnly="false"
                                   asp-route-highChainVolumeOnly="false"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { query = item.RecipientEmail, flowKey = item.FlowKey, status = Model.Status, stalePendingOnly = false, businessLinkedFailuresOnly = false, repeatedFailuresOnly = false, priorSuccessOnly = false, retryReadyOnly = false, retryBlockedOnly = false, highChainVolumeOnly = false, businessId = item.BusinessId })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Open Similar Chain</a>
                            </div>
                        }
                        @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@item.BusinessId" asp-route-query="@item.RecipientEmail" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.BusinessId, query = item.RecipientEmail, filter = "Open" })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Search Invitation</a>
                                <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("SupportQueue", "Businesses")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Support Queue</a>
                                <a asp-action="Details" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Inspect Business</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase) || string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-controller="Users" asp-action="Index" asp-route-q="@item.RecipientEmail" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Open Users</a>
                                @if (item.BusinessId.HasValue)
                                {
                                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@item.BusinessId" asp-route-query="@item.RecipientEmail" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Members", "Businesses", new { businessId = item.BusinessId, query = item.RecipientEmail, filter = "Attention" })"
                                       hx-target="#business-communication-audits-workspace-shell"
                                       hx-swap="outerHTML">Open Member Support</a>
                                }
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Communication Policy</a>
                            </div>
                        }
                        else if (string.Equals(item.FlowKey, "AdminCommunicationTest", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "BusinessCommunications")"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Communication Workspace</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                                   hx-target="#business-communication-audits-workspace-shell"
                                   hx-swap="outerHTML">Policy Settings</a>
                                @if (Model.CanSendTestEmail)
                                {
                                    <form asp-action="SendTestEmail" method="post" class="d-inline"
                                          hx-post="@Url.Action("SendTestEmail", "BusinessCommunications")"
                                          hx-target="#business-communication-audits-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Rerun Test</button>
                                    </form>
                                }
                            </div>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="EmailAudits"
       asp-route-query="@Model.Query"
       asp-route-status="@Model.Status"
       asp-route-flowKey="@Model.FlowKey"
       asp-route-stalePendingOnly="@Model.StalePendingOnly"
       asp-route-businessLinkedFailuresOnly="@Model.BusinessLinkedFailuresOnly"
       asp-route-repeatedFailuresOnly="@Model.RepeatedFailuresOnly"
       asp-route-priorSuccessOnly="@Model.PriorSuccessOnly"
       asp-route-retryReadyOnly="@Model.RetryReadyOnly"
       asp-route-retryBlockedOnly="@Model.RetryBlockedOnly"
       asp-route-highChainVolumeOnly="@Model.HighChainVolumeOnly"
       asp-route-businessId="@Model.BusinessId"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
