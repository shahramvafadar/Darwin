<form method="get" class="row g-2 mb-3"
      hx-get="@GlobalEmailAuditsUrl()"
      hx-target="#business-communication-audits-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("EmailAuditsSearchPlaceholder")" />
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.RecipientEmail))
    {
        <input type="hidden" name="recipientEmail" value="@Model.RecipientEmail" />
    }
    @if (Model.ChainFollowUpOnly)
    {
        <input type="hidden" name="chainFollowUpOnly" value="true" />
    }
    @if (Model.ChainResolvedOnly)
    {
        <input type="hidden" name="chainResolvedOnly" value="true" />
    }
    <div class="col-md-3">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <select name="flowKey" asp-items="Model.FlowItems" class="form-select"></select>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="stalePendingOnly" value="true" checked="@Model.StalePendingOnly" id="stalePendingOnly" />
            <label class="form-check-label" for="stalePendingOnly">@T.T("EmailAuditsStalePendingOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="businessLinkedFailuresOnly" value="true" checked="@Model.BusinessLinkedFailuresOnly" id="businessLinkedFailuresOnly" />
            <label class="form-check-label" for="businessLinkedFailuresOnly">@T.T("EmailAuditsBusinessLinkedFailuresOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="repeatedFailuresOnly" value="true" checked="@Model.RepeatedFailuresOnly" id="repeatedFailuresOnly" />
            <label class="form-check-label" for="repeatedFailuresOnly">@T.T("EmailAuditsRepeatedFailuresOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="priorSuccessOnly" value="true" checked="@Model.PriorSuccessOnly" id="priorSuccessOnly" />
            <label class="form-check-label" for="priorSuccessOnly">@T.T("EmailAuditsPriorSuccessOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="retryReadyOnly" value="true" checked="@Model.RetryReadyOnly" id="retryReadyOnly" />
            <label class="form-check-label" for="retryReadyOnly">@T.T("EmailAuditsRetryReadyOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="retryBlockedOnly" value="true" checked="@Model.RetryBlockedOnly" id="retryBlockedOnly" />
            <label class="form-check-label" for="retryBlockedOnly">@T.T("EmailAuditsRetryBlockedOnlyLabel")</label>
        </div>
    </div>
    <div class="col-md-auto">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="highChainVolumeOnly" value="true" checked="@Model.HighChainVolumeOnly" id="highChainVolumeOnly" />
            <label class="form-check-label" for="highChainVolumeOnly">@T.T("EmailAuditsHeavyChainsOnlyLabel")</label>
        </div>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
