@model Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditsListVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EmailDeliveryAudits");
    string GlobalEmailAuditsUrl() => Url.Action("EmailAudits", "BusinessCommunications") ?? string.Empty;
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string ProviderCallbacksUrl(string? query = null, string? provider = null, string? status = null) => Url.Action("ProviderCallbacks", "BusinessCommunications", new { query, provider, status }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string CommunicationDetailsUrl(Guid? businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string ChannelAuditsUrl(Guid? businessId, bool? phoneVerificationOnly = null) => Url.Action("ChannelAudits", "BusinessCommunications", new { businessId, phoneVerificationOnly }) ?? string.Empty;
    string UsersUrl(string? q = null) => Url.Action("Index", "Users", new { q }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null, string? query = null) => Url.Action("Invitations", "Businesses", new { businessId, query, filter }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null, string? query = null) => Url.Action("Members", "Businesses", new { businessId, query, filter }) ?? string.Empty;
    string EmailAuditsUrl(
        string? query = null,
        string? status = null,
        string? flowKey = null,
        string? recipientEmail = null,
        bool? stalePendingOnly = null,
        bool? businessLinkedFailuresOnly = null,
        bool? repeatedFailuresOnly = null,
        bool? priorSuccessOnly = null,
        bool? retryReadyOnly = null,
        bool? retryBlockedOnly = null,
        bool? highChainVolumeOnly = null,
        bool? chainFollowUpOnly = null,
        bool? chainResolvedOnly = null,
        Guid? businessId = null) => Url.Action("EmailAudits", "BusinessCommunications", new
        {
            query,
            status,
            flowKey,
            recipientEmail,
            stalePendingOnly,
            businessLinkedFailuresOnly,
            repeatedFailuresOnly,
            priorSuccessOnly,
            retryReadyOnly,
            retryBlockedOnly,
            highChainVolumeOnly,
            chainFollowUpOnly,
            chainResolvedOnly,
            businessId
        }) ?? string.Empty;

    string FlowLabel(string? flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string RetryPolicyStateLabel(string? retryPolicyState) => retryPolicyState switch
    {
        "Ready" => T.T("EmailAuditsRetryReadyLabel"),
        "Cooldown" => T.T("EmailAuditsRetryCooldownLabel"),
        "RateLimited" => T.T("EmailAuditsRetryRateLimitedLabel"),
        "Unsupported" => T.T("CommunicationEmailRetryPolicyUnsupported"),
        "Closed" => T.T("CommunicationEmailRetryPolicyClosed"),
        _ => string.IsNullOrWhiteSpace(retryPolicyState) ? T.T("CommonUnclassified") : T.T(retryPolicyState)
    };

    string DeliveryStatusLabel(string? status) => status switch
    {
        "Sent" => T.T("Sent"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };

    string ChainStatusMixLabel(string? statusMix) => statusMix switch
    {
        "Mixed success/failure" => T.T("CommunicationChainStatusMixed"),
        "Open failure chain" => T.T("CommunicationChainStatusOpenFailure"),
        "Failure-only chain" => T.T("CommunicationChainStatusFailureOnly"),
        "Pending-only chain" => T.T("CommunicationChainStatusPendingOnly"),
        "Success-only chain" => T.T("CommunicationChainStatusSuccessOnly"),
        "Single attempt" => T.T("CommunicationChainStatusSingleAttempt"),
        _ => string.IsNullOrWhiteSpace(statusMix) ? T.T("CommonUnclassified") : T.T(statusMix)
    };

    string LogicalRecipientEmail(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        string.IsNullOrWhiteSpace(item.IntendedRecipientEmail) ? item.RecipientEmail : item.IntendedRecipientEmail!;

    bool HasRecipientOverride(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        !string.IsNullOrWhiteSpace(item.IntendedRecipientEmail) &&
        !string.Equals(item.IntendedRecipientEmail, item.RecipientEmail, StringComparison.OrdinalIgnoreCase);

    string BusinessDisplayName(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        !string.IsNullOrWhiteSpace(item.BusinessName) ? item.BusinessName : item.BusinessId?.ToString() ?? T.T("NotApplicable");

    Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? InvitationWorkspaceFilter(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase)
            ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending
            : null;

    Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? MemberWorkspaceFilter(Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditListItemVm item) =>
        string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase)
            ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation
            : string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase)
                ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention
                : null;
    string EmailAuditHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string EmailAuditHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    var retryEscalationCount = Model.Summary.RetryReadyCount + Model.Summary.RetryBlockedCount;
    var followUpBacklogCount = Model.Summary.NeedsOperatorFollowUpCount + Model.Summary.RepeatedFailureCount;
    var chainAttentionCount = Model.Summary.HighChainVolumeCount + Model.Summary.StalePendingCount;
    var exactChainActive = !string.IsNullOrWhiteSpace(Model.RecipientEmail);
}

<div id="business-communication-audits-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open-text me-2"></i>@T.T("EmailDeliveryAudits")</h1>
        <p class="text-muted mb-0">@T.T("RecentSmtpAttempts")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"
                           hx-get="@GlobalBusinessCommunicationsUrl()"
           hx-target="#business-communication-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BackToCommunications")</a>
</div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("EmailDeliveryAudits")</h2>
                <p class="text-muted mb-0">@T.T("RecentSmtpAttempts")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
                   hx-target="#business-communication-audits-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-communications-policy"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                   hx-target="#business-communication-audits-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenPolicyAction")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("RetryReady")</div>
                        <span class="@EmailAuditHealthBadgeClass(Model.Summary.RetryReadyCount == 0)">@EmailAuditHealthBadgeText(Model.Summary.RetryReadyCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@retryEscalationCount</div>
                    <div class="small text-muted">@string.Format("{0} / {1}", Model.Summary.RetryReadyCount, Model.Summary.RetryBlockedCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="EmailAudits"
                           asp-route-retryReadyOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-success"
                           hx-get="@EmailAuditsUrl(retryReadyOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RetryReady")</a>
                        <a asp-action="EmailAudits"
                           asp-route-retryBlockedOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@EmailAuditsUrl(retryBlockedOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RetryBlocked")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("NeedsFollowUp")</div>
                        <span class="@EmailAuditHealthBadgeClass(followUpBacklogCount == 0)">@EmailAuditHealthBadgeText(followUpBacklogCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@followUpBacklogCount</div>
                    <div class="small text-muted">@T.T("CommunicationRepeatedFailureChainsNote")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="EmailAudits"
                           asp-route-repeatedFailuresOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(repeatedFailuresOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RepeatedFailures")</a>
                        <a asp-action="EmailAudits"
                           asp-route-priorSuccessOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(priorSuccessOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PriorSuccessContext")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("HeavyChains")</div>
                        <span class="@EmailAuditHealthBadgeClass(chainAttentionCount == 0)">@EmailAuditHealthBadgeText(chainAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@chainAttentionCount</div>
                    <div class="small text-muted">@T.T("EmailAuditsHeavyChainsOnlyLabel")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="EmailAudits"
                           asp-route-highChainVolumeOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@EmailAuditsUrl(highChainVolumeOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("HeavyChains")</a>
                        <a asp-action="EmailAudits"
                           asp-route-stalePendingOnly="true"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@EmailAuditsUrl(stalePendingOnly: true, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StalePending")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("ExactChainMode")</div>
                        <span class="@EmailAuditHealthBadgeClass(!exactChainActive)">@EmailAuditHealthBadgeText(!exactChainActive)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@(exactChainActive ? 1 : 0)</div>
                    <div class="small text-muted">@(exactChainActive ? Model.RecipientEmail : T.T("LeaveExactChain"))</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="EmailAudits"
                           asp-route-chainFollowUpOnly="true"
                           asp-route-recipientEmail="@Model.RecipientEmail"
                           asp-route-flowKey="@Model.FlowKey"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@EmailAuditsUrl(chainFollowUpOnly: true, recipientEmail: Model.RecipientEmail, flowKey: Model.FlowKey, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NeedsFollowUp")</a>
                        <a asp-action="EmailAudits"
                           asp-route-recipientEmail="@Model.RecipientEmail"
                           asp-route-flowKey="@Model.FlowKey"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(recipientEmail: Model.RecipientEmail, flowKey: Model.FlowKey, businessId: Model.BusinessId)"
                           hx-target="#business-communication-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("WholeChain")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("OperatorPlaybooksByFlow")</div>
    <div class="card-body">
        <div class="alert alert-secondary">
            @T.T("CommunicationEmailAuditsPlaybookIntro")
        </div>
        <div class="row g-3">
            @foreach (var playbook in Model.Playbooks)
            {
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@playbook.Title</div>
                            <a asp-action="EmailAudits"
                               asp-route-status="Failed"
                               asp-route-flowKey="@playbook.FlowKey"
                               asp-route-businessId="@Model.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@EmailAuditsUrl(status: "Failed", flowKey: playbook.FlowKey, businessId: Model.BusinessId)"
                               hx-target="#business-communication-audits-workspace-shell"
                               hx-swap="outerHTML">@T.T("OpenFailed")</a>
                        </div>
                        <div class="small text-muted mb-2">@playbook.ScopeNote</div>
                        <div class="small"><strong>@T.T("AllowedAction"):</strong> @playbook.AllowedAction</div>
                        <div class="small text-muted mt-2"><strong>@T.T("Escalation"):</strong> @playbook.EscalationRule</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-danger"
                       hx-get="@EmailAuditsUrl(status: "Failed", stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("FailedOnly")</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="true"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-warning"
                       hx-get="@EmailAuditsUrl(stalePendingOnly: true, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("StalePending")</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-businessLinkedFailuresOnly="true"
       asp-route-stalePendingOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl(status: "Failed", businessLinkedFailuresOnly: true, stalePendingOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("BusinessLinkedFailures")</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="true"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                       hx-get="@EmailAuditsUrl(status: "Failed", stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: true, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("RepeatedFailures")</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="true"
       asp-route-retryReadyOnly="false"
       asp-route-retryBlockedOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: true, retryReadyOnly: false, retryBlockedOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("PriorSuccessContext")</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-retryReadyOnly="true"
       asp-route-retryBlockedOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-success"
                           hx-get="@EmailAuditsUrl(stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, retryReadyOnly: true, retryBlockedOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("RetryReady")</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-retryReadyOnly="false"
       asp-route-retryBlockedOnly="true"
       asp-route-highChainVolumeOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-warning"
                           hx-get="@EmailAuditsUrl(stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, retryReadyOnly: false, retryBlockedOnly: true, highChainVolumeOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("RetryBlocked")</a>
    <a asp-action="EmailAudits"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-retryReadyOnly="false"
       asp-route-retryBlockedOnly="false"
       asp-route-highChainVolumeOnly="true"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-dark"
                           hx-get="@EmailAuditsUrl(stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, retryReadyOnly: false, retryBlockedOnly: false, highChainVolumeOnly: true, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("HeavyChains")</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="BusinessInvitation"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(status: "Failed", flowKey: "BusinessInvitation", stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("FailedInvitations")</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="AccountActivation"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(status: "Failed", flowKey: "AccountActivation", stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("FailedActivations")</a>
    <a asp-action="EmailAudits"
       asp-route-status="Failed"
       asp-route-flowKey="PasswordReset"
       asp-route-stalePendingOnly="false"
       asp-route-businessLinkedFailuresOnly="false"
       asp-route-repeatedFailuresOnly="false"
       asp-route-priorSuccessOnly="false"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(status: "Failed", flowKey: "PasswordReset", stalePendingOnly: false, businessLinkedFailuresOnly: false, repeatedFailuresOnly: false, priorSuccessOnly: false, businessId: Model.BusinessId)"
       hx-target="#business-communication-audits-workspace-shell"
       hx-swap="outerHTML">@T.T("FailedPasswordResets")</a>
    <a asp-action="EmailAudits"
       asp-route-flowKey="AdminCommunicationTest"
