            {
                <span>, @T.T("EmailAuditLastSuccessLabel") <code>@Model.ChainSummary.LastSuccessfulAttemptAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</code></span>
            }
            else
            {
                <span>, @T.T("EmailAuditNoSuccessfulDeliveryYet")</span>
            }
            <div class="small text-muted mt-2">
                @T.T("EmailAuditExactChainNote")
