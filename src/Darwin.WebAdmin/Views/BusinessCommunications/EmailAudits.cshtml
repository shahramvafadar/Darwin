@model Darwin.WebAdmin.ViewModels.Businesses.EmailDispatchAuditsListVm
@{
    ViewData["Title"] = "Email Delivery Audits";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope-open-text me-2"></i>Email Delivery Audits</h1>
        <p class="text-muted mb-0">Recent SMTP-based transactional delivery attempts and failures.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Communications</a>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by recipient, subject, provider, or status" />
    </div>
    <div class="col-md-3">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <select name="flowKey" asp-items="Model.FlowItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    @if (Model.BusinessId.HasValue)
    {
        <input type="hidden" name="businessId" value="@Model.BusinessId" />
    }
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="EmailAudits" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>When (UTC)</th>
                <th>Recipient</th>
                <th>Subject</th>
                <th>Flow</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted py-4">No email audits matched the selected filters.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.RecipientEmail</td>
                    <td>@item.Subject</td>
                    <td>@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</td>
                    <td>@item.Provider</td>
                    <td>
                        @if (string.Equals(item.Status, "Sent", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Sent</span>
                        }
                        else if (string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-danger">Failed</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger">@item.FailureMessage</div>
                        }
                        else if (item.CompletedAtUtc.HasValue)
                        {
                            <div class="small text-muted">Completed @item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        else
                        {
                            <div class="small text-muted">Attempt recorded</div>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="BusinessCommunications"
       asp-action="EmailAudits"
       asp-route-query="@Model.Query"
       asp-route-status="@Model.Status"
       asp-route-flowKey="@Model.FlowKey"
       asp-route-businessId="@Model.BusinessId">
</pager>
