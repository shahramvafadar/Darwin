@model Darwin.WebAdmin.ViewModels.Businesses.ProviderCallbackInboxListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("ProviderCallbackInboxTitle");

    string ProviderCallbacksUrl() => Url.Action("ProviderCallbacks", "BusinessCommunications") ?? string.Empty;
    string FilteredProviderCallbacksUrl(string? provider = null, string? status = null, bool? failedOnly = null, bool? stalePendingOnly = null, string? query = null) => Url.Action("ProviderCallbacks", "BusinessCommunications", new { provider, status, failedOnly, stalePendingOnly, query }) ?? string.Empty;
    string BusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string TemplatePreviewsUrl() => Url.Action("TemplatePreviews", "BusinessCommunications") ?? string.Empty;
    string CallbackPageUrl(int page) => Url.Action("ProviderCallbacks", "BusinessCommunications", new
    {
        page,
        pageSize = Model.PageSize,
        query = Model.Query,
        provider = Model.Provider,
        status = Model.Status,
        stalePendingOnly = Model.StalePendingOnly,
        failedOnly = Model.FailedOnly
    }) ?? string.Empty;

    int totalPages = Math.Max(1, (int)Math.Ceiling(Model.Total / (double)Math.Max(1, Model.PageSize)));

    string StatusBadgeClass(string? status) => status switch
    {
        "Processed" => "text-bg-success",
        "Failed" => "text-bg-danger",
        "Pending" => "text-bg-warning",
        _ => "text-bg-secondary"
    };

    string StatusLabel(string? status) => status switch
    {
        "Processed" => T.T("Processed"),
        "Failed" => T.T("Failed"),
        "Pending" => T.T("Pending"),
        _ => string.IsNullOrWhiteSpace(status) ? T.T("CommonUnclassified") : T.T(status)
    };
}

<div id="business-communications-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-inbox me-2"></i>@T.T("ProviderCallbackInboxTitle")</h1>
        <p class="text-muted mb-0">@T.T("ProviderCallbackInboxIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@BusinessCommunicationsUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommunicationOpsTitle")</a>
        <a asp-action="TemplatePreviews"
           class="btn btn-outline-secondary"
           hx-get="@TemplatePreviewsUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommunicationTemplatePreviewsTitle")</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@ProviderCallbacksUrl()"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("Total")</div>
                <div class="h4 mb-0">@Model.Summary.TotalCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-status="Pending" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@Url.Action("ProviderCallbacks", "BusinessCommunications", new { status = "Pending" })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("Pending")</div>
                <div class="h4 mb-0">@Model.Summary.PendingCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-failedOnly="true" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@Url.Action("ProviderCallbacks", "BusinessCommunications", new { failedOnly = true })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("Failed")</div>
                <div class="h4 mb-0">@Model.Summary.FailedCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-stalePendingOnly="true" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@Url.Action("ProviderCallbacks", "BusinessCommunications", new { stalePendingOnly = true })"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("StalePending")</div>
                <div class="h4 mb-0">@Model.Summary.StalePendingCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">@T.T("Processed")</div>
                <div class="h4 mb-0">@Model.Summary.ProcessedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">@T.T("Retried")</div>
                <div class="h4 mb-0">@Model.Summary.RetriedCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-provider="Brevo" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@FilteredProviderCallbacksUrl(provider: "Brevo")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoProviderCallbacks")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoTotalCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-provider="Brevo" asp-route-status="Pending" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@FilteredProviderCallbacksUrl(provider: "Brevo", status: "Pending")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoPendingCallbacks")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoPendingCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-provider="Brevo" asp-route-failedOnly="true" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@FilteredProviderCallbacksUrl(provider: "Brevo", failedOnly: true)"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoFailedCallbacks")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoFailedCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-provider="Brevo" asp-route-stalePendingOnly="true" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@FilteredProviderCallbacksUrl(provider: "Brevo", stalePendingOnly: true)"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoStalePendingCallbacks")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoStalePendingCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <a asp-action="ProviderCallbacks" asp-route-provider="Brevo" class="card text-decoration-none text-reset border-0 shadow-sm"
           hx-get="@FilteredProviderCallbacksUrl(provider: "Brevo")"
           hx-target="#business-communications-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoDeliveryFailureEvents")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoDeliveryFailureEventCount</div>
            </div>
        </a>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">@T.T("BrevoRecent24HourCallbacks")</div>
                <div class="h4 mb-0">@Model.Summary.BrevoRecent24HourCount</div>
            </div>
        </div>
    </div>
</div>

<form method="get"
      asp-action="ProviderCallbacks"
      class="card border-0 shadow-sm mb-4"
      hx-get="@ProviderCallbacksUrl()"
      hx-target="#business-communications-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="query">@T.T("Search")</label>
                <input class="form-control" id="query" name="query" value="@Model.Query" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="provider">@T.T("Provider")</label>
                <select class="form-select" id="provider" name="provider" asp-items="Model.ProviderItems"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label" for="status">@T.T("Status")</label>
                <select class="form-select" id="status" name="status" asp-items="Model.StatusItems"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label" for="pageSize">@T.T("PageSize")</label>
                <select class="form-select" id="pageSize" name="pageSize" asp-items="Model.PageSizeItems"></select>
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="stalePendingOnly" name="stalePendingOnly" value="true" checked="@Model.StalePendingOnly" />
                    <label class="form-check-label" for="stalePendingOnly">@T.T("StalePending")</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="failedOnly" name="failedOnly" value="true" checked="@Model.FailedOnly" />
                    <label class="form-check-label" for="failedOnly">@T.T("FailedOnly")</label>
                </div>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">@T.T("ApplyFilters")</button>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent fw-semibold">@T.T("ProviderCallbackInboxTitle")</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>@T.T("Provider")</th>
                    <th>@T.T("Type")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("IdempotencyKey")</th>
                    <th>@T.T("Attempts")</th>
                    <th>@T.T("Created")</th>
                    <th>@T.T("Payload")</th>
                    <th>@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted text-center py-4">@T.T("NoResults")</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    var rowVersion = Convert.ToBase64String(item.RowVersion);
                    <tr>
                        <td class="fw-semibold">@item.Provider</td>
                        <td>@item.CallbackType</td>
                        <td>
                            <span class="badge @StatusBadgeClass(item.Status)">@StatusLabel(item.Status)</span>
                            @if (item.IsStalePending)
                            {
                                <span class="badge text-bg-warning ms-1">@T.T("StalePending")</span>
                            }
                        </td>
                        <td><code>@(item.IdempotencyKey ?? T.T("CommonUnclassified"))</code></td>
                        <td>
                            <div>@item.AttemptCount</div>
                            @if (item.LastAttemptAtUtc.HasValue)
                            {
                                <div class="small text-muted">@T.T("LastAttempt"): @item.LastAttemptAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                            }
                        </td>
                        <td>
                            <div>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                            <div class="small text-muted">@item.AgeMinutes @T.T("Minutes")</div>
                            @if (item.ProcessedAtUtc.HasValue)
                            {
                                <div class="small text-muted">@T.T("Processed"): @item.ProcessedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                            }
                        </td>
                        <td>
                            <div class="small text-break">@item.PayloadPreview</div>
                            @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                            {
                                <div class="small text-danger mt-1">@item.FailureReason</div>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.Equals(item.Status, "Processed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form asp-action="UpdateProviderCallback" method="post"
                                          hx-post="@Url.Action("UpdateProviderCallback", "BusinessCommunications")"
                                          hx-target="#business-communications-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="rowVersion" value="@rowVersion" />
                                        <input type="hidden" name="action" value="MarkProcessed" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="query" value="@Model.Query" />
                                        <input type="hidden" name="provider" value="@Model.Provider" />
                                        <input type="hidden" name="status" value="@Model.Status" />
                                        <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="failedOnly" value="@Model.FailedOnly.ToString().ToLowerInvariant()" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">@T.T("MarkProcessed")</button>
                                    </form>
                                }
                                @if (!string.Equals(item.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form asp-action="UpdateProviderCallback" method="post"
                                          hx-post="@Url.Action("UpdateProviderCallback", "BusinessCommunications")"
                                          hx-target="#business-communications-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="rowVersion" value="@rowVersion" />
                                        <input type="hidden" name="action" value="Requeue" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="query" value="@Model.Query" />
                                        <input type="hidden" name="provider" value="@Model.Provider" />
                                        <input type="hidden" name="status" value="@Model.Status" />
                                        <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="failedOnly" value="@Model.FailedOnly.ToString().ToLowerInvariant()" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("Requeue")</button>
                                    </form>
                                }
                                @if (!string.Equals(item.Status, "Failed", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form asp-action="UpdateProviderCallback" method="post"
                                          class="d-flex gap-2"
                                          hx-post="@Url.Action("UpdateProviderCallback", "BusinessCommunications")"
                                          hx-target="#business-communications-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="rowVersion" value="@rowVersion" />
                                        <input type="hidden" name="action" value="MarkFailed" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="query" value="@Model.Query" />
                                        <input type="hidden" name="provider" value="@Model.Provider" />
                                        <input type="hidden" name="status" value="@Model.Status" />
                                        <input type="hidden" name="stalePendingOnly" value="@Model.StalePendingOnly.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="failedOnly" value="@Model.FailedOnly.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="failureReason" value="@T.T("ProviderCallbackMarkedFailedByOperator")" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("MarkFailed")</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    @if (totalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <div class="small text-muted">@T.T("Page") @Model.Page / @totalPages</div>
            <div class="btn-group">
                <a class="btn btn-sm btn-outline-secondary @(Model.Page <= 1 ? "disabled" : string.Empty)"
                   href="@CallbackPageUrl(Math.Max(1, Model.Page - 1))"
                   hx-get="@CallbackPageUrl(Math.Max(1, Model.Page - 1))"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Previous")</a>
                <a class="btn btn-sm btn-outline-secondary @(Model.Page >= totalPages ? "disabled" : string.Empty)"
                   href="@CallbackPageUrl(Math.Min(totalPages, Model.Page + 1))"
                   hx-get="@CallbackPageUrl(Math.Min(totalPages, Model.Page + 1))"
                   hx-target="#business-communications-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Next")</a>
            </div>
        </div>
    }
</div>
</div>
