@model Darwin.WebAdmin.ViewModels.Identity.RoleEditVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Darwin.WebAdmin
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div id="role-editor-shell">
    <h1 class="mb-3"><i class="fa fa-pen"></i> @T.T("EditRole")</h1>

    <form asp-action="Edit"
          method="post"
          class="needs-validation"
          novalidate
          hx-post="@Url.Action("Edit", "Roles")"
          hx-target="#role-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Key" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="IsSystem" />

        <div class="card mb-3">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@T.T("Key")</label>
                    <input class="form-control" value="@Model.Key" readonly />
                    <small class="text-muted">@T.T("ImmutableKeyHelp")</small>
                </div>

                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <field-help title="@T.T("DisplayName")" content="@T.T("AdminDisplayNameHelp")" placement="right"></field-help>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <field-help title="@T.T("Description")" content="@T.T("RoleDescriptionHelp")" placement="right"></field-help>
                    <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">@T.T("SystemRole")</label>
                    @if (Model.IsSystem)
                    {
                        <span class="badge bg-secondary"><i class="fa fa-lock"></i> @T.T("System")</span>
                    }
                    else
                    {
                        <span class="text-muted">@T.T("No")</span>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <div>
                @if (!Model.IsSystem)
                {
                    <button type="button"
                            class="btn btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#confirmDeleteModal"
                            data-action="@Url.Action("Delete", "Roles")"
                            data-id="@Model.Id"
                            data-rowversion="@Convert.ToBase64String(Model.RowVersion)"
                            data-name="@Model.DisplayName"
                            data-hx-target="#role-editor-shell"
                            data-hx-swap="outerHTML"
                            data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                        <i class="fa fa-trash"></i> @T.T("Delete")
                    </button>
                }
            </div>
            <div class="text-end">
                <a asp-action="Index"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Roles")"
                   hx-target="#role-editor-shell"
                   hx-swap="outerHTML"><i class="fa fa-arrow-left"></i> @T.T("Back")</a>
                <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
            </div>
        </div>
    </form>

    <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
