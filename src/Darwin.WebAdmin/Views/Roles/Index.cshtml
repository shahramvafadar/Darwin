@model Darwin.WebAdmin.ViewModels.Identity.RolesListItemVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Darwin.WebAdmin
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

@{
    ViewData["Title"] = T.T("Roles");
    string RolesGlobalIndexUrl() => Url.Action("Index", "Roles") ?? string.Empty;
    string RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter filter) => Url.Action("Index", "Roles", new { filter }) ?? string.Empty;
    string CreateRoleUrl() => Url.Action("Create", "Roles") ?? string.Empty;
    string EditRoleUrl(Guid id) => Url.Action("Edit", "Roles", new { id }) ?? string.Empty;
    string RolePermissionsUrl(Guid id) => Url.Action("Permissions", "Roles", new { id }) ?? string.Empty;
}

<div id="roles-workspace-shell">
    <h1 class="mb-3"><i class="fa fa-user-shield"></i> @T.T("Roles")</h1>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Total")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.All"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.All)"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("System")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.SystemCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.System"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.System)"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterSystem")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Custom")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.CustomCount</div>
                    <div class="mt-2 d-flex gap-2 flex-wrap">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.Custom"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.Custom)"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterCustom")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreateRoleUrl()"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML">@T.T("NewRole")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("DelegatedSupport")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.DelegatedSupportCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.DelegatedSupport"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.DelegatedSupport)"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterDelegatedSupport")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3 border-info-subtle">
        <div class="card-body">
            <h2 class="h6 mb-2">@T.T("RoleOpsPlaybook")</h2>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("RoleOpsPlaybookSystem")</span>
                    <a asp-action="Index"
                       asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.System"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.System)"
                       hx-target="#roles-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Open")</a>
                </div>
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("RoleOpsPlaybookDelegatedSupport")</span>
                    <a asp-action="Index"
                       asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.DelegatedSupport"
                       class="btn btn-sm btn-outline-info"
                       hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.DelegatedSupport)"
                       hx-target="#roles-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Open")</a>
                </div>
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("RoleOpsPlaybookCustom")</span>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.Custom"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@RolesIndexUrl(Darwin.WebAdmin.ViewModels.Identity.RoleQueueFilter.Custom)"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreateRoleUrl()"
                           hx-target="#roles-workspace-shell"
                           hx-swap="outerHTML">@T.T("NewRole")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get"
                  class="row g-2 align-items-end"
               hx-get="@RolesGlobalIndexUrl()"
                  hx-target="#roles-workspace-shell"
                  hx-swap="outerHTML">
                <div class="col-md-4">
                    <label class="form-label" for="q">@T.T("Search")</label>
                    <field-help title="@T.T("Search")" content="@T.T("RoleSearchHelp")" placement="right"></field-help>
                    <input type="text" id="q" name="q" value="@Model.Query" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="pageSize">@T.T("PageSize")</label>
                    <select id="pageSize" name="pageSize" class="form-select" asp-items="Model.PageSizeItems"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="filter">@T.T("Queue")</label>
                    <select id="filter" name="filter" class="form-select" asp-items="Model.FilterItems"></select>
                </div>
                <div class="col-md-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="fa fa-search"></i> @T.T("Search")
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary"
       hx-get="@RolesGlobalIndexUrl()"
                       hx-target="#roles-workspace-shell"
                       hx-swap="outerHTML">@T.T("Reset")</a>
                    <a asp-action="Create"
                       class="btn btn-primary"
                       hx-get="@CreateRoleUrl()"
                       hx-target="#roles-workspace-shell"
                       hx-swap="outerHTML">
                        <i class="fa fa-plus"></i> @T.T("NewRole")
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@T.T("DisplayName")</th>
                            <th>@T.T("Description")</th>
                    <th class="admin-w-120">@T.T("System")</th>
                    <th class="text-end admin-w-290">@T.T("Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted p-4">@T.T("NoRolesFound")</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var r in Model.Items)
                            {
                                <tr>
                                    <td>@r.DisplayName</td>
                                    <td>@(string.IsNullOrWhiteSpace(r.Description) ? "-" : r.Description)</td>
                                    <td>
                                        @if (r.IsSystem)
                                        {
                                            <span class="badge bg-secondary"><i class="fa fa-lock"></i> @T.T("System")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@T.T("No")</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (string.Equals(r.Key, "business-support-admins", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-info text-dark me-2">@T.T("DelegatedSupport")</span>
                                        }
                                        <a asp-action="Edit"
                                           asp-route-id="@r.Id"
                                           class="btn btn-sm btn-outline-primary me-1"
                                           hx-get="@EditRoleUrl(r.Id)"
                                           hx-target="#roles-workspace-shell"
                                           hx-swap="outerHTML">
                                            <i class="fa fa-pen"></i> @T.T("Edit")
                                        </a>

                                        <a asp-controller="Roles"
                                           asp-action="Permissions"
                                           asp-route-id="@r.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           hx-get="@RolePermissionsUrl(r.Id)"
                                           hx-target="#roles-workspace-shell"
                                           hx-swap="outerHTML">
                                            <i class="fa fa-shield-alt"></i> @T.T("Permissions")
                                        </a>

                                        @if (!r.IsSystem)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#confirmDeleteModal"
                                                    data-action="@Url.Action("Delete", "Roles")"
                                                    data-id="@r.Id"
                                                    data-name="@r.DisplayName"
                                                    data-rowversion="@Convert.ToBase64String(r.RowVersion)"
                                                    data-hx-target="#roles-workspace-shell"
                                                    data-hx-swap="outerHTML"
                                   >
                                                <i class="fa fa-trash"></i> @T.T("Delete")
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Roles"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#roles-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
    </pager>
</div>

@* shared confirmation modal (already exists in project) *@
<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
