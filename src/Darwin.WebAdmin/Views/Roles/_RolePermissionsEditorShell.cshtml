@model Darwin.WebAdmin.ViewModels.Identity.RolePermissionsEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditRolePermissions");
    string GlobalBusinessSupportQueueUrl() => Url.Action("SupportQueue", "Businesses") ?? string.Empty;
    string RolesIndexUrl() => Url.Action("Index", "Roles") ?? string.Empty;
    string DelegatedSupportPermissionsUrl() => Url.Action("Index", "Permissions", new { filter = Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport }) ?? string.Empty;
    string UnconfirmedUsersUrl() => Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed }) ?? string.Empty;
    string LockedUsersUrl() => Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Locked }) ?? string.Empty;
}

<div id="role-permissions-workspace-shell">
    <h1 class="mb-3">
        <i class="fa fa-lock"></i> @T.T("PermissionsForRole") - @Model.RoleDisplayName
    </h1>

    <div id="alerts-container">
        <partial name="~/Views/Shared/_Alerts.cshtml" />
    </div>

    <div class="card mb-3 border-info-subtle">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Permissions"
                   asp-action="Index"
                   asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport"
                   class="btn btn-sm btn-outline-info"
                   hx-get="@DelegatedSupportPermissionsUrl()"
                   hx-target="#role-permissions-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("IdentityFilterDelegatedSupport")</a>
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@GlobalBusinessSupportQueueUrl()"
                   hx-target="#role-permissions-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@UnconfirmedUsersUrl()"
                   hx-target="#role-permissions-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@LockedUsersUrl()"
                   hx-target="#role-permissions-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterLocked")</a>
            </div>
        </div>
    </div>

    <form asp-action="Permissions"
          method="post"
          class="row g-3"
          hx-post="@Url.Action("Permissions", "Roles")"
          hx-target="#role-permissions-workspace-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RoleId" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="col-12">
            <div class="card">
                <div class="card-header">@T.T("Permissions")</div>
                <div class="card-body">
                    @if (Model.AllPermissions?.Count > 0)
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-2">
                            @foreach (var p in Model.AllPermissions)
                            {
                                var isChecked = Model.SelectedPermissionIds?.Contains(p.Id) == true;
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedPermissionIds"
                                               value="@p.Id"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label">
                                            <strong>@p.DisplayName</strong>
                                            <small class="text-muted d-block">@p.Key - @p.Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">@T.T("NoPermissionsFound")</div>
                    }
                </div>
                <div class="card-footer text-end">
                    <a asp-controller="Roles"
                       asp-action="Index"
                       class="btn btn-outline-secondary"
                       hx-get="@RolesIndexUrl()"
                       hx-target="#role-permissions-workspace-shell"
                       hx-swap="outerHTML">
                        <i class="fa fa-arrow-left"></i> @T.T("Back")
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-check"></i> @T.T("Save")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
