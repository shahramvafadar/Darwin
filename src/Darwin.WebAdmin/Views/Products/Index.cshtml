@model Darwin.WebAdmin.ViewModels.Catalog.ProductsIndexVm
@{
    ViewData["Title"] = T.T("Products");
    var currentPage = Model.Page;
    var currentPageSize = Model.PageSize;
    var total = Model.Total;
    var query = Model.Query;
    var filter = Model.Filter;
    string ProductsIndexUrl(string? query = null, string? filter = null) => Url.Action("Index", "Products", new { query, filter }) ?? string.Empty;
    string ProductsCreateUrl() => Url.Action("Create", "Products") ?? string.Empty;
    string ProductsEditUrl(Guid id) => Url.Action("Edit", "Products", new { id }) ?? string.Empty;
    string FormatTimestamp(DateTime? timestampUtc) => timestampUtc?.ToLocalTime().ToString(System.Globalization.CultureInfo.CurrentCulture) ?? "-";
}

<div id="products-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
    <div>
        <h1 class="m-0">@T.T("Products")</h1>
        <div class="small text-muted mt-1">@T.T("ProductsWorkspaceIntro")</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2"
              hx-get="@ProductsIndexUrl()"
              hx-target="#products-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <input type="text" name="query" value="@query" class="form-control" placeholder="@T.T("SearchProductsPlaceholder")" />
            <input type="hidden" name="filter" value="@filter" />
            <button class="btn btn-outline-secondary" type="submit">
                <i class="fa fa-search"></i> @T.T("Search")
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary"
               hx-get="@ProductsIndexUrl()"
               hx-target="#products-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Reset")</a>
        </form>
        <a asp-action="Create" class="btn btn-primary"
           hx-get="@ProductsCreateUrl()"
           hx-target="#products-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CreateProduct")</a>
    </div>
</div>

<div class="admin-kpi-row mb-3">
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("Products")</span>
        <strong>@Model.Summary.TotalCount</strong>
        <field-help title="@T.T("Products")" content="@T.T("ProductsOpsTotalNote")" placement="bottom"></field-help>
    </div>
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("Inactive")</span>
        <strong>@Model.Summary.InactiveCount</strong>
        <field-help title="@T.T("Inactive")" content="@T.T("ProductsOpsInactiveNote")" placement="bottom"></field-help>
    </div>
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("Hidden")</span>
        <strong>@Model.Summary.HiddenCount</strong>
        <field-help title="@T.T("Hidden")" content="@T.T("ProductsOpsHiddenNote")" placement="bottom"></field-help>
    </div>
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("Scheduled")</span>
        <strong>@Model.Summary.ScheduledCount</strong>
        <field-help title="@T.T("Scheduled")" content="@T.T("ProductsOpsScheduledNote")" placement="bottom"></field-help>
    </div>
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("SingleVariant")</span>
        <strong>@Model.Summary.SingleVariantCount</strong>
        <field-help title="@T.T("SingleVariant")" content="@T.T("ProductsOpsSingleVariantNote")" placement="bottom"></field-help>
    </div>
    <div class="admin-kpi-item">
        <span class="text-muted small">@T.T("ActiveCatalogWindow")</span>
        <strong>@(Model.Summary.TotalCount - Model.Summary.HiddenCount)</strong>
        <field-help title="@T.T("ActiveCatalogWindow")" content="@T.T("ProductsOpsVisibilityWindowNote")" placement="bottom"></field-help>
    </div>
</div>

<details class="admin-playbook mb-4">
    <summary>@T.T("CatalogOperationsPlaybooks")</summary>
    <div class="admin-playbook-body">
        @foreach (var playbook in Model.Playbooks)
        {
            <div class="rounded border p-3 bg-light-subtle">
                <div class="fw-semibold">@playbook.QueueLabel</div>
                <div class="small text-muted mt-2">@playbook.WhyItMatters</div>
                <div class="small mt-2"><strong>@T.T("OperatorAction"):</strong> @playbook.OperatorAction</div>
            </div>
        }
    </div>
</details>

<div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index" asp-route-query="@query" class="btn @(string.IsNullOrEmpty(filter) ? "btn-primary" : "btn-outline-primary")"
           hx-get="@ProductsIndexUrl(query)" hx-target="#products-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("All")</a>
        <a asp-action="Index" asp-route-query="@query" asp-route-filter="inactive" class="btn @(filter == "inactive" ? "btn-primary" : "btn-outline-primary")"
           hx-get="@ProductsIndexUrl(query, "inactive")" hx-target="#products-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Inactive")</a>
        <a asp-action="Index" asp-route-query="@query" asp-route-filter="hidden" class="btn @(filter == "hidden" ? "btn-primary" : "btn-outline-primary")"
           hx-get="@ProductsIndexUrl(query, "hidden")" hx-target="#products-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Hidden")</a>
        <a asp-action="Index" asp-route-query="@query" asp-route-filter="single-variant" class="btn @(filter == "single-variant" ? "btn-primary" : "btn-outline-primary")"
           hx-get="@ProductsIndexUrl(query, "single-variant")" hx-target="#products-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("SingleVariant")</a>
        <a asp-action="Index" asp-route-query="@query" asp-route-filter="scheduled" class="btn @(filter == "scheduled" ? "btn-primary" : "btn-outline-primary")"
           hx-get="@ProductsIndexUrl(query, "scheduled")" hx-target="#products-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Scheduled")</a>
    </div>
    <div class="text-muted small">@T.T("TotalProductsLabel"): @Model.Summary.TotalCount</div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("ProductNameDefaultCulture")</th>
                        <th class="text-center">@T.T("Variants")</th>
                        <th class="text-center">@T.T("Active")</th>
                        <th class="text-center">@T.T("Visible")</th>
                        <th>@T.T("Modified")</th>
                        <th class="text-end">@T.T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">@T.T("NoProductsFound")</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var p in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(p.DefaultName) ? "-" : p.DefaultName)</div>
                                    @if (p.PublishStartUtc != null || p.PublishEndUtc != null)
                                    {
                                        <div class="small text-muted">@T.T("CatalogWindowLabel"): @FormatTimestamp(p.PublishStartUtc) @T.T("To") @FormatTimestamp(p.PublishEndUtc)</div>
                                    }
                                </td>
                                <td class="text-center"><span class="badge bg-secondary">@p.VariantCount</span></td>
                                <td class="text-center">
                                    @if (p.IsActive)
                                    {
                                        <span class="badge bg-success">@T.T("Yes")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-outline-secondary border">@T.T("No")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (p.IsVisible)
                                    {
                                        <span class="badge bg-success">@T.T("Yes")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-outline-secondary border">@T.T("No")</span>
                                    }
                                </td>
                                <td class="text-nowrap text-muted small">@FormatTimestamp(p.ModifiedAtUtc)</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"
                                       hx-get="@ProductsEditUrl(p.Id)"
                                       hx-target="#products-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">
                                        <i class="fas fa-edit"></i> @T.T("Edit")
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger ms-1"
                                            data-bs-toggle="modal"
                                            data-bs-target="#confirmDeleteModal"
                                            data-action="@Url.Action("Delete", "Products")"
                                            data-id="@p.Id"
                                            data-rowversion="@Convert.ToBase64String(p.RowVersion)"
                                            data-name="@(string.IsNullOrWhiteSpace(p.DefaultName) ? p.Id.ToString() : p.DefaultName)"
                                            data-hx-target="#products-workspace-shell"
                                            data-hx-swap="outerHTML"
                                   >
                                        <i class="fas fa-trash-alt"></i> @T.T("Delete")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <pager page="@currentPage"
               page-size="@currentPageSize"
               total="@total"
               asp-controller="Products"
               asp-action="Index"
               asp-route-query="@query"
               asp-route-filter="@filter"
               hx-target="#products-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true"></pager>

        <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
    </div>
</div>
</div>
