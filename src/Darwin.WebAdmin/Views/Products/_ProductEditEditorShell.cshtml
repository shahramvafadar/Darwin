@model Darwin.WebAdmin.ViewModels.Catalog.ProductEditVm
@{
    ViewData["Title"] = T.T("EditProduct");
}

<div id="product-editor-shell"
     data-product-description-placeholder="@T.T("ProductDescriptionPlaceholder")">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
        <div>
            <h1 class="m-0">@T.T("EditProduct")</h1>
            <div class="small text-muted mt-1">@T.T("ProductEditIntro")</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <div class="badge text-bg-light border">@T.T("Translations"): @Model.Translations.Count</div>
            <div class="badge text-bg-light border">@T.T("Variants"): @Model.Variants.Count</div>
            <div class="badge text-bg-light border">@T.T("ProductIdentifier"): @Model.Id</div>
        </div>
    </div>

    <form asp-action="Edit"
          method="post"
          hx-post="@Url.Action("Edit", "Products")"
          hx-target="#product-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        <partial name="_ProductForm" model="Model" />
    </form>
</div>
