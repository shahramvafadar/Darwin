@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyProgramsListVm
@{
    ViewData["Title"] = "Loyalty Programs";
}

<div id="loyalty-programs-workspace-shell">
    <h1 class="mb-3">Loyalty Programs</h1>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form asp-action="Programs"
              method="get"
              class="d-flex gap-2"
              hx-get="@Url.Action("Programs", "Loyalty")"
              hx-target="#loyalty-programs-workspace-shell"
              hx-swap="outerHTML">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            <button class="btn btn-outline-secondary" type="submit">Filter</button>
            <a asp-action="Programs"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Programs", "Loyalty")"
               hx-target="#loyalty-programs-workspace-shell"
               hx-swap="outerHTML">Reset</a>
        </form>
        <div class="d-flex gap-2">
            <a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
               hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">Campaigns</a>
            <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
               hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">Scan Sessions</a>
            <a asp-action="CreateProgram" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
               hx-get="@Url.Action("CreateProgram", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">New Program</a>
        </div>
    </div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Total</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
    <div class="col-md-3"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">Active</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-secondary-subtle"><div class="card-body"><div class="text-muted small">Inactive</div><div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">Spend-based</div><div class="fs-4 fw-semibold">@Model.Summary.PerCurrencyUnitCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">Missing Rules</div><div class="fs-4 fw-semibold">@Model.Summary.MissingRulesCount</div></div></div></div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Loyalty Program Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead><tr><th>Playbook</th><th>When It Applies</th><th>Operator Action</th></tr></thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

    <form asp-action="Programs"
          method="get"
          class="d-flex gap-2 mb-3"
          hx-get="@Url.Action("Programs", "Loyalty")"
          hx-target="#loyalty-programs-workspace-shell"
          hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="Programs"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Programs", "Loyalty")"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </form>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="Active"
           class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.Active ? "btn-success" : "btn-outline-success")"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId, filter = "Active" })"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Active</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="Inactive"
           class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.Inactive ? "btn-secondary" : "btn-outline-secondary")"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId, filter = "Inactive" })"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Inactive</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="PerCurrencyUnit"
           class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.PerCurrencyUnit ? "btn-info" : "btn-outline-info")"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId, filter = "PerCurrencyUnit" })"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Spend-based</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="MissingRules"
           class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.MissingRules ? "btn-warning" : "btn-outline-warning")"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId, filter = "MissingRules" })"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Missing Rules</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-programs-workspace-shell"
           hx-swap="outerHTML">Clear Queue Filters</a>
    </div>
<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Name</th><th>Accrual</th><th>Status</th><th>Updated</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">No loyalty programs found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.AccrualMode</td>
                    <td>
                        <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "Active" : "Inactive")</span>
                        @if (item.AccrualMode == Darwin.Domain.Enums.LoyaltyAccrualMode.PerCurrencyUnit)
                        {
                            <div><span class="badge text-bg-info mt-1">Spend-based</span></div>
                        }
                    </td>
                    <td>@(item.ModifiedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = item.Id })" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">Rewards</a>
                        <a asp-action="EditProgram" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditProgram", "Loyalty", new { id = item.Id })" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">Edit</a>
                        <form asp-action="DeleteProgram" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="businessId" value="@item.BusinessId" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Programs" asp-route-businessId="@Model.BusinessId"></pager>
</div>
