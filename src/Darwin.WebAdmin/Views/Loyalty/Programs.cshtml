@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyProgramsListVm
@{
    ViewData["Title"] = T.T("LoyaltyProgramsTitle");
    string LocalizeAccrualMode(object? accrualMode) => accrualMode is null ? "-" : T.T(accrualMode.ToString() ?? string.Empty);
    string ProgramsUrl(object? businessId = null, string? filter = null) => Url.Action("Programs", "Loyalty", new { businessId, filter }) ?? string.Empty;
    string CampaignsUrl(object? businessId = null) => Url.Action("Campaigns", "Loyalty", new { businessId }) ?? string.Empty;
    string ScanSessionsUrl(object? businessId = null) => Url.Action("ScanSessions", "Loyalty", new { businessId }) ?? string.Empty;
    string CreateProgramUrl(object? businessId = null) => Url.Action("CreateProgram", "Loyalty", new { businessId }) ?? string.Empty;
    string RewardTiersUrl(Guid loyaltyProgramId) => Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId }) ?? string.Empty;
    string EditProgramUrl(Guid id) => Url.Action("EditProgram", "Loyalty", new { id }) ?? string.Empty;
}

<div id="loyalty-programs-workspace-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />
    <h1 class="mb-3">@T.T("LoyaltyProgramsTitle")</h1>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <form asp-action="Programs" method="get" class="d-flex gap-2" hx-get="@ProgramsUrl()" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
            <a asp-action="Programs" class="btn btn-outline-secondary" hx-get="@ProgramsUrl()" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a>
        </form>
        <div class="d-flex gap-2">
            <a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@CampaignsUrl(Model.BusinessId)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Campaigns")</a>
            <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@ScanSessionsUrl(Model.BusinessId)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyScanSessionsTitle")</a>
            <a asp-action="CreateProgram" asp-route-businessId="@Model.BusinessId" class="btn btn-primary" hx-get="@CreateProgramUrl(Model.BusinessId)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyNewProgram")</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md-3"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("Active")</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-secondary-subtle"><div class="card-body"><div class="text-muted small">@T.T("Inactive")</div><div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltySpendBased")</div><div class="fs-4 fw-semibold">@Model.Summary.PerCurrencyUnitCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltyMissingRules")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingRulesCount</div></div></div></div>
    </div>

    @if (Model.Playbooks.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">@T.T("LoyaltyProgramPlaybooks")</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead><tr><th>@T.T("Playbook")</th><th>@T.T("WhenItApplies")</th><th>@T.T("OperatorAction")</th></tr></thead>
                    <tbody>
                    @foreach (var playbook in Model.Playbooks)
                    {
                        <tr><td class="fw-semibold">@playbook.Title</td><td>@playbook.ScopeNote</td><td>@playbook.OperatorAction</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <form asp-action="Programs" method="get" class="d-flex gap-2 mb-3" hx-get="@ProgramsUrl()" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="Programs" class="btn btn-outline-secondary" hx-get="@ProgramsUrl()" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a>
    </form>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="Active" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.Active ? "btn-success" : "btn-outline-success")" hx-get="@ProgramsUrl(Model.BusinessId, "Active")" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Active")</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="Inactive" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.Inactive ? "btn-secondary" : "btn-outline-secondary")" hx-get="@ProgramsUrl(Model.BusinessId, "Inactive")" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Inactive")</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="PerCurrencyUnit" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.PerCurrencyUnit ? "btn-info" : "btn-outline-info")" hx-get="@ProgramsUrl(Model.BusinessId, "PerCurrencyUnit")" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltySpendBased")</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" asp-route-filter="MissingRules" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyProgramQueueFilter.MissingRules ? "btn-warning" : "btn-outline-warning")" hx-get="@ProgramsUrl(Model.BusinessId, "MissingRules")" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyMissingRules")</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@ProgramsUrl(Model.BusinessId)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyClearQueueFilters")</a>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>@T.T("Name")</th><th>@T.T("LoyaltyAccrual")</th><th>@T.T("Status")</th><th>@T.T("Updated")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted">@T.T("LoyaltyNoProgramsFound")</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@LocalizeAccrualMode(item.AccrualMode)</td>
                        <td>
                            <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? T.T("Active") : T.T("Inactive"))</span>
                            @if (item.AccrualMode == Darwin.Domain.Enums.LoyaltyAccrualMode.PerCurrencyUnit)
                            {
                                <div><span class="badge text-bg-info mt-1">@T.T("LoyaltySpendBased")</span></div>
                            }
                        </td>
                        <td>@(item.ModifiedAtUtc?.ToLocalTime().ToString(System.Globalization.CultureInfo.CurrentCulture) ?? "-")</td>
                        <td class="text-end">
                            <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@item.Id" class="btn btn-sm btn-outline-primary" hx-get="@RewardTiersUrl(item.Id)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyRewards")</a>
                            <a asp-action="EditProgram" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" hx-get="@EditProgramUrl(item.Id)" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">@T.T("Edit")</a>
                            <form asp-action="DeleteProgram" method="post" class="d-inline" hx-post="@Url.Action("DeleteProgram", "Loyalty")" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Delete")</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Programs" asp-route-businessId="@Model.BusinessId" hx-target="#loyalty-programs-workspace-shell" hx-swap="outerHTML"></pager>
</div>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

