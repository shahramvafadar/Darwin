@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyProgramEditVm
@{
    var isCreate = ViewData["IsCreate"] as bool? == true;
    ViewData["Title"] = isCreate ? "Create Loyalty Program" : "Edit Loyalty Program";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@(isCreate ? "Create Loyalty Program" : "Edit Loyalty Program")</h1>
</div>

<partial name="_ProgramForm" model="Model" />
