@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyCampaignEditVm
@{
    string LocalizeCampaignState(object? state) => state is null ? "-" : T.T(state.ToString() ?? string.Empty);
    string CampaignsUrl(object? businessId = null) => Url.Action("Campaigns", "Loyalty", new { businessId }) ?? string.Empty;
}
<form asp-action="@(ViewData["IsCreate"] as bool? == true ? "CreateCampaign" : "EditCampaign")"
      method="post"
      hx-post="@Url.Action(ViewData["IsCreate"] as bool? == true ? "CreateCampaign" : "EditCampaign", "Loyalty")"
      hx-target="#loyalty-campaign-editor-shell"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    @if (ViewData["IsCreate"] as bool? != true)
    {
        <input asp-for="Id" type="hidden" />
        <input asp-for="RowVersion" type="hidden" />
    }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyCampaignIdentitySection")</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="BusinessId" class="form-label"></label>
                <field-help title="@T.T("Business")" content="@T.T("LoyaltyCampaignBusinessHelp")" placement="right"></field-help>
                <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="Name" class="form-label"></label>
                <field-help title="@T.T("Name")" content="@T.T("LoyaltyCampaignNameHelp")" placement="right"></field-help>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Channels" class="form-label"></label>
                <field-help title="@T.T("Channels")" content="@T.T("LoyaltyCampaignChannelsHelp")" placement="right"></field-help>
                <select asp-for="Channels" asp-items="Model.ChannelItems" class="form-select"></select>
            </div>
            @if (ViewData["IsCreate"] as bool? != true)
            {
                <div class="col-md-4">
                    <label asp-for="CampaignState" class="form-label"></label>
                    <field-help title="@T.T("CampaignState")" content="@T.T("LoyaltyCampaignStateHelp")" placement="right"></field-help>
                    <input asp-for="CampaignState" type="hidden" />
                    <input value="@LocalizeCampaignState(Model.CampaignState)" class="form-control" readonly />
                </div>
            }
        </div>
    </section>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyCampaignContentSection")</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Title" class="form-label"></label>
                <field-help title="@T.T("Title")" content="@T.T("LoyaltyCampaignTitleHelp")" placement="right"></field-help>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Subtitle" class="form-label"></label>
                <field-help title="@T.T("Subtitle")" content="@T.T("LoyaltyCampaignSubtitleHelp")" placement="right"></field-help>
                <input asp-for="Subtitle" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="MediaUrl" class="form-label"></label>
                <field-help title="@T.T("MediaUrl")" content="@T.T("LoyaltyCampaignMediaUrlHelp")" placement="right"></field-help>
                <input asp-for="MediaUrl" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="LandingUrl" class="form-label"></label>
                <field-help title="@T.T("LandingUrl")" content="@T.T("LoyaltyCampaignLandingUrlHelp")" placement="right"></field-help>
                <input asp-for="LandingUrl" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Body" class="form-label"></label>
                <field-help title="@T.T("Body")" content="@T.T("LoyaltyCampaignBodyHelp")" placement="right"></field-help>
                <textarea asp-for="Body" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyCampaignSchedulingSection")</h2>
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="StartsAtUtc" class="form-label"></label>
                <field-help title="@T.T("StartsAtUtc")" content="@T.T("LoyaltyCampaignStartsAtUtcHelp")" placement="right"></field-help>
                <input asp-for="StartsAtUtc" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="EndsAtUtc" class="form-label"></label>
                <field-help title="@T.T("EndsAtUtc")" content="@T.T("LoyaltyCampaignEndsAtUtcHelp")" placement="right"></field-help>
                <input asp-for="EndsAtUtc" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" />
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyCampaignRulesSection")</h2>
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="TargetingJson" class="form-label"></label>
                <field-help title="@T.T("TargetingJson")" content="@T.T("LoyaltyTargetingJsonHelp")" placement="right"></field-help>
                <textarea asp-for="TargetingJson" class="form-control" rows="4"></textarea>
            </div>
            <div class="col-12">
                <label asp-for="PayloadJson" class="form-label"></label>
                <field-help title="@T.T("PayloadJson")" content="@T.T("LoyaltyPayloadJsonHelp")" placement="right"></field-help>
                <textarea asp-for="PayloadJson" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </section>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@(ViewData["IsCreate"] as bool? == true ? T.T("Create") : T.T("Save"))</button>
        <a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@CampaignsUrl(Model.BusinessId)" hx-target="#loyalty-campaign-editor-shell" hx-swap="outerHTML">@T.T("Back")</a>
    </div>
</form>
