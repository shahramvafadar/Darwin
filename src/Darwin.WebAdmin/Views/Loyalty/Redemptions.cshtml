@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyRedemptionsListVm
@{
    ViewData["Title"] = "Loyalty Redemptions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Loyalty Redemptions</h1>
        <div class="text-muted">Review pending and completed reward redemptions across businesses.</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Accounts</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Scan Sessions</a>
    </div>
</div>

<form asp-action="Redemptions" method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search member, reward, or outcome" />
    </div>
    <div class="col-md-3">
        <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        <a asp-action="Redemptions" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.StatusFilter is null ? "btn-dark" : "btn-outline-dark")">All</a>
    <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyRedemptionStatus.Pending" class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyRedemptionStatus.Pending ? "btn-warning" : "btn-outline-warning")">Pending</a>
    <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyRedemptionStatus.Completed" class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyRedemptionStatus.Completed ? "btn-success" : "btn-outline-success")">Completed</a>
    <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyRedemptionStatus.Cancelled" class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyRedemptionStatus.Cancelled ? "btn-secondary" : "btn-outline-secondary")">Cancelled</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Member</th><th>Reward</th><th>Status</th><th>Scan</th><th>When</th><th>Note</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">No loyalty redemptions found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div>@item.ConsumerDisplayName</div>
                        <div class="small text-muted">@item.ConsumerEmail</div>
                    </td>
                    <td>
                        <div>@item.RewardLabel</div>
                        <div class="small text-muted">@item.PointsSpent pts</div>
                    </td>
                    <td>@item.Status</td>
                    <td>
                        <div>@(item.ScanStatus?.ToString() ?? "-")</div>
                        <div class="small text-muted">@(!string.IsNullOrWhiteSpace(item.ScanOutcome) ? item.ScanOutcome : "-")</div>
                    </td>
                    <td>@item.RedeemedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="small text-muted">@(string.IsNullOrWhiteSpace(item.Note) ? item.ScanFailureReason ?? "-" : item.Note)</td>
                    <td class="text-end">
                        <a asp-action="AccountDetails" asp-route-id="@item.LoyaltyAccountId" class="btn btn-sm btn-outline-primary">Account</a>
                        @if (item.Status == Darwin.Domain.Enums.LoyaltyRedemptionStatus.Pending)
                        {
                            <form asp-action="ConfirmRedemption" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="redemptionId" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <input type="hidden" name="loyaltyAccountId" value="@item.LoyaltyAccountId" />
                                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <button type="submit" class="btn btn-sm btn-outline-success">Confirm</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-status="@Model.StatusFilter"></pager>
