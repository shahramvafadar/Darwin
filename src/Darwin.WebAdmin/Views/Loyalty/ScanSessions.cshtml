@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyScanSessionsListVm
@{
    ViewData["Title"] = T.T("LoyaltyScanSessionsTitle");

    string LocalizeScanMode(object? mode) => mode is null ? "-" : T.T(mode.ToString() ?? string.Empty);
    string LocalizeScanStatus(Darwin.Domain.Enums.LoyaltyScanStatus status) => T.T(status.ToString());
    string LocalizeScanOutcome(string? outcome) => string.IsNullOrWhiteSpace(outcome) ? "-" : T.T(outcome);
    string LocalizeScanFailureReason(string? reason) => reason switch
    {
        "TokenAlreadyConsumed" => T.T("TokenAlreadyConsumed"),
        "Token was consumed concurrently by another request." => T.T("TokenAlreadyConsumed"),
        "AccountNotFound" => T.T("AccountNotFound"),
        "Loyalty account for scan session not found." => T.T("AccountNotFound"),
        "AccountNotActive" => T.T("AccountNotActive"),
        "Loyalty account is not active." => T.T("AccountNotActive"),
        "Expired" => T.T("Expired"),
        "Session expired before accrual confirmation." => T.T("Expired"),
        "Session expired before redemption confirmation." => T.T("Expired"),
        "Session expired before use." => T.T("Expired"),
        "NoSelections" => T.T("NoSelections"),
        "Scan session does not contain any selected rewards." => T.T("NoSelections"),
        "InvalidSelections" => T.T("InvalidSelections"),
        "Selected rewards do not require any points." => T.T("InvalidSelections"),
        "InsufficientPoints" => T.T("InsufficientPoints"),
        "Account does not have enough points at confirmation time." => T.T("InsufficientPoints"),
        _ => string.IsNullOrWhiteSpace(reason) ? "-" : T.T(reason)
    };
    var loyaltyCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LoyaltyDateTimeText(DateTime? utc) => utc?.ToString("g", loyaltyCulture) ?? "-";
    string ScanSessionsUrl(object? businessId = null, string? q = null, Darwin.Domain.Enums.LoyaltyScanMode? mode = null, Darwin.Domain.Enums.LoyaltyScanStatus? status = null) => Url.Action("ScanSessions", "Loyalty", new { businessId, q, mode, status }) ?? string.Empty;
    string ExpireScanSessionUrl() => Url.Action("ExpireScanSession", "Loyalty") ?? string.Empty;
    string ExpireExpiredScanSessionsUrl() => Url.Action("ExpireExpiredScanSessions", "Loyalty") ?? string.Empty;
    string RedemptionsUrl(object? businessId = null) => Url.Action("Redemptions", "Loyalty", new { businessId }) ?? string.Empty;
    string MobileOperationsUrl(object? businessId = null, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string ProviderReviewUrl() => Url.Action("ChannelAudits", "BusinessCommunications", new { providerReviewOnly = true }) ?? string.Empty;
}

<div id="loyalty-scan-sessions-workspace-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">@T.T("LoyaltyScanSessionsTitle")</h1>
            <div class="text-muted">@T.T("LoyaltyScanSessionsIntro")</div>
        </div>
        <div class="d-flex gap-2">
            @if (Model.BusinessId.HasValue)
            {
                <form asp-action="ExpireExpiredScanSessions" method="post" class="d-inline" hx-post="@ExpireExpiredScanSessionsUrl()" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                    <button type="submit" class="btn btn-outline-warning">@T.T("LoyaltyExpireStaleScanSessions")</button>
                </form>
            }
            <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@RedemptionsUrl(Model.BusinessId)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("Redemptions")</a>
            <a asp-controller="MobileOperations" asp-action="Index" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@MobileOperationsUrl(Model.BusinessId)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyMobileOps")</a>
            <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-providerReviewOnly="true" class="btn btn-outline-secondary" hx-get="@ProviderReviewUrl()" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("ProviderReview")</a>
        </div>
    </div>

    <form asp-action="ScanSessions" method="get" class="row g-2 mb-3" hx-get="@ScanSessionsUrl()" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">
        <div class="col-md-3">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("LoyaltySearchCustomerOrOutcome")" />
        </div>
        <div class="col-md-2">
            <select name="mode" asp-items="Model.ModeItems" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">@T.T("Filter")</button>
            <a asp-action="ScanSessions" class="btn btn-outline-secondary" hx-get="@ScanSessionsUrl()" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a>
        </div>
    </form>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-mode="@Darwin.Domain.Enums.LoyaltyScanMode.Accrual" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId, mode: Darwin.Domain.Enums.LoyaltyScanMode.Accrual)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyAccrual")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-mode="@Darwin.Domain.Enums.LoyaltyScanMode.Redemption" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId, mode: Darwin.Domain.Enums.LoyaltyScanMode.Redemption)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyRedemption")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Pending" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId, status: Darwin.Domain.Enums.LoyaltyScanStatus.Pending)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("Pending")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Completed" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId, status: Darwin.Domain.Enums.LoyaltyScanStatus.Completed)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("Completed")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Expired" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId, status: Darwin.Domain.Enums.LoyaltyScanStatus.Expired)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("Expired")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary btn-sm" hx-get="@ScanSessionsUrl(Model.BusinessId)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyClearQueueFilters")</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Total")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-info-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("LoyaltyAccrual")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.AccrualCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-primary-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("LoyaltyRedemption")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.RedemptionCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-warning-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Pending")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Expired")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.ExpiredCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-danger-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("LoyaltyFailurePressure")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.FailureCount</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Playbooks.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">@T.T("LoyaltyScanSessionPlaybooks")</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>@T.T("Playbook")</th>
                            <th>@T.T("WhenItApplies")</th>
                            <th>@T.T("OperatorAction")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var playbook in Model.Playbooks)
                        {
                            <tr>
                                <td class="fw-semibold">@playbook.Title</td>
                                <td>@playbook.ScopeNote</td>
                                <td>@playbook.OperatorAction</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Customer")</th>
                    <th>@T.T("Mode")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("Outcome")</th>
                    <th>@T.T("Created")</th>
                    <th>@T.T("Completed")</th>
                    <th>@T.T("Failure")</th>
                    <th class="text-end">@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">@T.T("LoyaltyNoScanSessionsFound")</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div>@item.CustomerDisplayName</div>
                                <div class="small text-muted">@item.CustomerEmail</div>
                            </td>
                            <td>@LocalizeScanMode(item.Mode)</td>
                            <td>@LocalizeScanStatus(item.Status)</td>
                            <td>@LocalizeScanOutcome(item.Outcome)</td>
                            <td>
                                <div>@LoyaltyDateTimeText(item.CreatedAtUtc)</div>
                                <div class="small text-muted">@T.T("LoyaltyExp") @LoyaltyDateTimeText(item.ExpiresAtUtc)</div>
                            </td>
                            <td>@LoyaltyDateTimeText(item.CompletedAtUtc)</td>
                            <td class="small text-muted">@LocalizeScanFailureReason(item.FailureReason)</td>
                            <td class="text-end">
                                @if (item.Status == Darwin.Domain.Enums.LoyaltyScanStatus.Pending && item.ExpiresAtUtc <= DateTime.UtcNow)
                                {
                                    <form asp-action="ExpireScanSession" method="post" class="d-inline" hx-post="@ExpireScanSessionUrl()" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="businessId" value="@item.BusinessId" />
                                        <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("Expire")</button>
                                    </form>
                                }
                                <a asp-controller="MobileOperations" asp-action="Index" asp-route-businessId="@item.BusinessId" asp-route-q="@item.CustomerEmail" class="btn btn-sm btn-outline-secondary" hx-get="@MobileOperationsUrl(item.BusinessId, item.CustomerEmail)" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyMobileOps")</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-mode="@Model.ModeFilter" asp-route-status="@Model.StatusFilter" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML"></pager>
</div>
