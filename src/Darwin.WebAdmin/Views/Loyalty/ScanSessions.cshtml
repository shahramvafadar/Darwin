@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyScanSessionsListVm
@{
    ViewData["Title"] = "Loyalty Scan Sessions";
}

<div id="loyalty-scan-sessions-workspace-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Loyalty Scan Sessions</h1>
            <div class="text-muted">Recent QR, accrual, and redemption flow diagnostics for business mobile operations.</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
               hx-get="@Url.Action("Redemptions", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">Redemptions</a>
            <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-outline-secondary"
               hx-get="@Url.Action("Index", "MobileOperations")" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML">Mobile Ops</a>
        </div>
    </div>

    <form asp-action="ScanSessions"
          method="get"
          class="row g-2 mb-3"
          hx-get="@Url.Action("ScanSessions", "Loyalty")"
          hx-target="#loyalty-scan-sessions-workspace-shell"
          hx-swap="outerHTML">
        <div class="col-md-3">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search customer or outcome" />
        </div>
        <div class="col-md-2">
            <select name="mode" asp-items="Model.ModeItems" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-action="ScanSessions"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("ScanSessions", "Loyalty")"
               hx-target="#loyalty-scan-sessions-workspace-shell"
               hx-swap="outerHTML">Reset</a>
        </div>
    </form>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           asp-route-mode="@Darwin.Domain.Enums.LoyaltyScanMode.Accrual"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId, mode = Darwin.Domain.Enums.LoyaltyScanMode.Accrual })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Accrual</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           asp-route-mode="@Darwin.Domain.Enums.LoyaltyScanMode.Redemption"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId, mode = Darwin.Domain.Enums.LoyaltyScanMode.Redemption })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Redemption</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Pending"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId, status = Darwin.Domain.Enums.LoyaltyScanStatus.Pending })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Pending</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Completed"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId, status = Darwin.Domain.Enums.LoyaltyScanStatus.Completed })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Completed</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="@Darwin.Domain.Enums.LoyaltyScanStatus.Expired"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId, status = Darwin.Domain.Enums.LoyaltyScanStatus.Expired })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Expired</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-scan-sessions-workspace-shell"
           hx-swap="outerHTML">Clear Queue Filters</a>
    </div>


    <div class="row g-3 mb-4">
        <div class="col-md-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">Total</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">Accrual</div><div class="fs-4 fw-semibold">@Model.Summary.AccrualCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">Redemption</div><div class="fs-4 fw-semibold">@Model.Summary.RedemptionCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">Pending</div><div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-secondary-subtle"><div class="card-body"><div class="text-muted small">Expired</div><div class="fs-4 fw-semibold">@Model.Summary.ExpiredCount</div></div></div></div>
        <div class="col-md-2"><div class="card h-100 border-danger-subtle"><div class="card-body"><div class="text-muted small">Failure Pressure</div><div class="fs-4 fw-semibold">@Model.Summary.FailureCount</div></div></div></div>
    </div>

    @if (Model.Playbooks.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">Scan Session Playbooks</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead><tr><th>Playbook</th><th>When It Applies</th><th>Operator Action</th></tr></thead>
                    <tbody>
                    @foreach (var playbook in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@playbook.Title</td>
                            <td>@playbook.ScopeNote</td>
                            <td>@playbook.OperatorAction</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>Customer</th><th>Mode</th><th>Status</th><th>Outcome</th><th>Created</th><th>Completed</th><th>Failure</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted">No scan sessions found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div>@item.CustomerDisplayName</div>
                            <div class="small text-muted">@item.CustomerEmail</div>
                        </td>
                        <td>@item.Mode</td>
                        <td>@item.Status</td>
                        <td>@item.Outcome</td>
                        <td>
                            <div>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                            <div class="small text-muted">Exp: @item.ExpiresAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                        <td>@(item.CompletedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td class="small text-muted">@(string.IsNullOrWhiteSpace(item.FailureReason) ? "-" : item.FailureReason)</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-mode="@Model.ModeFilter" asp-route-status="@Model.StatusFilter" hx-target="#loyalty-scan-sessions-workspace-shell" hx-swap="outerHTML"></pager>
</div>
