@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyAccountsListVm
@{
    ViewData["Title"] = T.T("LoyaltyAccountsTitle");

    string LocalizeAccountStatus(Darwin.Domain.Enums.LoyaltyAccountStatus status) => T.T(status.ToString());
    var loyaltyCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LoyaltyDateTimeText(DateTime? utc) => utc?.ToString("g", loyaltyCulture) ?? "-";
    string AccountsUrl(object? businessId = null, string? q = null, Darwin.Domain.Enums.LoyaltyAccountStatus? status = null) => Url.Action("Accounts", "Loyalty", new { businessId, q, status }) ?? string.Empty;
    string CreateAccountUrl(object? businessId = null) => Url.Action("CreateAccount", "Loyalty", new { businessId }) ?? string.Empty;
    string ProgramsUrl(object? businessId = null) => Url.Action("Programs", "Loyalty", new { businessId }) ?? string.Empty;
    string CampaignsUrl(object? businessId = null) => Url.Action("Campaigns", "Loyalty", new { businessId }) ?? string.Empty;
    string RedemptionsUrl(object? businessId = null) => Url.Action("Redemptions", "Loyalty", new { businessId }) ?? string.Empty;
    string ScanSessionsUrl(object? businessId = null) => Url.Action("ScanSessions", "Loyalty", new { businessId }) ?? string.Empty;
    string AccountDetailsUrl(Guid id) => Url.Action("AccountDetails", "Loyalty", new { id }) ?? string.Empty;
    string AdjustPointsUrl(Guid loyaltyAccountId) => Url.Action("AdjustPoints", "Loyalty", new { loyaltyAccountId }) ?? string.Empty;
}

<div id="loyalty-accounts-workspace-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <h1 class="mb-3">@T.T("LoyaltyAccountsTitle")</h1>

    <form asp-action="Accounts" method="get" class="row g-2 mb-3" hx-get="@AccountsUrl()" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">
        <div class="col-md-3">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("LoyaltySearchByMember")" />
        </div>
        <div class="col-md-3">
            <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">@T.T("Filter")</button>
            <a asp-action="Accounts" class="btn btn-outline-secondary" hx-get="@AccountsUrl()" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a>
        </div>
    </form>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="CreateAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-primary" hx-get="@CreateAccountUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyCreateAccount")</a>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@ProgramsUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Programs")</a>
        <a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@CampaignsUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Campaigns")</a>
        <a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@RedemptionsUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Redemptions")</a>
        <a asp-action="ScanSessions" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@ScanSessionsUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyScanSessionsTitle")</a>
    </div>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.StatusFilter is null ? "btn-dark" : "btn-outline-dark")" hx-get="@AccountsUrl(Model.BusinessId)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("All")</a>
        <a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyAccountStatus.Active" class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyAccountStatus.Active ? "btn-success" : "btn-outline-success")" hx-get="@AccountsUrl(Model.BusinessId, status: Darwin.Domain.Enums.LoyaltyAccountStatus.Active)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Active")</a>
        <a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" asp-route-status="@Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended" class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended ? "btn-warning" : "btn-outline-warning")" hx-get="@AccountsUrl(Model.BusinessId, status: Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Suspended")</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Total")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-success-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Active")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-warning-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Suspended")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.SuspendedCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100 border-secondary-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("LoyaltyZeroBalance")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.ZeroBalanceCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-info-subtle">
                <div class="card-body">
                    <div class="text-muted small">@T.T("LoyaltyRecentAccrual30d")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.RecentAccrualCount</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Playbooks.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header">@T.T("LoyaltyAccountPlaybooks")</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>@T.T("Playbook")</th>
                            <th>@T.T("WhenItApplies")</th>
                            <th>@T.T("OperatorAction")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var playbook in Model.Playbooks)
                        {
                            <tr>
                                <td class="fw-semibold">@playbook.Title</td>
                                <td>@playbook.ScopeNote</td>
                                <td>@playbook.OperatorAction</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Member")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("Points")</th>
                    <th>@T.T("Lifetime")</th>
                    <th>@T.T("LastAccrual")</th>
                    <th class="text-end">@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">@T.T("LoyaltyNoAccountsFound")</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div>@item.UserDisplayName</div>
                                <div class="small text-muted">@item.UserEmail</div>
                            </td>
                            <td>@LocalizeAccountStatus(item.Status)</td>
                            <td>@item.PointsBalance</td>
                            <td>@item.LifetimePoints</td>
                            <td>@LoyaltyDateTimeText(item.LastAccrualAtUtc)</td>
                            <td class="text-end">
                                <a asp-action="AccountDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" hx-get="@AccountDetailsUrl(item.Id)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Details")</a>
                                <a asp-action="AdjustPoints" asp-route-loyaltyAccountId="@item.Id" class="btn btn-sm btn-outline-secondary" hx-get="@AdjustPointsUrl(item.Id)" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML">@T.T("Adjust")</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Accounts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-status="@Model.StatusFilter" hx-target="#loyalty-accounts-workspace-shell" hx-swap="outerHTML"></pager>
</div>
