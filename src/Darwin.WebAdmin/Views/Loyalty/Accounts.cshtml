@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyAccountsListVm
@{
    ViewData["Title"] = "Loyalty Accounts";
}

<div id="loyalty-accounts-workspace-shell">
    <h1 class="mb-3">Loyalty Accounts</h1>

    <form asp-action="Accounts"
          method="get"
          class="row g-2 mb-3"
          hx-get="@Url.Action("Accounts", "Loyalty")"
          hx-target="#loyalty-accounts-workspace-shell"
          hx-swap="outerHTML">
        <div class="col-md-3">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        </div>
        <div class="col-md-3">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search by member" />
        </div>
        <div class="col-md-3">
            <select name="status" asp-items="Model.StatusItems" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">Filter</button>
            <a asp-action="Accounts"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Accounts", "Loyalty")"
               hx-target="#loyalty-accounts-workspace-shell"
               hx-swap="outerHTML">Reset</a>
        </div>
    </form>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="CreateAccount"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-primary"
           hx-get="@Url.Action("CreateAccount", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Create Account</a>
        <a asp-action="Programs"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Programs</a>
        <a asp-action="Campaigns"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Campaigns</a>
        <a asp-action="Redemptions"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Redemptions", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Redemptions</a>
        <a asp-action="ScanSessions"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("ScanSessions", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Scan Sessions</a>
    </div>

    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-action="Accounts"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm @(Model.StatusFilter is null ? "btn-dark" : "btn-outline-dark")"
           hx-get="@Url.Action("Accounts", "Loyalty", new { businessId = Model.BusinessId })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">All</a>
        <a asp-action="Accounts"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="@Darwin.Domain.Enums.LoyaltyAccountStatus.Active"
           class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyAccountStatus.Active ? "btn-success" : "btn-outline-success")"
           hx-get="@Url.Action("Accounts", "Loyalty", new { businessId = Model.BusinessId, status = Darwin.Domain.Enums.LoyaltyAccountStatus.Active })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Active</a>
        <a asp-action="Accounts"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="@Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended"
           class="btn btn-sm @(Model.StatusFilter == Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended ? "btn-warning" : "btn-outline-warning")"
           hx-get="@Url.Action("Accounts", "Loyalty", new { businessId = Model.BusinessId, status = Darwin.Domain.Enums.LoyaltyAccountStatus.Suspended })"
           hx-target="#loyalty-accounts-workspace-shell"
           hx-swap="outerHTML">Suspended</a>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>Member</th><th>Status</th><th>Points</th><th>Lifetime</th><th>Last Accrual</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted">No loyalty accounts found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div>@item.UserDisplayName</div>
                            <div class="small text-muted">@item.UserEmail</div>
                        </td>
                        <td>@item.Status</td>
                        <td>@item.PointsBalance</td>
                        <td>@item.LifetimePoints</td>
                        <td>@(item.LastAccrualAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td class="text-end">
                            <a asp-action="AccountDetails"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("AccountDetails", "Loyalty", new { id = item.Id })"
                               hx-target="#loyalty-accounts-workspace-shell"
                               hx-swap="outerHTML">Details</a>
                            <a asp-action="AdjustPoints"
                               asp-route-loyaltyAccountId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("AdjustPoints", "Loyalty", new { loyaltyAccountId = item.Id })"
                               hx-target="#loyalty-accounts-workspace-shell"
                               hx-swap="outerHTML">Adjust</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Accounts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-status="@Model.StatusFilter"></pager>
</div>
