@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyProgramEditVm
@{ var accrualModeOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.LoyaltyAccrualMode>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) }); }
<form asp-action="@(ViewData["IsCreate"] as bool? == true ? "CreateProgram" : "EditProgram")" method="post" class="row g-3" hx-post="@Url.Action(ViewData["IsCreate"] as bool? == true ? "CreateProgram" : "EditProgram", "Loyalty")" hx-target="#loyalty-program-editor-shell" hx-swap="outerHTML">
@Html.AntiForgeryToken()
@if (ViewData["IsCreate"] as bool? != true) { <input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" /> }
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div>
<div class="col-md-4"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
<div class="col-md-4"><label asp-for="AccrualMode" class="form-label"></label><select asp-for="AccrualMode" asp-items="accrualModeOptions" class="form-select"></select></div>
<div class="col-md-4"><label asp-for="PointsPerCurrencyUnit" class="form-label"></label><input asp-for="PointsPerCurrencyUnit" class="form-control" /></div>
<div class="col-12"><label asp-for="RulesJson" class="form-label"></label><textarea asp-for="RulesJson" class="form-control" rows="6"></textarea><div class="form-text">@T.T("LoyaltyRulesJsonHelp")</div></div>
<div class="col-12 form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
<div class="col-12 d-flex gap-2"><button type="submit" class="btn btn-primary">@(ViewData["IsCreate"] as bool? == true ? T.T("Create") : T.T("Save"))</button><a asp-action="Programs" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@Url.Action("Programs", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-program-editor-shell" hx-swap="outerHTML">@T.T("Back")</a>@if (ViewData["IsCreate"] as bool? != true) { <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.Id" class="btn btn-outline-primary" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.Id })" hx-target="#loyalty-program-editor-shell" hx-swap="outerHTML">@T.T("LoyaltyRewardTiersTitle")</a> }</div>
</form>
