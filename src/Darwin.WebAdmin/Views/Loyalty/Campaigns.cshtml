@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyCampaignsListVm
@{
    ViewData["Title"] = T.T("LoyaltyCampaignsTitle");
    string LocalizeCampaignState(string? state) => string.IsNullOrWhiteSpace(state) ? "-" : T.T(state);
}
<div id="loyalty-campaigns-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="mb-1">@T.T("LoyaltyCampaignsTitle")</h1><div class="text-muted">@T.T("LoyaltyCampaignsIntro")</div></div><a asp-action="CreateCampaign" asp-route-businessId="@Model.BusinessId" class="btn btn-primary" hx-get="@Url.Action("CreateCampaign", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyNewCampaign")</a></div>
<div class="row g-3 mb-4"><div class="col-md-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("Active")</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">@T.T("Scheduled")</div><div class="fs-4 fw-semibold">@Model.Summary.ScheduledCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-secondary-subtle"><div class="card-body"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("Expired")</div><div class="fs-4 fw-semibold">@Model.Summary.ExpiredCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltyPushEnabled")</div><div class="fs-4 fw-semibold">@Model.Summary.PushEnabledCount</div></div></div></div></div>
@if (Model.Playbooks.Count > 0) { <div class="card mb-4"><div class="card-header">@T.T("LoyaltyCampaignPlaybooks")</div><div class="table-responsive"><table class="table table-sm mb-0 align-middle"><thead><tr><th>@T.T("Playbook")</th><th>@T.T("WhenItApplies")</th><th>@T.T("OperatorAction")</th></tr></thead><tbody>@foreach (var playbook in Model.Playbooks){<tr><td class="fw-semibold">@playbook.Title</td><td>@playbook.ScopeNote</td><td>@playbook.OperatorAction</td></tr>}</tbody></table></div></div> }
<form asp-action="Campaigns" method="get" class="d-flex gap-2 mb-3" hx-get="@Url.Action("Campaigns", "Loyalty")" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML"><select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select><select name="filter" asp-items="Model.FilterItems" class="form-select"></select><button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button><a asp-action="Campaigns" class="btn btn-outline-secondary" hx-get="@Url.Action("Campaigns", "Loyalty")" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a></form>
<div class="d-flex gap-2 flex-wrap mb-3"><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" asp-route-filter="Active" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.Campaigns.LoyaltyCampaignQueueFilter.Active ? "btn-success" : "btn-outline-success")" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId, filter = "Active" })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Active")</a><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" asp-route-filter="Scheduled" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.Campaigns.LoyaltyCampaignQueueFilter.Scheduled ? "btn-info" : "btn-outline-info")" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId, filter = "Scheduled" })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Scheduled")</a><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" asp-route-filter="Draft" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.Campaigns.LoyaltyCampaignQueueFilter.Draft ? "btn-secondary" : "btn-outline-secondary")" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId, filter = "Draft" })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Draft")</a><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" asp-route-filter="Expired" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.Campaigns.LoyaltyCampaignQueueFilter.Expired ? "btn-warning" : "btn-outline-warning")" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId, filter = "Expired" })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Expired")</a><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" asp-route-filter="PushEnabled" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.Campaigns.LoyaltyCampaignQueueFilter.PushEnabled ? "btn-primary" : "btn-outline-primary")" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId, filter = "PushEnabled" })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyPushEnabled")</a><a asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("Campaigns", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyClearQueueFilters")</a></div>
<div class="table-responsive"><table class="table table-sm table-striped align-middle"><thead><tr><th>@T.T("Name")</th><th>@T.T("Title")</th><th>@T.T("State")</th><th>@T.T("Channels")</th><th>@T.T("LoyaltyWindow")</th><th class="text-end">@T.T("Actions")</th></tr></thead><tbody>@if (Model.Items.Count == 0) { <tr><td colspan="6" class="text-center text-muted">@T.T("LoyaltyNoCampaignsFound")</td></tr> } else { foreach (var item in Model.Items) { <tr><td>@item.Name</td><td>@item.Title</td><td><span class="badge @(item.CampaignState == "Active" ? "text-bg-success" : item.CampaignState == "Scheduled" ? "text-bg-info" : item.CampaignState == "Expired" ? "text-bg-warning" : "text-bg-secondary")">@LocalizeCampaignState(item.CampaignState)</span></td><td>@(item.Channels == 3 ? T.T("LoyaltyInAppPlusPush") : T.T("LoyaltyInAppOnly")) @if (item.Channels == 3){<div><span class="badge text-bg-primary mt-1">@T.T("LoyaltyPushEnabled")</span></div>}</td><td><div>@(item.StartsAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div><div class="small text-muted">@T.T("LoyaltyTo") @(item.EndsAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div></td><td class="text-end"><a asp-action="EditCampaign" asp-route-id="@item.Id" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("EditCampaign", "Loyalty", new { id = item.Id, businessId = item.BusinessId })" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@T.T("Edit")</a> <form asp-action="SetCampaignActivation" method="post" class="d-inline" hx-post="@Url.Action("SetCampaignActivation", "Loyalty")" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="businessId" value="@item.BusinessId" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" /><input type="hidden" name="isActive" value="@((!item.IsActive).ToString())" /><button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")">@(item.IsActive ? T.T("Deactivate") : T.T("Activate"))</button></form></td></tr> } }</tbody></table></div>
<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="Campaigns" asp-route-businessId="@Model.BusinessId" hx-target="#loyalty-campaigns-workspace-shell" hx-swap="outerHTML"></pager>
</div>
