@model Darwin.WebAdmin.ViewModels.Loyalty.CreateLoyaltyAccountVm
@{
    string AccountsUrl(object? businessId = null) => Url.Action("Accounts", "Loyalty", new { businessId }) ?? string.Empty;
}
<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="CreateAccount" method="post" hx-post="@Url.Action("CreateAccount", "Loyalty")" hx-target="#loyalty-account-create-editor-shell" hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <section class="admin-form-section">
                <h2 class="admin-form-section-title">@T.T("LoyaltyAccountIdentitySection")</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="BusinessId" class="form-label">@T.T("Business")</label>
                        <field-help title="@T.T("Business")" content="@T.T("LoyaltyAccountBusinessHelp")" placement="right"></field-help>
                        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
                        <span asp-validation-for="BusinessId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="UserId" class="form-label">@T.T("Member")</label>
                        <field-help title="@T.T("Member")" content="@T.T("LoyaltyAccountMemberHelp")" placement="right"></field-help>
                        <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select>
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <div class="alert alert-info">@T.T("LoyaltyCreateAccountHelp")</div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">@T.T("LoyaltyCreateAccount")</button>
                <a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@AccountsUrl(Model.BusinessId)" hx-target="#loyalty-account-create-editor-shell" hx-swap="outerHTML">@T.T("Cancel")</a>
            </div>
        </form>
    </div>
</div>
