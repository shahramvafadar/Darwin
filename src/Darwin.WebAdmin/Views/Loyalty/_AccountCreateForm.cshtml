@model Darwin.WebAdmin.ViewModels.Loyalty.CreateLoyaltyAccountVm
<div class="card shadow-sm"><div class="card-body"><form asp-action="CreateAccount" method="post" class="row g-3" hx-post="@Url.Action("CreateAccount", "Loyalty")" hx-target="#loyalty-account-create-editor-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="col-md-6"><label asp-for="BusinessId" class="form-label">@T.T("Business")</label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select><span asp-validation-for="BusinessId" class="text-danger"></span></div><div class="col-md-6"><label asp-for="UserId" class="form-label">@T.T("Member")</label><select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select><span asp-validation-for="UserId" class="text-danger"></span></div><div class="col-12"><div class="alert alert-info mb-0">@T.T("LoyaltyCreateAccountHelp")</div></div><div class="col-12 d-flex gap-2"><button type="submit" class="btn btn-primary">@T.T("LoyaltyCreateAccount")</button><a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@Url.Action("Accounts", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-account-create-editor-shell" hx-swap="outerHTML">@T.T("Cancel")</a></div></form></div></div>
