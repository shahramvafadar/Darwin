@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyRewardTiersListVm
@{
    ViewData["Title"] = "Loyalty Reward Tiers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Reward Tiers</h1>
        <div class="text-muted">@Model.ProgramName</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditProgram" asp-route-id="@Model.LoyaltyProgramId" class="btn btn-outline-secondary">Program</a>
        <a asp-action="CreateRewardTier" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-primary">New Reward Tier</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Total</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
    <div class="col-md-3"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">Self Redemption</div><div class="fs-4 fw-semibold">@Model.Summary.SelfRedemptionCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">Missing Description</div><div class="fs-4 fw-semibold">@Model.Summary.MissingDescriptionCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">Discount Rewards</div><div class="fs-4 fw-semibold">@Model.Summary.DiscountRewardCount</div></div></div></div>
    <div class="col-md-2"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">Free Item</div><div class="fs-4 fw-semibold">@Model.Summary.FreeItemCount</div></div></div></div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Reward Tier Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead><tr><th>Playbook</th><th>When It Applies</th><th>Operator Action</th></tr></thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<form asp-action="RewardTiers" method="get" class="d-flex gap-2 mb-3">
    <input type="hidden" name="loyaltyProgramId" value="@Model.LoyaltyProgramId" />
    <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    <button class="btn btn-outline-secondary" type="submit">Filter</button>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-outline-secondary">Reset</a>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="SelfRedemption" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.SelfRedemption ? "btn-success" : "btn-outline-success")">Self Redemption</a>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="MissingDescription" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.MissingDescription ? "btn-warning" : "btn-outline-warning")">Missing Description</a>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="DiscountRewards" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.DiscountRewards ? "btn-info" : "btn-outline-info")">Discount Rewards</a>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="FreeItem" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.FreeItem ? "btn-primary" : "btn-outline-primary")">Free Item</a>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Points</th><th>Type</th><th>Value</th><th>Self Redeem</th><th>Description</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No reward tiers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.PointsRequired</td>
                    <td>@item.RewardType</td>
                    <td>@item.RewardValue</td>
                    <td>
                        <span class="badge @(item.AllowSelfRedemption ? "text-bg-success" : "text-bg-secondary")">@(item.AllowSelfRedemption ? "Enabled" : "Manual")</span>
                    </td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span class="badge text-bg-warning">Missing description</span>
                        }
                        else
                        {
                            @item.Description
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditRewardTier" asp-route-id="@item.Id" asp-route-loyaltyProgramId="@item.LoyaltyProgramId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="DeleteRewardTier" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="loyaltyProgramId" value="@item.LoyaltyProgramId" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId"></pager>
