@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyRewardTiersListVm
@{
    ViewData["Title"] = "Loyalty Reward Tiers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Reward Tiers</h1>
        <div class="text-muted">@Model.ProgramName</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="EditProgram" asp-route-id="@Model.LoyaltyProgramId" class="btn btn-outline-secondary">Program</a>
        <a asp-action="CreateRewardTier" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-primary">New Reward Tier</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Points</th><th>Type</th><th>Value</th><th>Self Redeem</th><th>Description</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No reward tiers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.PointsRequired</td>
                    <td>@item.RewardType</td>
                    <td>@item.RewardValue</td>
                    <td>@(item.AllowSelfRedemption ? "Yes" : "No")</td>
                    <td>@item.Description</td>
                    <td class="text-end">
                        <a asp-action="EditRewardTier" asp-route-id="@item.Id" asp-route-loyaltyProgramId="@item.LoyaltyProgramId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="DeleteRewardTier" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="loyaltyProgramId" value="@item.LoyaltyProgramId" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId"></pager>
