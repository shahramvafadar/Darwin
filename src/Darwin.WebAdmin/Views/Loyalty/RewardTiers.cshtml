@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyRewardTiersListVm
@{
    ViewData["Title"] = T.T("LoyaltyRewardTiersTitle");
    string LocalizeRewardType(object? rewardType) => rewardType is null ? "-" : T.T(rewardType.ToString() ?? string.Empty);
}
<div id="loyalty-reward-tiers-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3"><div><h1 class="mb-1">@T.T("LoyaltyRewardTiersTitle")</h1><div class="text-muted">@Model.ProgramName</div></div><div class="d-flex gap-2"><a asp-action="EditProgram" asp-route-id="@Model.LoyaltyProgramId" class="btn btn-outline-secondary" hx-get="@Url.Action("EditProgram", "Loyalty", new { id = Model.LoyaltyProgramId })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyProgram")</a><a asp-action="CreateRewardTier" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-primary" hx-get="@Url.Action("CreateRewardTier", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyNewRewardTier")</a></div></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div><div class="col-md-3"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltySelfRedemption")</div><div class="fs-4 fw-semibold">@Model.Summary.SelfRedemptionCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltyMissingDescription")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingDescriptionCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltyDiscountRewards")</div><div class="fs-4 fw-semibold">@Model.Summary.DiscountRewardCount</div></div></div></div><div class="col-md-2"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">@T.T("LoyaltyFreeItem")</div><div class="fs-4 fw-semibold">@Model.Summary.FreeItemCount</div></div></div></div></div>
@if (Model.Playbooks.Count > 0) { <div class="card mb-4"><div class="card-header">@T.T("LoyaltyRewardTierPlaybooks")</div><div class="table-responsive"><table class="table table-sm mb-0 align-middle"><thead><tr><th>@T.T("Playbook")</th><th>@T.T("WhenItApplies")</th><th>@T.T("OperatorAction")</th></tr></thead><tbody>@foreach (var playbook in Model.Playbooks){<tr><td class="fw-semibold">@playbook.Title</td><td>@playbook.ScopeNote</td><td>@playbook.OperatorAction</td></tr>}</tbody></table></div></div> }
<form asp-action="RewardTiers" method="get" class="d-flex gap-2 mb-3" hx-get="@Url.Action("RewardTiers", "Loyalty")" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML"><input type="hidden" name="loyaltyProgramId" value="@Model.LoyaltyProgramId" /><select name="filter" asp-items="Model.FilterItems" class="form-select"></select><button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-outline-secondary" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a></form>
<div class="d-flex gap-2 flex-wrap mb-3"><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="SelfRedemption" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.SelfRedemption ? "btn-success" : "btn-outline-success")" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId, filter = "SelfRedemption" })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltySelfRedemption")</a><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="MissingDescription" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.MissingDescription ? "btn-warning" : "btn-outline-warning")" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId, filter = "MissingDescription" })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyMissingDescription")</a><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="DiscountRewards" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.DiscountRewards ? "btn-info" : "btn-outline-info")" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId, filter = "DiscountRewards" })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyDiscountRewards")</a><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" asp-route-filter="FreeItem" class="btn btn-sm @(Model.Filter == Darwin.Application.Loyalty.DTOs.LoyaltyRewardTierQueueFilter.FreeItem ? "btn-primary" : "btn-outline-primary")" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId, filter = "FreeItem" })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyFreeItem")</a><a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId = Model.LoyaltyProgramId })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyClearQueueFilters")</a></div>
<div class="table-responsive"><table class="table table-sm table-striped align-middle"><thead><tr><th>@T.T("LoyaltyPoints")</th><th>@T.T("Type")</th><th>@T.T("Value")</th><th>@T.T("LoyaltySelfRedeem")</th><th>@T.T("Description")</th><th class="text-end">@T.T("Actions")</th></tr></thead><tbody>@if (Model.Items.Count == 0) { <tr><td colspan="6" class="text-center text-muted">@T.T("LoyaltyNoRewardTiersFound")</td></tr> } else { foreach (var item in Model.Items) { <tr><td>@item.PointsRequired</td><td>@LocalizeRewardType(item.RewardType)</td><td>@item.RewardValue</td><td><span class="badge @(item.AllowSelfRedemption ? "text-bg-success" : "text-bg-secondary")">@(item.AllowSelfRedemption ? T.T("Enabled") : T.T("LoyaltyManual"))</span></td><td>@if (string.IsNullOrWhiteSpace(item.Description)){<span class="badge text-bg-warning">@T.T("LoyaltyMissingDescription")</span>} else {@item.Description}</td><td class="text-end"><a asp-action="EditRewardTier" asp-route-id="@item.Id" asp-route-loyaltyProgramId="@item.LoyaltyProgramId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("EditRewardTier", "Loyalty", new { id = item.Id, loyaltyProgramId = item.LoyaltyProgramId })" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@T.T("Edit")</a> <form asp-action="DeleteRewardTier" method="post" class="d-inline" hx-post="@Url.Action("DeleteRewardTier", "Loyalty")" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="loyaltyProgramId" value="@item.LoyaltyProgramId" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" /><button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Delete")</button></form></td></tr> } }</tbody></table></div>
<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Loyalty" asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" hx-target="#loyalty-reward-tiers-workspace-shell" hx-swap="outerHTML"></pager>
</div>
