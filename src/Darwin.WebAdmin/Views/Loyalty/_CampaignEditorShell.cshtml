@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyCampaignEditVm
@{
    var isCreate = ViewData["IsCreate"] as bool? == true;
    ViewData["Title"] = isCreate ? "Create Loyalty Campaign" : "Edit Loyalty Campaign";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">@(isCreate ? "Create Loyalty Campaign" : "Edit Loyalty Campaign")</h1>
        @if (!isCreate)
        {
            <div class="text-muted">Current state: @Model.CampaignState</div>
        }
    </div>
</div>

<partial name="_CampaignForm" model="Model" />
