@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyAccountDetailsVm
@{
    ViewData["Title"] = T.T("LoyaltyAccountDetailsTitle");
    string LocalizeAccountStatus(Darwin.Domain.Enums.LoyaltyAccountStatus status) => T.T(status.ToString());
    string LocalizeRedemptionStatus(Darwin.Domain.Enums.LoyaltyRedemptionStatus status) => T.T(status.ToString());
    string LocalizeScanStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeScanOutcome(string? outcome) => string.IsNullOrWhiteSpace(outcome) ? "-" : T.T(outcome);
    string LocalizeScanFailureReason(string? reason) => reason switch
    {
        "TokenAlreadyConsumed" => T.T("TokenAlreadyConsumed"),
        "Token was consumed concurrently by another request." => T.T("TokenAlreadyConsumed"),
        "AccountNotFound" => T.T("AccountNotFound"),
        "Loyalty account for scan session not found." => T.T("AccountNotFound"),
        "AccountNotActive" => T.T("AccountNotActive"),
        "Loyalty account is not active." => T.T("AccountNotActive"),
        "Expired" => T.T("Expired"),
        "Session expired before accrual confirmation." => T.T("Expired"),
        "Session expired before redemption confirmation." => T.T("Expired"),
        "Session expired before use." => T.T("Expired"),
        "NoSelections" => T.T("NoSelections"),
        "Scan session does not contain any selected rewards." => T.T("NoSelections"),
        "InvalidSelections" => T.T("InvalidSelections"),
        "Selected rewards do not require any points." => T.T("InvalidSelections"),
        "InsufficientPoints" => T.T("InsufficientPoints"),
        "Account does not have enough points at confirmation time." => T.T("InsufficientPoints"),
        _ => string.IsNullOrWhiteSpace(reason) ? "-" : T.T(reason)
    };
    var loyaltyCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LoyaltyDateTimeText(DateTime? utc) => utc?.ToString("g", loyaltyCulture) ?? "-";
}
<div id="loyalty-account-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3"><div><h1 class="mb-1">@T.T("LoyaltyAccountTitle")</h1><div class="text-muted">@Model.UserDisplayName (@Model.UserEmail)</div></div><div class="d-flex gap-2"><a asp-action="Redemptions" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@Url.Action("Redemptions", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@T.T("Redemptions")</a><a asp-controller="MobileOperations" asp-action="Index" asp-route-q="@Model.UserEmail" class="btn btn-outline-secondary" hx-get="@Url.Action("Index", "MobileOperations", new { q = Model.UserEmail })" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyMobileOps")</a><a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-providerReviewOnly="true" class="btn btn-outline-secondary" hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { providerReviewOnly = true })" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@T.T("ProviderReview")</a><a asp-action="AdjustPoints" asp-route-loyaltyAccountId="@Model.Id" class="btn btn-outline-primary" hx-get="@Url.Action("AdjustPoints", "Loyalty", new { loyaltyAccountId = Model.Id })" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@T.T("LoyaltyAdjustPoints")</a>@if (Model.Status == Darwin.Domain.Enums.LoyaltyAccountStatus.Active) { <form asp-action="SuspendAccount" method="post" class="d-inline" hx-post="@Url.Action("SuspendAccount", "Loyalty")" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" /><button type="submit" class="btn btn-outline-warning">@T.T("Suspend")</button></form> } else { <form asp-action="ActivateAccount" method="post" class="d-inline" hx-post="@Url.Action("ActivateAccount", "Loyalty")" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" /><button type="submit" class="btn btn-outline-success">@T.T("Activate")</button></form> }<a asp-action="Accounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary" hx-get="@Url.Action("Accounts", "Loyalty", new { businessId = Model.BusinessId })" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@T.T("Back")</a></div></div>
<div class="row g-3 mb-4"><div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Status")</div><div class="fs-5">@LocalizeAccountStatus(Model.Status)</div></div></div><div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Points")</div><div class="fs-5">@Model.PointsBalance</div></div></div><div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Lifetime")</div><div class="fs-5">@Model.LifetimePoints</div></div></div><div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("LastAccrual")</div><div class="fs-6">@LoyaltyDateTimeText(Model.LastAccrualAtUtc)</div></div></div></div>
<div class="row g-3"><div class="col-xl-6"><div class="card"><div class="card-header">@T.T("LoyaltyRecentTransactions")</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>@T.T("When")</th><th>@T.T("Delta")</th><th>@T.T("Reward")</th><th>@T.T("Note")</th></tr></thead><tbody>@if (Model.Transactions.Count == 0) { <tr><td colspan="4" class="text-center text-muted py-3">@T.T("LoyaltyNoTransactionsFound")</td></tr> } else { foreach (var item in Model.Transactions) { <tr><td>@LoyaltyDateTimeText(item.OccurredAtUtc)</td><td>@item.PointsDelta</td><td>@(item.RewardTierId?.ToString() ?? "-")</td><td>@item.Note</td></tr> } }</tbody></table></div></div></div><div class="col-xl-6"><div class="card"><div class="card-header">@T.T("LoyaltyRecentRedemptions")</div><div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>@T.T("When")</th><th>@T.T("Reward")</th><th>@T.T("Status")</th><th>@T.T("Points")</th><th>@T.T("LoyaltyScan")</th><th>@T.T("Note")</th><th class="text-end">@T.T("Action")</th></tr></thead><tbody>@if (Model.Redemptions.Count == 0) { <tr><td colspan="7" class="text-center text-muted py-3">@T.T("LoyaltyNoRedemptionsFound")</td></tr> } else { foreach (var item in Model.Redemptions) { <tr><td>@LoyaltyDateTimeText(item.RedeemedAtUtc)</td><td><div>@item.RewardLabel</div><div class="small text-muted">@item.RewardTierId</div></td><td>@LocalizeRedemptionStatus(item.Status)</td><td>@item.PointsSpent</td><td><div>@LocalizeScanStatus(item.ScanStatus)</div><div class="small text-muted">@LocalizeScanOutcome(item.ScanOutcome)</div></td><td class="small text-muted">@(string.IsNullOrWhiteSpace(item.Note) ? LocalizeScanFailureReason(item.ScanFailureReason) : item.Note)</td><td class="text-end">@if (item.Status == Darwin.Domain.Enums.LoyaltyRedemptionStatus.Pending) { <form asp-action="ConfirmRedemption" method="post" class="d-inline" hx-post="@Url.Action("ConfirmRedemption", "Loyalty")" hx-target="#loyalty-account-workspace-shell" hx-swap="outerHTML">@Html.AntiForgeryToken()<input type="hidden" name="redemptionId" value="@item.Id" /><input type="hidden" name="businessId" value="@Model.BusinessId" /><input type="hidden" name="loyaltyAccountId" value="@Model.Id" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" /><button type="submit" class="btn btn-sm btn-outline-success">@T.T("Confirm")</button></form> }</td></tr> } }</tbody></table></div></div></div></div>
</div>

