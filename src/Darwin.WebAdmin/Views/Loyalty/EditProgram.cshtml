@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyProgramEditVm
@{
    ViewData["Title"] = "Edit Loyalty Program";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Edit Loyalty Program</h1>
    <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.Id" class="btn btn-outline-primary">Reward Tiers</a>
</div>

<form asp-action="EditProgram" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="RowVersion" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-4">
        <label asp-for="BusinessId" class="form-label"></label>
        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="AccrualMode" class="form-label"></label>
        <select asp-for="AccrualMode" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.LoyaltyAccrualMode>()" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="PointsPerCurrencyUnit" class="form-label"></label>
        <input asp-for="PointsPerCurrencyUnit" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="RulesJson" class="form-label"></label>
        <textarea asp-for="RulesJson" class="form-control" rows="6"></textarea>
    </div>
    <div class="col-12 form-check ms-2">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Programs" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
