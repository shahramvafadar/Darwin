@model Darwin.WebAdmin.ViewModels.Loyalty.LoyaltyRewardTierEditVm
@{
    var rewardTypeOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.LoyaltyRewardType>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) });
    string RewardTiersUrl(Guid loyaltyProgramId) => Url.Action("RewardTiers", "Loyalty", new { loyaltyProgramId }) ?? string.Empty;
}
<form asp-action="@(ViewData["IsCreate"] as bool? == true ? "CreateRewardTier" : "EditRewardTier")"
      method="post"
      hx-post="@Url.Action(ViewData["IsCreate"] as bool? == true ? "CreateRewardTier" : "EditRewardTier", "Loyalty")"
      hx-target="#loyalty-reward-tier-editor-shell"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    @if (ViewData["IsCreate"] as bool? != true)
    {
        <input asp-for="Id" type="hidden" />
        <input asp-for="RowVersion" type="hidden" />
    }
    <input asp-for="LoyaltyProgramId" type="hidden" />
    <input asp-for="BusinessId" type="hidden" />
    <input asp-for="ProgramName" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyRewardTierThresholdSection")</h2>
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="PointsRequired" class="form-label"></label>
                <field-help title="@T.T("PointsRequired")" content="@T.T("LoyaltyRewardTierPointsRequiredHelp")" placement="right"></field-help>
                <input asp-for="PointsRequired" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="RewardType" class="form-label"></label>
                <field-help title="@T.T("RewardType")" content="@T.T("LoyaltyRewardTierRewardTypeHelp")" placement="right"></field-help>
                <select asp-for="RewardType" asp-items="rewardTypeOptions" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="RewardValue" class="form-label"></label>
                <field-help title="@T.T("RewardValue")" content="@T.T("LoyaltyRewardTierRewardValueHelp")" placement="right"></field-help>
                <input asp-for="RewardValue" class="form-control" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="AllowSelfRedemption" class="form-check-input" />
                    <label asp-for="AllowSelfRedemption" class="form-check-label"></label>
                    <field-help title="@T.T("AllowSelfRedemption")" content="@T.T("LoyaltyRewardTierAllowSelfRedemptionHelp")" placement="right"></field-help>
                </div>
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("LoyaltyRewardTierContentSection")</h2>
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <field-help title="@T.T("Description")" content="@T.T("LoyaltyRewardTierDescriptionHelp")" placement="right"></field-help>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-12">
                <label asp-for="MetadataJson" class="form-label"></label>
                <field-help title="@T.T("MetadataJson")" content="@T.T("LoyaltyRewardMetadataHelp")" placement="right"></field-help>
                <textarea asp-for="MetadataJson" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </section>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@(ViewData["IsCreate"] as bool? == true ? T.T("Create") : T.T("Save"))</button>
        <a asp-action="RewardTiers" asp-route-loyaltyProgramId="@Model.LoyaltyProgramId" class="btn btn-outline-secondary" hx-get="@RewardTiersUrl(Model.LoyaltyProgramId)" hx-target="#loyalty-reward-tier-editor-shell" hx-swap="outerHTML">@T.T("Back")</a>
    </div>
</form>
