@model Darwin.WebAdmin.ViewModels.Shipping.ShippingMethodEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string ShippingMethodFormOpsHealthBadgeClass(bool healthy) => healthy ? "text-bg-success" : "text-bg-warning";
    string ShippingMethodsGlobalIndexUrl() => Url.Action("Index", "ShippingMethods") ?? string.Empty;
    string ShippingMethodsIndexUrl(string filter) => Url.Action("Index", "ShippingMethods", new { filter }) ?? string.Empty;
    string CreateShippingMethodUrl() => Url.Action("Create", "ShippingMethods") ?? string.Empty;
    string ShipmentsQueueUrl(string filter) => Url.Action("ShipmentsQueue", "Orders", new { filter }) ?? string.Empty;
    string ShippingSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" }) ?? string.Empty;
    var shippingMethodFormMissingRates = Model.Rates.Count == 0;
    var shippingMethodFormDhl = string.Equals(Model.Carrier, "DHL", StringComparison.OrdinalIgnoreCase);
    var shippingMethodFormGlobalCoverage = string.IsNullOrWhiteSpace(Model.CountriesCsv);
    var shippingMethodFormMissingCurrency = string.IsNullOrWhiteSpace(Model.Currency);
    var shippingMethodFormInactive = !Model.IsActive;
    var shippingMethodFormAttentionCount =
        (shippingMethodFormMissingRates ? 1 : 0) +
        (shippingMethodFormMissingCurrency ? 1 : 0) +
        (shippingMethodFormInactive ? 1 : 0);
}

<input type="hidden" asp-for="Id" />
<input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @ShippingMethodFormOpsHealthBadgeClass(shippingMethodFormAttentionCount == 0)">@T.T("NeedsAttention"): @shippingMethodFormAttentionCount</span>
                    <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormMissingRates)">@T.T("MissingRates")</span>
                    <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormMissingCurrency)">@T.T("Currency")</span>
                    <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormInactive)">@T.T("Inactive")</span>
                    @if (shippingMethodFormDhl)
                    {
                        <span class="badge text-bg-primary">@T.T("DhlMethods")</span>
                    }
                    @if (shippingMethodFormGlobalCoverage)
                    {
                        <span class="badge text-bg-info">@T.T("GlobalCoverage")</span>
                    }
                </div>
                <h2 class="h5 mb-1">@T.T("ShippingMethods")</h2>
                <p class="text-muted mb-0">@T.T("ShippingMethodEditorIntro")</p>
            </div>
            <div class="text-md-end">
                <div class="small text-muted">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@shippingMethodFormAttentionCount</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("MissingRates")</span>
                        <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormMissingRates)">@(shippingMethodFormMissingRates ? 1 : 0)</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="MissingRates"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ShippingMethodsIndexUrl("MissingRates")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="Orders"
                           asp-action="ShipmentsQueue"
                           asp-route-filter="MissingService"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShipmentsQueueUrl("MissingService")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShipmentsQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("DhlMethods")</span>
                        <span class="badge @ShippingMethodFormOpsHealthBadgeClass(shippingMethodFormDhl)">@(shippingMethodFormDhl ? 1 : 0)</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="Dhl"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@ShippingMethodsIndexUrl("Dhl")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-shipping"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShippingSettingsUrl()"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShippingSettings")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("GlobalCoverage")</span>
                        <span class="badge @ShippingMethodFormOpsHealthBadgeClass(shippingMethodFormGlobalCoverage)">@(shippingMethodFormGlobalCoverage ? 1 : 0)</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="GlobalCoverage"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@ShippingMethodsIndexUrl("GlobalCoverage")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="Orders"
                           asp-action="ShipmentsQueue"
                           asp-route-filter="CarrierReview"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShipmentsQueueUrl("CarrierReview")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShipmentsQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("Inactive")</span>
                        <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormInactive)">@(shippingMethodFormInactive ? 1 : 0)</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="Inactive"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShippingMethodsIndexUrl("Inactive")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CreateShippingMethodUrl()"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CreateMethod")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">@T.T("MethodDetails")</div>
    <div class="card-body">
        <section class="admin-form-section">
            <h2 class="admin-form-section-title">@T.T("ShippingMethodCarrierService")</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <field-help title="@T.T("Name")" content="@T.T("ShippingMethodNameHelp")" placement="right"></field-help>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Carrier" class="form-label"></label>
                    <field-help title="@T.T("Carrier")" content="@T.T("ShippingMethodCarrierHelp")" placement="right"></field-help>
                    <input asp-for="Carrier" class="form-control" />
                    <span asp-validation-for="Carrier" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Service" class="form-label"></label>
                    <field-help title="@T.T("Service")" content="@T.T("ShippingMethodServiceHelp")" placement="right"></field-help>
                    <input asp-for="Service" class="form-control" />
                    <span asp-validation-for="Service" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="admin-form-section">
            <h2 class="admin-form-section-title">@T.T("ShippingMethodCoverageStatus")</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CountriesCsv" class="form-label">@T.T("CountriesCsv")</label>
                    <field-help title="@T.T("CountriesCsv")" content="@T.T("ShippingMethodCountriesHelp")" placement="right"></field-help>
                    <input asp-for="CountriesCsv" class="form-control" placeholder="@T.T("ShippingMethodCountriesPlaceholder")" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Currency" class="form-label"></label>
                    <field-help title="@T.T("Currency")" content="@T.T("ShippingMethodCurrencyHelp")" placement="right"></field-help>
                    <input asp-for="Currency" class="form-control" placeholder="@T.T("ShippingMethodCurrencyPlaceholder")" maxlength="3" />
                </div>
                <div class="col-md-3 d-flex align-items-center">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                        <field-help title="@T.T("Active")" content="@T.T("ShippingMethodActiveHelp")" placement="right"></field-help>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("RateTiers")</span>
        <button type="button" class="btn btn-sm btn-outline-primary" data-shipping-rate-add>
            <i class="fa-solid fa-plus"></i> @T.T("AddRate")
        </button>
    </div>
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormMissingRates)">@T.T("MissingRates"): @(shippingMethodFormMissingRates ? 1 : 0)</span>
            <span class="badge @ShippingMethodFormOpsHealthBadgeClass(!shippingMethodFormMissingCurrency)">@T.T("Currency"): @(shippingMethodFormMissingCurrency ? 1 : 0)</span>
            @if (shippingMethodFormDhl)
            {
                <span class="badge text-bg-primary">@T.T("DhlMethods")</span>
            }
            @if (shippingMethodFormGlobalCoverage)
            {
                <span class="badge text-bg-info">@T.T("GlobalCoverage")</span>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle" id="shipping-rates-table">
                <thead>
                    <tr>
                        <th>@T.T("MaxMass") <field-help title="@T.T("MaxMass")" content="@T.T("ShippingRateMaxMassHelp")" placement="right"></field-help></th>
                        <th>@T.T("MaxSubtotalNet") <field-help title="@T.T("MaxSubtotalNet")" content="@T.T("ShippingRateMaxSubtotalHelp")" placement="right"></field-help></th>
                        <th>@T.T("PriceMinor") <field-help title="@T.T("PriceMinor")" content="@T.T("ShippingRatePriceMinorHelp")" placement="right"></field-help></th>
                        <th class="admin-w-80">@T.T("Sort") <field-help title="@T.T("Sort")" content="@T.T("ShippingRateSortHelp")" placement="right"></field-help></th>
                        <th class="admin-w-80"></th>
                    </tr>
                </thead>
                <tbody id="shipping-rate-rows">
                @for (var i = 0; i < Model.Rates.Count; i++)
                {
                    <tr data-rate-row>
                        <td>
                            <input type="hidden" name="Rates[@i].Id" value="@(Model.Rates[i].Id?.ToString() ?? string.Empty)" />
                            <input type="number" class="form-control form-control-sm" name="Rates[@i].MaxShipmentMass" value="@(Model.Rates[i].MaxShipmentMass?.ToString() ?? string.Empty)" min="0" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" name="Rates[@i].MaxSubtotalNetMinor" value="@(Model.Rates[i].MaxSubtotalNetMinor?.ToString() ?? string.Empty)" min="0" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" name="Rates[@i].PriceMinor" value="@Model.Rates[i].PriceMinor" min="0" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" name="Rates[@i].SortOrder" value="@Model.Rates[i].SortOrder" min="0" />
                        </td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger" data-shipping-rate-remove>
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="form-text">
            @T.T("ShippingRateTiersHelp")
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-floppy-disk"></i> @T.T("Save")
    </button>
    <a asp-action="Index"
       class="btn btn-outline-secondary"
           hx-get="@ShippingMethodsGlobalIndexUrl()"
       hx-target="#shipping-methods-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        @T.T("Cancel")
    </a>
</div>

<template id="shipping-rate-row-template">
    <tr data-rate-row>
        <td>
            <input type="hidden" name="Rates[__index__].Id" value="" />
            <input type="number" class="form-control form-control-sm" name="Rates[__index__].MaxShipmentMass" min="0" />
        </td>
        <td>
            <input type="number" class="form-control form-control-sm" name="Rates[__index__].MaxSubtotalNetMinor" min="0" />
        </td>
        <td>
            <input type="number" class="form-control form-control-sm" name="Rates[__index__].PriceMinor" min="0" value="0" />
        </td>
        <td>
            <input type="number" class="form-control form-control-sm" name="Rates[__index__].SortOrder" min="0" value="0" />
        </td>
        <td class="text-end">
            <button type="button" class="btn btn-sm btn-outline-danger" data-shipping-rate-remove>
                <i class="fa-solid fa-trash"></i>
            </button>
        </td>
    </tr>
</template>
