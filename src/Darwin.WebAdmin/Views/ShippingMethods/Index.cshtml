@model Darwin.WebAdmin.ViewModels.Shipping.ShippingMethodsListVm
@using System.Globalization
@{
    ViewData["Title"] = T.T("ShippingMethods");
    string ShippingMethodOpsHealthBadgeClass(bool healthy) => healthy ? "text-bg-success" : "text-bg-warning";
    string ShippingMethodOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    string ShippingMethodsGlobalIndexUrl() => Url.Action("Index", "ShippingMethods") ?? string.Empty;
    string ShippingMethodsIndexUrl(string filter) => Url.Action("Index", "ShippingMethods", new { filter }) ?? string.Empty;
    string CreateShippingMethodUrl() => Url.Action("Create", "ShippingMethods") ?? string.Empty;
    string EditShippingMethodUrl(Guid id) => Url.Action("Edit", "ShippingMethods", new { id }) ?? string.Empty;
    string ShipmentsQueueUrl(string filter) => Url.Action("ShipmentsQueue", "Orders", new { filter }) ?? string.Empty;
    string ShippingSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" }) ?? string.Empty;
    var shippingMethodAttentionCount = Model.Summary.MissingRatesCount + Model.Summary.InactiveCount;
}

<div id="shipping-methods-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-truck-fast me-2"></i>@T.T("ShippingMethods")</h1>
        <p class="text-muted mb-0">@T.T("ShippingMethodsWorkspaceIntro")</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"
       hx-get="@CreateShippingMethodUrl()"
       hx-target="#shipping-methods-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-plus"></i> @T.T("CreateMethod")
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @ShippingMethodOpsHealthBadgeClass(shippingMethodAttentionCount == 0)">@ShippingMethodOpsHealthBadgeText(shippingMethodAttentionCount == 0)</span>
                    <span class="badge @ShippingMethodOpsHealthBadgeClass(Model.Summary.DhlCount > 0)">@ShippingMethodOpsHealthBadgeText(Model.Summary.DhlCount > 0)</span>
                </div>
                <h2 class="h5 mb-1">@T.T("ShippingMethods")</h2>
                <p class="text-muted mb-0">@T.T("ShippingMethodsWorkspaceIntro")</p>
            </div>
            <div class="text-md-end">
                <div class="small text-muted">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@shippingMethodAttentionCount</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("MissingRates")</span>
                        <span class="badge @ShippingMethodOpsHealthBadgeClass(Model.Summary.MissingRatesCount == 0)">@Model.Summary.MissingRatesCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("OperatorAction")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="MissingRates"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ShippingMethodsIndexUrl("MissingRates")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="Orders"
                           asp-action="ShipmentsQueue"
                           asp-route-filter="MissingService"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShipmentsQueueUrl("MissingService")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShipmentsQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("DhlMethods")</span>
                        <span class="badge @ShippingMethodOpsHealthBadgeClass(Model.Summary.DhlCount > 0)">@Model.Summary.DhlCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("ShippingSettings")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="Dhl"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@ShippingMethodsIndexUrl("Dhl")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-shipping"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShippingSettingsUrl()"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShippingSettings")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("Inactive")</span>
                        <span class="badge @ShippingMethodOpsHealthBadgeClass(Model.Summary.InactiveCount == 0)">@Model.Summary.InactiveCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("CreateMethod")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="Inactive"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShippingMethodsIndexUrl("Inactive")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CreateShippingMethodUrl()"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CreateMethod")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("GlobalCoverage")</span>
                        <span class="badge @ShippingMethodOpsHealthBadgeClass(Model.Summary.GlobalCoverageCount > 0)">@Model.Summary.GlobalCoverageCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("MultiRate")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="GlobalCoverage"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@ShippingMethodsIndexUrl("GlobalCoverage")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Index"
                           asp-route-filter="MultiRate"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@ShippingMethodsIndexUrl("MultiRate")"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MultiRate")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Active")</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Inactive")</div><div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("MissingRates")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingRatesCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("DhlMethods")</div><div class="fs-4 fw-semibold">@Model.Summary.DhlCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("GlobalCoverage")</div><div class="fs-4 fw-semibold">@Model.Summary.GlobalCoverageCount</div></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a asp-action="Index" asp-route-filter="MissingRates" class="btn btn-sm btn-outline-warning" hx-get="@ShippingMethodsIndexUrl("MissingRates")" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MissingRates")</a>
            <a asp-action="Index" asp-route-filter="Dhl" class="btn btn-sm btn-outline-secondary" hx-get="@ShippingMethodsIndexUrl("Dhl")" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("DhlMethods")</a>
            <a asp-action="Index" asp-route-filter="Inactive" class="btn btn-sm btn-outline-secondary" hx-get="@ShippingMethodsIndexUrl("Inactive")" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Inactive")</a>
            <a asp-action="Index" asp-route-filter="GlobalCoverage" class="btn btn-sm btn-outline-info" hx-get="@ShippingMethodsIndexUrl("GlobalCoverage")" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("GlobalCoverage")</a>
            <a asp-action="Index" asp-route-filter="MultiRate" class="btn btn-sm btn-outline-primary" hx-get="@ShippingMethodsIndexUrl("MultiRate")" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MultiRate")</a>
        </div>
        <form method="get" class="row g-2"
               hx-get="@ShippingMethodsGlobalIndexUrl()"
              hx-target="#shipping-methods-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <div class="col-md-4">
                <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchShippingMethodsPlaceholder")" />
            </div>
            <div class="col-md-3"><select name="filter" asp-items="Model.FilterItems" class="form-select"></select></div>
            <div class="col-md-2"><select name="pageSize" asp-items="Model.PageSizeItems" class="form-select"></select></div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
<a asp-action="Index" class="btn btn-outline-secondary" hx-get="@ShippingMethodsGlobalIndexUrl()" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Reset")</a>
            </div>
        </form>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("ShippingMethodPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var item in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@item.Title</div>
                        <div class="small text-muted mt-2">@item.ScopeNote</div>
                        <div class="small mt-2"><strong>@T.T("OperatorAction"):</strong> @item.OperatorAction</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("CarrierService")</th>
                <th>@T.T("Countries")</th>
                <th>@T.T("Currency")</th>
                <th>@T.T("Rates")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Updated")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted py-4">@T.T("NoShippingMethodsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td><div class="fw-semibold">@item.Name</div><div class="small text-muted">@item.DisplayName</div></td>
                    <td>@item.Carrier / @item.Service</td>
                    <td>@(string.IsNullOrWhiteSpace(item.CountriesCsv) ? T.T("All") : item.CountriesCsv)</td>
                    <td>@(string.IsNullOrWhiteSpace(item.Currency) ? "-" : item.Currency)</td>
                    <td>
                        <span class="badge @(item.RatesCount > 0 ? "text-bg-success" : "text-bg-warning")">@item.RatesCount</span>
                        @if (item.HasMultipleRates)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("MultiRate")</span></div>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? T.T("Active") : T.T("Inactive"))</span>
                        @if (item.IsDhl)
                        {
                            <div><span class="badge text-bg-primary mt-1">@T.T("DhlMethods")</span></div>
                        }
                        @if (item.HasGlobalCoverage)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("GlobalCoverage")</span></div>
                        }
                    </td>
                    <td>@(item.ModifiedAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? "-")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@EditShippingMethodUrl(item.Id)"
                           hx-target="#shipping-methods-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"><i class="fa-solid fa-pen"></i> @T.T("Edit")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="ShippingMethods" asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#shipping-methods-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
