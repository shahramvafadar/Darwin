@model Darwin.WebAdmin.ViewModels.Shipping.ShippingMethodsListVm
@{
    ViewData["Title"] = "Shipping Methods";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-truck-fast me-2"></i>Shipping Methods</h1>
        <p class="text-muted mb-0">Phase-1 shipping configuration with queue filters for active, incomplete, and DHL-first review.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Create Method
    </a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by name, carrier, service, or countries" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="pageSize" asp-items="Model.PageSizeItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Index" asp-route-filter="MissingRates" class="btn btn-sm btn-outline-warning">Missing Rates</a>
    <a asp-action="Index" asp-route-filter="Dhl" class="btn btn-sm btn-outline-secondary">DHL</a>
    <a asp-action="Index" asp-route-filter="Inactive" class="btn btn-sm btn-outline-secondary">Inactive</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Carrier / Service</th>
                <th>Countries</th>
                <th>Currency</th>
                <th>Rates</th>
                <th>Status</th>
                <th>Updated</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted py-4">No shipping methods found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        <div class="small text-muted">@item.DisplayName</div>
                    </td>
                    <td>@item.Carrier / @item.Service</td>
                    <td>@(string.IsNullOrWhiteSpace(item.CountriesCsv) ? "All" : item.CountriesCsv)</td>
                    <td>@(string.IsNullOrWhiteSpace(item.Currency) ? "-" : item.Currency)</td>
                    <td>
                        <span class="badge @(item.RatesCount > 0 ? "text-bg-success" : "text-bg-warning")">@item.RatesCount</span>
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>@(item.ModifiedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="ShippingMethods"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
