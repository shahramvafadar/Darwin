@model Darwin.WebAdmin.ViewModels.Shipping.ShippingMethodEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] ?? false;
}

<div id="shipping-method-editor-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@(isCreate ? T.T("CreateShippingMethod") : T.T("EditShippingMethod"))</h1>
            <p class="text-muted mb-0">@T.T("ShippingMethodEditorIntro")</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "ShippingMethods")"
           hx-target="#shipping-methods-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Back")</a>
    </div>

    <form asp-action="@(isCreate ? "Create" : "Edit")"
          method="post"
          hx-post="@Url.Action(isCreate ? "Create" : "Edit", "ShippingMethods")"
          hx-target="#shipping-method-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <partial name="_ShippingMethodForm" model="Model" />
    </form>
</div>
