@model IReadOnlyList<Darwin.Application.Catalog.DTOs.CategoryListItemDto>
@{
    ViewData["Title"] = "Categories";
    var currentPage = (int)(ViewBag.Page ?? 1);
    var currentPageSize = (int)(ViewBag.PageSize ?? 20);
    var total = (int)(ViewBag.Total ?? 0);
    var query = (string)(ViewBag.Query ?? string.Empty);
}

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
    <h2 class="m-0">Categories</h2>
    <div class="d-flex flex-wrap gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="query" value="@query" class="form-control" placeholder="Search..." />
            <button class="btn btn-outline-secondary" type="submit">
                <i class="fa fa-search"></i> Search
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </form>
        <a asp-action="Create" class="btn btn-primary">Create Category</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Name (de-DE)</th>
                        <th class="text-center">Active</th>
                        <th class="text-center">Sort</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No categories found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td>@(string.IsNullOrWhiteSpace(c.Name) ? "-" : c.Name)</td>
                                <td class="text-center">
                                    @if (c.IsActive)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-outline-secondary border">No</span>
                                    }
                                </td>
                                <td class="text-center">@c.SortOrder</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
@*                                     <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this category?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash-alt"></i> Delete
                                        </button>
                                    </form> *@
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger ms-1"
                                            data-bs-toggle="modal"
                                            data-bs-target="#confirmDeleteModal"
                                            data-action="@Url.Action("Delete", "Categories")"
                                            data-id="@c.Id"
                                            data-rowversion="@Convert.ToBase64String(c.RowVersion)"
                                            data-name="@(string.IsNullOrWhiteSpace(c.Name) ? c.Id.ToString() : c.Name)">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </button>

                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <pager page="@currentPage"
               page-size="@currentPageSize"
               total="@total"
               asp-controller="Categories"
               asp-action="Index"
               asp-route-query="@query"></pager>

        <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
    </div>
</div>
