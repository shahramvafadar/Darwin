@model Darwin.WebAdmin.ViewModels.Catalog.CategoryEditVm
@{
    ViewData["Title"] = T.T("EditCategory");
    string CategoriesIndexUrl() => Url.Action("Index", "Categories") ?? string.Empty;
}

<div id="category-editor-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
        <div>
            <h1 class="m-0">@T.T("EditCategory")</h1>
            <div class="small text-muted mt-1">@T.T("CategoryEditIntro")</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <div class="badge text-bg-light border">@T.T("Translations"): @Model.Translations.Count</div>
            <div class="badge text-bg-light border">@T.T("CategoryIdentifier"): @Model.Id</div>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="needs-validation" novalidate hx-post="@Url.Action("Edit", "Categories")" hx-target="#category-editor-shell" hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="card shadow-sm">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">@T.T("ParentCategory")</label>
                        <select asp-for="ParentId" class="form-select">
                            <option value="">@T.T("NoParentOption")</option>
                            @if (ViewBag.Categories is IEnumerable<Darwin.Application.Catalog.Queries.LookupItem> cats)
                            {
                                foreach (var c in cats)
                                {
                                    <option value="@c.Id" selected="@(Model.ParentId == c.Id)">@c.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@T.T("SortOrder")</label>
                        <input asp-for="SortOrder" class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" for="IsActive">@T.T("Active")</label>
                        </div>
                    </div>
                </div>

                <hr />

                <h5 class="mt-2">@T.T("Translations")</h5>
                @for (int i = 0; i < Model.Translations.Count; i++)
                {
                    <div class="border rounded p-3 mb-3">
                        <div class="row g-3">
                            <div class="col-md-2">
                                <label class="form-label">@T.T("Culture")</label>
                                <input asp-for="Translations[@i].Culture" class="form-control" />
                                <span asp-validation-for="Translations[@i].Culture" class="text-danger"></span>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">@T.T("Name")</label>
                                <input asp-for="Translations[@i].Name" class="form-control" />
                                <span asp-validation-for="Translations[@i].Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">@T.T("Slug")</label>
                                <input asp-for="Translations[@i].Slug" class="form-control" />
                                <span asp-validation-for="Translations[@i].Slug" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">@T.T("Description")</label>
                                <textarea asp-for="Translations[@i].Description" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer text-end">
                <a asp-action="Index" class="btn btn-secondary" hx-get="@CategoriesIndexUrl()" hx-target="#categories-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Back")</a>
                <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            </div>
        </div>
    </form>
</div>
