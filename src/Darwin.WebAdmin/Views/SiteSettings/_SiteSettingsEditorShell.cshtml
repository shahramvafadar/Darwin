@model Darwin.WebAdmin.ViewModels.Settings.SiteSettingVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditSiteSettings");
}

<div id="site-settings-editor-shell">
<h1 class="mb-3">@T.T("SiteSettingsTitle")</h1>

<form asp-action="Edit"
      method="post"
      class="needs-validation"
      novalidate
      hx-post="@Url.Action("Edit", "SiteSettings")"
      hx-target="#site-settings-editor-shell"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />

    <div class="alert alert-secondary mb-4" role="alert">
        <div class="fw-semibold mb-2">@T.T("SettingsCategories")</div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-basics">@T.T("General")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-localization">@T.T("Localization")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-security">@T.T("Security")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-mobile">@T.T("Mobile")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-business-app">@T.T("BusinessApp")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-payments">@T.T("Payments")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-tax">@T.T("TaxAndInvoicing")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-shipping">@T.T("Shipping")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-retention">@T.T("Operational")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-measurement">@T.T("Units")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-seo">@T.T("Seo")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-analytics">@T.T("Analytics")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-whatsapp">@T.T("WhatsApp")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-webauthn">@T.T("WebAuthn")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-smtp">@T.T("SMTP")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-sms">@T.T("SMS")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-admin-routing">@T.T("AdminAlerts")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-communications-policy">@T.T("CommunicationPolicy")</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("SettingsOwnershipMatrix")</div>
        <div class="card-body">
            <div class="small text-muted mb-3">
                @T.T("SiteSettingsOwnershipIntro")
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Area")</th>
                            <th>@T.T("OwnedHere")</th>
                            <th>@T.T("BusinessScope")</th>
                            <th>@T.T("OperatorHandoff")</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsLocalizationDefaultsTitle")</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@T.T("GlobalOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsLocalizationDefaultsOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsLocalizationDefaultsBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsLocalizationDefaultsAction")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Businesses"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("BusinessSetupQueue")</a>
                                    <a asp-controller="Businesses"
                                       asp-action="SupportQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("NeedsAttention")</a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsCommunicationPolicyTitle")</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@T.T("GlobalOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsCommunicationPolicyOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsCommunicationPolicyBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsCommunicationPolicyAction")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Businesses"
                                       asp-action="SupportQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("BusinessSupport")</a>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "BusinessCommunications")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("CommunicationOps")</a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsPaymentsShippingTitle")</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@T.T("GlobalOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsPaymentsShippingOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsPaymentsShippingBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsPaymentsShippingAction")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Billing"
                                       asp-action="Payments"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Payments", "Billing")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("PaymentOps")</a>
                                    <a asp-controller="Orders"
                                       asp-action="ShipmentsQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("ShipmentsQueue", "Orders")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("ShipmentOps")</a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsBrandingDefaultsTitle")</td>
                            <td>
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">@T.T("BusinessOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsBrandingDefaultsOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsBrandingDefaultsBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsBrandingDefaultsAction")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Businesses"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("OpenBusinesses")</a>
                                    <a asp-controller="Businesses"
                                       asp-action="SupportQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("SubscriberSupport")</a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Basics -->
    <div id="site-settings-basics" class="card mb-4">
        <div class="card-header">@T.T("General")</div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <field-help title="Title" content="Displayed in the browser title and UI headers. Max 200 characters." placement="right"></field-help>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="LogoUrl" class="form-label"></label>
                    <field-help title="Logo URL" content="Absolute or app-relative URL for logo (e.g., /img/logo.svg)." placement="right"></field-help>
                    <input asp-for="LogoUrl" class="form-control" />
                    <span asp-validation-for="LogoUrl" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactEmail" class="form-label"></label>
                    <field-help title="Contact email" content="Primary contact email displayed publicly in footer/contact page." placement="right"></field-help>
                    <input asp-for="ContactEmail" class="form-control" />
                    <span asp-validation-for="ContactEmail" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Localization -->
    <div id="site-settings-localization" class="card mb-4">
        <div class="card-header">@T.T("Localization")</div>
        <div class="card-body">
            <div class="alert alert-secondary mb-3">
                @T.T("SiteSettingsLocalizationIntro")
            </div>
            <div class="row g-3 mb-3">
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("SiteSettingsFallbackGovernanceTitle")</div>
                        <div class="small text-muted">@T.T("SiteSettingsFallbackGovernanceNote")</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("SiteSettingsBusinessOverridePathTitle")</div>
                        <div class="small text-muted">@T.T("SiteSettingsBusinessOverridePathNote")</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("SiteSettingsOperatorHandoffTitle")</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Businesses"
                               asp-action="Index"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Businesses")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("SiteSettingsBusinessDefaults")</a>
                            <a asp-controller="CRM"
                               asp-action="Customers"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Customers", "Crm")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("SiteSettingsCustomerLocaleReview")</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="DefaultCulture" class="form-label"></label>
                    <field-help title="Default culture" content="Format: ll-CC (e.g., de-DE). Used as fallback culture." placement="right"></field-help>
                    <select asp-for="DefaultCulture" class="form-select">
                        <option value="de-DE">de-DE</option>
                        <option value="en-US">en-US</option>
                    </select>
                    <span asp-validation-for="DefaultCulture" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="SupportedCulturesCsv" class="form-label"></label>
                    <field-help title="Supported cultures" content="Comma-separated cultures (e.g., de-DE,en-US). Drives Admin dropdowns and hreflang." placement="right"></field-help>
                    <input asp-for="SupportedCulturesCsv" class="form-control" value="@Model.SupportedCulturesCsv" />
                    <span asp-validation-for="SupportedCulturesCsv" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="DefaultCountry" class="form-label"></label>
                    <field-help title="Default country" content="ISO 3166-1 alpha-2 (e.g., DE)." placement="right"></field-help>
                    <select asp-for="DefaultCountry" class="form-select">
                        <option value="DE">DE</option>
                        <option value="US">US</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="DefaultCurrency" class="form-label"></label>
                    <field-help title="Currency" content="ISO 4217 currency code. Default EUR." placement="right"></field-help>
                    <select asp-for="DefaultCurrency" class="form-select">
                        <option value="EUR">EUR</option>
                        <option value="USD">USD</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="TimeZone" class="form-label"></label>
                    <field-help title="Time zone" content="IANA name (e.g., Europe/Berlin)." placement="right"></field-help>
                    <select asp-for="TimeZone" class="form-select">
                        <option value="Europe/Berlin">Europe/Berlin</option>
                        <option value="UTC">UTC</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="HomeSlug" class="form-label"></label>
                    <field-help title="Home slug" content="Slug of the homepage when building localized routes." placement="right"></field-help>
                    <input asp-for="HomeSlug" class="form-control" />
                </div>
            </div>
            <div class="alert alert-light border small mb-0">
                @T.T("SiteSettingsFallbackRuleNote")
            </div>

            <div class="mt-3">
                <label asp-for="AdminTextOverridesJson" class="form-label"></label>
                <textarea asp-for="AdminTextOverridesJson" class="form-control font-monospace" rows="6" placeholder='{"de-DE":{"Logout":"Abmelden"},"en-US":{"Logout":"Sign out"}}'></textarea>
                <span asp-validation-for="AdminTextOverridesJson" class="text-danger"></span>
                <div class="form-text">
                    Optional platform-level wording overrides layered on top of shared admin resources. Use JSON in the form
                    <code>{"de-DE":{"Key":"Value"},"en-US":{"Key":"Value"}}</code>.
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="DateFormat" class="form-label"></label>
                    <field-help title="Date format" content="Default date format string (e.g., yyyy-MM-dd)." placement="right"></field-help>
                    <input asp-for="DateFormat" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="TimeFormat" class="form-label"></label>
                    <field-help title="Time format" content="Default time format string (e.g., HH:mm)." placement="right"></field-help>
                    <input asp-for="TimeFormat" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- Security -->
    <div id="site-settings-security" class="card mb-4">
        <div class="card-header">Security & JWT</div>
        <div class="card-body">
            <div class="alert alert-warning mb-3" role="alert">
                Treat signing keys and token lifetimes as production-sensitive settings. Changes here affect public APIs and mobile authentication.
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" asp-for="JwtEnabled" />
                <label class="form-check-label" asp-for="JwtEnabled"></label>
                <field-help title="JWT enabled" content="Disables issuing and accepting JWT access/refresh tokens when turned off." placement="right"></field-help>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="JwtIssuer" class="form-label"></label>
                    <input asp-for="JwtIssuer" class="form-control" />
                    <span asp-validation-for="JwtIssuer" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="JwtAudience" class="form-label"></label>
                    <input asp-for="JwtAudience" class="form-control" />
                    <span asp-validation-for="JwtAudience" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="JwtClockSkewSeconds" class="form-label"></label>
                    <input asp-for="JwtClockSkewSeconds" class="form-control" type="number" min="0" />
                    <span asp-validation-for="JwtClockSkewSeconds" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="JwtAccessTokenMinutes" class="form-label"></label>
                    <input asp-for="JwtAccessTokenMinutes" class="form-control" type="number" min="1" />
                    <span asp-validation-for="JwtAccessTokenMinutes" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="JwtRefreshTokenDays" class="form-label"></label>
                    <input asp-for="JwtRefreshTokenDays" class="form-control" type="number" min="1" />
                    <span asp-validation-for="JwtRefreshTokenDays" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3 d-flex align-items-center">
                    <div class="form-check form-switch">
                        <input class="form-check-input" asp-for="JwtEmitScopes" />
                        <label class="form-check-label" asp-for="JwtEmitScopes"></label>
                    </div>
                </div>
                <div class="col-md-3 mb-3 d-flex align-items-center">
                    <div class="form-check form-switch">
                        <input class="form-check-input" asp-for="JwtSingleDeviceOnly" />
                        <label class="form-check-label" asp-for="JwtSingleDeviceOnly"></label>
                    </div>
                </div>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" asp-for="JwtRequireDeviceBinding" />
                <label class="form-check-label" asp-for="JwtRequireDeviceBinding"></label>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="JwtSigningKey" class="form-label"></label>
                    <field-help title="Signing key" content="Use a long high-entropy secret in production. Rotating this key affects active tokens." placement="right"></field-help>
                    <input asp-for="JwtSigningKey" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="JwtSigningKey" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="JwtPreviousSigningKey" class="form-label"></label>
                    <field-help title="Previous signing key" content="Optional rotation slot so validators can accept tokens signed before a key change." placement="right"></field-help>
                    <input asp-for="JwtPreviousSigningKey" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="JwtPreviousSigningKey" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile -->
    <div id="site-settings-mobile" class="card mb-4">
        <div class="card-header">Mobile Bootstrap</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MobileQrTokenRefreshSeconds" class="form-label"></label>
                    <field-help title="QR token refresh" content="Refresh cadence for mobile QR/session tokens. Lower values improve security but increase refresh traffic." placement="right"></field-help>
                    <input asp-for="MobileQrTokenRefreshSeconds" class="form-control" type="number" min="0" />
                    <span asp-validation-for="MobileQrTokenRefreshSeconds" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MobileMaxOutboxItems" class="form-label"></label>
                    <field-help title="Max outbox items" content="Upper bound for offline/mobile outbox buffering before the client must flush or block." placement="right"></field-help>
                    <input asp-for="MobileMaxOutboxItems" class="form-control" type="number" min="0" />
                    <span asp-validation-for="MobileMaxOutboxItems" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div id="site-settings-business-app" class="card mb-4">
        <div class="card-header">Business App Legal and Billing Handoffs</div>
        <div class="card-body">
            <div class="alert alert-secondary mb-3">
                These URLs are used by business-facing mobile flows that hand operators off to external legal or billing pages rather than executing those actions inside the app.
            </div>
            <div class="small text-muted mb-3">
                Keep only platform-wide handoff URLs here. Validate the final brand, sender, and local business defaults from Business Setup before treating a tenant as go-live ready.
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="BusinessManagementWebsiteUrl" class="form-label"></label>
                    <input asp-for="BusinessManagementWebsiteUrl" class="form-control" placeholder="https://www.loyan.de" />
                    <span asp-validation-for="BusinessManagementWebsiteUrl" class="text-danger"></span>
                    <div class="form-text">Used by the business app subscription screen for plan/billing handoff.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountDeletionUrl" class="form-label"></label>
                    <input asp-for="AccountDeletionUrl" class="form-control" placeholder="https://www.loyan.de/account-deletion" />
                    <span asp-validation-for="AccountDeletionUrl" class="text-danger"></span>
                    <div class="form-text">Used by the business app deletion handoff flow.</div>
                </div>
                <div class="col-md-4">
                    <label asp-for="ImpressumUrl" class="form-label"></label>
                    <input asp-for="ImpressumUrl" class="form-control" placeholder="https://www.loyan.de/impressum" />
                    <span asp-validation-for="ImpressumUrl" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PrivacyPolicyUrl" class="form-label"></label>
                    <input asp-for="PrivacyPolicyUrl" class="form-control" placeholder="https://www.loyan.de/datenschutz" />
                    <span asp-validation-for="PrivacyPolicyUrl" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="BusinessTermsUrl" class="form-label"></label>
                    <input asp-for="BusinessTermsUrl" class="form-control" placeholder="https://www.loyan.de/agb-business" />
                    <span asp-validation-for="BusinessTermsUrl" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div id="site-settings-payments" class="card mb-4">
        <div class="card-header">Payments (Stripe-first)</div>
        <div class="card-body">
            <div class="alert alert-secondary mb-3">
                Stripe is the phase-1 payment provider. Keep the abstraction generic in code, but manage the near-term operational credentials and webhook verification here.
            </div>
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" asp-for="StripeEnabled" />
                <label class="form-check-label" asp-for="StripeEnabled"></label>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="StripeMerchantDisplayName" class="form-label"></label>
                    <input asp-for="StripeMerchantDisplayName" class="form-control" />
                    <span asp-validation-for="StripeMerchantDisplayName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StripePublishableKey" class="form-label"></label>
                    <input asp-for="StripePublishableKey" class="form-control" autocomplete="off" />
