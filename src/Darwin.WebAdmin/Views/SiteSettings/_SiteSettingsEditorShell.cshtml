                    </div>
                </div>
            </div>
            <div class="alert alert-light border mt-3 mb-3 small">
                Phone verification policy:
                if the client does not specify a channel, the platform uses the preferred channel above.
                If fallback is enabled, the system may switch between SMS and WhatsApp when the preferred or requested channel is unavailable.
            </div>
            <div class="alert alert-light border mt-3 mb-3 small">
                Supported placeholders:
                <code>{business_name}</code>,
                <code>{role}</code>,
                <code>{token}</code>,
                <code>{expires_at_utc}</code>,
                <code>{acceptance_link}</code>,
                <code>{acceptance_link_html}</code>,
                <code>{invitation_action}</code>,
                <code>{invitation_intro_html}</code>,
                <code>{email}</code>,
                <code>{phone_e164}</code>,
                <code>{channel}</code>,
                <code>{requested_by}</code>,
                <code>{attempted_at_utc}</code>,
                <code>{test_target}</code>,
                <code>{transport_state}</code>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CommunicationTestEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="CommunicationTestEmailSubjectTemplate" class="form-control" placeholder="Darwin communication test for {channel}" />
                    <span asp-validation-for="CommunicationTestEmailSubjectTemplate" class="text-danger"></span>
                    <div class="form-text">Subject used for operator-side diagnostic email tests.</div>
                </div>
                <div class="col-md-12">
                    <label asp-for="CommunicationTestEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestEmailBodyTemplate" class="form-control" rows="5" placeholder="&lt;p&gt;This is a Darwin {channel} communication test.&lt;/p&gt;"></textarea>
                    <span asp-validation-for="CommunicationTestEmailBodyTemplate" class="text-danger"></span>
                    <div class="form-text">HTML body used for diagnostic email tests to the configured test inbox.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunicationTestSmsTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestSmsTemplate" class="form-control" rows="3" placeholder="Darwin SMS transport test requested by {requested_by} at {attempted_at_utc} UTC for {test_target}."></textarea>
                    <span asp-validation-for="CommunicationTestSmsTemplate" class="text-danger"></span>
                    <div class="form-text">Plain-text SMS used for operator-side SMS provider validation.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunicationTestWhatsAppTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestWhatsAppTemplate" class="form-control" rows="3" placeholder="Darwin WhatsApp transport test requested by {requested_by} at {attempted_at_utc} UTC for {test_target}."></textarea>
                    <span asp-validation-for="CommunicationTestWhatsAppTemplate" class="text-danger"></span>
                    <div class="form-text">Plain-text WhatsApp message used for operator-side WhatsApp validation.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="BusinessInvitationEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="BusinessInvitationEmailSubjectTemplate" class="form-control" placeholder="Invitation to join {business_name} on Darwin" />
                    <span asp-validation-for="BusinessInvitationEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountActivationEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="AccountActivationEmailSubjectTemplate" class="form-control" placeholder="Confirm your Darwin account email" />
                    <span asp-validation-for="AccountActivationEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="BusinessInvitationEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="BusinessInvitationEmailBodyTemplate" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="BusinessInvitationEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="AccountActivationEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="AccountActivationEmailBodyTemplate" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="AccountActivationEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PasswordResetEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="PasswordResetEmailSubjectTemplate" class="form-control" placeholder="Reset your Darwin account password" />
                    <span asp-validation-for="PasswordResetEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="PasswordResetEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="PasswordResetEmailBodyTemplate" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="PasswordResetEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneVerificationSmsTemplate" class="form-label"></label>
                    <textarea asp-for="PhoneVerificationSmsTemplate" class="form-control" rows="3" placeholder="Your Darwin verification code is {token}. It expires at {expires_at_utc} UTC."></textarea>
                    <span asp-validation-for="PhoneVerificationSmsTemplate" class="text-danger"></span>
                    <div class="form-text">Plain-text SMS template for current-user mobile verification.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneVerificationWhatsAppTemplate" class="form-label"></label>
                    <textarea asp-for="PhoneVerificationWhatsAppTemplate" class="form-control" rows="3" placeholder="Confirm your Darwin mobile number with code {token}. It expires at {expires_at_utc} UTC."></textarea>
                    <span asp-validation-for="PhoneVerificationWhatsAppTemplate" class="text-danger"></span>
                    <div class="form-text">Plain-text WhatsApp template for current-user mobile verification.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>
</div>
