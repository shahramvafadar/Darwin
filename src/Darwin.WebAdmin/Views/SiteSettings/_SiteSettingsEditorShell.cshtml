@model Darwin.WebAdmin.ViewModels.Settings.SiteSettingVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditSiteSettings");
    var activeFragment = ViewData["ActiveFragment"] as string;
    var adminOverrideCultures = Darwin.Application.Settings.DTOs.SiteSettingDto.SupportedCulturesCsvDefault
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var adminPrimaryCulture = adminOverrideCultures.Length > 0
        ? adminOverrideCultures[0]
        : Darwin.WebAdmin.Localization.AdminCultureCatalog.DefaultCulture;
    var adminSecondaryCulture = adminOverrideCultures.Length > 1 ? adminOverrideCultures[1] : adminPrimaryCulture;
    var adminOverridesPlaceholder =
        "{\"" + adminPrimaryCulture + "\":{\"Logout\":\"" + T.T("AdminTextOverrideExampleGermanLogout") + "\"},\"" +
        adminSecondaryCulture + "\":{\"Logout\":\"" + T.T("AdminTextOverrideExampleEnglishLogout") + "\"}}";
    var adminOverridesExample =
        "{\"" + adminPrimaryCulture + "\":{\"" + T.T("AdminTextOverrideExampleKey") + "\":\"" + T.T("AdminTextOverrideExampleValue") + "\"},\"" +
        adminSecondaryCulture + "\":{\"" + T.T("AdminTextOverrideExampleKey") + "\":\"" + T.T("AdminTextOverrideExampleValue") + "\"}}";

    string CommunicationChannelLabel(string channel) => channel switch
    {
        "SMS" => T.T("SMS"),
        "WhatsApp" => T.T("WhatsApp"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };

    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };

    string SiteSettingsSectionTitle(string? sectionId) => sectionId switch
    {
        "site-settings-basics" => T.T("General"),
        "site-settings-localization" => T.T("Localization"),
        "site-settings-security" => T.T("Security"),
        "site-settings-mobile" => T.T("Mobile"),
        "site-settings-business-app" => T.T("BusinessApp"),
        "site-settings-payments" => T.T("Payments"),
        "site-settings-tax" => T.T("TaxAndInvoicing"),
        "site-settings-shipping" => T.T("Shipping"),
        "site-settings-retention" => T.T("Operational"),
        "site-settings-measurement" => T.T("Units"),
        "site-settings-seo" => T.T("Seo"),
        "site-settings-analytics" => T.T("Analytics"),
        "site-settings-whatsapp" => CommunicationChannelLabel("WhatsApp"),
        "site-settings-webauthn" => T.T("WebAuthn"),
        "site-settings-smtp" => T.T("SMTP"),
        "site-settings-sms" => CommunicationChannelLabel("SMS"),
        "site-settings-admin-routing" => T.T("AdminAlerts"),
        "site-settings-communications-policy" => T.T("CommunicationPolicy"),
        _ => T.T("SiteSettings")
    };

    bool IsFocusedSection(string sectionId) => string.Equals(activeFragment, sectionId, StringComparison.OrdinalIgnoreCase);

    string SectionCardClass(string sectionId) => IsFocusedSection(sectionId)
        ? "card mb-4 border-primary shadow-sm"
        : "card mb-4";

    string ReadinessBadgeClass(bool isReady) => isReady
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";

    string ReadinessBadgeText(bool isReady) => isReady ? T.T("Configured") : T.T("NeedsAttention");

    bool localizationDefaultsReady = !string.IsNullOrWhiteSpace(Model.DefaultCulture)
        && !string.IsNullOrWhiteSpace(Model.SupportedCulturesCsv)
        && !string.IsNullOrWhiteSpace(Model.TimeZone);
    bool localizationOverridesReady = !string.IsNullOrWhiteSpace(Model.AdminTextOverridesJson);
    bool localizationHandoffReady = !string.IsNullOrWhiteSpace(Model.DefaultCountry)
        && !string.IsNullOrWhiteSpace(Model.DefaultCurrency);
    bool localizationReadiness = localizationDefaultsReady && localizationOverridesReady && localizationHandoffReady;

    bool communicationTransportReady = Model.SmtpEnabled
        && !string.IsNullOrWhiteSpace(Model.SmtpHost)
        && !string.IsNullOrWhiteSpace(Model.SmtpFromAddress);
    bool communicationAlertsReady = !string.IsNullOrWhiteSpace(Model.AdminAlertEmailsCsv)
        || !string.IsNullOrWhiteSpace(Model.AdminAlertSmsRecipientsCsv);
    bool communicationPolicyReady = !string.IsNullOrWhiteSpace(Model.TransactionalEmailSubjectPrefix)
        && !string.IsNullOrWhiteSpace(Model.CommunicationTestInboxEmail);
    bool communicationTestTargetsReady = !string.IsNullOrWhiteSpace(Model.CommunicationTestInboxEmail)
        && !string.IsNullOrWhiteSpace(Model.CommunicationTestSmsRecipientE164)
        && !string.IsNullOrWhiteSpace(Model.CommunicationTestWhatsAppRecipientE164);
    bool communicationReadiness = communicationTransportReady && communicationAlertsReady && communicationPolicyReady;
    bool communicationExecutionReadiness = communicationReadiness && communicationTestTargetsReady;
    bool communicationDeliveryVisibilityReady = communicationTransportReady
        && communicationAlertsReady
        && communicationTestTargetsReady;
    bool invitationTemplateReady = !string.IsNullOrWhiteSpace(Model.BusinessInvitationEmailSubjectTemplate)
        && !string.IsNullOrWhiteSpace(Model.BusinessInvitationEmailBodyTemplate);
    bool activationTemplateReady = !string.IsNullOrWhiteSpace(Model.AccountActivationEmailSubjectTemplate)
        && !string.IsNullOrWhiteSpace(Model.AccountActivationEmailBodyTemplate);
    bool passwordResetTemplateReady = !string.IsNullOrWhiteSpace(Model.PasswordResetEmailSubjectTemplate)
        && !string.IsNullOrWhiteSpace(Model.PasswordResetEmailBodyTemplate);
    bool phoneVerificationTemplateReady = !string.IsNullOrWhiteSpace(Model.PhoneVerificationSmsTemplate)
        && !string.IsNullOrWhiteSpace(Model.PhoneVerificationWhatsAppTemplate);
bool communicationTemplateInventoryReady = invitationTemplateReady
    && activationTemplateReady
    && passwordResetTemplateReady
    && phoneVerificationTemplateReady;
bool communicationTemplateExecutionReadiness = communicationPolicyReady && communicationTemplateInventoryReady;
bool communicationRuntimeExecutionReady = communicationExecutionReadiness
    && communicationDeliveryVisibilityReady
    && communicationTemplateInventoryReady;

    bool paymentsReady = Model.StripeEnabled
        && !string.IsNullOrWhiteSpace(Model.StripePublishableKey)
        && !string.IsNullOrWhiteSpace(Model.StripeSecretKey);
    bool taxReady = Model.VatEnabled
        && !string.IsNullOrWhiteSpace(Model.InvoiceIssuerLegalName)
        && !string.IsNullOrWhiteSpace(Model.InvoiceIssuerCountry);
    bool shippingReady = Model.DhlEnabled
        && !string.IsNullOrWhiteSpace(Model.DhlApiBaseUrl)
        && !string.IsNullOrWhiteSpace(Model.DhlApiKey)
        && !string.IsNullOrWhiteSpace(Model.DhlAccountNumber);
    bool shippingIdentityReady = !string.IsNullOrWhiteSpace(Model.DhlShipperName)
        && !string.IsNullOrWhiteSpace(Model.DhlShipperEmail)
        && !string.IsNullOrWhiteSpace(Model.DhlShipperStreet)
        && !string.IsNullOrWhiteSpace(Model.DhlShipperPostalCode)
        && !string.IsNullOrWhiteSpace(Model.DhlShipperCity)
        && !string.IsNullOrWhiteSpace(Model.DhlShipperCountry);
    bool shippingThresholdsReady = Model.ShipmentAttentionDelayHours > 0
        && Model.ShipmentTrackingGraceHours > 0;
    bool shippingExecutionReadiness = shippingReady && shippingIdentityReady && shippingThresholdsReady;
    bool commerceReadiness = paymentsReady && taxReady && shippingReady;

    bool jwtReady = Model.JwtEnabled
        && !string.IsNullOrWhiteSpace(Model.JwtIssuer)
        && !string.IsNullOrWhiteSpace(Model.JwtAudience);
    bool signingKeyReady = !string.IsNullOrWhiteSpace(Model.JwtSigningKey);
    bool webAuthnReady = !string.IsNullOrWhiteSpace(Model.WebAuthnRelyingPartyId)
        && !string.IsNullOrWhiteSpace(Model.WebAuthnAllowedOriginsCsv);
    bool securityReadiness = jwtReady && signingKeyReady && webAuthnReady;

    string CommunicationFlowLabel(string flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationTemplateInventoryInvitationFlow"),
        "AccountActivation" => T.T("CommunicationTemplateInventoryActivationFlow"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };

    string ConfiguredValueText(string? value, string fallbackKey = "NotConfigured")
        => string.IsNullOrWhiteSpace(value) ? T.T(fallbackKey) : value.Trim();

    string CommunicationPolicyBadgeClass(bool configured)
        => configured ? "badge bg-success-subtle text-success-emphasis" : "badge bg-warning-subtle text-warning-emphasis";

    string CommunicationPolicyStatusText(bool configured)
        => configured ? T.T("Configured") : T.T("NeedsAttention");

    string CommunicationTemplateAnchorHref(string flowKey) => flowKey switch
    {
        "BusinessInvitation" => "#BusinessInvitationEmailSubjectTemplate",
        "AccountActivation" => "#AccountActivationEmailSubjectTemplate",
        "PasswordReset" => "#PasswordResetEmailSubjectTemplate",
        "AdminCommunicationTest" => "#CommunicationTestEmailSubjectTemplate",
        "PhoneVerification" => "#PhoneVerificationPreferredChannel",
        _ => "#site-settings-communications-policy"
    };
}

<div id="site-settings-editor-shell">
<h1 class="mb-3">@T.T("SiteSettingsTitle")</h1>

<form asp-action="Edit"
      method="post"
      class="needs-validation"
      novalidate
      hx-post="@Url.Action("Edit", "SiteSettings")"
      hx-target="#site-settings-editor-shell"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <input type="hidden" name="fragment" value="@activeFragment" />

    @if (!string.IsNullOrWhiteSpace(activeFragment))
    {
        <div class="alert alert-primary mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3" role="alert">
            <div>
                <div class="fw-semibold">@SiteSettingsSectionTitle(activeFragment)</div>
                <div class="small">@T.T("Open") @SiteSettingsSectionTitle(activeFragment)</div>
            </div>
            <a class="btn btn-sm btn-outline-primary" href="#@activeFragment">@T.T("Open")</a>
        </div>
    }

    <div class="alert alert-secondary mb-4" role="alert">
        <div class="fw-semibold mb-2">@T.T("SettingsCategories")</div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-basics">@T.T("General")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-localization">@T.T("Localization")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-security">@T.T("Security")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-mobile">@T.T("Mobile")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-business-app">@T.T("BusinessApp")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-payments">@T.T("Payments")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-tax">@T.T("TaxAndInvoicing")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-shipping">@T.T("Shipping")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-retention">@T.T("Operational")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-measurement">@T.T("Units")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-seo">@T.T("Seo")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-analytics">@T.T("Analytics")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-whatsapp">@CommunicationChannelLabel("WhatsApp")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-webauthn">@T.T("WebAuthn")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-smtp">@T.T("SMTP")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-sms">@CommunicationChannelLabel("SMS")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-admin-routing">@T.T("AdminAlerts")</a>
            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-communications-policy">@T.T("CommunicationPolicy")</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("Operational")</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div class="fw-semibold">@T.T("Localization")</div>
                            <span class="@ReadinessBadgeClass(localizationReadiness)">@ReadinessBadgeText(localizationReadiness)</span>
                        </div>
                        <div class="small text-muted mb-3">@T.T("SiteSettingsLocalizationIntro")</div>
                        <ul class="small mb-3 ps-3">
                            <li>@T.T("SiteSettingsFallbackGovernanceTitle"): @ReadinessBadgeText(localizationDefaultsReady)</li>
                            <li>@T.T("SiteSettingsBusinessOverridePathTitle"): @ReadinessBadgeText(localizationOverridesReady)</li>
                            <li>@T.T("SiteSettingsOperatorHandoffTitle"): @ReadinessBadgeText(localizationHandoffReady)</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-localization">@T.T("Open")</a>
                            <a asp-controller="Businesses"
                               asp-action="Index"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Businesses")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessSetupQueue")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div class="fw-semibold">@T.T("Communications")</div>
                            <span class="@ReadinessBadgeClass(communicationReadiness)">@ReadinessBadgeText(communicationReadiness)</span>
                        </div>
                        <div class="small text-muted mb-3">@T.T("SiteSettingsTransactionalPolicyIntro")</div>
                        <ul class="small mb-3 ps-3">
                            <li>@T.T("SiteSettingsEmailSmtpTitle"): @ReadinessBadgeText(communicationTransportReady)</li>
                            <li>@T.T("AdminAlerts"): @ReadinessBadgeText(communicationAlertsReady)</li>
                            <li>@T.T("CommunicationPolicy"): @ReadinessBadgeText(communicationPolicyReady)</li>
                            <li>@T.T("Communications"): @ReadinessBadgeText(communicationDeliveryVisibilityReady)</li>
                            <li>@T.T("CommunicationTemplateInventoryTitle"): @ReadinessBadgeText(communicationTemplateExecutionReadiness)</li>
                            <li>@T.T("RuntimeExecution"): @ReadinessBadgeText(communicationRuntimeExecutionReady)</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-communications-policy">@T.T("Open")</a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="Index"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "BusinessCommunications")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("CommunicationOps")</a>
                            <a asp-controller="Businesses"
                               asp-action="Invitations"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Invitations", "Businesses", new { filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending })"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Pending")</a>
                            <a asp-controller="Users"
                               asp-action="Index"
                               asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed })"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                            <a asp-controller="Users"
                               asp-action="Index"
                               asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Locked })"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("UsersFilterLocked")</a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-flowKey="PasswordReset"
                               asp-route-status="Failed"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { flowKey = "PasswordReset", status = "Failed" })"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div class="fw-semibold">@T.T("Payments") / @T.T("Shipping")</div>
                            <span class="@ReadinessBadgeClass(commerceReadiness)">@ReadinessBadgeText(commerceReadiness)</span>
                        </div>
                        <div class="small text-muted mb-3">@T.T("SiteSettingsPaymentsShippingAction")</div>
                        <ul class="small mb-3 ps-3">
                            <li>@T.T("SiteSettingsPaymentsStripeTitle"): @ReadinessBadgeText(paymentsReady)</li>
                            <li>@T.T("SiteSettingsTaxVatTitle"): @ReadinessBadgeText(taxReady)</li>
                            <li>@T.T("SiteSettingsShippingDhlTitle"): @ReadinessBadgeText(shippingReady)</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-payments">@T.T("Open")</a>
                            <a asp-controller="Billing"
                               asp-action="Payments"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Payments", "Billing")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("PaymentOps")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div class="fw-semibold">@T.T("Security")</div>
                            <span class="@ReadinessBadgeClass(securityReadiness)">@ReadinessBadgeText(securityReadiness)</span>
                        </div>
                        <div class="small text-muted mb-3">@T.T("SiteSettingsCommunicationPolicyBusiness")</div>
                        <ul class="small mb-3 ps-3">
                            <li>@T.T("SiteSettingsSecurityJwtTitle"): @ReadinessBadgeText(jwtReady)</li>
                            <li>@T.T("SiteSettingsSigningKeyTitle"): @ReadinessBadgeText(signingKeyReady)</li>
                            <li>@T.T("SiteSettingsWebAuthnPasskeysTitle"): @ReadinessBadgeText(webAuthnReady)</li>
                        </ul>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="#site-settings-security">@T.T("Open")</a>
                            <a asp-controller="Users"
                               asp-action="Index"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Users")"
                               hx-target="#site-settings-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Users")</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("SettingsOwnershipMatrix")</div>
        <div class="card-body">
            <div class="small text-muted mb-3">
                @T.T("SiteSettingsOwnershipIntro")
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Area")</th>
                            <th>@T.T("OwnedHere")</th>
                            <th>@T.T("BusinessScope")</th>
                            <th>@T.T("OperatorHandoff")</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsLocalizationDefaultsTitle")</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@T.T("GlobalOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsLocalizationDefaultsOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsLocalizationDefaultsBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsLocalizationDefaultsAction")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Businesses"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("BusinessSetupQueue")</a>
                                    <a asp-controller="Businesses"
                                       asp-action="SupportQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">@T.T("SiteSettingsCommunicationPolicyTitle")</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@T.T("GlobalOwner")</span>
                                <div class="mt-2">@T.T("SiteSettingsCommunicationPolicyOwned")</div>
                            </td>
                            <td>@T.T("SiteSettingsCommunicationPolicyBusiness")</td>
                            <td>
                                <div class="small text-muted mb-2">@T.T("SiteSettingsCommunicationPolicyAction")</div>
                                <div class="small text-muted mb-2">@T.T("CommunicationPolicy") / @T.T("Communications") / @T.T("CommunicationTemplateInventoryTitle") / @T.T("RuntimeExecution")</div>
                                <div class="small text-muted mb-2">@T.T("RuntimeExecution"): @T.T("Pending") / @T.T("UsersFilterUnconfirmed") / @T.T("UsersFilterLocked") / @T.T("OpenFailedPasswordResets")</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-controller="Businesses"
                                       asp-action="SupportQueue"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("BusinessSupport")</a>
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="Index"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "BusinessCommunications")"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("CommunicationOps")</a>
                                    <a asp-controller="Businesses"
                                       asp-action="Invitations"
                                       asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Invitations", "Businesses", new { filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending })"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("Pending")</a>
                                    <a asp-controller="Users"
                                       asp-action="Index"
                                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed })"
                                       hx-target="#site-settings-editor-shell"
                                       hx-swap="outerHTML"
