            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SmsApiSecret" class="form-label"></label>
                    <input asp-for="SmsApiSecret" class="form-control" type="password" autocomplete="new-password" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SmsExtraSettingsJson" class="form-label"></label>
                    <textarea asp-for="SmsExtraSettingsJson" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Routing -->
    <div id="site-settings-admin-routing" class="card mb-4">
        <div class="card-header">@T.T("AdminAlertRouting")</div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="AdminAlertEmailsCsv" class="form-label"></label>
                <input asp-for="AdminAlertEmailsCsv" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="AdminAlertSmsRecipientsCsv" class="form-label"></label>
                <field-help title="@T.T("SiteSettingsAdminSmsRecipientsTitle")" content="@T.T("SiteSettingsAdminSmsRecipientsHelp")" placement="right"></field-help>
                <input asp-for="AdminAlertSmsRecipientsCsv" class="form-control" />
            </div>
        </div>
    </div>

    <div id="site-settings-communications-policy" class="card mb-4">
        <div class="card-header">@T.T("BusinessCommunicationTransactionalPolicyTitle")</div>
        <div class="card-body">
            <div class="alert alert-secondary mb-3">
                @T.T("SiteSettingsTransactionalPolicyIntro")
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="TransactionalEmailSubjectPrefix" class="form-label"></label>
                    <input asp-for="TransactionalEmailSubjectPrefix" class="form-control" placeholder="@T.T("SiteSettingsTransactionalEmailSubjectPrefixPlaceholder")" />
                    <span asp-validation-for="TransactionalEmailSubjectPrefix" class="text-danger"></span>
                    <div class="form-text">@T.T("BusinessCommunicationPhaseOneImplicationSubjectPrefix")</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunicationTestInboxEmail" class="form-label"></label>
                    <input asp-for="CommunicationTestInboxEmail" class="form-control" placeholder="@T.T("SiteSettingsCommunicationTestInboxPlaceholder")" />
                    <span asp-validation-for="CommunicationTestInboxEmail" class="text-danger"></span>
                    <div class="form-text">@T.T("BusinessCommunicationPhaseOneImplicationTestInbox")</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="CommunicationTestSmsRecipientE164" class="form-label"></label>
                    <input asp-for="CommunicationTestSmsRecipientE164" class="form-control" placeholder="@T.T("SiteSettingsCommunicationTestPhonePlaceholder")" />
                    <span asp-validation-for="CommunicationTestSmsRecipientE164" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsCommunicationTestSmsTargetHelp")</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="CommunicationTestWhatsAppRecipientE164" class="form-label"></label>
                    <input asp-for="CommunicationTestWhatsAppRecipientE164" class="form-control" placeholder="@T.T("SiteSettingsCommunicationTestPhonePlaceholder")" />
                    <span asp-validation-for="CommunicationTestWhatsAppRecipientE164" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsWhatsAppTransportTestHelp")</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="PhoneVerificationPreferredChannel" class="form-label"></label>
                    <select asp-for="PhoneVerificationPreferredChannel" class="form-select">
                        <option value="Sms">@CommunicationChannelLabel("SMS")</option>
                        <option value="WhatsApp">@CommunicationChannelLabel("WhatsApp")</option>
                    </select>
                    <span asp-validation-for="PhoneVerificationPreferredChannel" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsPhoneVerificationPreferredChannelHelp")</div>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" asp-for="PhoneVerificationAllowFallback" />
                        <label class="form-check-label" asp-for="PhoneVerificationAllowFallback"></label>
                    </div>
                </div>
            </div>
            <div class="alert alert-light border mt-3 mb-3 small">
                @T.T("SiteSettingsPhoneVerificationPolicyNote")
            </div>
            <div class="alert alert-light border mt-3 mb-3 small">
                @T.T("SiteSettingsSupportedPlaceholdersTitle"):
                <code>{business_name}</code>,
                <code>{role}</code>,
                <code>{token}</code>,
                <code>{expires_at_utc}</code>,
                <code>{acceptance_link}</code>,
                <code>{acceptance_link_html}</code>,
                <code>{invitation_action}</code>,
                <code>{invitation_intro_html}</code>,
                <code>{email}</code>,
                <code>{phone_e164}</code>,
                <code>{channel}</code>,
                <code>{requested_by}</code>,
                <code>{attempted_at_utc}</code>,
                <code>{test_target}</code>,
                <code>{transport_state}</code>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CommunicationTestEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="CommunicationTestEmailSubjectTemplate" class="form-control" placeholder="@T.T("SiteSettingsCommunicationTestEmailSubjectPlaceholder")" />
                    <span asp-validation-for="CommunicationTestEmailSubjectTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsCommunicationTestEmailSubjectHelp")</div>
                </div>
                <div class="col-md-12">
                    <label asp-for="CommunicationTestEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestEmailBodyTemplate" class="form-control" rows="5" placeholder="@T.T("SiteSettingsCommunicationTestEmailBodyPlaceholder")"></textarea>
                    <span asp-validation-for="CommunicationTestEmailBodyTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsCommunicationTestEmailBodyHelp")</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunicationTestSmsTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestSmsTemplate" class="form-control" rows="3" placeholder="@T.T("SiteSettingsCommunicationTestSmsTemplatePlaceholder")"></textarea>
                    <span asp-validation-for="CommunicationTestSmsTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsCommunicationTestSmsTemplateHelp")</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunicationTestWhatsAppTemplate" class="form-label"></label>
                    <textarea asp-for="CommunicationTestWhatsAppTemplate" class="form-control" rows="3" placeholder="@T.T("SiteSettingsCommunicationTestWhatsAppTemplatePlaceholder")"></textarea>
                    <span asp-validation-for="CommunicationTestWhatsAppTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsCommunicationTestWhatsAppTemplateHelp")</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="BusinessInvitationEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="BusinessInvitationEmailSubjectTemplate" class="form-control" placeholder="@T.T("SiteSettingsBusinessInvitationEmailSubjectPlaceholder")" />
                    <span asp-validation-for="BusinessInvitationEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountActivationEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="AccountActivationEmailSubjectTemplate" class="form-control" placeholder="@T.T("SiteSettingsAccountActivationEmailSubjectPlaceholder")" />
                    <span asp-validation-for="AccountActivationEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="BusinessInvitationEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="BusinessInvitationEmailBodyTemplate" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="BusinessInvitationEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="AccountActivationEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="AccountActivationEmailBodyTemplate" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="AccountActivationEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PasswordResetEmailSubjectTemplate" class="form-label"></label>
                    <input asp-for="PasswordResetEmailSubjectTemplate" class="form-control" placeholder="@T.T("SiteSettingsPasswordResetEmailSubjectPlaceholder")" />
                    <span asp-validation-for="PasswordResetEmailSubjectTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="PasswordResetEmailBodyTemplate" class="form-label"></label>
                    <textarea asp-for="PasswordResetEmailBodyTemplate" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="PasswordResetEmailBodyTemplate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneVerificationSmsTemplate" class="form-label"></label>
                    <textarea asp-for="PhoneVerificationSmsTemplate" class="form-control" rows="3" placeholder="@T.T("SiteSettingsPhoneVerificationSmsTemplatePlaceholder")"></textarea>
                    <span asp-validation-for="PhoneVerificationSmsTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsPhoneVerificationSmsTemplateHelp")</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneVerificationWhatsAppTemplate" class="form-label"></label>
                    <textarea asp-for="PhoneVerificationWhatsAppTemplate" class="form-control" rows="3" placeholder="@T.T("SiteSettingsPhoneVerificationWhatsAppTemplatePlaceholder")"></textarea>
                    <span asp-validation-for="PhoneVerificationWhatsAppTemplate" class="text-danger"></span>
                    <div class="form-text">@T.T("SiteSettingsPhoneVerificationWhatsAppTemplateHelp")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">@T.T("Save")</button>
    </div>
</form>
</div>
