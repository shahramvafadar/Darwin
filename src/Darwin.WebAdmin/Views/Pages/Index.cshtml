@model IReadOnlyList<Darwin.Application.CMS.DTOs.PageListItemDto>
@{
    ViewData["Title"] = "Pages";
    var currentPage = (int)(ViewBag.Page ?? 1);
    var currentPageSize = (int)(ViewBag.PageSize ?? 20);
    var total = (int)(ViewBag.Total ?? 0);
    var query = (string)(ViewBag.Query ?? string.Empty);
}
<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
    <h2 class="mb-0">Pages</h2>
    <div class="d-flex flex-wrap gap-2">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="query" value="@query" class="form-control" placeholder="Search..." />
            <button class="btn btn-outline-secondary" type="submit">
                <i class="fa fa-search"></i> Search
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </form>
        <a asp-action="Create" class="btn btn-primary">Create Page</a>
    </div>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title (de-DE)</th>
                        <th>Status</th>
                        <th>Publish Window (UTC)</th>
                        <th>Modified</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@(p.Title ?? "-")</td>
                            <td>@p.Status</td>
                            <td>@(p.PublishStartUtc?.ToString("u") ?? "-") ? @(p.PublishEndUtc?.ToString("u") ?? "-")</td>
                            <td>@p.ModifiedAtUtc.ToString("u")</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-pen"></i> Edit
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("Delete", "Pages")"
                                        data-id="@p.Id"
                                        data-name="@(p.Title ?? p.Id.ToString())"
                                        data-rowversion="@Convert.ToBase64String(p.RowVersion)">
                                    <i class="fa fa-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <pager page="@currentPage"
               page-size="@currentPageSize"
               total="@total"
               asp-controller="Pages"
               asp-action="Index"
               asp-route-query="@query"></pager>

        <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />

    </div>
</div>
