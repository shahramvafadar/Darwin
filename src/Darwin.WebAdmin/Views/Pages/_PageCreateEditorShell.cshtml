@model Darwin.WebAdmin.ViewModels.CMS.PageCreateVm
@{
    ViewData["Title"] = T.T("PageCreateTitle");
}

<div id="page-editor-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
        <div>
            <h2 class="mb-1">@T.T("PageCreateTitle")</h2>
            <p class="text-muted mb-0">@T.T("PageCreateIntro")</p>
        </div>
    </div>

    <form asp-action="Create"
          method="post"
          hx-post="@Url.Action("Create", "Pages")"
          hx-target="#page-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <partial name="_PageForm" model="Model" />
    </form>
</div>

<partial name="_PageEditorScript" />
