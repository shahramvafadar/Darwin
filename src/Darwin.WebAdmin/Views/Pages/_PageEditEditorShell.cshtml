@model Darwin.WebAdmin.ViewModels.CMS.PageEditVm
@{
    ViewData["Title"] = T.T("PageEditTitle");
}

<div id="page-editor-shell"
     data-page-editor-placeholder="@T.T("PageEditorPlaceholder")"
     data-page-image-upload-failed="@T.T("PageImageUploadFailed")"
     data-page-editor-quill-not-loaded="@T.T("PageEditorQuillNotLoaded")"
     data-page-editor-upload-failed-error="@T.T("PageEditorUploadFailedError")"
     data-page-image-upload-url="@Url.Action("UploadQuill", "Media")">
    <partial name="~/Views/Shared/_Alerts.cshtml" />
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
        <div>
            <h2 class="mb-1">@T.T("PageEditTitle")</h2>
            <p class="text-muted mb-0">@T.T("PageEditIntro")</p>
        </div>
    </div>

    <form asp-action="Edit"
          method="post"
          hx-post="@Url.Action("Edit", "Pages")"
          hx-target="#page-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        <partial name="_PageForm" model="Model" />
    </form>
</div>
