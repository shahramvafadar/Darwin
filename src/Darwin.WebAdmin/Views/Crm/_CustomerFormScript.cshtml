<script>
    (function () {
      window.darwinAdmin = window.darwinAdmin || {};

      window.darwinAdmin.initCustomerAddressEditor = window.darwinAdmin.initCustomerAddressEditor || function (root) {
        if (!root) return;

        const container = root.querySelector('#customerAddresses');
        const template = root.querySelector('#customerAddressTemplate');
        const addButton = root.querySelector('#addCustomerAddress');

        if (addButton && !addButton.dataset.customerAddressesBound) {
          addButton.dataset.customerAddressesBound = 'true';
          addButton.addEventListener('click', function () {
            if (!container || !template) return;
            const index = container.querySelectorAll('.address-row').length;
            container.insertAdjacentHTML('beforeend', template.innerHTML.replaceAll('__index__', index));
          });
        }

        if (container && !container.dataset.customerAddressesRemoveBound) {
          container.dataset.customerAddressesRemoveBound = 'true';
          container.addEventListener('click', function (event) {
            const button = event.target.closest('.remove-address');
            if (button) {
              button.closest('.address-row')?.remove();
            }
          });
        }
      };

      window.darwinAdmin.initCustomerAddressEditor(document.getElementById('crm-customer-editor-shell'));
    })();
</script>
