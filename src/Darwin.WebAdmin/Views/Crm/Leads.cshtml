@model Darwin.WebAdmin.ViewModels.CRM.LeadsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CrmLeadsTitle");
    string LocalizeLeadStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
}

<div id="crm-leads-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@T.T("Leads")</h1>
    <a asp-action="Index"
       hx-get="@Url.Action("Index", "Crm")"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("Overview")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Customers")</div><div class="fs-4 fw-semibold">@Model.Summary.CustomerCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Leads")</div><div class="fs-4 fw-semibold">@Model.Summary.LeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Qualified")</div><div class="fs-4 fw-semibold">@Model.Summary.QualifiedLeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("OpenPipeline")</div><div class="fs-4 fw-semibold">@Model.Summary.Currency @((Model.Summary.OpenPipelineMinor / 100.0M).ToString("0.00"))</div></div></div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Qualified")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.QualifiedCount</div>
                    <div class="small text-muted mt-2">@T.T("Qualified leads visible in this queue slice.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Unassigned")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.UnassignedCount</div>
                    <div class="small text-muted mt-2">@T.T("Rows that still need an explicit lead owner.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Unconverted")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.UnconvertedCount</div>
                    <div class="small text-muted mt-2">@T.T("Leads not yet attached to a CRM customer record.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Customer")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.LinkedCustomerCount</div>
                    <div class="small text-muted mt-2">@T.T("Leads already carrying linked customer context.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Interactions")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.HighInteractionCount</div>
                    <div class="small text-muted mt-2">@T.T("Visible leads with heavier interaction history needing review.")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("CrmOperatorPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@T.T(playbook.Title)</div>
                        <div class="small text-muted mt-2">@T.T(playbook.ScopeNote)</div>
                        <div class="small mt-2"><strong>@T.T("CrmNextStep"):</strong> @T.T(playbook.OperatorAction)</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Leads" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("Leads", "Crm")"
          hx-target="#crm-leads-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchLeadsPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
    </form>

    <a asp-action="CreateLead"
       hx-get="@Url.Action("CreateLead", "Crm")"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-primary">
        <i class="fa fa-plus"></i> @T.T("NewLead")
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Leads" asp-route-filter="Qualified" hx-get="@Url.Action("Leads", "Crm", new { q = Model.Query, filter = "Qualified" })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Qualified ? "btn-warning" : "btn-outline-warning")">@T.T("Qualified")</a>
    <a asp-action="Leads" asp-route-filter="Unassigned" hx-get="@Url.Action("Leads", "Crm", new { q = Model.Query, filter = "Unassigned" })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unassigned ? "btn-info" : "btn-outline-info")">@T.T("Unassigned")</a>
    <a asp-action="Leads" asp-route-filter="Unconverted" hx-get="@Url.Action("Leads", "Crm", new { q = Model.Query, filter = "Unconverted" })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unconverted ? "btn-primary" : "btn-outline-primary")">@T.T("Unconverted")</a>
    <a asp-action="Leads" hx-get="@Url.Action("Leads", "Crm", new { q = Model.Query })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Company")</th>
                <th>@T.T("Email")</th>
                <th>@T.T("Phone")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Owner")</th>
                <th>@T.T("Interactions")</th>
                <th>@T.T("UpdatedUtc")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoLeadsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.CompanyName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td><span class="badge text-bg-light">@LocalizeLeadStatus(item.Status)</span></td>
                    <td>@(string.IsNullOrWhiteSpace(item.AssignedToUserDisplayName) ? "-" : item.AssignedToUserDisplayName)</td>
                    <td>@item.InteractionCount</td>
                    <td>@item.ModifiedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-success">
                                <i class="fa fa-user"></i> @T.T("Customer")
                            </a>
                            <a asp-action="CreateOpportunity" asp-route-customerId="@item.CustomerId.Value" hx-get="@Url.Action("CreateOpportunity", "Crm", new { customerId = item.CustomerId.Value })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-briefcase"></i> @T.T("Opportunity")
                            </a>
                        }
                        else if (item.Status == Darwin.Domain.Enums.LeadStatus.Qualified)
                        {
                            <form asp-controller="Crm" asp-action="ConvertLead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="LeadId" value="@item.Id" />
                                <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <input type="hidden" name="CopyNotesToCustomer" value="true" />
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    <i class="fa fa-arrow-right"></i> @T.T("Convert")
                                </button>
                            </form>
                        }
                        <a asp-action="EditLead" asp-route-id="@item.Id" asp-fragment="lead-interactions-grid" hx-get="@Url.Action("EditLead", "Crm", new { id = item.Id, fragment = "lead-interactions-grid" })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> @T.T("Interactions")
                        </a>
                        <a asp-action="EditLead" asp-route-id="@item.Id" hx-get="@Url.Action("EditLead", "Crm", new { id = item.Id })" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Leads"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
