@model Darwin.WebAdmin.ViewModels.CRM.LeadsListVm
@{
    ViewData["Title"] = "CRM Leads";
}

<h1 class="mb-3">Leads</h1>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Customers</div><div class="fs-4 fw-semibold">@Model.Summary.CustomerCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Leads</div><div class="fs-4 fw-semibold">@Model.Summary.LeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Qualified</div><div class="fs-4 fw-semibold">@Model.Summary.QualifiedLeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Open Pipeline</div><div class="fs-4 fw-semibold">EUR @((Model.Summary.OpenPipelineMinor / 100.0M).ToString("0.00"))</div></div></div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Leads" method="get" class="d-flex gap-2">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search leads">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> Search</button>
    </form>

    <a asp-action="CreateLead" class="btn btn-primary">
        <i class="fa fa-plus"></i> New Lead
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Leads" asp-route-filter="Qualified" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Qualified ? "btn-warning" : "btn-outline-warning")">Qualified</a>
    <a asp-action="Leads" asp-route-filter="Unassigned" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unassigned ? "btn-info" : "btn-outline-info")">Unassigned</a>
    <a asp-action="Leads" asp-route-filter="Unconverted" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unconverted ? "btn-primary" : "btn-outline-primary")">Unconverted</a>
    <a asp-action="Leads" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Company</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Owner</th>
                <th>Interactions</th>
                <th>Updated (UTC)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">No leads found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.CompanyName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td><span class="badge text-bg-light">@item.Status</span></td>
                    <td>@(string.IsNullOrWhiteSpace(item.AssignedToUserDisplayName) ? "-" : item.AssignedToUserDisplayName)</td>
                    <td>@item.InteractionCount</td>
                    <td>@item.ModifiedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="btn btn-sm btn-outline-success">
                                <i class="fa fa-user"></i> Customer
                            </a>
                            <a asp-action="CreateOpportunity" asp-route-customerId="@item.CustomerId.Value" class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-briefcase"></i> Opportunity
                            </a>
                        }
                        else if (item.Status == Darwin.Domain.Enums.LeadStatus.Qualified)
                        {
                            <form asp-controller="Crm" asp-action="ConvertLead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="LeadId" value="@item.Id" />
                                <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <input type="hidden" name="CopyNotesToCustomer" value="true" />
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    <i class="fa fa-arrow-right"></i> Convert
                                </button>
                            </form>
                        }
                        <a asp-action="EditLead" asp-route-id="@item.Id" asp-fragment="lead-interactions-grid" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> Interactions
                        </a>
                        <a asp-action="EditLead" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Leads"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
