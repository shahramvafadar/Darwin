@model Darwin.WebAdmin.ViewModels.CRM.LeadsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CrmLeadsTitle");
    string GlobalCrmIndexUrl() => Url.Action("Index", "Crm") ?? string.Empty;
    string GlobalCrmCustomersUrl() => Url.Action("Customers", "Crm") ?? string.Empty;
    string GlobalCrmLeadsUrl() => Url.Action("Leads", "Crm") ?? string.Empty;
    string CrmLeadsUrl(string? filter = null) => Url.Action("Leads", "Crm", string.IsNullOrWhiteSpace(filter) ? new { q = Model.Query } : new { q = Model.Query, filter }) ?? string.Empty;
    string GlobalCrmOpportunitiesUrl() => Url.Action("Opportunities", "Crm") ?? string.Empty;
    string CreateCrmLeadUrl() => Url.Action("CreateLead", "Crm") ?? string.Empty;
    string EditCrmLeadUrl(Guid id) => Url.Action("EditLead", "Crm", new { id }) ?? string.Empty;
    string EditCrmLeadInteractionsUrl(Guid id) => Url.Action("EditLead", "Crm", new { id, fragment = "lead-interactions-grid" }) ?? string.Empty;
    string EditCrmCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string CreateCrmOpportunityForCustomerUrl(Guid customerId) => Url.Action("CreateOpportunity", "Crm", new { customerId }) ?? string.Empty;
    var crmCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeLeadStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string CrmDateTimeText(DateTime? utc) => utc?.ToString("g", crmCulture) ?? "-";
    string CrmLeadOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string CrmLeadOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var crmLeadAttentionCount = Model.OpsSummary.UnassignedCount + Model.OpsSummary.UnconvertedCount;
}

<div id="crm-leads-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@T.T("Leads")</h1>
    <a asp-action="Index"
       hx-get="@GlobalCrmIndexUrl()"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("Overview")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Customers")</div><div class="fs-4 fw-semibold">@Model.Summary.CustomerCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Leads")</div><div class="fs-4 fw-semibold">@Model.Summary.LeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Qualified")</div><div class="fs-4 fw-semibold">@Model.Summary.QualifiedLeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("OpenPipeline")</div><div class="fs-4 fw-semibold">@Model.Summary.Currency @((Model.Summary.OpenPipelineMinor / 100.0M).ToString("0.00"))</div></div></div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                            <span class="@CrmLeadOpsHealthBadgeClass(crmLeadAttentionCount == 0)">@CrmLeadOpsHealthBadgeText(crmLeadAttentionCount == 0)</span>
                        </div>
                        <p class="text-muted small mb-0 mt-2">
                            @T.T("CrmOperatorPlaybooks")
                            @if (crmLeadAttentionCount > 0)
                            {
                                <span class="ms-1">@T.T("NeedsAttention"): @crmLeadAttentionCount</span>
                            }
                        </p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="CreateLead"
                           hx-get="@CreateCrmLeadUrl()"
                           hx-target="#crm-leads-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-primary">@T.T("NewLead")</a>
                        <a asp-action="Customers"
       hx-get="@GlobalCrmCustomersUrl()"
                           hx-target="#crm-leads-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Qualified")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmLeadOpsHealthBadgeClass(Model.OpsSummary.QualifiedCount > 0)">@Model.OpsSummary.QualifiedCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmLeadQualifiedPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Leads" asp-route-filter="Qualified" hx-get="@CrmLeadsUrl("Qualified")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">@T.T("Qualified")</a>
                                <a asp-action="Opportunities" hx-get="@GlobalCrmOpportunitiesUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Opportunity")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Unassigned")</div>
                                    <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                                </div>
                                <span class="@CrmLeadOpsHealthBadgeClass(Model.OpsSummary.UnassignedCount == 0)">@Model.OpsSummary.UnassignedCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmLeadUnassignedPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Leads" asp-route-filter="Unassigned" hx-get="@CrmLeadsUrl("Unassigned")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-info">@T.T("Unassigned")</a>
                                <a asp-action="CreateLead" hx-get="@CreateCrmLeadUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("NewLead")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Unconverted")</div>
                                    <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                                </div>
                                <span class="@CrmLeadOpsHealthBadgeClass(Model.OpsSummary.UnconvertedCount == 0)">@Model.OpsSummary.UnconvertedCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmLeadUnconvertedPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Leads" asp-route-filter="Unconverted" hx-get="@CrmLeadsUrl("Unconverted")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("Unconverted")</a>
<a asp-action="Customers" hx-get="@GlobalCrmCustomersUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Interactions")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmLeadOpsHealthBadgeClass(Model.OpsSummary.HighInteractionCount > 0)">@Model.OpsSummary.HighInteractionCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Leads" hx-get="@CrmLeadsUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Interactions")</a>
                                <a asp-action="Opportunities" hx-get="@GlobalCrmOpportunitiesUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("Opportunity")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Qualified")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.QualifiedCount</div>
                    <div class="small text-muted mt-2">@T.T("Qualified leads visible in this queue slice.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Unassigned")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.UnassignedCount</div>
                    <div class="small text-muted mt-2">@T.T("Rows that still need an explicit lead owner.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Unconverted")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.UnconvertedCount</div>
                    <div class="small text-muted mt-2">@T.T("Leads not yet attached to a CRM customer record.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Customer")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.LinkedCustomerCount</div>
                    <div class="small text-muted mt-2">@T.T("Leads already carrying linked customer context.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Interactions")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.HighInteractionCount</div>
                    <div class="small text-muted mt-2">@T.T("Visible leads with heavier interaction history needing review.")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("CrmOperatorPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@T.T(playbook.Title)</div>
                        <div class="small text-muted mt-2">@T.T(playbook.ScopeNote)</div>
                        <div class="small mt-2"><strong>@T.T("CrmNextStep"):</strong> @T.T(playbook.OperatorAction)</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Leads" method="get" class="d-flex gap-2"
          hx-get="@GlobalCrmLeadsUrl()"
          hx-target="#crm-leads-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchLeadsPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
    </form>

    <a asp-action="CreateLead"
       hx-get="@CreateCrmLeadUrl()"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-primary">
        <i class="fa fa-plus"></i> @T.T("NewLead")
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Leads" asp-route-filter="Qualified" hx-get="@CrmLeadsUrl("Qualified")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Qualified ? "btn-warning" : "btn-outline-warning")">@T.T("Qualified")</a>
    <a asp-action="Leads" asp-route-filter="Unassigned" hx-get="@CrmLeadsUrl("Unassigned")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unassigned ? "btn-info" : "btn-outline-info")">@T.T("Unassigned")</a>
    <a asp-action="Leads" asp-route-filter="Unconverted" hx-get="@CrmLeadsUrl("Unconverted")" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.LeadQueueFilter.Unconverted ? "btn-primary" : "btn-outline-primary")">@T.T("Unconverted")</a>
    <a asp-action="Leads" hx-get="@CrmLeadsUrl()" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Company")</th>
                <th>@T.T("Email")</th>
                <th>@T.T("Phone")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Owner")</th>
                <th>@T.T("Interactions")</th>
                <th>@T.T("UpdatedUtc")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoLeadsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var rowVersion = Convert.ToBase64String(item.RowVersion);
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.CompanyName</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td><span class="badge text-bg-light">@LocalizeLeadStatus(item.Status)</span></td>
                    <td>@(string.IsNullOrWhiteSpace(item.AssignedToUserDisplayName) ? "-" : item.AssignedToUserDisplayName)</td>
                    <td>@item.InteractionCount</td>
                    <td>@CrmDateTimeText(item.ModifiedAtUtc)</td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                        @if (item.Status != Darwin.Domain.Enums.LeadStatus.Converted)
                        {
                            @if (item.Status != Darwin.Domain.Enums.LeadStatus.Qualified)
                            {
                                <form asp-action="UpdateLeadLifecycle" method="post" class="d-inline"
                                      hx-post="@Url.Action("UpdateLeadLifecycle", "Crm")"
                                      hx-target="#crm-leads-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Qualify" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("Qualify")</button>
                                </form>
                            }
                            @if (item.Status != Darwin.Domain.Enums.LeadStatus.Disqualified)
                            {
                                <form asp-action="UpdateLeadLifecycle" method="post" class="d-inline"
                                      hx-post="@Url.Action("UpdateLeadLifecycle", "Crm")"
                                      hx-target="#crm-leads-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Disqualify" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Disqualify")</button>
                                </form>
                            }
                            @if (item.Status == Darwin.Domain.Enums.LeadStatus.Disqualified)
                            {
                                <form asp-action="UpdateLeadLifecycle" method="post" class="d-inline"
                                      hx-post="@Url.Action("UpdateLeadLifecycle", "Crm")"
                                      hx-target="#crm-leads-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Reopen" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("Reopen")</button>
                                </form>
                            }
                        }
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" hx-get="@EditCrmCustomerUrl(item.CustomerId.Value)" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-success">
                                <i class="fa fa-user"></i> @T.T("Customer")
                            </a>
                            <a asp-action="CreateOpportunity" asp-route-customerId="@item.CustomerId.Value" hx-get="@CreateCrmOpportunityForCustomerUrl(item.CustomerId.Value)" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-briefcase"></i> @T.T("Opportunity")
                            </a>
                        }
                        else if (item.Status == Darwin.Domain.Enums.LeadStatus.Qualified)
                        {
                            <form asp-controller="Crm" asp-action="ConvertLead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="LeadId" value="@item.Id" />
                                <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <input type="hidden" name="CopyNotesToCustomer" value="true" />
                                <button type="submit" class="btn btn-sm btn-outline-success">
                                    <i class="fa fa-arrow-right"></i> @T.T("Convert")
                                </button>
                            </form>
                        }
                        <a asp-action="EditLead" asp-route-id="@item.Id" asp-fragment="lead-interactions-grid" hx-get="@EditCrmLeadInteractionsUrl(item.Id)" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> @T.T("Interactions")
                        </a>
                        <a asp-action="EditLead" asp-route-id="@item.Id" hx-get="@EditCrmLeadUrl(item.Id)" hx-target="#crm-leads-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Leads"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-leads-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
