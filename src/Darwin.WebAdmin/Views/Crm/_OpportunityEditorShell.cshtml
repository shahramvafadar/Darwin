@model Darwin.WebAdmin.ViewModels.CRM.OpportunityEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = Model.Id == Guid.Empty;
    var formAction = (string?)ViewData["FormAction"] ?? (isCreate ? "CreateOpportunity" : "EditOpportunity");
    string GlobalCrmOpportunitiesUrl() => Url.Action("Opportunities", "Crm") ?? string.Empty;
    string EditCrmCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string CrmInvoicesForCustomerUrl(Guid customerId) => Url.Action("Invoices", "Crm", new { q = customerId }) ?? string.Empty;
    string EditCrmOpportunitySectionUrl(Guid id) => Url.Action("EditOpportunity", "Crm", new { id, fragment = "opportunity-interactions-section" }) ?? string.Empty;
    string CrmOpportunityInteractionsUrl(Guid opportunityId) => Url.Action("OpportunityInteractions", "Crm", new { opportunityId }) ?? string.Empty;
    string LocalizeOpportunityStage(object? stage) => stage is null ? "-" : T.T(stage.ToString() ?? string.Empty);
}

<div id="crm-opportunity-editor-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    @if (!isCreate)
    {
        <div class="card border-0 bg-light mb-3">
            <div class="card-body py-3">
                <div class="row g-3 small">
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Stage")</div>
                        <div class="fw-semibold">@LocalizeOpportunityStage(Model.Stage)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Customer")</div>
                        <div class="fw-semibold">@(Model.CustomerId == Guid.Empty ? T.T("Missing") : (string.IsNullOrWhiteSpace(Model.CustomerDisplayName) ? Model.CustomerId.ToString() : Model.CustomerDisplayName))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Estimated")</div>
                        <div class="fw-semibold">@Model.Currency @((Model.EstimatedValueMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Items")</div>
                        <div class="fw-semibold">@Model.Items.Count</div>
                    </div>
                </div>
                <div class="row g-3 small mt-1">
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Owner")</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.AssignedToUserDisplayName) ? T.T("Unassigned") : Model.AssignedToUserDisplayName)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted">@T.T("Interactions")</div>
                        <div class="fw-semibold">@Model.InteractionCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 bg-light mb-3">
            <div class="card-body py-3">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div>
                        <div class="fw-semibold">@T.T("OpportunityFollowUpWorkspace")</div>
                        <div class="small text-muted mt-1">@T.T("OpportunityFollowUpWorkspaceNote")</div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="EditCustomer"
                           asp-route-id="@Model.CustomerId"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@EditCrmCustomerUrl(Model.CustomerId)"
                           hx-target="#crm-opportunity-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-user"></i> @T.T("OpenCustomer")
                        </a>
                        <a asp-action="Invoices"
                           asp-route-q="@Model.CustomerId"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@CrmInvoicesForCustomerUrl(Model.CustomerId)"
                           hx-target="#crm-opportunity-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-file-invoice"></i> @T.T("ReviewInvoices")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <form asp-action="@formAction"
          method="post"
          hx-post="@Url.Action(formAction, "Crm")"
          hx-target="#crm-opportunity-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Currency" />
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }
        <partial name="_OpportunityForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
            <a asp-action="Opportunities" hx-get="@GlobalCrmOpportunitiesUrl()" hx-target="#crm-opportunity-editor-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Back")</a>
        </div>
    </form>

    @if (!isCreate)
    {
        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@T.T("Interactions")</span>
                <a asp-action="EditOpportunity"
                   asp-route-id="@Model.Id"
                   asp-fragment="opportunity-interactions-section"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@EditCrmOpportunitySectionUrl(Model.Id)"
                   hx-target="#crm-opportunity-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Open")</a>
            </div>
            <div class="card-body" id="opportunity-interactions-section"
                 hx-get="@CrmOpportunityInteractionsUrl(Model.Id)"
                 hx-trigger="load"
                 hx-target="this"
                 hx-swap="innerHTML">
                <div class="text-muted small">@T.T("Loading")...</div>
            </div>
        </div>
    }
</div>
