@model Darwin.WebAdmin.ViewModels.CRM.ConsentsPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

@functions {
    System.Globalization.CultureInfo CrmCulture => System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeConsentType(object? type) => type is null ? "-" : T.T(type.ToString() ?? string.Empty);
    string CrmDateTimeText(DateTime? utc) => utc?.ToString("g", CrmCulture) ?? "-";
}

<div hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <partial name="~/Views/Shared/_Alerts.cshtml" />
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Type")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("GrantedAtUtcShort")</th>
                    <th>@T.T("RevokedAtUtcShort")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted">@T.T("NoConsentHistory")</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@LocalizeConsentType(item.Type)</td>
                            <td>@(item.Granted ? T.T("Granted") : T.T("Revoked"))</td>
                            <td>@CrmDateTimeText(item.GrantedAtUtc)</td>
                            <td>@CrmDateTimeText(item.RevokedAtUtc)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Crm"
           asp-action="CustomerConsents"
           asp-route-customerId="@Model.CustomerId">
    </pager>
</div>
