@using Darwin.Application.Billing.DTOs
@using System.Globalization
@model Darwin.WebAdmin.ViewModels.CRM.InvoicesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Invoices");
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalRefundsUrl() => Url.Action("Refunds", "Billing") ?? string.Empty;
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string GlobalCrmIndexUrl() => Url.Action("Index", "Crm") ?? string.Empty;
    string GlobalCrmCustomersUrl() => Url.Action("Customers", "Crm") ?? string.Empty;
    string CrmInvoicesUrl(object? q = null, string? filter = null) => Url.Action("Invoices", "Crm", new { q, filter }) ?? string.Empty;
    string CrmOpportunitiesUrl() => Url.Action("Opportunities", "Crm") ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string EditCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string OrderDetailsUrl(Guid id, string? fragment = null) => Url.Action("Details", "Orders", new { id, fragment }) ?? string.Empty;
    string EditInvoiceUrl(Guid id) => Url.Action("EditInvoice", "Crm", new { id }) ?? string.Empty;
    string EditPaymentUrl(Guid id) => Url.Action("EditPayment", "Billing", new { id }) ?? string.Empty;
    string PaymentsUrl(PaymentQueueFilter? queue = null) => Url.Action("Payments", "Billing", new { queue }) ?? string.Empty;
    string LocalizeCrmInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
    string CrmInvoiceOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string CrmInvoiceOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var crmInvoiceAttentionCount = Model.OpsSummary.DraftCount + Model.OpsSummary.OverdueCount + Model.OpsSummary.MissingVatIdCount + Model.OpsSummary.RefundedCount;
}

<div id="crm-invoices-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">@T.T("Invoices")</h1>
        <div class="text-muted small">@T.T("InvoicesQueueIntro")</div>
    </div>
    <a asp-action="Index"
       hx-get="@GlobalCrmIndexUrl()"
       hx-target="#crm-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("Overview")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.OpsSummary.DraftCount</div></div></div></div>
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("DueSoon")</div><div class="fs-4 fw-semibold">@Model.OpsSummary.DueSoonCount</div></div></div></div>
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Overdue")</div><div class="fs-4 fw-semibold">@Model.OpsSummary.OverdueCount</div></div></div></div>
    <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("VatIdMissing")</div><div class="fs-4 fw-semibold">@Model.OpsSummary.MissingVatIdCount</div><div class="small text-muted mt-1">@T.T("Refunded"): @Model.OpsSummary.RefundedCount</div></div></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                            <span class="@CrmInvoiceOpsHealthBadgeClass(crmInvoiceAttentionCount == 0)">@CrmInvoiceOpsHealthBadgeText(crmInvoiceAttentionCount == 0)</span>
                        </div>
                        <p class="text-muted small mb-0 mt-2">
                            @T.T("InvoicesQueueIntro")
                            @if (crmInvoiceAttentionCount > 0)
                            {
                                <span class="ms-1">@T.T("NeedsAttention"): @crmInvoiceAttentionCount</span>
                            }
                        </p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Invoices"
                           hx-get="@CrmInvoicesUrl(Model.Query)"
                           hx-target="#crm-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-primary">@T.T("Invoices")</a>
                        <a asp-action="Customers"
       hx-get="@GlobalCrmCustomersUrl()"
                           hx-target="#crm-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Draft")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmInvoiceOpsHealthBadgeClass(Model.OpsSummary.DraftCount == 0)">@Model.OpsSummary.DraftCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Invoices" asp-route-filter="Draft" hx-get="@CrmInvoicesUrl(Model.Query, "Draft")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Draft ? "btn-secondary" : "btn-outline-secondary")">@T.T("Draft")</a>
                                <a asp-action="Opportunities" hx-get="@CrmOpportunitiesUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("OpenOpportunities")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("DueSoon")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmInvoiceOpsHealthBadgeClass(Model.OpsSummary.DueSoonCount == 0)">@Model.OpsSummary.DueSoonCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("Payment")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Invoices" asp-route-filter="DueSoon" hx-get="@CrmInvoicesUrl(Model.Query, "DueSoon")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.DueSoon ? "btn-warning" : "btn-outline-warning")">@T.T("DueSoon")</a>
                                <a asp-controller="Billing" asp-action="Payments" hx-get="@GlobalPaymentsUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-dark">@T.T("Payments")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Overdue")</div>
                                    <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                                </div>
                                <span class="@CrmInvoiceOpsHealthBadgeClass(Model.OpsSummary.OverdueCount == 0)">@Model.OpsSummary.OverdueCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("Customer")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Invoices" asp-route-filter="Overdue" hx-get="@CrmInvoicesUrl(Model.Query, "Overdue")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Overdue ? "btn-danger" : "btn-outline-danger")">@T.T("Overdue")</a>
<a asp-action="Customers" hx-get="@GlobalCrmCustomersUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("VatIdMissing")</div>
                                    <div class="small text-muted mt-1">@T.T("Refunded")</div>
                                </div>
                                <span class="@CrmInvoiceOpsHealthBadgeClass(Model.OpsSummary.MissingVatIdCount == 0 && Model.OpsSummary.RefundedCount == 0)">@(Model.OpsSummary.MissingVatIdCount + Model.OpsSummary.RefundedCount)</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("TaxSettings")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Invoices" asp-route-filter="MissingVatId" hx-get="@CrmInvoicesUrl(Model.Query, "MissingVatId")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.MissingVatId ? "btn-danger" : "btn-outline-danger")">@T.T("FixVatId")</a>
                                <a asp-action="Invoices" asp-route-filter="Refunded" hx-get="@CrmInvoicesUrl(Model.Query, "Refunded")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Refunded ? "btn-warning" : "btn-outline-warning")">@T.T("Refunded")</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" hx-get="@SiteSettingsUrl("site-settings-tax")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("TaxSettings")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Customers")</div><div class="fs-4 fw-semibold">@Model.Summary.CustomerCount</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("OpenOpportunities")</div><div class="fs-4 fw-semibold">@Model.Summary.OpenOpportunityCount</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Segments")</div><div class="fs-4 fw-semibold">@Model.Summary.SegmentCount</div></div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Interactions7d")</div><div class="fs-4 fw-semibold">@Model.Summary.RecentInteractionCount</div></div></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("CrmOperatorPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var item in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@T.T(item.Title)</div>
                        <div class="small text-muted mt-2">@T.T(item.ScopeNote)</div>
                        <div class="small mt-2"><strong>@T.T("CrmNextStep"):</strong> @item.OperatorAction</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxInvoicingPolicy")</span>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" hx-get="@SiteSettingsUrl("site-settings-tax")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("OpenTaxSettings")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("VatEnabled")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.VatEnabled ? T.T("Yes") : T.T("No"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("DefaultVat")</div><div class="fw-semibold mt-1">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("PriceMode")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.PricesIncludeVat ? T.T("VatInclusive") : T.T("VatExclusive"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ReverseCharge")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Issuer")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : T.T("Missing"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("TaxId")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.InvoiceIssuerTaxIdConfigured ? T.T("Ready") : T.T("Missing"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("SiteSettingInvoiceIssuerCountry")</div><div class="fw-semibold mt-1">@(string.IsNullOrWhiteSpace(Model.TaxPolicy.InvoiceIssuerCountry) ? T.T("Missing") : Model.TaxPolicy.InvoiceIssuerCountry)</div></div></div>
        </div>
        <div class="small text-muted mt-3">@T.T("InvoicesTaxPolicyNote")</div>
        <div class="row g-3 mt-1">
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ArchiveReadiness")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.ArchiveReadinessComplete ? T.T("Ready") : T.T("NeedsIssuerData"))</div><div class="small text-muted mt-2">@Model.TaxPolicy.ArchiveReadinessLabel</div></div></div>
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("EInvoiceBaseline")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.EInvoiceBaselineReady ? T.T("Ready") : T.T("NotReady"))</div><div class="small text-muted mt-2">@Model.TaxPolicy.EInvoiceBaselineLabel</div></div></div>
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("StructuredExportReadiness")</div><div class="fw-semibold mt-1">@(Model.TaxPolicy.StructuredExportBaselineReady ? T.T("Ready") : T.T("NotReady"))</div><div class="small text-muted mt-2">@Model.TaxPolicy.StructuredExportBaselineLabel</div><div class="small text-muted mt-1">@Model.TaxPolicy.ComplianceScopeNote</div></div></div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" hx-get="@SiteSettingsUrl("site-settings-tax")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("TaxSettings")</a>
            @if (!Model.TaxPolicy.ArchiveReadinessComplete)
            {
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" hx-get="@SiteSettingsUrl("site-settings-tax")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">@T.T("CompleteIssuerData")</a>
            }
            @if (!Model.TaxPolicy.EInvoiceBaselineReady)
            {
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" hx-get="@SiteSettingsUrl("site-settings-tax")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-danger">@T.T("ReviewEInvoiceBaseline")</a>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-3"><div class="col-lg-8"><form asp-action="Invoices" method="get" class="row g-2"
      hx-get="@GlobalInvoicesUrl()"
      hx-target="#crm-invoices-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="filter" value="@Model.Filter" />
    <div class="col-md-4">
        <input name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchInvoicesPlaceholder")" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-outline-secondary">@T.T("Filter")</button>
    </div>
</form>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Invoices" hx-get="@CrmInvoicesUrl(Model.Query)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.All ? "btn-dark" : "btn-outline-dark")">@T.T("All")</a>
    <a asp-action="Invoices" asp-route-filter="Draft" hx-get="@CrmInvoicesUrl(Model.Query, "Draft")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Draft ? "btn-secondary" : "btn-outline-secondary")">@T.T("Draft")</a>
    <a asp-action="Invoices" asp-route-filter="DueSoon" hx-get="@CrmInvoicesUrl(Model.Query, "DueSoon")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.DueSoon ? "btn-warning" : "btn-outline-warning")">@T.T("DueSoon")</a>
    <a asp-action="Invoices" asp-route-filter="Overdue" hx-get="@CrmInvoicesUrl(Model.Query, "Overdue")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Overdue ? "btn-danger" : "btn-outline-danger")">@T.T("Overdue")</a>
    <a asp-action="Invoices" asp-route-filter="MissingVatId" hx-get="@CrmInvoicesUrl(Model.Query, "MissingVatId")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.MissingVatId ? "btn-danger" : "btn-outline-danger")">@T.T("VatIdMissing")</a>
    <a asp-action="Invoices" asp-route-filter="Refunded" hx-get="@CrmInvoicesUrl(Model.Query, "Refunded")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.InvoiceQueueFilter.Refunded ? "btn-warning" : "btn-outline-warning")">@T.T("Refunded")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Invoice")</th>
                <th>@T.T("Customer")</th>
                <th>@T.T("Order")</th>
                <th>@T.T("Payment")</th>
                <th>@T.T("TaxProfile")</th>
                <th class="text-end">@T.T("NetTaxGross")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Due")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted">@T.T("NoInvoicesFound")</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var crmInvoiceNeedsCollectionFollowUp =
                        item.BalanceMinor > 0 ||
                        item.Status == Darwin.Domain.Enums.InvoiceStatus.Open;
                    var crmInvoiceNeedsPendingPaymentFollowUp =
                        item.PaymentId.HasValue &&
                        item.BalanceMinor > 0 &&
                        item.Status != Darwin.Domain.Enums.InvoiceStatus.Paid;
                    var crmInvoiceNeedsUnlinkedPaymentFollowUp =
                        !item.PaymentId.HasValue &&
                        item.BalanceMinor > 0;
                    var crmInvoiceHasRefundPressure = item.RefundedAmountMinor > 0;
                    var crmInvoiceNeedsRefundedPaymentFollowUp =
                        item.PaymentId.HasValue &&
                        item.RefundedAmountMinor > 0;
                    var crmInvoiceNeedsVatRemediation =
                        item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business &&
                        string.IsNullOrWhiteSpace(item.CustomerVatId);
                    <tr>
                        <td><code>@item.Id</code></td>
                        <td>
                            @if (item.CustomerId.HasValue)
                            {
                                <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" hx-get="@EditCustomerUrl(item.CustomerId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" hx-get="@OrderDetailsUrl(item.OrderId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.PaymentId.HasValue)
                            {
                                <div>@item.PaymentSummary</div>
                            }
                            else
                            {
                                <span class="text-muted">@T.T("Unlinked")</span>
                            }
                        </td>
                        <td>
                            @if (item.CustomerTaxProfileType.HasValue)
                            {
                                <span class="badge @(item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@LocalizeCustomerTaxProfileType(item.CustomerTaxProfileType)</span>
                                @if (!string.IsNullOrWhiteSpace(item.CustomerVatId))
                                {
                                    <div class="small text-muted">@item.CustomerVatId</div>
                                }
                                else if (item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                                {
                                    <div class="small text-danger">@T.T("VatIdMissing")</div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="small text-muted">@T.T("Net"): @item.Currency @((item.TotalNetMinor / 100.0M).ToString("0.00"))</div>
                            <div class="small text-muted">@T.T("Tax"): @item.Currency @((item.TotalTaxMinor / 100.0M).ToString("0.00"))</div>
                            <div class="fw-semibold">@T.T("Gross"): @item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</div>
                            @if (item.RefundedAmountMinor > 0)
                            {
                                <div class="small text-warning">@T.T("Refunded"): @item.Currency @((item.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                            }
                            <div class="small text-muted">@T.T("Settled"): @item.Currency @((item.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                            <div class="small @(item.BalanceMinor > 0 ? "text-danger" : "text-success")">
                                @T.T("Balance"): @item.Currency @((item.BalanceMinor / 100.0M).ToString("0.00"))
                            </div>
                        </td>
                        <td>@LocalizeCrmInvoiceStatus(item.Status)</td>
                                <td>@item.DueDateUtc.ToLocalTime().ToString("d", CultureInfo.CurrentCulture)</td>
                        <td class="text-end">
                            <a asp-action="EditInvoice" asp-route-id="@item.Id" hx-get="@EditInvoiceUrl(item.Id)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Open")</a>
                            @if (item.CustomerId.HasValue)
                            {
                                <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" hx-get="@EditCustomerUrl(item.CustomerId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("Customer")</a>
                                @if (item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business && string.IsNullOrWhiteSpace(item.CustomerVatId))
                                {
                                    <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" hx-get="@EditCustomerUrl(item.CustomerId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-danger">@T.T("FixVatId")</a>
                                }
                            }
                            @if (item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" hx-get="@OrderDetailsUrl(item.OrderId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-info">@T.T("Order")</a>
                            }
                            @if (item.PaymentId.HasValue && item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" asp-fragment="payments" hx-get="@OrderDetailsUrl(item.OrderId.Value, "payments")" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-dark">@T.T("Payment")</a>
                            }
                            @if (item.PaymentId.HasValue)
                            {
                                <a asp-controller="Billing" asp-action="EditPayment" asp-route-id="@item.PaymentId.Value" hx-get="@EditPaymentUrl(item.PaymentId.Value)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Payments")</a>
                            }
                            @if (crmInvoiceNeedsCollectionFollowUp)
                            {
                                <a asp-controller="Billing" asp-action="Payments" hx-get="@GlobalPaymentsUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">@T.T("Payments")</a>
                            }
                            @if (crmInvoiceNeedsPendingPaymentFollowUp)
                            {
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@PaymentQueueFilter.Pending" hx-get="@PaymentsUrl(PaymentQueueFilter.Pending)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">@T.T("Pending")</a>
                            }
                            @if (crmInvoiceNeedsUnlinkedPaymentFollowUp)
                            {
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@PaymentQueueFilter.Unlinked" hx-get="@PaymentsUrl(PaymentQueueFilter.Unlinked)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-dark">@T.T("Unlinked")</a>
                            }
                            @if (crmInvoiceHasRefundPressure)
                            {
                                <a asp-controller="Billing" asp-action="Refunds" hx-get="@GlobalRefundsUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-danger">@T.T("RefundQueueTitle")</a>
                            }
                            @if (crmInvoiceNeedsRefundedPaymentFollowUp)
                            {
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@PaymentQueueFilter.Refunded" hx-get="@PaymentsUrl(PaymentQueueFilter.Refunded)" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Refunded")</a>
                            }
                            @if (crmInvoiceNeedsVatRemediation)
                            {
                                <a asp-controller="Billing" asp-action="TaxCompliance" hx-get="@GlobalTaxComplianceUrl()" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-danger">@T.T("TaxComplianceTitle")</a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.InvoiceStatus.Draft)
                            {
                                <form asp-action="TransitionInvoiceStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Open" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("Post")</button>
                                </form>
                            }
                            @if (item.Status != Darwin.Domain.Enums.InvoiceStatus.Paid && item.BalanceMinor <= 0)
                            {
                                <form asp-action="TransitionInvoiceStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Paid" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">@T.T("MarkPaid")</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Crm" asp-action="Invoices" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#crm-invoices-workspace-shell" hx-swap="outerHTML"></pager>
</div>

</div>

