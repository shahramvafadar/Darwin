@model Darwin.WebAdmin.ViewModels.CRM.InvoicesListVm
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Invoices</h1>
        <div class="text-muted small">CRM and order-generated invoices in one operational queue.</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Tax &amp; Invoicing Policy</span>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" class="btn btn-sm btn-outline-secondary">Open Tax Settings</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">VAT Enabled</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.VatEnabled ? "Yes" : "No")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Default VAT</div>
                    <div class="fw-semibold mt-1">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Price Mode</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.PricesIncludeVat ? "VAT Inclusive" : "VAT Exclusive")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Reverse Charge</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.AllowReverseCharge ? "Allowed" : "Disabled")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Issuer</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : "Missing")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Tax ID</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.InvoiceIssuerTaxIdConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
        </div>
        <div class="small text-muted mt-3">
            This is a phase-1 VAT support surface for invoice review. It exposes current tax defaults and issuer identity without claiming full tax-engine automation or compliance completion.
        </div>
        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Archive Readiness</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.ArchiveReadinessComplete ? "Ready" : "Needs issuer data")</div>
                    <div class="small text-muted mt-2">@Model.TaxPolicy.ArchiveReadinessLabel</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">E-Invoice Baseline</div>
                    <div class="fw-semibold mt-1">@(Model.TaxPolicy.EInvoiceBaselineReady ? "Ready" : "Not ready")</div>
                    <div class="small text-muted mt-2">@Model.TaxPolicy.ComplianceScopeNote</div>
                </div>
            </div>
        </div>
    </div>
</div>

<form asp-action="Invoices" method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="q" value="@Model.Query" class="form-control" placeholder="Search by id, order, customer, payment" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Invoice</th>
                <th>Customer</th>
                <th>Order</th>
                <th>Payment</th>
                <th>Tax Profile</th>
                <th class="text-end">Net / Tax / Gross</th>
                <th>Status</th>
                <th>Due</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted">No invoices found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td><code>@item.Id</code></td>
                        <td>
                            @if (item.CustomerId.HasValue)
                            {
                                <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.PaymentId.HasValue)
                            {
                                <div>@item.PaymentSummary</div>
                            }
                            else
                            {
                                <span class="text-muted">Unlinked</span>
                            }
                        </td>
                        <td>
                            @if (item.CustomerTaxProfileType.HasValue)
                            {
                                <span class="badge @(item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@item.CustomerTaxProfileType</span>
                                @if (!string.IsNullOrWhiteSpace(item.CustomerVatId))
                                {
                                    <div class="small text-muted">@item.CustomerVatId</div>
                                }
                                else if (item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                                {
                                    <div class="small text-danger">VAT ID missing</div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="small text-muted">Net: @item.Currency @((item.TotalNetMinor / 100.0M).ToString("0.00"))</div>
                            <div class="small text-muted">Tax: @item.Currency @((item.TotalTaxMinor / 100.0M).ToString("0.00"))</div>
                            <div class="fw-semibold">Gross: @item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</div>
                            @if (item.RefundedAmountMinor > 0)
                            {
                                <div class="small text-warning">Refunded: @item.Currency @((item.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                            }
                            <div class="small text-muted">Settled: @item.Currency @((item.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                            <div class="small @(item.BalanceMinor > 0 ? "text-danger" : "text-success")">
                                Balance: @item.Currency @((item.BalanceMinor / 100.0M).ToString("0.00"))
                            </div>
                        </td>
                        <td>@item.Status</td>
                        <td>@item.DueDateUtc.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-action="EditInvoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Open</a>
                            @if (item.CustomerId.HasValue)
                            {
                                <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="btn btn-sm btn-outline-primary">Customer</a>
                            }
                            @if (item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="btn btn-sm btn-outline-info">Order</a>
                            }
                            @if (item.PaymentId.HasValue && item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" asp-fragment="payments" class="btn btn-sm btn-outline-dark">Payment</a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.InvoiceStatus.Draft)
                            {
                                <form asp-action="TransitionInvoiceStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Open" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Post</button>
                                </form>
                            }
                            @if (item.Status != Darwin.Domain.Enums.InvoiceStatus.Paid && item.BalanceMinor <= 0)
                            {
                                <form asp-action="TransitionInvoiceStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@item.Id" />
                                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Paid" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Mark Paid</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Crm" asp-action="Invoices" asp-route-q="@Model.Query"></pager>
