@model Darwin.WebAdmin.ViewModels.CRM.InvoicesListVm
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Invoices</h1>
        <div class="text-muted small">CRM and order-generated invoices in one operational queue.</div>
    </div>
</div>

<form asp-action="Invoices" method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="q" value="@Model.Query" class="form-control" placeholder="Search by id, order, customer, payment" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Invoice</th>
                <th>Customer</th>
                <th>Order</th>
                <th>Payment</th>
                <th class="text-end">Total</th>
                <th>Status</th>
                <th>Due</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted">No invoices found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td><code>@item.Id</code></td>
                        <td>
                            @if (item.CustomerId.HasValue)
                            {
                                <a asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.OrderId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="text-decoration-none">
                                    @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.PaymentId.HasValue)
                            {
                                <div>@item.PaymentSummary</div>
                            }
                            else
                            {
                                <span class="text-muted">Unlinked</span>
                            }
                        </td>
                        <td class="text-end">
                            <div>@item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</div>
                            @if (item.RefundedAmountMinor > 0)
                            {
                                <div class="small text-warning">Refunded: @item.Currency @((item.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                            }
                            <div class="small text-muted">Settled: @item.Currency @((item.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                            <div class="small @(item.BalanceMinor > 0 ? "text-danger" : "text-success")">
                                Balance: @item.Currency @((item.BalanceMinor / 100.0M).ToString("0.00"))
                            </div>
                        </td>
                        <td>@item.Status</td>
                        <td>@item.DueDateUtc.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-action="EditInvoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Open</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Crm" asp-action="Invoices" asp-route-q="@Model.Query"></pager>
