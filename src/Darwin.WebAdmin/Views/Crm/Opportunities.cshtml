@model Darwin.WebAdmin.ViewModels.CRM.OpportunitiesListVm
@{
    ViewData["Title"] = "CRM Opportunities";
}

<h1 class="mb-3">Opportunities</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Opportunities" method="get" class="d-flex gap-2">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search opportunities">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> Search</button>
    </form>

    <a asp-action="CreateOpportunity" class="btn btn-primary">
        <i class="fa fa-plus"></i> New Opportunity
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Opportunities" asp-route-filter="Open" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.Open ? "btn-primary" : "btn-outline-primary")">Open</a>
    <a asp-action="Opportunities" asp-route-filter="ClosingSoon" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.ClosingSoon ? "btn-warning" : "btn-outline-warning")">Closing Soon</a>
    <a asp-action="Opportunities" asp-route-filter="HighValue" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.HighValue ? "btn-info" : "btn-outline-info")">High Value</a>
    <a asp-action="Opportunities" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Customer</th>
                <th>Stage</th>
                <th>Estimated</th>
                <th>Close date</th>
                <th>Items</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">No opportunities found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.CustomerDisplayName</td>
                    <td><span class="badge text-bg-light">@item.Stage</span></td>
                    <td>EUR @((item.EstimatedValueMinor / 100M).ToString("0.00"))</td>
                    <td>@item.ExpectedCloseDateUtc?.ToString("yyyy-MM-dd")</td>
                    <td>@item.ItemCount</td>
                    <td class="text-end">
                        <a asp-action="EditOpportunity" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Opportunities"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
