@model Darwin.WebAdmin.ViewModels.CRM.OpportunitiesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CrmOpportunitiesTitle");
}

<div id="crm-opportunities-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@T.T("Opportunities")</h1>
    <a asp-action="Index"
       hx-get="@Url.Action("Index", "Crm")"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("Overview")</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Opportunities" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("Opportunities", "Crm")"
          hx-target="#crm-opportunities-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchOpportunitiesPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
    </form>

    <a asp-action="CreateOpportunity"
       hx-get="@Url.Action("CreateOpportunity", "Crm")"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-primary">
        <i class="fa fa-plus"></i> @T.T("NewOpportunity")
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Opportunities" asp-route-filter="Open" hx-get="@Url.Action("Opportunities", "Crm", new { q = Model.Query, filter = "Open" })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.Open ? "btn-primary" : "btn-outline-primary")">@T.T("OpenQueue")</a>
    <a asp-action="Opportunities" asp-route-filter="ClosingSoon" hx-get="@Url.Action("Opportunities", "Crm", new { q = Model.Query, filter = "ClosingSoon" })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.ClosingSoon ? "btn-warning" : "btn-outline-warning")">@T.T("ClosingSoon")</a>
    <a asp-action="Opportunities" asp-route-filter="HighValue" hx-get="@Url.Action("Opportunities", "Crm", new { q = Model.Query, filter = "HighValue" })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.HighValue ? "btn-info" : "btn-outline-info")">@T.T("HighValue")</a>
    <a asp-action="Opportunities" hx-get="@Url.Action("Opportunities", "Crm", new { q = Model.Query })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Title")</th>
                <th>@T.T("Customer")</th>
                <th>@T.T("Stage")</th>
                <th>@T.T("Estimated")</th>
                <th>@T.T("CloseDate")</th>
                <th>@T.T("Owner")</th>
                <th>@T.T("Items")</th>
                <th>@T.T("UpdatedUtc")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoOpportunitiesFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.CustomerDisplayName</td>
                    <td><span class="badge text-bg-light">@item.Stage</span></td>
                    <td>EUR @((item.EstimatedValueMinor / 100M).ToString("0.00"))</td>
                    <td>@item.ExpectedCloseDateUtc?.ToString("yyyy-MM-dd")</td>
                    <td>@(string.IsNullOrWhiteSpace(item.AssignedToUserDisplayName) ? "-" : item.AssignedToUserDisplayName)</td>
                    <td>@item.ItemCount</td>
                    <td>@item.ModifiedAtUtc?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a asp-action="EditCustomer" asp-route-id="@item.CustomerId" hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-success">
                            <i class="fa fa-user"></i> @T.T("Customer")
                        </a>
                        <a asp-action="EditOpportunity" asp-route-id="@item.Id" asp-fragment="opportunity-interactions-grid" hx-get="@Url.Action("EditOpportunity", "Crm", new { id = item.Id, fragment = "opportunity-interactions-grid" })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> @T.T("Interactions")
                        </a>
                        <a asp-action="EditOpportunity" asp-route-id="@item.Id" hx-get="@Url.Action("EditOpportunity", "Crm", new { id = item.Id })" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Opportunities"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
