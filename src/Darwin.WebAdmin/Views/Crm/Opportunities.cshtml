@model Darwin.WebAdmin.ViewModels.CRM.OpportunitiesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CrmOpportunitiesTitle");
    string GlobalCrmIndexUrl() => Url.Action("Index", "Crm") ?? string.Empty;
    string GlobalCrmCustomersUrl() => Url.Action("Customers", "Crm") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string GlobalCrmOpportunitiesUrl() => Url.Action("Opportunities", "Crm") ?? string.Empty;
    string CrmOpportunitiesUrl(string? filter = null) => Url.Action("Opportunities", "Crm", string.IsNullOrWhiteSpace(filter) ? new { q = Model.Query } : new { q = Model.Query, filter }) ?? string.Empty;
    string CreateCrmOpportunityUrl() => Url.Action("CreateOpportunity", "Crm") ?? string.Empty;
    string EditCrmOpportunityUrl(Guid id) => Url.Action("EditOpportunity", "Crm", new { id }) ?? string.Empty;
    string EditCrmOpportunityInteractionsUrl(Guid id) => Url.Action("EditOpportunity", "Crm", new { id, fragment = "opportunity-interactions-grid" }) ?? string.Empty;
    string EditCrmCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    var crmCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeOpportunityStage(object? stage) => stage is null ? "-" : T.T(stage.ToString() ?? string.Empty);
    string CrmDateTimeText(DateTime? utc) => utc?.ToString("g", crmCulture) ?? "-";
    string CrmOpportunityOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string CrmOpportunityOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var crmOpportunityAttentionCount = Model.OpsSummary.ClosingSoonCount + Model.OpsSummary.UnassignedCount;
}

<div id="crm-opportunities-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@T.T("Opportunities")</h1>
    <a asp-action="Index"
       hx-get="@GlobalCrmIndexUrl()"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("Overview")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Customers")</div><div class="fs-4 fw-semibold">@Model.Summary.CustomerCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("OpenOpportunities")</div><div class="fs-4 fw-semibold">@Model.Summary.OpenOpportunityCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Leads")</div><div class="fs-4 fw-semibold">@Model.Summary.LeadCount</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("OpenPipeline")</div><div class="fs-4 fw-semibold">@Model.Summary.Currency @((Model.Summary.OpenPipelineMinor / 100.0M).ToString("0.00"))</div></div></div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                            <span class="@CrmOpportunityOpsHealthBadgeClass(crmOpportunityAttentionCount == 0)">@CrmOpportunityOpsHealthBadgeText(crmOpportunityAttentionCount == 0)</span>
                        </div>
                        <p class="text-muted small mb-0 mt-2">
                            @T.T("CrmOperatorPlaybooks")
                            @if (crmOpportunityAttentionCount > 0)
                            {
                                <span class="ms-1">@T.T("NeedsAttention"): @crmOpportunityAttentionCount</span>
                            }
                        </p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="CreateOpportunity"
                           hx-get="@CreateCrmOpportunityUrl()"
                           hx-target="#crm-opportunities-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-primary">@T.T("NewOpportunity")</a>
                        <a asp-action="Customers"
       hx-get="@GlobalCrmCustomersUrl()"
                           hx-target="#crm-opportunities-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true"
                           class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("OpenQueue")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmOpportunityOpsHealthBadgeClass(Model.OpsSummary.OpenCount > 0)">@Model.OpsSummary.OpenCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Opportunities" asp-route-filter="Open" hx-get="@CrmOpportunitiesUrl("Open")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("OpenQueue")</a>
                                <a asp-action="CreateOpportunity" hx-get="@CreateCrmOpportunityUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("NewOpportunity")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("ClosingSoon")</div>
                                    <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                                </div>
                                <span class="@CrmOpportunityOpsHealthBadgeClass(Model.OpsSummary.ClosingSoonCount == 0)">@Model.OpsSummary.ClosingSoonCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmOpportunityClosingSoonPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Opportunities" asp-route-filter="ClosingSoon" hx-get="@CrmOpportunitiesUrl("ClosingSoon")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">@T.T("ClosingSoon")</a>
<a asp-action="Customers" hx-get="@GlobalCrmCustomersUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Customers")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("HighValue")</div>
                                    <div class="small text-muted mt-1">@T.T("Queue")</div>
                                </div>
                                <span class="@CrmOpportunityOpsHealthBadgeClass(Model.OpsSummary.HighValueCount > 0)">@Model.OpsSummary.HighValueCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmOpportunityHighInteractionPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Opportunities" asp-route-filter="HighValue" hx-get="@CrmOpportunitiesUrl("HighValue")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-info">@T.T("HighValue")</a>
                            <a asp-action="Invoices" hx-get="@GlobalInvoicesUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Invoices")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("Unassigned")</div>
                                    <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                                </div>
                                <span class="@CrmOpportunityOpsHealthBadgeClass(Model.OpsSummary.UnassignedCount == 0)">@Model.OpsSummary.UnassignedCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmOpportunityUnassignedPlaybookAction")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Opportunities" hx-get="@CrmOpportunitiesUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("Unassigned")</a>
                                <a asp-action="CreateOpportunity" hx-get="@CreateCrmOpportunityUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("NewOpportunity")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("OpenQueue")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.OpenCount</div>
                    <div class="small text-muted mt-2">@T.T("Opportunity rows still active in the pipeline.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ClosingSoon")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.ClosingSoonCount</div>
                    <div class="small text-muted mt-2">@T.T("Visible opportunities requiring near-term close-date review.")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("HighValue")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.HighValueCount</div>
                    <div class="small text-muted mt-2">@T.T("High-value pipeline rows visible in the current slice.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Unassigned")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.UnassignedCount</div>
                    <div class="small text-muted mt-2">@T.T("Opportunities still missing an explicit owner.")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Interactions")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.HighInteractionCount</div>
                    <div class="small text-muted mt-2">@T.T("Rows with heavier interaction trails that may need operator review.")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("CrmOperatorPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@T.T(playbook.Title)</div>
                        <div class="small text-muted mt-2">@T.T(playbook.ScopeNote)</div>
                        <div class="small mt-2"><strong>@T.T("CrmNextStep"):</strong> @T.T(playbook.OperatorAction)</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Opportunities" method="get" class="d-flex gap-2"
          hx-get="@GlobalCrmOpportunitiesUrl()"
          hx-target="#crm-opportunities-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchOpportunitiesPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
    </form>

    <a asp-action="CreateOpportunity"
       hx-get="@CreateCrmOpportunityUrl()"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-primary">
        <i class="fa fa-plus"></i> @T.T("NewOpportunity")
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Opportunities" asp-route-filter="Open" hx-get="@CrmOpportunitiesUrl("Open")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.Open ? "btn-primary" : "btn-outline-primary")">@T.T("OpenQueue")</a>
    <a asp-action="Opportunities" asp-route-filter="ClosingSoon" hx-get="@CrmOpportunitiesUrl("ClosingSoon")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.ClosingSoon ? "btn-warning" : "btn-outline-warning")">@T.T("ClosingSoon")</a>
    <a asp-action="Opportunities" asp-route-filter="HighValue" hx-get="@CrmOpportunitiesUrl("HighValue")" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.OpportunityQueueFilter.HighValue ? "btn-info" : "btn-outline-info")">@T.T("HighValue")</a>
    <a asp-action="Opportunities" hx-get="@CrmOpportunitiesUrl()" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Title")</th>
                <th>@T.T("Customer")</th>
                <th>@T.T("Stage")</th>
                <th>@T.T("Estimated")</th>
                <th>@T.T("CloseDate")</th>
                <th>@T.T("Owner")</th>
                <th>@T.T("Items")</th>
                <th>@T.T("UpdatedUtc")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoOpportunitiesFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var rowVersion = Convert.ToBase64String(item.RowVersion);
                var isClosed = item.Stage == Darwin.Domain.Enums.OpportunityStage.ClosedWon ||
                    item.Stage == Darwin.Domain.Enums.OpportunityStage.ClosedLost;
                <tr>
                    <td>@item.Title</td>
                    <td>@item.CustomerDisplayName</td>
                    <td><span class="badge text-bg-light">@LocalizeOpportunityStage(item.Stage)</span></td>
                    <td>@item.Currency @((item.EstimatedValueMinor / 100M).ToString("0.00"))</td>
                                <td>@item.ExpectedCloseDateUtc?.ToLocalTime().ToString("d", crmCulture)</td>
                    <td>@(string.IsNullOrWhiteSpace(item.AssignedToUserDisplayName) ? "-" : item.AssignedToUserDisplayName)</td>
                    <td>@item.ItemCount</td>
                    <td>@CrmDateTimeText(item.ModifiedAtUtc)</td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                        @if (!isClosed)
                        {
                            <form asp-action="UpdateOpportunityLifecycle" method="post" class="d-inline"
                                  hx-post="@Url.Action("UpdateOpportunityLifecycle", "Crm")"
                                  hx-target="#crm-opportunities-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="rowVersion" value="@rowVersion" />
                                <input type="hidden" name="action" value="Advance" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="q" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("Advance")</button>
                            </form>
                            <form asp-action="UpdateOpportunityLifecycle" method="post" class="d-inline"
                                  hx-post="@Url.Action("UpdateOpportunityLifecycle", "Crm")"
                                  hx-target="#crm-opportunities-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="rowVersion" value="@rowVersion" />
                                <input type="hidden" name="action" value="CloseWon" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="q" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-success">@T.T("CloseWon")</button>
                            </form>
                            <form asp-action="UpdateOpportunityLifecycle" method="post" class="d-inline"
                                  hx-post="@Url.Action("UpdateOpportunityLifecycle", "Crm")"
                                  hx-target="#crm-opportunities-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="rowVersion" value="@rowVersion" />
                                <input type="hidden" name="action" value="CloseLost" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="q" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("CloseLost")</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="UpdateOpportunityLifecycle" method="post" class="d-inline"
                                  hx-post="@Url.Action("UpdateOpportunityLifecycle", "Crm")"
                                  hx-target="#crm-opportunities-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="rowVersion" value="@rowVersion" />
                                <input type="hidden" name="action" value="Reopen" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="q" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("Reopen")</button>
                            </form>
                        }
                        <a asp-action="EditCustomer" asp-route-id="@item.CustomerId" hx-get="@EditCrmCustomerUrl(item.CustomerId)" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-success">
                            <i class="fa fa-user"></i> @T.T("Customer")
                        </a>
                        <a asp-action="EditOpportunity" asp-route-id="@item.Id" asp-fragment="opportunity-interactions-grid" hx-get="@EditCrmOpportunityInteractionsUrl(item.Id)" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> @T.T("Interactions")
                        </a>
                        <a asp-action="EditOpportunity" asp-route-id="@item.Id" hx-get="@EditCrmOpportunityUrl(item.Id)" hx-target="#crm-opportunities-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Opportunities"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-opportunities-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
