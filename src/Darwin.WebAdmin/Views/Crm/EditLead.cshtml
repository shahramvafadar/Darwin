@model Darwin.WebAdmin.ViewModels.CRM.LeadEditVm
@{
    ViewData["Title"] = "Edit Lead";
}

<h1 class="mb-3">Edit Lead</h1>

<form asp-action="EditLead" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <partial name="_LeadForm" model="Model" />
    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> Save</button>
        <a asp-action="Leads" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

<hr class="my-4" />

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><strong>Add Interaction</strong></div>
            <div class="card-body">
                <form asp-controller="Crm"
                      asp-action="LeadInteractions"
                      method="post"
                      hx-post="@Url.Action("LeadInteractions", "Crm")"
                      hx-target="#lead-interactions-grid"
                      hx-swap="innerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="LeadId" value="@Model.Id" />
                    <div class="col-md-6">
                        <label class="form-label">Type</label>
                        <select name="Type" class="form-select" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionType>()"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Channel</label>
                        <select name="Channel" class="form-select" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionChannel>()"></select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Subject</label>
                        <input name="Subject" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Content</label>
                        <textarea name="Content" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Owner</label>
                        <select name="UserId" class="form-select" asp-items="Model.NewInteraction.UserOptions"></select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">Add Interaction</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><strong>Interactions</strong></div>
            <div class="card-body" id="lead-interactions-grid"
                 hx-get="@Url.Action("LeadInteractions", "Crm", new { leadId = Model.Id })"
                 hx-trigger="load"
                 hx-swap="innerHTML"></div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
