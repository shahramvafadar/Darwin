@model Darwin.WebAdmin.ViewModels.CRM.LeadEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditLead");
    var interactionTypeOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionType>()
        .Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = option.Value,
            Text = T.T(option.Text)
        });
    var interactionChannelOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionChannel>()
        .Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem
        {
            Value = option.Value,
            Text = T.T(option.Text)
        });
    string LeadInteractionsUrl(Guid leadId) => Url.Action("LeadInteractions", "Crm", new { leadId }) ?? string.Empty;
}

<h1 class="mb-3">@T.T("EditLead")</h1>

<partial name="_LeadEditorShell" model="Model" />

<hr class="my-4" />

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header"><strong>@T.T("LeadConversion")</strong></div>
            <div class="card-body">
                @if (Model.CustomerId.HasValue)
                {
                    <p class="mb-3">@T.T("LeadAlreadyLinkedToCustomer")</p>
                    <a asp-action="EditCustomer" asp-route-id="@Model.CustomerId.Value" class="btn btn-outline-success">
                        <i class="fa fa-user"></i> @T.T("OpenCustomer")
                    </a>
                }
                else
                {
                    <form asp-controller="Crm" asp-action="ConvertLead" method="post" class="row g-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="LeadId" value="@Model.Id" />
                        <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                        <div class="col-md-6">
                            <label class="form-label">@T.T("LinkToExistingUser")</label>
                            <select name="UserId" class="form-select" asp-items="Model.Conversion.UserOptions"></select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input type="checkbox" name="CopyNotesToCustomer" value="true" checked="checked" class="form-check-input" id="copyNotesToCustomer" />
                                <label class="form-check-label" for="copyNotesToCustomer">@T.T("CopyNotes")</label>
                            </div>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-success">
                                <i class="fa fa-arrow-right"></i> @T.T("ConvertToCustomer")
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><strong>@T.T("AddInteraction")</strong></div>
            <div class="card-body">
                <form asp-controller="Crm"
                      asp-action="LeadInteractions"
                      method="post"
                      hx-post="@Url.Action("LeadInteractions", "Crm")"
                      hx-target="#lead-interactions-grid"
                      hx-swap="innerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="LeadId" value="@Model.Id" />
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Type")</label>
                        <select name="Type" class="form-select" asp-items="interactionTypeOptions"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Channel")</label>
                        <select name="Channel" class="form-select" asp-items="interactionChannelOptions"></select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">@T.T("Subject")</label>
                        <input name="Subject" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">@T.T("Content")</label>
                        <textarea name="Content" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Owner")</label>
                        <select name="UserId" class="form-select" asp-items="Model.NewInteraction.UserOptions"></select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">@T.T("AddInteraction")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><strong>@T.T("Interactions")</strong></div>
            <div class="card-body" id="lead-interactions-grid"
                 hx-get="@LeadInteractionsUrl(Model.Id)"
                 hx-target="this"
                 hx-trigger="load"
                 hx-swap="innerHTML"></div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
