@model Darwin.WebAdmin.ViewModels.CRM.CustomersListVm
@{
    ViewData["Title"] = "CRM Customers";
}

<h1 class="mb-3">Customers</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Customers" method="get" class="d-flex gap-2">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search customers">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> Search</button>
    </form>

    <a asp-action="CreateCustomer" class="btn btn-primary">
        <i class="fa fa-plus"></i> New Customer
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Customers" asp-route-filter="LinkedUser" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.LinkedUser ? "btn-info" : "btn-outline-info")">Linked User</a>
    <a asp-action="Customers" asp-route-filter="NeedsSegmentation" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.NeedsSegmentation ? "btn-warning" : "btn-outline-warning")">Needs Segmentation</a>
    <a asp-action="Customers" asp-route-filter="HasOpportunities" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.HasOpportunities ? "btn-primary" : "btn-outline-primary")">Has Opportunities</a>
    <a asp-action="Customers" asp-route-filter="Business" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.Business ? "btn-dark" : "btn-outline-dark")">B2B</a>
    <a asp-action="Customers" asp-route-filter="MissingVatId" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.MissingVatId ? "btn-danger" : "btn-outline-danger")">B2B Missing VAT ID</a>
    <a asp-action="Customers" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Company</th>
                <th>Tax Profile</th>
                <th>Segments</th>
                <th>Opportunities</th>
                <th>Updated</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">No customers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @item.DisplayName
                        @if (item.UserId.HasValue)
                        {
                            <span class="badge text-bg-info ms-2">Linked user</span>
                        }
                    </td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.CompanyName</td>
                    <td>
                        <span class="badge @(item.TaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@item.TaxProfileType</span>
                        @if (!string.IsNullOrWhiteSpace(item.VatId))
                        {
                            <div class="small text-muted">@item.VatId</div>
                        }
                        else if (item.TaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                        {
                            <div class="small text-danger">VAT ID missing</div>
                        }
                    </td>
                    <td>@item.SegmentCount</td>
                    <td>@item.OpportunityCount</td>
                    <td>
                        <div>@(item.ModifiedAtUtc ?? item.CreatedAtUtc).ToString("yyyy-MM-dd")</div>
                        <div class="small text-muted">@((item.ModifiedAtUtc.HasValue ? "Updated" : "Created"))</div>
                    </td>
                    <td class="text-end">
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> Edit
                        </a>
                        @if (item.UserId.HasValue)
                        {
                            <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId.Value" class="btn btn-sm btn-outline-info">
                                <i class="fa fa-user"></i> User
                            </a>
                        }
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" asp-fragment="customer-interactions-section" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-comments"></i> Interactions
                        </a>
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" asp-fragment="customer-segments-section" class="btn btn-sm btn-outline-warning">
                            <i class="fa fa-tags"></i> Segments
                        </a>
                        <a asp-action="CreateOpportunity" asp-route-customerId="@item.Id" class="btn btn-sm btn-outline-success">
                            <i class="fa fa-briefcase"></i> Opportunity
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Customers"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
