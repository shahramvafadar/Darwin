@model Darwin.WebAdmin.ViewModels.CRM.CustomersListVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CrmCustomersTitle");
    string GlobalCrmCustomersUrl() => Url.Action("Customers", "Crm") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string CreateCustomerUrl() => Url.Action("CreateCustomer", "Crm") ?? string.Empty;
    string CrmCustomersUrl(object? q = null, string? filter = null) => Url.Action("Customers", "Crm", new { q, filter }) ?? string.Empty;
    string CrmSegmentsUrl() => Url.Action("Segments", "Crm") ?? string.Empty;
    string CrmInvoicesUrl(object? q = null, string? filter = null) => Url.Action("Invoices", "Crm", new { q, filter }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string EditCustomerUrl(Guid id, string? fragment = null) => Url.Action("EditCustomer", "Crm", new { id, fragment }) ?? string.Empty;
    string UserEditUrl(object? id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string CreateOpportunityUrl(Guid customerId) => Url.Action("CreateOpportunity", "Crm", new { customerId }) ?? string.Empty;
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
    string CrmCustomerOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string CrmCustomerOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var crmCustomerAttentionCount = Model.OpsSummary.NeedsSegmentationCount + Model.OpsSummary.MissingVatIdCount + Model.Items.Count(x => x.UsesPlatformLocaleFallback);
}

<div id="crm-customers-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3">@T.T("Customers")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Customers" method="get" class="d-flex gap-2"
          hx-get="@GlobalCrmCustomersUrl()"
          hx-target="#crm-customers-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchCustomersPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
        <a asp-action="Customers" class="btn btn-outline-secondary"
           hx-get="@GlobalCrmCustomersUrl()"
           hx-target="#crm-customers-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>

    <a asp-action="CreateCustomer" class="btn btn-primary"
       hx-get="@CreateCustomerUrl()"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa fa-plus"></i> @T.T("NewCustomer")
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Customers")</div>
            <div class="display-6 fw-semibold mt-1">@Model.Summary.CustomerCount</div>
            <div class="small text-muted mt-2">@T.T("CrmCustomersFootprintNote")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Segments")</div>
            <div class="display-6 fw-semibold mt-1">@Model.Summary.SegmentCount</div>
            <div class="small text-muted mt-2">@T.T("CrmCustomerSegmentsCoverageNote")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("OpenPipeline")</div>
            <div class="display-6 fw-semibold mt-1">@((Model.Summary.OpenPipelineMinor / 100m).ToString("N0"))</div>
            <div class="small text-muted mt-2">@T.T("CrmCustomerPipelineNote")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Interactions7d")</div>
            <div class="display-6 fw-semibold mt-1">@Model.Summary.RecentInteractionCount</div>
            <div class="small text-muted mt-2">@T.T("CrmCustomerRecentInteractionsNote")</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                            <span class="@CrmCustomerOpsHealthBadgeClass(crmCustomerAttentionCount == 0)">@CrmCustomerOpsHealthBadgeText(crmCustomerAttentionCount == 0)</span>
                        </div>
                        <p class="text-muted small mb-0 mt-2">
                            @T.T("Customers")
                            @if (crmCustomerAttentionCount > 0)
                            {
                                <span class="ms-1">@T.T("NeedsAttention"): @crmCustomerAttentionCount</span>
                            }
                        </p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="CreateCustomer"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreateCustomerUrl()"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NewCustomer")</a>
                        <a asp-action="Invoices"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalInvoicesUrl()"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReviewInvoices")</a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("NeedsSegmentation")</div>
                                    <div class="small text-muted mt-1">@T.T("Segments")</div>
                                </div>
                                <span class="@CrmCustomerOpsHealthBadgeClass(Model.OpsSummary.NeedsSegmentationCount == 0)">@Model.OpsSummary.NeedsSegmentationCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("ReviewSegmentation")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Customers" asp-route-filter="NeedsSegmentation" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.NeedsSegmentation ? "btn-warning" : "btn-outline-warning")"
                                   hx-get="@CrmCustomersUrl(Model.Query, "NeedsSegmentation")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("NeedsSegmentation")</a>
                                <a asp-action="Segments"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmSegmentsUrl()"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Segments")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("B2BMissingVatId")</div>
                                    <div class="small text-muted mt-1">@T.T("TaxSettings")</div>
                                </div>
                                <span class="@CrmCustomerOpsHealthBadgeClass(Model.OpsSummary.MissingVatIdCount == 0)">@Model.OpsSummary.MissingVatIdCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("ReviewInvoices")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Customers" asp-route-filter="MissingVatId" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.MissingVatId ? "btn-danger" : "btn-outline-danger")"
                                   hx-get="@CrmCustomersUrl(Model.Query, "MissingVatId")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("B2BMissingVatId")</a>
                                <a asp-action="Invoices" asp-route-filter="MissingVatId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmInvoicesUrl(filter: "MissingVatId")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("ReviewInvoices")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("LocaleFallback")</div>
                                    <div class="small text-muted mt-1">@T.T("VisibleLocaleFallbacks")</div>
                                </div>
                                <span class="@CrmCustomerOpsHealthBadgeClass(Model.Items.Count(x => x.UsesPlatformLocaleFallback) == 0)">@Model.Items.Count(x => x.UsesPlatformLocaleFallback)</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("UsesPlatformLocaleFallback")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Customers" asp-route-filter="UsesPlatformLocaleFallback" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.UsesPlatformLocaleFallback ? "btn-secondary" : "btn-outline-secondary")"
                                   hx-get="@CrmCustomersUrl(Model.Query, "UsesPlatformLocaleFallback")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("LocaleFallback")</a>
                                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-localization"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-localization")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Open")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <div class="fw-semibold">@T.T("HasOpportunities")</div>
                                    <div class="small text-muted mt-1">@T.T("ReviewInvoices")</div>
                                </div>
                                <span class="@CrmCustomerOpsHealthBadgeClass(Model.OpsSummary.HasOpportunitiesCount == 0)">@Model.OpsSummary.HasOpportunitiesCount</span>
                            </div>
                            <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a asp-action="Customers" asp-route-filter="HasOpportunities" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.HasOpportunities ? "btn-primary" : "btn-outline-primary")"
                                   hx-get="@CrmCustomersUrl(Model.Query, "HasOpportunities")"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("HasOpportunities")</a>
                                <a asp-action="Invoices"
                                   class="btn btn-sm btn-outline-secondary"
                                       hx-get="@GlobalInvoicesUrl()"
                                   hx-target="#crm-customers-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("ReviewInvoices")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("PlatformFallbackCulture")</div>
            <div class="fw-semibold mt-1">@Model.PlatformDefaultCulture</div>
            <div class="small text-muted mt-2">@T.T("CrmPlatformFallbackCultureNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("VisibleLocaleFallbacks")</div>
            <div class="fw-semibold mt-1">@Model.Items.Count(x => x.UsesPlatformLocaleFallback)</div>
            <div class="small text-muted mt-2">@T.T("CrmVisibleLocaleFallbacksNote")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("VisibleLinkedUserLocales")</div>
            <div class="fw-semibold mt-1">@Model.Items.Count(x => !x.UsesPlatformLocaleFallback)</div>
            <div class="small text-muted mt-2">@T.T("CrmVisibleLinkedUserLocalesNote")</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("LinkedUser")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.LinkedUserCount</div>
                    <div class="small text-muted mt-2">@T.T("CrmCustomerLinkedIdentityNote")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("NeedsSegmentation")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.NeedsSegmentationCount</div>
                    <div class="small text-muted mt-2">@T.T("CrmCustomerNeedsSegmentationNote")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("HasOpportunities")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.HasOpportunitiesCount</div>
                    <div class="small text-muted mt-2">@T.T("CrmCustomerOpportunityContextNote")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("B2B")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.BusinessCount</div>
                    <div class="small text-muted mt-2">@T.T("CrmCustomerBusinessProfileNote")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("VatIdMissing")</div>
                    <div class="fw-semibold mt-1">@Model.OpsSummary.MissingVatIdCount</div>
                    <div class="small text-muted mt-2">@T.T("CrmCustomerMissingVatNote")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("CrmOperatorPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@T.T(playbook.Title)</div>
                        <div class="small text-muted mt-2">@T.T(playbook.ScopeNote)</div>
                        <div class="small mt-2"><strong>@T.T("CrmNextStep"):</strong> @T.T(playbook.OperatorAction)</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Customers" asp-route-filter="LinkedUser" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.LinkedUser ? "btn-info" : "btn-outline-info")"
       hx-get="@CrmCustomersUrl(filter: "LinkedUser")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("LinkedUser")</a>
    <a asp-action="Customers" asp-route-filter="NeedsSegmentation" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.NeedsSegmentation ? "btn-warning" : "btn-outline-warning")"
       hx-get="@CrmCustomersUrl(filter: "NeedsSegmentation")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NeedsSegmentation")</a>
    <a asp-action="Customers" asp-route-filter="HasOpportunities" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.HasOpportunities ? "btn-primary" : "btn-outline-primary")"
       hx-get="@CrmCustomersUrl(filter: "HasOpportunities")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("HasOpportunities")</a>
    <a asp-action="Customers" asp-route-filter="Business" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.Business ? "btn-dark" : "btn-outline-dark")"
       hx-get="@CrmCustomersUrl(filter: "Business")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("B2B")</a>
    <a asp-action="Customers" asp-route-filter="MissingVatId" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.MissingVatId ? "btn-danger" : "btn-outline-danger")"
       hx-get="@CrmCustomersUrl(filter: "MissingVatId")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("B2BMissingVatId")</a>
    <a asp-action="Customers" asp-route-filter="UsesPlatformLocaleFallback" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.UsesPlatformLocaleFallback ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@CrmCustomersUrl(filter: "UsesPlatformLocaleFallback")"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("LocaleFallback")</a>
    <a asp-action="Customers" class="btn btn-sm btn-outline-secondary"
           hx-get="@GlobalCrmCustomersUrl()"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Email")</th>
                <th>@T.T("Phone")</th>
                <th>@T.T("Company")</th>
                <th>@T.T("Locale")</th>
                <th>@T.T("TaxProfile")</th>
                <th>@T.T("Segments")</th>
                <th>@T.T("Opportunities")</th>
                <th>@T.T("Updated")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="10" class="text-center text-muted">@T.T("NoCustomersFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @item.DisplayName
                        @if (item.UserId.HasValue)
                        {
                            <span class="badge text-bg-info ms-2">@T.T("LinkedUser")</span>
                        }
                    </td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.CompanyName</td>
                    <td>
                        @if (item.UsesPlatformLocaleFallback)
                        {
                            <span class="badge text-bg-secondary">@T.T("Fallback")</span>
                            <div class="small text-muted">@Model.PlatformDefaultCulture</div>
                        }
                        else
                        {
                            <span class="badge text-bg-info">@T.T("UserLocale")</span>
                            <div class="small text-muted">@item.Locale</div>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.TaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@LocalizeCustomerTaxProfileType(item.TaxProfileType)</span>
                        @if (!string.IsNullOrWhiteSpace(item.VatId))
                        {
                            <div class="small text-muted">@item.VatId</div>
                        }
                        else if (item.TaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                        {
                            <div class="small text-danger">@T.T("VatIdMissing")</div>
                        }
                    </td>
                    <td>@item.SegmentCount</td>
                    <td>@item.OpportunityCount</td>
                    <td>
                                    <div>@(item.ModifiedAtUtc ?? item.CreatedAtUtc).ToLocalTime().ToString("d", CultureInfo.CurrentCulture)</div>
                        <div class="small text-muted">@T.T(item.ModifiedAtUtc.HasValue ? "Updated" : "Created")</div>
                    </td>
                    <td class="text-end">
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditCustomerUrl(item.Id)"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                        @if (item.UserId.HasValue)
                        {
                            <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId.Value" class="btn btn-sm btn-outline-info"
                               hx-get="@UserEditUrl(item.UserId.Value)"
                               hx-target="#crm-customers-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                            <i class="fa fa-user"></i> @T.T("Users")
                            </a>
                        }
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" asp-fragment="customer-interactions-section" class="btn btn-sm btn-outline-primary"
                           hx-get="@EditCustomerUrl(item.Id, "customer-interactions-section")"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-comments"></i> @T.T("Interactions")
                        </a>
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" asp-fragment="customer-segments-section" class="btn btn-sm btn-outline-warning"
                           hx-get="@EditCustomerUrl(item.Id, "customer-segments-section")"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-tags"></i> @T.T("Segments")
                        </a>
                        <a asp-action="CreateOpportunity" asp-route-customerId="@item.Id" class="btn btn-sm btn-outline-success"
                           hx-get="@CreateOpportunityUrl(item.Id)"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-briefcase"></i> @T.T("Opportunity")
                        </a>
                        <a asp-action="Invoices" asp-route-q="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@CrmInvoicesUrl(item.Id)"
                           hx-target="#crm-customers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-file-invoice"></i> @T.T("ReviewInvoices")
                        </a>
                        @if (item.TaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business && string.IsNullOrWhiteSpace(item.VatId))
                        {
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" class="btn btn-sm btn-outline-danger"
                               hx-get="@SiteSettingsUrl("site-settings-tax")"
                               hx-target="#crm-customers-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-scale-balanced"></i> @T.T("TaxSettings")
                            </a>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Customers"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-customers-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
