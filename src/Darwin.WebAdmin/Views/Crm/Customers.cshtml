@model Darwin.WebAdmin.ViewModels.CRM.CustomersListVm
@{
    ViewData["Title"] = "CRM Customers";
}

<h1 class="mb-3">Customers</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Customers" method="get" class="d-flex gap-2">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search customers">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> Search</button>
    </form>

    <a asp-action="CreateCustomer" class="btn btn-primary">
        <i class="fa fa-plus"></i> New Customer
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Customers" asp-route-filter="LinkedUser" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.LinkedUser ? "btn-info" : "btn-outline-info")">Linked User</a>
    <a asp-action="Customers" asp-route-filter="NeedsSegmentation" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.NeedsSegmentation ? "btn-warning" : "btn-outline-warning")">Needs Segmentation</a>
    <a asp-action="Customers" asp-route-filter="HasOpportunities" class="btn btn-sm @(Model.Filter == Darwin.Application.CRM.DTOs.CustomerQueueFilter.HasOpportunities ? "btn-primary" : "btn-outline-primary")">Has Opportunities</a>
    <a asp-action="Customers" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Company</th>
                <th>Segments</th>
                <th>Opportunities</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">No customers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        @item.DisplayName
                        @if (item.UserId.HasValue)
                        {
                            <span class="badge text-bg-info ms-2">Linked user</span>
                        }
                    </td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.CompanyName</td>
                    <td>@item.SegmentCount</td>
                    <td>@item.OpportunityCount</td>
                    <td class="text-end">
                        <a asp-action="EditCustomer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="fa fa-pen"></i> Edit
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Customers"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
