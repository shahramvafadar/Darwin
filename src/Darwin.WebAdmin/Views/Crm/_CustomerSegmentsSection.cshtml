@model Darwin.WebAdmin.ViewModels.CRM.CustomerMembershipsVm

<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="3" class="text-center text-muted">No assigned segments.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td class="text-end">
                            <form asp-controller="Crm"
                                  asp-action="RemoveCustomerSegmentMembership"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("RemoveCustomerSegmentMembership", "Crm")"
                                  hx-target="#customer-segments-grid"
                                  hx-swap="innerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="customerId" value="@Model.CustomerId" />
                                <input type="hidden" name="membershipId" value="@item.MembershipId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
