@model Darwin.WebAdmin.ViewModels.CRM.InvoiceEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string LocalizeCrmInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
    var invoiceStatusOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.InvoiceStatus>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) });
}

<div id="crm-invoice-editor-shell">
    <h1 class="mb-3">@T.T("EditInvoice")</h1>
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="alert alert-light border mb-3">
        <div class="row g-2 small">
            <div class="col-md-4">
                <strong>@T.T("Invoice"):</strong> <code>@Model.Id</code>
            </div>
            <div class="col-md-4">
                <strong>@T.T("Order"):</strong>
                @if (Model.OrderId.HasValue)
                {
                    <a asp-controller="Orders"
                       asp-action="Details"
                       asp-route-id="@Model.OrderId.Value"
                       class="text-decoration-none"
                       hx-get="@Url.Action("Details", "Orders", new { id = Model.OrderId.Value })"
                       hx-target="#crm-invoice-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.OrderNumber) ? Model.OrderId.Value.ToString() : Model.OrderNumber)
                    </a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </div>
            <div class="col-md-4">
                <strong>@T.T("Customer"):</strong>
                @if (Model.CustomerId.HasValue)
                {
                    <a asp-action="EditCustomer"
                       asp-route-id="@Model.CustomerId.Value"
                       class="text-decoration-none"
                       hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                       hx-target="#crm-invoice-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.CustomerDisplayName) ? Model.CustomerId.Value.ToString() : Model.CustomerDisplayName)
                    </a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
                @if (Model.CustomerTaxProfileType.HasValue)
                {
                    <div class="small mt-1">
                        <span class="badge @(Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@LocalizeCustomerTaxProfileType(Model.CustomerTaxProfileType)</span>
                        @if (!string.IsNullOrWhiteSpace(Model.CustomerVatId))
                        {
                            <span class="text-muted ms-1">@Model.CustomerVatId</span>
                        }
                        else if (Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                        {
                            <span class="text-danger ms-1">@T.T("VatIdMissing")</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card border-0 bg-light mb-3">
        <div class="card-body py-3">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="small text-uppercase text-muted fw-semibold">@T.T("QuickStatus")</span>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Open" />
                    <button type="submit" class="btn btn-outline-secondary btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Open ? "disabled" : null)>
                        @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Draft ? T.T("PostInvoice") : T.T("SetOpen"))
                    </button>
                </form>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Paid" />
                    <button type="submit" class="btn btn-outline-success btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Paid ? "disabled" : null)>@T.T("MarkPaid")</button>
                </form>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Cancelled" />
                    <button type="submit" class="btn btn-outline-danger btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Cancelled ? "disabled" : null)>@T.T("VoidInvoice")</button>
                </form>

                <span class="badge text-bg-primary-subtle border border-primary-subtle text-primary-emphasis ms-auto">
                    @T.T("Current"): @LocalizeCrmInvoiceStatus(Model.Status)
                </span>
            </div>
        </div>
    </div>

    <div class="card border-0 bg-light mb-3">
        <div class="card-body py-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="fw-semibold">@T.T("InvoiceFollowUpWorkspace")</div>
                    <div class="small text-muted mt-1">@T.T("InvoiceFollowUpWorkspaceNote")</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.CustomerId.HasValue)
                    {
                        <a asp-action="EditCustomer"
                           asp-route-id="@Model.CustomerId.Value"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-user"></i> @T.T("OpenCustomer")
                        </a>
                    }
                    @if (Model.OrderId.HasValue)
                    {
                        <a asp-controller="Orders"
                           asp-action="Details"
                           asp-route-id="@Model.OrderId.Value"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@Url.Action("Details", "Orders", new { id = Model.OrderId.Value })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-box"></i> @T.T("ReviewOrder")
                        </a>
                    }
                    @if (Model.PaymentId.HasValue && Model.OrderId.HasValue)
                    {
                        <a asp-controller="Orders"
                           asp-action="Details"
                           asp-route-id="@Model.OrderId.Value"
                           asp-fragment="payments"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("Details", "Orders", new { id = Model.OrderId.Value, fragment = "payments" })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-credit-card"></i> @T.T("ReviewPaymentTrail")
                        </a>
                    }
                    <a asp-action="Invoices"
                       asp-route-q="@Model.CustomerId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Invoices", "Crm", new { q = Model.CustomerId })"
                       hx-target="#crm-invoice-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa fa-list"></i> @T.T("RelatedInvoices")
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card border-0 bg-light">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="small text-uppercase text-muted fw-semibold">@T.T("TaxInvoicingPolicy")</div>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            @T.T("OpenTaxSettings")
                        </a>
                    </div>
                    <div class="row g-3 small">
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("VatEnabled")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.VatEnabled ? T.T("Yes") : T.T("No"))</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("DefaultVat")</div>
                            <div class="fw-semibold">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("PriceMode")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.PricesIncludeVat ? T.T("VatInclusive") : T.T("VatExclusive"))</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("ReverseCharge")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("Issuer")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : T.T("Missing"))</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("TaxId")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.InvoiceIssuerTaxIdConfigured ? T.T("Ready") : T.T("Missing"))</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("ArchiveReadiness")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.ArchiveReadinessComplete ? T.T("Ready") : T.T("MissingData"))</div>
                            <div class="small text-muted mt-1">@Model.TaxPolicy.ArchiveReadinessLabel</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">@T.T("EInvoiceBaseline")</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.EInvoiceBaselineReady ? T.T("BaselineReady") : T.T("NotReady"))</div>
                            <div class="small text-muted mt-1">@Model.TaxPolicy.EInvoiceBaselineLabel</div>
                        </div>
                    </div>
                    <div class="small text-muted mt-3">@Model.TaxPolicy.ComplianceScopeNote</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            @T.T("TaxSettings")
                        </a>
                        @if (Model.CustomerId.HasValue)
                        {
                            <a asp-action="EditCustomer"
                               asp-route-id="@Model.CustomerId.Value"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                               hx-target="#crm-invoice-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                @T.T("CustomerTaxProfile")
                            </a>
                            @if (Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business && string.IsNullOrWhiteSpace(Model.CustomerVatId))
                            {
                                <a asp-action="EditCustomer"
                                   asp-route-id="@Model.CustomerId.Value"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                                   hx-target="#crm-invoice-editor-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("FixVatId")
                                </a>
                            }
                        }
                        @if (!Model.TaxPolicy.ArchiveReadinessComplete)
                        {
                            <a asp-controller="SiteSettings"
                               asp-action="Edit"
                               asp-fragment="site-settings-tax"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                               hx-target="#crm-invoice-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                @T.T("CompleteIssuerData")
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">@T.T("NetTaxGross")</div>
                    <div>@Model.Currency @((Model.TotalNetMinor / 100.0M).ToString("0.00")) @T.T("Net")</div>
                    <div>@Model.Currency @((Model.TotalTaxMinor / 100.0M).ToString("0.00")) @T.T("Tax")</div>
                    <div class="fs-5">@Model.Currency @((Model.TotalGrossMinor / 100.0M).ToString("0.00")) @T.T("Gross")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">@T.T("RefundedSettled")</div>
                    <div>@Model.Currency @((Model.RefundedAmountMinor / 100.0M).ToString("0.00")) @T.T("Refunded")</div>
                    <div class="small text-muted">@Model.Currency @((Model.SettledAmountMinor / 100.0M).ToString("0.00")) @T.T("Settled")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">@T.T("OpenBalance")</div>
                    <div class="fs-5 @(Model.BalanceMinor > 0 ? "text-danger" : "text-success")">
                        @Model.Currency @((Model.BalanceMinor / 100.0M).ToString("0.00"))
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.PaymentId.HasValue && Model.SettledAmountMinor > 0)
    {
        <div class="card border-0 bg-light mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="small text-uppercase text-muted fw-semibold">@T.T("RefundWorkflow")</div>
                        <div class="small text-muted">@T.T("RefundWorkflowNote")</div>
                    </div>
                    <div class="text-end small">
                        <div class="text-muted">@T.T("MaxRefundableNow")</div>
                        <div class="fw-semibold">@Model.Currency @((Model.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                </div>
                <form asp-action="RefundInvoice"
                      method="post"
                      hx-post="@Url.Action("RefundInvoice", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="InvoiceId" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="Currency" value="@Model.Currency" />
                    <div class="col-md-4">
                        <label class="form-label" for="invoice-refund-amount">@T.T("RefundAmountMinor")</label>
                        <input id="invoice-refund-amount" name="AmountMinor" value="@(Model.Refund.AmountMinor > 0 ? Model.Refund.AmountMinor : Model.SettledAmountMinor)" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="invoice-refund-reason">@T.T("Reason")</label>
                        <input id="invoice-refund-reason" name="Reason" value="@Model.Refund.Reason" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-outline-warning w-100">@T.T("Refund")</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <form asp-action="EditInvoice"
          method="post"
          hx-post="@Url.Action("EditInvoice", "Crm")"
          hx-target="#crm-invoice-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="BusinessId" class="form-label"></label>
                <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerId" class="form-label"></label>
                <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="PaymentId" class="form-label"></label>
                <select asp-for="PaymentId" asp-items="Model.PaymentOptions" class="form-select"></select>
                @if (!string.IsNullOrWhiteSpace(Model.PaymentSummary))
                {
                    <div class="form-text">@T.T("Current"): @Model.PaymentSummary</div>
                }
            </div>
            <div class="col-md-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="invoiceStatusOptions" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="Currency" class="form-label"></label>
                <input asp-for="Currency" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="DueDateUtc" class="form-label"></label>
                <input asp-for="DueDateUtc" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="PaidAtUtc" class="form-label"></label>
                <input asp-for="PaidAtUtc" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalNetMinor" class="form-label"></label>
                <input asp-for="TotalNetMinor" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalTaxMinor" class="form-label"></label>
                <input asp-for="TotalTaxMinor" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalGrossMinor" class="form-label"></label>
                <input asp-for="TotalGrossMinor" class="form-control" />
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            <a asp-action="Invoices" hx-get="@Url.Action("Invoices", "Crm")" hx-target="#crm-invoice-editor-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Back")</a>
        </div>
    </form>
</div>
