@model Darwin.WebAdmin.ViewModels.CRM.InvoiceEditVm

<div id="crm-invoice-editor-shell">
    <h1 class="mb-3">Edit Invoice</h1>

    <div class="alert alert-light border mb-3">
        <div class="row g-2 small">
            <div class="col-md-4">
                <strong>Invoice:</strong> <code>@Model.Id</code>
            </div>
            <div class="col-md-4">
                <strong>Order:</strong>
                @if (Model.OrderId.HasValue)
                {
                    <a asp-controller="Orders"
                       asp-action="Details"
                       asp-route-id="@Model.OrderId.Value"
                       class="text-decoration-none"
                       hx-get="@Url.Action("Details", "Orders", new { id = Model.OrderId.Value })"
                       hx-target="#crm-invoice-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.OrderNumber) ? Model.OrderId.Value.ToString() : Model.OrderNumber)
                    </a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </div>
            <div class="col-md-4">
                <strong>Customer:</strong>
                @if (Model.CustomerId.HasValue)
                {
                    <a asp-action="EditCustomer"
                       asp-route-id="@Model.CustomerId.Value"
                       class="text-decoration-none"
                       hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                       hx-target="#crm-invoice-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.CustomerDisplayName) ? Model.CustomerId.Value.ToString() : Model.CustomerDisplayName)
                    </a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
                @if (Model.CustomerTaxProfileType.HasValue)
                {
                    <div class="small mt-1">
                        <span class="badge @(Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@Model.CustomerTaxProfileType</span>
                        @if (!string.IsNullOrWhiteSpace(Model.CustomerVatId))
                        {
                            <span class="text-muted ms-1">@Model.CustomerVatId</span>
                        }
                        else if (Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                        {
                            <span class="text-danger ms-1">VAT ID missing</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card border-0 bg-light mb-3">
        <div class="card-body py-3">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="small text-uppercase text-muted fw-semibold">Quick Status</span>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Open" />
                    <button type="submit" class="btn btn-outline-secondary btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Open ? "disabled" : null)>
                        @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Draft ? "Post Invoice" : "Set Open")
                    </button>
                </form>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Paid" />
                    <button type="submit" class="btn btn-outline-success btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Paid ? "disabled" : null)>Mark Paid</button>
                </form>

                <form asp-action="TransitionInvoiceStatus"
                      method="post"
                      hx-post="@Url.Action("TransitionInvoiceStatus", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="d-inline-flex">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="TargetStatus" value="@Darwin.Domain.Enums.InvoiceStatus.Cancelled" />
                    <button type="submit" class="btn btn-outline-danger btn-sm" @(Model.Status == Darwin.Domain.Enums.InvoiceStatus.Cancelled ? "disabled" : null)>Void Invoice</button>
                </form>

                <span class="badge text-bg-primary-subtle border border-primary-subtle text-primary-emphasis ms-auto">
                    Current: @Model.Status
                </span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card border-0 bg-light">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="small text-uppercase text-muted fw-semibold">Tax &amp; Invoicing Policy</div>
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            Open Tax Settings
                        </a>
                    </div>
                    <div class="row g-3 small">
                        <div class="col-md-2">
                            <div class="text-muted">VAT Enabled</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.VatEnabled ? "Yes" : "No")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Default VAT</div>
                            <div class="fw-semibold">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Price Mode</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.PricesIncludeVat ? "VAT Inclusive" : "VAT Exclusive")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Reverse Charge</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.AllowReverseCharge ? "Allowed" : "Disabled")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Issuer</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : "Missing")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Tax ID</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.InvoiceIssuerTaxIdConfigured ? "Ready" : "Missing")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Archive</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.ArchiveReadinessComplete ? "Ready" : "Missing data")</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">E-Invoice</div>
                            <div class="fw-semibold">@(Model.TaxPolicy.EInvoiceBaselineReady ? "Baseline ready" : "Not ready")</div>
                        </div>
                    </div>
                    <div class="small text-muted mt-3">@Model.TaxPolicy.ComplianceScopeNote</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#crm-invoice-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            Tax Settings
                        </a>
                        @if (Model.CustomerId.HasValue)
                        {
                            <a asp-action="EditCustomer"
                               asp-route-id="@Model.CustomerId.Value"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                               hx-target="#crm-invoice-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                Customer Tax Profile
                            </a>
                            @if (Model.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business && string.IsNullOrWhiteSpace(Model.CustomerVatId))
                            {
                                <a asp-action="EditCustomer"
                                   asp-route-id="@Model.CustomerId.Value"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("EditCustomer", "Crm", new { id = Model.CustomerId.Value })"
                                   hx-target="#crm-invoice-editor-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    Fix VAT ID
                                </a>
                            }
                        }
                        @if (!Model.TaxPolicy.ArchiveReadinessComplete)
                        {
                            <a asp-controller="SiteSettings"
                               asp-action="Edit"
                               asp-fragment="site-settings-tax"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                               hx-target="#crm-invoice-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                Complete Issuer Data
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">Net / Tax / Gross</div>
                    <div>@Model.Currency @((Model.TotalNetMinor / 100.0M).ToString("0.00")) net</div>
                    <div>@Model.Currency @((Model.TotalTaxMinor / 100.0M).ToString("0.00")) tax</div>
                    <div class="fs-5">@Model.Currency @((Model.TotalGrossMinor / 100.0M).ToString("0.00")) gross</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">Refunded / Settled</div>
                    <div>@Model.Currency @((Model.RefundedAmountMinor / 100.0M).ToString("0.00")) refunded</div>
                    <div class="small text-muted">@Model.Currency @((Model.SettledAmountMinor / 100.0M).ToString("0.00")) settled</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 bg-light">
                <div class="card-body py-3">
                    <div class="small text-uppercase text-muted fw-semibold">Open Balance</div>
                    <div class="fs-5 @(Model.BalanceMinor > 0 ? "text-danger" : "text-success")">
                        @Model.Currency @((Model.BalanceMinor / 100.0M).ToString("0.00"))
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.PaymentId.HasValue && Model.SettledAmountMinor > 0)
    {
        <div class="card border-0 bg-light mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="small text-uppercase text-muted fw-semibold">Refund Workflow</div>
                        <div class="small text-muted">Use refund when captured funds must be returned. Use void only if funds were not collected.</div>
                    </div>
                    <div class="text-end small">
                        <div class="text-muted">Max refundable now</div>
                        <div class="fw-semibold">@Model.Currency @((Model.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                </div>
                <form asp-action="RefundInvoice"
                      method="post"
                      hx-post="@Url.Action("RefundInvoice", "Crm")"
                      hx-target="#crm-invoice-editor-shell"
                      hx-swap="outerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="InvoiceId" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <input type="hidden" name="Currency" value="@Model.Currency" />
                    <div class="col-md-4">
                        <label class="form-label" for="invoice-refund-amount">Refund amount (minor)</label>
                        <input id="invoice-refund-amount" name="AmountMinor" value="@(Model.Refund.AmountMinor > 0 ? Model.Refund.AmountMinor : Model.SettledAmountMinor)" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="invoice-refund-reason">Reason</label>
                        <input id="invoice-refund-reason" name="Reason" value="@Model.Refund.Reason" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-outline-warning w-100">Refund</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <form asp-action="EditInvoice"
          method="post"
          hx-post="@Url.Action("EditInvoice", "Crm")"
          hx-target="#crm-invoice-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="BusinessId" class="form-label"></label>
                <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerId" class="form-label"></label>
                <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="PaymentId" class="form-label"></label>
                <select asp-for="PaymentId" asp-items="Model.PaymentOptions" class="form-select"></select>
                @if (!string.IsNullOrWhiteSpace(Model.PaymentSummary))
                {
                    <div class="form-text">Current: @Model.PaymentSummary</div>
                }
            </div>
            <div class="col-md-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.InvoiceStatus>()" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="Currency" class="form-label"></label>
                <input asp-for="Currency" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="DueDateUtc" class="form-label"></label>
                <input asp-for="DueDateUtc" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="PaidAtUtc" class="form-label"></label>
                <input asp-for="PaidAtUtc" type="datetime-local" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalNetMinor" class="form-label"></label>
                <input asp-for="TotalNetMinor" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalTaxMinor" class="form-label"></label>
                <input asp-for="TotalTaxMinor" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="TotalGrossMinor" class="form-label"></label>
                <input asp-for="TotalGrossMinor" class="form-control" />
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Invoices" hx-get="@Url.Action("Invoices", "Crm")" hx-target="#crm-invoice-editor-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>
