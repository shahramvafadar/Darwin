@model Darwin.WebAdmin.ViewModels.CRM.CustomerSegmentsListVm
@{
    ViewData["Title"] = "Customer Segments";
}

<div id="crm-segments-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Customer Segments</h1>
        <p class="text-muted mb-0">Review CRM segmentation hygiene before campaigns, support filters, and reporting depend on it.</p>
    </div>
    <a asp-action="CreateSegment"
       hx-get="@Url.Action("CreateSegment", "Crm")"
       hx-target="#crm-segments-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-primary">
        <i class="fa fa-plus"></i> New Segment
    </a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">Total</div><div class="fs-4 fw-semibold">@Model.SegmentSummary.TotalCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">In Use</div><div class="fs-4 fw-semibold">@Model.SegmentSummary.InUseCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">Empty</div><div class="fs-4 fw-semibold">@Model.SegmentSummary.EmptyCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">Missing Description</div><div class="fs-4 fw-semibold">@Model.SegmentSummary.MissingDescriptionCount</div></div></div>
</div>

<div class="card mb-3">
    <div class="card-header">Segment Ops Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("Segments", "Crm")"
      hx-target="#crm-segments-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="col-md-4">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search segments" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Segments" asp-route-filter="Empty" hx-get="@Url.Action("Segments", "Crm", new { q = Model.Query, filter = "Empty" })" hx-target="#crm-segments-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-warning">Empty</a>
    <a asp-action="Segments" asp-route-filter="InUse" hx-get="@Url.Action("Segments", "Crm", new { q = Model.Query, filter = "InUse" })" hx-target="#crm-segments-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">In Use</a>
    <a asp-action="Segments" asp-route-filter="MissingDescription" hx-get="@Url.Action("Segments", "Crm", new { q = Model.Query, filter = "MissingDescription" })" hx-target="#crm-segments-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">Missing Description</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th class="text-end">Members</th>
                <th>Status</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted">No segments found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td class="text-end">@item.MemberCount</td>
                        <td>
                            @if (item.MemberCount > 0)
                            {
                                <span class="badge text-bg-primary">In use</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning">Empty</span>
                            }
                            @if (!item.HasDescription)
                            {
                                <div><span class="badge text-bg-secondary mt-1">Missing description</span></div>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="EditSegment" asp-route-id="@item.Id" hx-get="@Url.Action("EditSegment", "Crm", new { id = item.Id })" hx-target="#crm-segments-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Segments"
       asp-route-q="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#crm-segments-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
