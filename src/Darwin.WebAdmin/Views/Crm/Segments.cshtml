@model Darwin.WebAdmin.ViewModels.CRM.CustomerSegmentsListVm
@{
    ViewData["Title"] = "Customer Segments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Customer Segments</h1>
    <a asp-action="CreateSegment" class="btn btn-primary">
        <i class="fa fa-plus"></i> New Segment
    </a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search segments" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th class="text-end">Members</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="4" class="text-center text-muted">No segments found.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Description</td>
                        <td class="text-end">@item.MemberCount</td>
                        <td class="text-end">
                            <a asp-action="EditSegment" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Crm"
       asp-action="Segments"
       asp-route-q="@Model.Query">
</pager>
