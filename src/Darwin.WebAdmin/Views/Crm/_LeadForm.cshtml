@model Darwin.WebAdmin.ViewModels.CRM.LeadEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var leadStatusOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.LeadStatus>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) }); }

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("CrmLeadIdentitySection")</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <field-help title="@T.T("FirstName")" content="@T.T("CrmLeadFirstNameHelp")" placement="right"></field-help>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <field-help title="@T.T("LastName")" content="@T.T("CrmLeadLastNameHelp")" placement="right"></field-help>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="CompanyName" class="form-label"></label>
            <field-help title="@T.T("CompanyName")" content="@T.T("CrmLeadCompanyNameHelp")" placement="right"></field-help>
            <input asp-for="CompanyName" class="form-control" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Status" class="form-label"></label>
            <field-help title="@T.T("Status")" content="@T.T("CrmLeadStatusHelp")" placement="right"></field-help>
            <select asp-for="Status" asp-items="leadStatusOptions" class="form-select"></select>
        </div>
    </div>
</section>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("CrmLeadContactOwnershipSection")</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <field-help title="@T.T("Email")" content="@T.T("CrmLeadEmailHelp")" placement="right"></field-help>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Phone" class="form-label"></label>
            <field-help title="@T.T("Phone")" content="@T.T("CrmLeadPhoneHelp")" placement="right"></field-help>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="AssignedToUserId" class="form-label"></label>
            <field-help title="@T.T("AssignedTo")" content="@T.T("CrmLeadAssignedToHelp")" placement="right"></field-help>
            <select asp-for="AssignedToUserId" asp-items="Model.UserOptions" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="CustomerId" class="form-label"></label>
            <field-help title="@T.T("Customer")" content="@T.T("CrmLeadCustomerHelp")" placement="right"></field-help>
            <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="Source" class="form-label"></label>
            <field-help title="@T.T("Source")" content="@T.T("CrmLeadSourceHelp")" placement="right"></field-help>
            <input asp-for="Source" class="form-control" />
            <span asp-validation-for="Source" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label"></label>
            <field-help title="@T.T("Notes")" content="@T.T("CrmLeadNotesHelp")" placement="right"></field-help>
            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>
    </div>
</section>
