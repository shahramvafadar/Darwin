@model Darwin.WebAdmin.ViewModels.CRM.CustomerEditVm
@{
    ViewData["Title"] = "Edit Customer";
}

<h1 class="mb-3">Edit Customer</h1>

<form asp-action="EditCustomer" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <partial name="_CustomerForm" model="Model" />
    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> Save</button>
        <a asp-action="Customers" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const container = document.getElementById('customerAddresses');
            const template = document.getElementById('customerAddressTemplate');
            document.getElementById('addCustomerAddress')?.addEventListener('click', function () {
                container.insertAdjacentHTML('beforeend', template.innerHTML.replaceAll('__index__', container.querySelectorAll('.address-row').length));
            });
            container?.addEventListener('click', function (event) {
                const button = event.target.closest('.remove-address');
                if (button) button.closest('.address-row')?.remove();
            });
        })();
    </script>
}
