@model Darwin.WebAdmin.ViewModels.CRM.CustomerEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditCustomer");
}

@{
    ViewData["FormAction"] = "EditCustomer";
}
<partial name="~/Views/Crm/_CustomerEditorShell.cshtml" model="Model" />

<hr class="my-4" />

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header"><strong>@T.T("AddInteraction")</strong></div>
            <div class="card-body">
                <form asp-controller="Crm"
                      asp-action="CustomerInteractions"
                      method="post"
                      hx-post="@Url.Action("CustomerInteractions", "Crm")"
                      hx-target="#customer-interactions-grid"
                      hx-swap="innerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerId" value="@Model.Id" />
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Type")</label>
                        <select name="Type" class="form-select" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionType>()"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Channel")</label>
                        <select name="Channel" class="form-select" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.InteractionChannel>()"></select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">@T.T("Subject")</label>
                        <input name="Subject" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">@T.T("Content")</label>
                        <textarea name="Content" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Owner")</label>
                        <select name="UserId" class="form-select" asp-items="Model.NewInteraction.UserOptions"></select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">@T.T("AddInteraction")</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card mt-3" id="customer-interactions-section">
            <div class="card-header"><strong>@T.T("Interactions")</strong></div>
            <div class="card-body" id="customer-interactions-grid"
                 hx-get="@Url.Action("CustomerInteractions", "Crm", new { customerId = Model.Id })"
                 hx-trigger="load"
                 hx-swap="innerHTML"></div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header"><strong>@T.T("RecordConsent")</strong></div>
            <div class="card-body">
                <form asp-controller="Crm"
                      asp-action="CustomerConsents"
                      method="post"
                      hx-post="@Url.Action("CustomerConsents", "Crm")"
                      hx-target="#customer-consents-grid"
                      hx-swap="innerHTML"
                      class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerId" value="@Model.Id" />
                    <div class="col-md-6">
                        <label class="form-label">@T.T("ConsentType")</label>
                        <select name="Type" class="form-select" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.ConsentType>()"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Status")</label>
                        <select name="Granted" class="form-select">
                            <option value="true">@T.T("Granted")</option>
                            <option value="false">@T.T("Revoked")</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("GrantedAtUtc")</label>
                        <input name="GrantedAtUtc" type="datetime-local" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T.T("RevokedAtUtc")</label>
                        <input name="RevokedAtUtc" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary">@T.T("RecordConsent")</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card mt-3" id="customer-consents-section">
            <div class="card-header"><strong>@T.T("ConsentHistory")</strong></div>
            <div class="card-body" id="customer-consents-grid"
                 hx-get="@Url.Action("CustomerConsents", "Crm", new { customerId = Model.Id })"
                 hx-trigger="load"
                 hx-swap="innerHTML"></div>
        </div>
    </div>

    <div class="col-12">
        <div class="card" id="customer-segments-section">
            <div class="card-header"><strong>@T.T("SegmentMemberships")</strong></div>
            <div class="card-body">
                <form asp-controller="Crm"
                      asp-action="CustomerSegmentMemberships"
                      method="post"
                      hx-post="@Url.Action("CustomerSegmentMemberships", "Crm")"
                      hx-target="#customer-segments-grid"
                      hx-swap="innerHTML"
                      class="row g-3 mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerId" value="@Model.Id" />
                    <div class="col-md-6">
                        <label class="form-label">@T.T("Segment")</label>
                        <select name="CustomerSegmentId" class="form-select" asp-items="Model.SegmentOptions"></select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-outline-primary">@T.T("AssignSegment")</button>
                    </div>
                </form>
                <div id="customer-segments-grid"
                     hx-get="@Url.Action("CustomerSegmentMemberships", "Crm", new { customerId = Model.Id })"
                     hx-trigger="load"
                     hx-swap="innerHTML"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
