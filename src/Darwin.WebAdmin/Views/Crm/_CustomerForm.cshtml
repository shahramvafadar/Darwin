@using Darwin.Application.Settings.DTOs
@model Darwin.WebAdmin.ViewModels.CRM.CustomerEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
    var customerTaxProfileTypeOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.CustomerTaxProfileType>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) });
}

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("CrmCustomerIdentitySection")</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="UserId" class="form-label"></label>
            <field-help title="@T.T("User")" content="@T.T("CrmCustomerLinkedUserHelp")" placement="right"></field-help>
            <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select>
        </div>

        <div class="col-md-6">
            <label asp-for="CompanyName" class="form-label"></label>
            <field-help title="@T.T("CompanyName")" content="@T.T("CrmCustomerCompanyNameHelp")" placement="right"></field-help>
            <input asp-for="CompanyName" class="form-control" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <field-help title="@T.T("FirstName")" content="@T.T("CrmCustomerFirstNameHelp")" placement="right"></field-help>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <field-help title="@T.T("LastName")" content="@T.T("CrmCustomerLastNameHelp")" placement="right"></field-help>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>
</section>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("CrmCustomerTaxContactSection")</h2>
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="TaxProfileType" class="form-label"></label>
            <field-help title="@T.T("TaxProfile")" content="@T.T("CrmCustomerTaxProfileHelp")" placement="right"></field-help>
            <select asp-for="TaxProfileType" asp-items="customerTaxProfileTypeOptions" class="form-select"></select>
            <span asp-validation-for="TaxProfileType" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="VatId" class="form-label"></label>
            <field-help title="@T.T("CustomerVatId")" content="@T.T("CrmCustomerVatIdHelp")" placement="right"></field-help>
            <input asp-for="VatId" class="form-control" />
            <span asp-validation-for="VatId" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Email" class="form-label"></label>
            <field-help title="@T.T("Email")" content="@T.T("CrmCustomerEmailHelp")" placement="right"></field-help>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Phone" class="form-label"></label>
            <field-help title="@T.T("Phone")" content="@T.T("CrmCustomerPhoneHelp")" placement="right"></field-help>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Notes" class="form-label"></label>
            <field-help title="@T.T("Notes")" content="@T.T("CrmCustomerNotesHelp")" placement="right"></field-help>
            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.EffectiveEmail) || !string.IsNullOrWhiteSpace(Model.EffectiveFirstName))
{
    <div class="alert alert-info mt-4 mb-0">
        <strong>@T.T("EffectiveProfile")</strong><br />
        @T.T("Name"): @($"{Model.EffectiveFirstName} {Model.EffectiveLastName}".Trim())<br />
        @T.T("Email"): @Model.EffectiveEmail<br />
        @T.T("Phone"): @Model.EffectivePhone<br />
        @T.T("TaxProfile"): @LocalizeCustomerTaxProfileType(Model.TaxProfileType)
        @if (!string.IsNullOrWhiteSpace(Model.VatId))
        {
            <><br />@T.T("TaxId"): @Model.VatId</>
        }
    </div>
}

<div class="d-flex justify-content-between align-items-center mt-4">
    <h3 class="mb-0">@T.T("CrmAddresses") <field-help title="@T.T("CrmAddresses")" content="@T.T("CrmCustomerAddressesHelp")" placement="right"></field-help></h3>
    <button type="button"
            class="btn btn-outline-secondary btn-sm"
            id="addCustomerAddress"
            data-dynamic-lines-add
            data-dynamic-lines-container="#customerAddresses"
            data-dynamic-lines-template="#customerAddressTemplate"
            data-dynamic-lines-row=".address-row">
        <i class="fa fa-plus"></i> @T.T("AddAddress")
    </button>
</div>

<div id="customerAddresses" class="mt-3">
@for (var i = 0; i < Model.Addresses.Count; i++)
{
    <div class="card mb-3 address-row">
        <div class="card-body">
            <input type="hidden" asp-for="Addresses[i].Id" />
            <input type="hidden" asp-for="Addresses[i].AddressId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Addresses[i].Line1" class="form-label"></label>
                    <input asp-for="Addresses[i].Line1" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Addresses[i].Line2" class="form-label"></label>
                    <input asp-for="Addresses[i].Line2" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Addresses[i].PostalCode" class="form-label"></label>
                    <input asp-for="Addresses[i].PostalCode" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Addresses[i].City" class="form-label"></label>
                    <input asp-for="Addresses[i].City" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Addresses[i].State" class="form-label"></label>
                    <input asp-for="Addresses[i].State" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Addresses[i].Country" class="form-label"></label>
                    <input asp-for="Addresses[i].Country" class="form-control" />
                </div>
                <div class="col-md-4">
                    <div class="form-check mt-4 pt-2">
                        <input asp-for="Addresses[i].IsDefaultBilling" class="form-check-input" />
                        <label asp-for="Addresses[i].IsDefaultBilling" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check mt-4 pt-2">
                        <input asp-for="Addresses[i].IsDefaultShipping" class="form-check-input" />
                        <label asp-for="Addresses[i].IsDefaultShipping" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="text-end mt-3">
                <button type="button" class="btn btn-sm btn-outline-danger remove-address" data-dynamic-lines-remove data-dynamic-lines-row=".address-row">@T.T("Remove")</button>
            </div>
        </div>
    </div>
}
</div>

<template id="customerAddressTemplate">
    <div class="card mb-3 address-row"><div class="card-body">
        <input type="hidden" name="Addresses[__index__].Id" value="" />
        <input type="hidden" name="Addresses[__index__].AddressId" value="" />
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">@T.T("AddressLine1")</label><input class="form-control" name="Addresses[__index__].Line1" /></div>
            <div class="col-md-6"><label class="form-label">@T.T("AddressLine2")</label><input class="form-control" name="Addresses[__index__].Line2" /></div>
            <div class="col-md-4"><label class="form-label">@T.T("PostalCode")</label><input class="form-control" name="Addresses[__index__].PostalCode" /></div>
            <div class="col-md-4"><label class="form-label">@T.T("City")</label><input class="form-control" name="Addresses[__index__].City" /></div>
            <div class="col-md-4"><label class="form-label">@T.T("State")</label><input class="form-control" name="Addresses[__index__].State" /></div>
            <div class="col-md-4"><label class="form-label">@T.T("Country")</label><input class="form-control" name="Addresses[__index__].Country" value="@SiteSettingDto.DefaultCountryDefault" /></div>
            <div class="col-md-4"><div class="form-check mt-4 pt-2"><input class="form-check-input" type="checkbox" value="true" name="Addresses[__index__].IsDefaultBilling" /><input type="hidden" name="Addresses[__index__].IsDefaultBilling" value="false" /><label class="form-check-label">@T.T("DefaultBilling")</label></div></div>
            <div class="col-md-4"><div class="form-check mt-4 pt-2"><input class="form-check-input" type="checkbox" value="true" name="Addresses[__index__].IsDefaultShipping" /><input type="hidden" name="Addresses[__index__].IsDefaultShipping" value="false" /><label class="form-check-label">@T.T("DefaultShipping")</label></div></div>
        </div>
        <div class="text-end mt-3"><button type="button" class="btn btn-sm btn-outline-danger remove-address" data-dynamic-lines-remove data-dynamic-lines-row=".address-row">@T.T("Remove")</button></div>
    </div></div>
</template>
