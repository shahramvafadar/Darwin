@model Darwin.WebAdmin.ViewModels.CRM.CustomerSegmentEditVm
@{
    var actionName = ViewData["FormAction"] as string ?? "EditSegment";
    var isCreate = string.Equals(actionName, "CreateSegment", StringComparison.Ordinal);
    ViewData["Title"] = isCreate ? "Create Segment" : "Edit Segment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">@(isCreate ? "Create Segment" : "Edit Segment")</h1>
        <div class="text-muted">Customer segmentation taxonomy and targeting hygiene.</div>
    </div>
</div>

<partial name="_SegmentForm" model="Model" />
