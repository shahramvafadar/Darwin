@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@*
    Generic confirmation modal for destructive actions (delete).
    - Accessible & mobile-friendly (Bootstrap).
    - Accepts:
        data-action (absolute/relative POST url)  OR
        data-area + data-controller + data-action (to compose url)
      and also:
        data-id (Guid)
        data-rowversion (base64)
        data-name (display text)
*@

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmDeleteTitle">@T.T("ConfirmDeleteTitle")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@T.T("Close")"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">@T.T("ConfirmDeleteWarning")</p>
                <p class="fw-semibold mb-0">
                    @T.T("ConfirmDeleteItemLabel"): <span id="confirmDeleteName" class="text-danger"></span>
                </p>
            </div>

            <div class="modal-footer">
                <form id="confirmDeleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="confirmDeleteId" />
                    <input type="hidden" name="rowVersion" id="confirmDeleteRowVersion" />
                    <input type="hidden" name="userId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@T.T("Cancel")</button>
                    <button type="submit" class="btn btn-danger">@T.T("Delete")</button>
                </form>
            </div>
        </div>
    </div>
</div>
