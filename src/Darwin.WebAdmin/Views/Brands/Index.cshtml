@model Darwin.WebAdmin.ViewModels.Catalog.BrandsListVm
@{
    ViewData["Title"] = T.T("Brands");
}

<div id="brands-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
    <div>
        <h1 class="m-0">@T.T("Brands")</h1>
        <div class="small text-muted mt-1">@T.T("BrandsWorkspaceIntro")</div>
    </div>
    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <form asp-action="Index" method="get" class="d-flex gap-2"
              hx-get="@Url.Action("Index", "Brands")"
              hx-target="#brands-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchBrandsPlaceholder")">
            <input type="hidden" name="filter" value="@Model.Filter">
            <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
            <a asp-action="Index" class="btn btn-outline-secondary"
               hx-get="@Url.Action("Index", "Brands")"
               hx-target="#brands-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Reset")</a>
        </form>

        <a asp-action="Create" class="btn btn-primary"
           hx-get="@Url.Action("Create", "Brands")"
           hx-target="#brands-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-plus"></i> @T.T("CreateBrand")
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Brands")</div><div class="display-6 fw-semibold mt-1">@Model.Summary.TotalCount</div><div class="small text-muted mt-2">@T.T("BrandsOpsTotalNote")</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Unpublished")</div><div class="display-6 fw-semibold mt-1">@Model.Summary.UnpublishedCount</div><div class="small text-muted mt-2">@T.T("BrandsOpsUnpublishedNote")</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("MissingSlug")</div><div class="display-6 fw-semibold mt-1">@Model.Summary.MissingSlugCount</div><div class="small text-muted mt-2">@T.T("BrandsOpsMissingSlugNote")</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("MissingLogo")</div><div class="display-6 fw-semibold mt-1">@Model.Summary.MissingLogoCount</div><div class="small text-muted mt-2">@T.T("BrandsOpsMissingLogoNote")</div></div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" asp-route-query="@Model.Query" class="btn @(string.IsNullOrEmpty(Model.Filter) ? "btn-primary" : "btn-outline-primary")"
               hx-get="@Url.Action("Index", "Brands", new { query = Model.Query })" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("All")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="unpublished" class="btn @(Model.Filter == "unpublished" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@Url.Action("Index", "Brands", new { query = Model.Query, filter = "unpublished" })" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Unpublished")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="missing-slug" class="btn @(Model.Filter == "missing-slug" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@Url.Action("Index", "Brands", new { query = Model.Query, filter = "missing-slug" })" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MissingSlug")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="missing-logo" class="btn @(Model.Filter == "missing-logo" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@Url.Action("Index", "Brands", new { query = Model.Query, filter = "missing-logo" })" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MissingLogo")</a>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h6 mb-3">@T.T("BrandOperationsPlaybooks")</h2>
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@playbook.QueueLabel</div>
                        <div class="small text-muted mt-2">@playbook.WhyItMatters</div>
                        <div class="small mt-2"><strong>@T.T("OperatorAction"):</strong> @playbook.OperatorAction</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Slug")</th>
                <th>@T.T("Published")</th>
                <th>@T.T("Logo")</th>
                <th>@T.T("Modified")</th>
                <th class="text-end" style="width:220px;">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items?.Count > 0)
            {
                foreach (var b in Model.Items)
                {
                    <tr>
                        <td>@b.Name</td>
                        <td>@(string.IsNullOrWhiteSpace(b.Slug) ? "-" : b.Slug)</td>
                        <td>
                            @if (b.IsPublished)
                            {
                                <span class="badge bg-success">@T.T("Yes")</span>
                            }
                            else
                            {
                                <span class="badge bg-outline-secondary border">@T.T("No")</span>
                            }
                        </td>
                        <td>
                            @if (b.LogoMediaId != null)
                            {
                                <span class="badge bg-success">@T.T("Configured")</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@T.T("Missing")</span>
                            }
                        </td>
                        <td>@b.ModifiedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "Brands", new { id = b.Id })"
                               hx-target="#brands-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-pen"></i> @T.T("Edit")
                            </a>

                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#confirmDeleteModal"
                                    data-action="@Url.Action("Delete", "Brands")"
                                    data-id="@b.Id"
                                    data-name="@b.Name"
                                    data-rowversion="@Convert.ToBase64String(b.RowVersion)"
                                    data-hx-target="#brands-workspace-shell"
                                    data-hx-swap="outerHTML"
                                    data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                                <i class="fa fa-trash"></i> @T.T("Delete")
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted">@T.T("NoBrandsFound")</td></tr>
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Brands"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#brands-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
