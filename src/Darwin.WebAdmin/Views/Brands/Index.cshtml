@model Darwin.WebAdmin.ViewModels.Catalog.BrandsListVm
@using System.Globalization
@{
    ViewData["Title"] = T.T("Brands");
    string BrandsIndexUrl(string? query = null, string? filter = null) => Url.Action("Index", "Brands", new { query, filter }) ?? string.Empty;
    string BrandsCreateUrl() => Url.Action("Create", "Brands") ?? string.Empty;
    string BrandsEditUrl(Guid id) => Url.Action("Edit", "Brands", new { id }) ?? string.Empty;
}

<div id="brands-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
    <div>
        <h1 class="m-0">@T.T("Brands")</h1>
        <div class="small text-muted mt-1">@T.T("BrandsWorkspaceIntro")</div>
    </div>
    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <form asp-action="Index" method="get" class="d-flex gap-2"
              hx-get="@BrandsIndexUrl()"
              hx-target="#brands-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchBrandsPlaceholder")">
            <input type="hidden" name="filter" value="@Model.Filter">
            <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-search"></i> @T.T("Search")</button>
            <a asp-action="Index" class="btn btn-outline-secondary"
               hx-get="@BrandsIndexUrl()"
               hx-target="#brands-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Reset")</a>
        </form>

        <a asp-action="Create" class="btn btn-primary"
           hx-get="@BrandsCreateUrl()"
           hx-target="#brands-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-plus"></i> @T.T("CreateBrand")
        </a>
    </div>
</div>

<div class="admin-kpi-row mb-4">
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("Brands") <field-help title="@T.T("Brands")" content="@T.T("BrandsOpsTotalNote")" placement="right"></field-help></div><div class="fs-4 fw-semibold mt-1">@Model.Summary.TotalCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("Unpublished") <field-help title="@T.T("Unpublished")" content="@T.T("BrandsOpsUnpublishedNote")" placement="right"></field-help></div><div class="fs-4 fw-semibold mt-1">@Model.Summary.UnpublishedCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MissingSlug") <field-help title="@T.T("MissingSlug")" content="@T.T("BrandsOpsMissingSlugNote")" placement="right"></field-help></div><div class="fs-4 fw-semibold mt-1">@Model.Summary.MissingSlugCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MissingLogo") <field-help title="@T.T("MissingLogo")" content="@T.T("BrandsOpsMissingLogoNote")" placement="right"></field-help></div><div class="fs-4 fw-semibold mt-1">@Model.Summary.MissingLogoCount</div></div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" asp-route-query="@Model.Query" class="btn @(string.IsNullOrEmpty(Model.Filter) ? "btn-primary" : "btn-outline-primary")"
               hx-get="@BrandsIndexUrl(Model.Query)" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("All")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="unpublished" class="btn @(Model.Filter == "unpublished" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@BrandsIndexUrl(Model.Query, "unpublished")" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Unpublished")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="missing-slug" class="btn @(Model.Filter == "missing-slug" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@BrandsIndexUrl(Model.Query, "missing-slug")" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MissingSlug")</a>
            <a asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="missing-logo" class="btn @(Model.Filter == "missing-logo" ? "btn-primary" : "btn-outline-primary")"
               hx-get="@BrandsIndexUrl(Model.Query, "missing-logo")" hx-target="#brands-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MissingLogo")</a>
        </div>
    </div>
    <div class="col-lg-4">
        <details class="admin-playbook h-100">
            <summary>@T.T("BrandOperationsPlaybooks")</summary>
            <div class="admin-playbook-body">
            <div class="d-grid gap-3">
                @foreach (var playbook in Model.Playbooks)
                {
                    <div class="rounded border p-3 bg-light-subtle">
                        <div class="fw-semibold">@playbook.QueueLabel</div>
                        <div class="small text-muted mt-2">@playbook.WhyItMatters</div>
                        <div class="small mt-2"><strong>@T.T("OperatorAction"):</strong> @playbook.OperatorAction</div>
                    </div>
                }
            </div>
            </div>
        </details>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Slug")</th>
                <th>@T.T("Published")</th>
                <th>@T.T("Logo")</th>
                <th>@T.T("Modified")</th>
                    <th class="text-end admin-w-220">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items?.Count > 0)
            {
                foreach (var b in Model.Items)
                {
                    <tr>
                        <td>@b.Name</td>
                        <td>@(string.IsNullOrWhiteSpace(b.Slug) ? "-" : b.Slug)</td>
                        <td>
                            @if (b.IsPublished)
                            {
                                <span class="badge bg-success">@T.T("Yes")</span>
                            }
                            else
                            {
                                <span class="badge bg-outline-secondary border">@T.T("No")</span>
                            }
                        </td>
                        <td>
                            @if (b.LogoMediaId != null)
                            {
                                <span class="badge bg-success">@T.T("Configured")</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@T.T("Missing")</span>
                            }
                        </td>
                        <td>@b.ModifiedAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary"
                               hx-get="@BrandsEditUrl(b.Id)"
                               hx-target="#brands-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-pen"></i> @T.T("Edit")
                            </a>

                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#confirmDeleteModal"
                                    data-action="@Url.Action("Delete", "Brands")"
                                    data-id="@b.Id"
                                    data-name="@b.Name"
                                    data-rowversion="@Convert.ToBase64String(b.RowVersion)"
                                    data-hx-target="#brands-workspace-shell"
                                    data-hx-swap="outerHTML"
                                   >
                                <i class="fa fa-trash"></i> @T.T("Delete")
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted">@T.T("NoBrandsFound")</td></tr>
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Brands"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#brands-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
