@model Darwin.WebAdmin.ViewModels.Catalog.BrandEditVm
@{
    string BrandsIndexUrl() => Url.Action("Index", "Brands") ?? string.Empty;
}

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <section class="admin-form-section">
            <h2 class="admin-form-section-title">@T.T("BrandIdentity")</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Slug" class="form-label">@T.T("Slug")</label>
                    <field-help title="@T.T("Slug")" content="@T.T("BrandSlugHelp")" placement="right"></field-help>
                    <input asp-for="Slug" class="form-control" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LogoMediaId" class="form-label">@T.T("LogoMediaId")</label>
                    <field-help title="@T.T("LogoMediaId")" content="@T.T("BrandLogoHelp")" placement="right"></field-help>
                    <input asp-for="LogoMediaId" class="form-control" />
                    <span asp-validation-for="LogoMediaId" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="admin-form-section">
            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                <h2 class="admin-form-section-title mb-0">@T.T(Model.MultilingualEnabled ? "Translations" : "DefaultLanguageContent")</h2>
                <span class="badge text-bg-light border">
                    @(Model.MultilingualEnabled ? T.T("MultilingualContentMode") : T.T("SingleLanguageContentMode"))
                </span>
            </div>

            @for (int i = 0; i < Model.Translations.Count; i++)
            {
                <div class="border rounded p-3 mb-3">
                    <input type="hidden" asp-for="Translations[i].Id" />
                    @if (!Model.MultilingualEnabled)
                    {
                        <input type="hidden" asp-for="Translations[i].Culture" />
                    }
                    <div class="row g-3">
                        @if (Model.MultilingualEnabled)
                        {
                            <div class="col-md-2">
                                <label asp-for="Translations[i].Culture" class="form-label">@T.T("Culture")</label>
                                <field-help title="@T.T("Culture")" content="@T.T("BrandCultureHelp")" placement="right"></field-help>
                                <input asp-for="Translations[i].Culture" class="form-control" />
                                <span asp-validation-for="Translations[i].Culture" class="text-danger"></span>
                            </div>
                        }
                        <div class="@(Model.MultilingualEnabled ? "col-md-4" : "col-md-6")">
                            <label asp-for="Translations[i].Name" class="form-label">@T.T("Name")</label>
                            <field-help title="@T.T("Name")" content="@T.T("BrandNameHelp")" placement="right"></field-help>
                            <input asp-for="Translations[i].Name" class="form-control" />
                            <span asp-validation-for="Translations[i].Name" class="text-danger"></span>
                        </div>
                        <div class="@(Model.MultilingualEnabled ? "col-md-6" : "col-md-6")">
                            <label asp-for="Translations[i].DescriptionHtml" class="form-label">@T.T("DescriptionHtml")</label>
                            <field-help title="@T.T("DescriptionHtml")" content="@T.T("BrandDescriptionHelp")" placement="right"></field-help>
                            <textarea asp-for="Translations[i].DescriptionHtml" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Translations[i].DescriptionHtml" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            }
        </section>
    </div>

    <div class="card-footer text-end">
        <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@BrandsIndexUrl()"
           hx-target="#brands-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Back")</a>
    </div>
</div>
