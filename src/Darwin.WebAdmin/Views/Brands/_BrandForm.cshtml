@model Darwin.WebAdmin.ViewModels.Catalog.BrandEditVm

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Slug" class="form-label">@T.T("Slug")</label>
                <input asp-for="Slug" class="form-control" />
                <span class="form-text">@T.T("BrandSlugHelp")</span>
                <span asp-validation-for="Slug" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LogoMediaId" class="form-label">@T.T("LogoMediaId")</label>
                <input asp-for="LogoMediaId" class="form-control" />
                <span class="form-text">@T.T("BrandLogoHelp")</span>
                <span asp-validation-for="LogoMediaId" class="text-danger"></span>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><strong>@T.T("Translations")</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    @for (int i = 0; i < Model.Translations.Count; i++)
                    {
                        <div class="col-12 border-bottom pb-3 mb-3">
                            <div class="row g-2">
                                <div class="col-md-2">
                                    <label asp-for="Translations[i].Culture" class="form-label">@T.T("Culture")</label>
                                    <input asp-for="Translations[i].Culture" class="form-control" />
                                    <span class="form-text">@T.T("BrandCultureHelp")</span>
                                    <span asp-validation-for="Translations[i].Culture" class="text-danger"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Translations[i].Name" class="form-label">@T.T("Name")</label>
                                    <input asp-for="Translations[i].Name" class="form-control" />
                                    <span asp-validation-for="Translations[i].Name" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Translations[i].DescriptionHtml" class="form-label">@T.T("DescriptionHtml")</label>
                                    <textarea asp-for="Translations[i].DescriptionHtml" class="form-control" rows="3"></textarea>
                                    <span class="form-text">@T.T("BrandDescriptionHelp")</span>
                                    <span asp-validation-for="Translations[i].DescriptionHtml" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer text-end">
        <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Brands")"
           hx-target="#brands-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Back")</a>
    </div>
</div>
