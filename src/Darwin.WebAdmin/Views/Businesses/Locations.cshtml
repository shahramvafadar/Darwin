@model Darwin.WebAdmin.ViewModels.Businesses.BusinessLocationsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessLocationsTitle");
    string GlobalBusinessLocationsUrl() => Url.Action("Locations", "Businesses") ?? string.Empty;
    string BusinessEditUrl(Guid? id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string CreateLocationUrl(Guid? businessId, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter? filter) =>
        Url.Action("CreateLocation", "Businesses", new { businessId, page, pageSize, query, filter }) ?? string.Empty;
    string BusinessLocationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter? filter = null) =>
        Url.Action("Locations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string EditLocationUrl(Guid id, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter? filter) =>
        Url.Action("EditLocation", "Businesses", new { id, page, pageSize, query, filter }) ?? string.Empty;
    string InvitationWorkspaceLabel() => T.T("Invitations");
}

<div id="business-locations-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-location-dot me-2"></i>@T.T("BusinessLocationsTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit"
           asp-route-id="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessEditUrl(Model.Business.Id)"
           hx-target="#business-locations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@(Model.Business.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           class="btn btn-outline-secondary"
           hx-get="@BusinessInvitationsUrl(Model.Business.Id, Model.Business.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           hx-target="#business-locations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@InvitationWorkspaceLabel()</a>
        <a asp-action="CreateLocation"
           asp-route-businessId="@Model.Business.Id"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-primary"
           hx-get="@CreateLocationUrl(Model.Business.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
           hx-target="#business-locations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-plus"></i> @T.T("BusinessLocationsAddLocationAction")
        </a>
    </div>
</div>

<form method="get"
      class="row g-2 mb-3"
          hx-get="@GlobalBusinessLocationsUrl()"
      hx-target="#business-locations-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessLocationsSearchPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Locations"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessLocationsUrl(Model.Business.Id)"
           hx-target="#business-locations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("Total")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            <div class="mt-2">
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Business.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessLocationsUrl(Model.Business.Id)"
                   hx-target="#business-locations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Total")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("Primary")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PrimaryCount</div>
            <div class="mt-2">
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.Primary"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessLocationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.Primary)"
                   hx-target="#business-locations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Primary")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("MissingAddress")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingAddressCount</div>
            <div class="mt-2">
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.MissingAddress"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessLocationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.MissingAddress)"
                   hx-target="#business-locations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MissingAddress")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("BusinessLocationsMissingCoordinatesLabel")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingCoordinatesCount</div>
            <div class="mt-2">
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.MissingCoordinates"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessLocationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessLocationQueueFilter.MissingCoordinates)"
                   hx-target="#business-locations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessLocationsMissingCoordinatesLabel")</a>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessLocationsPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-locations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.QueueLabel</a>
                        </td>
                        <td>
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-locations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.WhyItMatters</a>
                        </td>
                        <td>
                            <div class="mb-2">
                                <a href="@playbook.QueueActionUrl"
                                   class="link-body-emphasis text-decoration-none"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-locations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.OperatorAction</a>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-locations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueLabel</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("City")</th>
                <th>@T.T("Region")</th>
                <th>@T.T("Country")</th>
                <th class="text-center">@T.T("Primary")</th>
                        <th class="text-end admin-w-240">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <div>@T.T("BusinessLocationsEmptyState")</div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center mt-3">
                        <a asp-action="CreateLocation"
                           asp-route-businessId="@Model.Business.Id"
                           asp-route-page="@Model.Page"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-query="@Model.Query"
                           asp-route-filter="@Model.Filter"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CreateLocationUrl(Model.Business.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessLocationsAddLocationAction")</a>
                        <a asp-action="Setup"
                           asp-route-id="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSetupUrl(Model.Business.Id)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Setup")</a>
                        <a asp-action="MerchantReadiness"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@(item.City ?? "-")</td>
                    <td>@(item.Region ?? "-")</td>
                    <td>@(item.CountryCode ?? "-")</td>
                    <td class="text-center">
                        @if (item.IsPrimary)
                        {
                            <span class="badge text-bg-success">@T.T("Primary")</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (!item.HasAddress)
                        {
                            <span class="badge text-bg-warning me-1">@T.T("BusinessLocationsAddressMissingBadge")</span>
                        }
                        @if (!item.HasCoordinates)
                        {
                            <span class="badge text-bg-secondary me-1">@T.T("BusinessLocationsCoordinatesMissingBadge")</span>
                        }
                        <a asp-action="EditLocation"
                           asp-route-id="@item.Id"
                           asp-route-page="@Model.Page"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-query="@Model.Query"
                           asp-route-filter="@Model.Filter"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@EditLocationUrl(item.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-pen"></i> @T.T("CommonEdit")
                        </a>
                        <a asp-action="Setup"
                           asp-route-id="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSetupUrl(Model.Business.Id)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-list-check"></i> @T.T("Setup")
                        </a>
                        <a asp-action="MerchantReadiness"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
                           hx-target="#business-locations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-clipboard-check"></i> @T.T("MerchantReadinessTitle")
                        </a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#confirmDeleteModal"
                                data-action="@Url.Action("DeleteLocation", "Businesses")"
                                data-id="@item.Id"
                                data-name="@item.Name"
                                data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                data-userid="@Model.Business.Id"
                                data-hx-target="#business-locations-workspace-shell"
                                data-hx-swap="outerHTML"
                                               >
                            <i class="fa-solid fa-box-archive"></i> @T.T("Archive")
                        </button>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Locations"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#business-locations-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>

