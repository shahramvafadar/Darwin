@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    ViewData["Title"] = isCreate ? "Create Business" : "Edit Business";
}

<div id="business-editor-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@(isCreate ? "Create Business" : "Edit Business")</h1>
            <p class="text-muted mb-0">Tenant setup starts here. After saving, continue with owner assignment and primary location.</p>
        </div>
        @if (!isCreate)
        {
            <div class="d-flex gap-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-user-group"></i> Members
                </a>
                <a asp-action="Subscription"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-credit-card"></i> Subscription
                </a>
                <a asp-action="Setup"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-sliders"></i> Setup
                </a>
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Locations", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-location-dot"></i> Locations
                </a>
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-envelope"></i> Invitations
                </a>
            </div>
        }
    </div>

    @if (!isCreate)
    {
        var checklistComplete = Model.ActiveOwnerCount > 0 &&
                                Model.PrimaryLocationCount > 0 &&
                                Model.HasContactEmailConfigured &&
                                Model.HasLegalNameConfigured;

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Owners</div>
                    <div class="fs-4 fw-semibold">@Model.ActiveOwnerCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Members</div>
                    <div class="fs-4 fw-semibold">@Model.MemberCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Locations</div>
                    <div class="fs-4 fw-semibold">@Model.LocationCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Pending Invites</div>
                    <div class="fs-4 fw-semibold">@Model.InvitationCount</div>
                </div>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">Operational Status</div>
                    @if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                    {
                        <span class="badge text-bg-warning">Pending approval</span>
                    }
                    else if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved)
                    {
                        <span class="badge text-bg-success">Approved</span>
                    }
                    else
                    {
                        <span class="badge text-bg-danger">Suspended</span>
                    }

                    @if (Model.ApprovedAtUtc.HasValue)
                    {
                        <div class="small text-muted mt-2">Approved at @Model.ApprovedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</div>
                    }

                    @if (Model.SuspendedAtUtc.HasValue)
                    {
                        <div class="small text-muted mt-1">Suspended at @Model.SuspendedAtUtc.Value.ToString("yyyy-MM-dd HH:mm") UTC</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SuspensionReason))
                    {
                        <div class="small text-muted mt-1">Reason: @Model.SuspensionReason</div>
                    }
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <button type="submit" class="btn btn-success">Approve</button>
                        </form>
                    }
                    else if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Reactivate" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <button type="submit" class="btn btn-success">Reactivate</button>
                        </form>
                    }

                    @if (Model.OperationalStatus != Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Suspend" method="post" class="d-flex gap-2 flex-wrap">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <input type="text" name="note" class="form-control" style="min-width: 240px;" placeholder="Optional suspension reason" />
                            <button type="submit" class="btn btn-outline-danger">Suspend</button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">Onboarding Checklist</div>
                    <div class="fw-semibold">@(checklistComplete ? "Ready for go-live review" : "Setup still incomplete")</div>
                </div>
                <div>
                    @if (checklistComplete)
                    {
                        <span class="badge text-bg-success">Checklist complete</span>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">Checklist incomplete</span>
                    }
                </div>
            </div>

            <div class="row g-2 mt-2">
                <div class="col-md-6">
                    <div class="small">@((Model.ActiveOwnerCount > 0) ? "Yes" : "No") - Active owner assigned</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@((Model.PrimaryLocationCount > 0) ? "Yes" : "No") - Primary location configured</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@(Model.HasContactEmailConfigured ? "Yes" : "No") - Contact email configured</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@(Model.HasLegalNameConfigured ? "Yes" : "No") - Legal business name configured</div>
                </div>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">Next Actions</div>
                    <div class="fw-semibold">Use these shortcuts to complete setup without leaving the onboarding workflow.</div>
                </div>
                @if (checklistComplete && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                {
                    <span class="badge text-bg-info">Ready for approval review</span>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                @if (Model.ActiveOwnerCount == 0)
                {
                    <a asp-action="CreateMember"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@Url.Action("CreateMember", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-user-plus"></i> Assign Owner
                    </a>
                }
                @if (Model.PrimaryLocationCount == 0)
                {
                    <a asp-action="CreateLocation"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@Url.Action("CreateLocation", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-location-dot"></i> Add Primary Location
                    </a>
                }
                @if (!Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured)
                {
                    <a href="#business-core-fields" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-pen-to-square"></i> Complete Business Profile
                    </a>
                }
                <a asp-action="CreateInvitation"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("CreateInvitation", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-envelope"></i> Invite User
                </a>
                <a asp-action="Subscription"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-credit-card"></i> Review Subscription
                </a>
                <a asp-action="Setup"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Id })"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML">
                    <i class="fa-solid fa-sliders"></i> Open Setup Workspace
                </a>
                @if (Model.InvitationCount > 0)
                {
                    <a asp-action="Invitations"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-list-check"></i> Review Invitations
                    </a>
                }
            </div>
        </div>

        @if (!checklistComplete)
        {
            <div class="alert alert-warning">
                This business is not onboarding-complete yet.
                @if (Model.ActiveOwnerCount == 0)
                {
                    <span>Add at least one active owner.</span>
                }
                @if (Model.ActiveOwnerCount == 0 && (Model.PrimaryLocationCount == 0 || !Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured))
                {
                    <span class="mx-1">and</span>
                }
                @if (Model.PrimaryLocationCount == 0)
                {
                    <span>Add a primary location.</span>
                }
                @if (Model.PrimaryLocationCount == 0 && (!Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured))
                {
                    <span class="mx-1">and</span>
                }
                @if (!Model.HasContactEmailConfigured)
                {
                    <span>configure a contact email.</span>
                }
                @if (!Model.HasContactEmailConfigured && !Model.HasLegalNameConfigured)
                {
                    <span class="mx-1">and</span>
                }
                @if (!Model.HasLegalNameConfigured)
                {
                    <span>complete the legal business name.</span>
                }
            </div>
        }
    }

    <form asp-action="@(isCreate ? "Create" : "Edit")"
          method="post"
          hx-post="@Url.Action(isCreate ? "Create" : "Edit", "Businesses")"
          hx-target="#business-editor-shell"
          hx-swap="outerHTML"
          id="business-core-fields">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }

        <partial name="_BusinessForm" model="Model" />
    </form>
</div>
