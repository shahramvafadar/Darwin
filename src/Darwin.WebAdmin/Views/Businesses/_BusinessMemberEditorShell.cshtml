@model Darwin.WebAdmin.ViewModels.Businesses.BusinessMemberEditVm
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
}

<div id="business-member-editor-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@(isCreate ? "Assign Business Member" : "Edit Business Member")</h1>
            <p class="text-muted mb-0">@Model.Business.Name</p>
        </div>
        <a asp-action="Members"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.BusinessId })"
           hx-target="#business-member-editor-shell"
           hx-swap="outerHTML">Back to members</a>
    </div>

    @if (!isCreate && Model.IsLastActiveOwner)
    {
        <div class="alert alert-danger">
            This member is currently the last active owner for the business. Demoting, deactivating, or removing this membership requires a FullAdmin override with a mandatory reason. The override will be audit-logged.
        </div>
    }

    @if (!isCreate)
    {
        <div class="card mb-4">
            <div class="card-header">Member Support Actions</div>
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <span class="me-auto text-muted">@Model.UserEmail</span>
                    @if (Model.EmailConfirmed)
                    {
                        <span class="badge text-bg-success">Email Confirmed</span>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">Pending Activation</span>
                    }

                    @if (Model.LockoutEndUtc.HasValue && Model.LockoutEndUtc.Value > DateTime.UtcNow)
                    {
                        <span class="badge text-bg-danger">Locked</span>
                    }
                    else
                    {
                        <span class="badge text-bg-success">Unlocked</span>
                    }
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Users"
                       asp-action="Edit"
                       asp-route-id="@Model.UserId"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "Users", new { id = Model.UserId })"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-user"></i> Open User Profile
                    </a>
                    <a asp-action="StaffAccessBadge"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("StaffAccessBadge", "Businesses", new { id = Model.Id })"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-qrcode"></i> Staff Badge
                    </a>
                    @if (!Model.EmailConfirmed)
                    {
                        <form asp-action="SendMemberActivationEmail"
                              method="post"
                              hx-post="@Url.Action("SendMemberActivationEmail", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="fa-solid fa-paper-plane"></i> Send Activation
                            </button>
                        </form>
                        <form asp-action="ConfirmMemberEmail"
                              method="post"
                              hx-post="@Url.Action("ConfirmMemberEmail", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <button type="submit" class="btn btn-outline-success">
                                <i class="fa-solid fa-check"></i> Confirm Email
                            </button>
                        </form>
                    }
                    <form asp-action="SendMemberPasswordReset"
                          method="post"
                          hx-post="@Url.Action("SendMemberPasswordReset", "Businesses")"
                          hx-target="#business-member-editor-shell"
                          hx-swap="outerHTML"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                        <input type="hidden" name="returnToEdit" value="true" />
                        <button type="submit" class="btn btn-outline-warning">
                            <i class="fa-solid fa-key"></i> Send Reset
                        </button>
                    </form>
                    @if (Model.LockoutEndUtc.HasValue && Model.LockoutEndUtc.Value > DateTime.UtcNow)
                    {
                        <form asp-action="UnlockMemberUser"
                              method="post"
                              hx-post="@Url.Action("UnlockMemberUser", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <button type="submit" class="btn btn-outline-success">
                                <i class="fa-solid fa-lock-open"></i> Unlock
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="LockMemberUser"
                              method="post"
                              hx-post="@Url.Action("LockMemberUser", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fa-solid fa-lock"></i> Lock
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }

    <form asp-action="@(isCreate ? "CreateMember" : "EditMember")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateMember" : "EditMember", "Businesses")"
          hx-target="#business-member-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BusinessId" />
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="RowVersion" />
        }

        <partial name="_BusinessMemberForm" model="Model" />
    </form>

    @if (!isCreate && Model.IsLastActiveOwner)
    {
        <div class="card border-danger mt-4">
            <div class="card-header text-danger">Controlled Owner Override</div>
            <div class="card-body">
                <p class="text-muted">
                    Use this only when support must remove the final active owner and there is no safer recovery path.
                </p>
                <form asp-action="ForceDeleteMember"
                      method="post"
                      hx-post="@Url.Action("ForceDeleteMember", "Businesses")"
                      hx-target="#business-member-editor-shell"
                      hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <div class="mb-3">
                        <label asp-for="OverrideReason" class="form-label">Override reason</label>
                        <textarea asp-for="OverrideReason" class="form-control" rows="3" placeholder="Explain why this last-owner override is necessary."></textarea>
                        <span asp-validation-for="OverrideReason" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-triangle-exclamation"></i> Force Remove Last Active Owner
                    </button>
                </form>
            </div>
        </div>
    }
</div>
