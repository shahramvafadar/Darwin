@model Darwin.WebAdmin.ViewModels.Businesses.BusinessMemberEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    string BusinessMembersUrl(Guid? businessId, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter) =>
        Url.Action("Members", "Businesses", new { businessId, page, pageSize, query, filter }) ?? string.Empty;
    string BusinessOwnerOverrideAuditsUrl(Guid? businessId) => Url.Action("OwnerOverrideAudits", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string UserEditUrl(Guid? id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string LoyaltyAccountsUrl(string? q) => Url.Action("Accounts", "Loyalty", new { q }) ?? string.Empty;
    string StaffAccessBadgeUrl(Guid? id) => Url.Action("StaffAccessBadge", "Businesses", new { id }) ?? string.Empty;
    string EmailAuditsUrl(Guid? businessId, string? status = null, string? flowKey = null, string? recipientEmail = null) =>
        Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status, flowKey, recipientEmail }) ?? string.Empty;
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("CommonMembers")
    };
}

<div id="business-member-editor-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@(isCreate ? T.T("AssignBusinessMemberTitle") : T.T("EditBusinessMemberTitle"))</h1>
            <p class="text-muted mb-0">@Model.Business.Name</p>
        </div>
        <a asp-action="Members"
           asp-route-businessId="@Model.BusinessId"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.BusinessId, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
           hx-target="#business-member-editor-shell"
           hx-swap="outerHTML">@T.T("BackToMembersAction")</a>
    </div>

    @if (!isCreate && Model.IsLastActiveOwner)
    {
        <div class="alert alert-danger">
            <div>@T.T("BusinessMemberLastActiveOwnerWarning")</div>
            <div class="d-flex gap-2 flex-wrap mt-3">
                <a asp-action="OwnerOverrideAudits"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessOwnerOverrideAuditsUrl(Model.BusinessId)"
                   hx-target="#business-member-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessMembersOwnerOverrideAuditAction")</a>
                <a asp-action="MerchantReadiness"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessMerchantReadinessUrl(Model.BusinessId)"
                   hx-target="#business-member-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                <a asp-action="SupportQueue"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
                   hx-target="#business-member-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
            </div>
        </div>
    }

    @if (!isCreate)
    {
        <div class="card mb-4">
            <div class="card-header">@T.T("BusinessMemberSupportActionsTitle")</div>
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <span class="me-auto text-muted">@Model.UserEmail</span>
                    @if (Model.EmailConfirmed)
                    {
                        <span class="badge text-bg-success">@T.T("BusinessMemberEmailConfirmedBadge")</span>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</span>
                    }

                    @if (Model.LockoutEndUtc.HasValue && Model.LockoutEndUtc.Value > DateTime.UtcNow)
                    {
                        <span class="badge text-bg-danger">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</span>
                    }
                    else
                    {
                        <span class="badge text-bg-success">@T.T("BusinessMemberUnlockedBadge")</span>
                    }
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Users"
                       asp-action="Edit"
                       asp-route-id="@Model.UserId"
                       class="btn btn-outline-secondary"
                       hx-get="@UserEditUrl(Model.UserId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
                    </a>
                    <a asp-controller="MobileOperations"
                       asp-action="Index"
                       asp-route-businessId="@Model.BusinessId"
                       asp-route-q="@Model.UserEmail"
                       class="btn btn-outline-secondary"
                       hx-get="@MobileOperationsUrl(Model.BusinessId, Model.UserEmail)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                    </a>
                    <a asp-controller="Loyalty"
                       asp-action="Accounts"
                       asp-route-q="@Model.UserEmail"
                       class="btn btn-outline-secondary"
                       hx-get="@LoyaltyAccountsUrl(Model.UserEmail)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-star"></i> @T.T("Loyalty")
                    </a>
                    <a asp-action="StaffAccessBadge"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@StaffAccessBadgeUrl(Model.Id)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML">
                        <i class="fa-solid fa-qrcode"></i> @T.T("BusinessStaffAccessBadgeTitle")
                    </a>
                    @if (!Model.EmailConfirmed)
                    {
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-status="Failed"
                           asp-route-flowKey="AccountActivation"
                           asp-route-recipientEmail="@Model.UserEmail"
                           class="btn btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(Model.BusinessId, status: "Failed", flowKey: "AccountActivation", recipientEmail: Model.UserEmail)"
                           hx-target="#business-member-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-envelope-circle-check"></i> @T.T("OpenFailedActivationEmails")
                        </a>
                        <form asp-action="SendMemberActivationEmail"
                              method="post"
                              hx-post="@Url.Action("SendMemberActivationEmail", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="filter" value="@Model.Filter" />
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="fa-solid fa-paper-plane"></i> @T.T("BusinessMemberSendActivationAction")
                            </button>
                        </form>
                        <form asp-action="ConfirmMemberEmail"
                              method="post"
                              hx-post="@Url.Action("ConfirmMemberEmail", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="filter" value="@Model.Filter" />
                            <button type="submit" class="btn btn-outline-success">
                                <i class="fa-solid fa-check"></i> @T.T("BusinessMemberConfirmEmailAction")
                            </button>
                        </form>
                    }
                    <form asp-action="SendMemberPasswordReset"
                          method="post"
                          hx-post="@Url.Action("SendMemberPasswordReset", "Businesses")"
                          hx-target="#business-member-editor-shell"
                          hx-swap="outerHTML"
                          class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                        <input type="hidden" name="returnToEdit" value="true" />
                        <input type="hidden" name="page" value="@Model.Page" />
                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                        <input type="hidden" name="query" value="@Model.Query" />
                        <input type="hidden" name="filter" value="@Model.Filter" />
                        <button type="submit" class="btn btn-outline-warning">
                            <i class="fa-solid fa-key"></i> @T.T("BusinessMemberSendResetAction")
                        </button>
                    </form>
                    <a asp-controller="BusinessCommunications"
                       asp-action="EmailAudits"
                       asp-route-businessId="@Model.BusinessId"
                       asp-route-status="Failed"
                       asp-route-flowKey="PasswordReset"
                       asp-route-recipientEmail="@Model.UserEmail"
                       class="btn btn-outline-secondary"
                       hx-get="@EmailAuditsUrl(Model.BusinessId, status: "Failed", flowKey: "PasswordReset", recipientEmail: Model.UserEmail)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-triangle-exclamation"></i> @T.T("OpenFailedPasswordResets")
                    </a>
                    @if (Model.LockoutEndUtc.HasValue && Model.LockoutEndUtc.Value > DateTime.UtcNow)
                    {
                        <form asp-action="UnlockMemberUser"
                              method="post"
                              hx-post="@Url.Action("UnlockMemberUser", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="filter" value="@Model.Filter" />
                            <button type="submit" class="btn btn-outline-success">
                                <i class="fa-solid fa-lock-open"></i> @T.T("UsersUnlockAction")
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="LockMemberUser"
                              method="post"
                              hx-post="@Url.Action("LockMemberUser", "Businesses")"
                              hx-target="#business-member-editor-shell"
                              hx-swap="outerHTML"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="businessId" value="@Model.BusinessId" />
                            <input type="hidden" name="returnToEdit" value="true" />
                            <input type="hidden" name="page" value="@Model.Page" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="query" value="@Model.Query" />
                            <input type="hidden" name="filter" value="@Model.Filter" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fa-solid fa-lock"></i> @T.T("UsersLockAction")
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }

    <form asp-action="@(isCreate ? "CreateMember" : "EditMember")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateMember" : "EditMember", "Businesses")"
          hx-target="#business-member-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BusinessId" />
        <input type="hidden" asp-for="Page" />
        <input type="hidden" asp-for="PageSize" />
        <input type="hidden" asp-for="Query" />
        <input type="hidden" asp-for="Filter" />
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        }

        <partial name="_BusinessMemberForm" model="Model" />
    </form>

    <div class="d-flex gap-2 flex-wrap mt-4">
        <a asp-action="Members"
           asp-route-businessId="@Model.BusinessId"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.BusinessId, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
           hx-target="#business-member-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonMembers")</a>
        <a asp-action="SupportQueue"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
           hx-target="#business-member-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-action="MerchantReadiness"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMerchantReadinessUrl(Model.BusinessId)"
           hx-target="#business-member-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
    </div>

    @if (!isCreate && Model.IsLastActiveOwner)
    {
        <div class="card border-danger mt-4">
            <div class="card-header text-danger">@T.T("BusinessMemberControlledOwnerOverrideTitle")</div>
            <div class="card-body">
                <p class="text-muted">
                    @T.T("BusinessMemberControlledOwnerOverrideNote")
                </p>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <a asp-action="OwnerOverrideAudits"
                       asp-route-businessId="@Model.BusinessId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessOwnerOverrideAuditsUrl(Model.BusinessId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessMembersOwnerOverrideAuditAction")</a>
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.BusinessId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.BusinessId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.BusinessId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
                <form asp-action="ForceDeleteMember"
                      method="post"
                      hx-post="@Url.Action("ForceDeleteMember", "Businesses")"
                      hx-target="#business-member-editor-shell"
                      hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <div class="mb-3">
                        <label asp-for="OverrideReason" class="form-label">@T.T("BusinessMemberOverrideReasonLabel")</label>
                        <textarea asp-for="OverrideReason" class="form-control" rows="3" placeholder="@T.T("BusinessMemberOverrideReasonPlaceholder")"></textarea>
                        <span asp-validation-for="OverrideReason" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-triangle-exclamation"></i> @T.T("BusinessMemberForceRemoveLastOwnerAction")
                    </button>
                </form>
            </div>
        </div>
    }
</div>
