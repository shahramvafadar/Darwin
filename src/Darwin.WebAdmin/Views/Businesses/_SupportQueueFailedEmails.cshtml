@model IReadOnlyList<Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportFailedEmailVm>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div id="support-queue-failed-emails" class="card h-100">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("RecentFailedEmailEvents")</span>
        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    hx-get="@Url.Action("SupportQueueFailedEmailsFragment", "Businesses")"
                    hx-target="#support-queue-failed-emails"
                    hx-swap="outerHTML">
                @T.T("Refresh")
            </button>
            <a asp-controller="BusinessCommunications"
               asp-action="EmailAudits"
               asp-route-status="Failed"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed" })"
               hx-target="#business-support-queue-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("FullAuditLog")</a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-muted">@T.T("NoFailedEmailEventsQueued")</div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var item in Model)
                {
                    <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between gap-2">
                            <div>
                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.FlowKey) ? T.T("Unclassified") : item.FlowKey)</div>
                                <div class="small text-muted">@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                @if (item.BusinessId.HasValue && !string.IsNullOrWhiteSpace(item.BusinessName))
                                {
                                    <div class="small mt-1">
                                        <a asp-action="Edit"
                                           asp-controller="Businesses"
                                           asp-route-id="@item.BusinessId"
                                           class="text-decoration-none"
                                           hx-get="@Url.Action("Edit", "Businesses", new { id = item.BusinessId })"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.BusinessName</a>
                                    </div>
                                }
                            </div>
                            @if (item.BusinessId.HasValue)
                            {
                                <a asp-controller="BusinessCommunications"
                                   asp-action="Details"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("BusinessLabel")</a>
                            }
                        </div>
                        <div class="small mt-2">
                            <a asp-controller="Users"
                               asp-action="Index"
                               asp-route-q="@item.RecipientEmail"
                               class="text-decoration-none"
                               hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.RecipientEmail</a>
                        </div>
                        <div class="small text-muted">@item.Subject</div>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-2">@item.FailureMessage</div>
                        }
                        <div class="small mt-2">@item.RecommendedAction</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-status="Failed"
                               asp-route-flowKey="@item.FlowKey"
                               asp-route-businessId="@item.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = item.FlowKey, businessId = item.BusinessId })"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenSimilarFailures")</a>
                            @if (item.BusinessId.HasValue)
                            {
                                <a asp-controller="Businesses"
                                   asp-action="Edit"
                                   asp-route-id="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "Businesses", new { id = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Edit")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="Details"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationOps")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("EmailDeliveryAudits")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
                                <a asp-action="MerchantReadiness"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="Payments"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Payments", "Billing", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Payments")</a>
                                <a asp-controller="Businesses"
                                   asp-action="Subscription"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Subscription", "Businesses", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Subscription")</a>
                                <a asp-controller="Businesses"
                                   asp-action="SubscriptionInvoices"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = item.BusinessId })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SubscriptionInvoicesTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="TaxCompliance"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("TaxCompliance", "Billing")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("TaxComplianceTitle")</a>
                            }
                            @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-action="Invitations"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="Open"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.BusinessId, filter = "Open" })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenInvitations")</a>
                                <a asp-action="MerchantReadiness"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            }
                            else if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="PendingActivation"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("Members", "Businesses", new { businessId = item.BusinessId, filter = "PendingActivation" })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenMembers")</a>
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-filter="Unconfirmed"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "Users", new { filter = "Unconfirmed" })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "MobileOperations")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                <a asp-action="MerchantReadiness"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            }
                            else if (string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-q="@item.RecipientEmail"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("Index", "Users", new { q = item.RecipientEmail })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenUsers")</a>
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-filter="Locked"
                                   asp-route-q="@item.RecipientEmail"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "Users", new { filter = "Locked", q = item.RecipientEmail })"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("UsersFilterLocked")</a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "MobileOperations")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                                <a asp-action="MerchantReadiness"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
