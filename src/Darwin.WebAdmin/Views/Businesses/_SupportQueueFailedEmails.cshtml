@model IReadOnlyList<Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportFailedEmailVm>
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalSupportQueueFailedEmailsFragmentUrl() => Url.Action("SupportQueueFailedEmailsFragment", "Businesses") ?? string.Empty;
    string BusinessEditUrl(Guid? id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessLocationsUrl(Guid? businessId) => Url.Action("Locations", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null, string? query = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter, query }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSubscriptionUrl(Guid? businessId) => Url.Action("Subscription", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSubscriptionInvoicesUrl(Guid? businessId) => Url.Action("SubscriptionInvoices", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessOwnerOverrideAuditsUrl(Guid? businessId) => Url.Action("OwnerOverrideAudits", "Businesses", new { businessId }) ?? string.Empty;
    string UsersUrl(string? q = null, Darwin.Application.Identity.DTOs.UserQueueFilter? filter = null) =>
        Url.Action("Index", "Users", new { q, filter }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string BusinessCommunicationsDetailsUrl(Guid? businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string EmailAuditsUrl(
        Guid? businessId = null,
        string? status = null,
        string? flowKey = null,
        string? recipientEmail = null,
        bool? retryBlockedOnly = null,
        bool? chainFollowUpOnly = null,
        bool? repeatedFailuresOnly = null,
        bool? businessLinkedFailuresOnly = null,
        bool? stalePendingOnly = null) => Url.Action("EmailAudits", "BusinessCommunications", new
        {
            businessId,
            status,
            flowKey,
            recipientEmail,
            retryBlockedOnly,
            chainFollowUpOnly,
            repeatedFailuresOnly,
            businessLinkedFailuresOnly,
            stalePendingOnly
        }) ?? string.Empty;
    string ChannelAuditsUrl(Guid? businessId, bool? phoneVerificationOnly = null, bool? actionBlockedOnly = null, bool? escalationCandidatesOnly = null) =>
        Url.Action("ChannelAudits", "BusinessCommunications", new { businessId, phoneVerificationOnly, actionBlockedOnly, escalationCandidatesOnly }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId) => Url.Action("Index", "MobileOperations", new { businessId }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string PaymentsUrl(Guid? businessId) => Url.Action("Payments", "Billing", new { businessId }) ?? string.Empty;
    string RefundsUrl(Guid? businessId) => Url.Action("Refunds", "Billing", new { businessId }) ?? string.Empty;
    string FinancialAccountsUrl(Guid? businessId) => Url.Action("FinancialAccounts", "Billing", new { businessId }) ?? string.Empty;
    string ExpensesUrl(Guid? businessId) => Url.Action("Expenses", "Billing", new { businessId }) ?? string.Empty;
    string JournalEntriesUrl(Guid? businessId) => Url.Action("JournalEntries", "Billing", new { businessId }) ?? string.Empty;
    string FlowLabel(string? flowKey) => flowKey switch
    {
        "BusinessInvitation" => T.T("CommunicationDetailsActiveFlowInvitation"),
        "AccountActivation" => T.T("CommunicationDetailsActiveFlowActivation"),
        "PasswordReset" => T.T("CommunicationTemplateInventoryPasswordResetFlow"),
        "AdminCommunicationTest" => T.T("CommunicationTemplateInventoryAdminTestFlow"),
        "PhoneVerification" => T.T("CommunicationTemplateInventoryPhoneVerificationFlow"),
        _ => string.IsNullOrWhiteSpace(flowKey) ? T.T("CommonUnclassified") : T.T(flowKey)
    };
    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired => T.T("Expired"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Accepted => T.T("Accepted"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Revoked => T.T("Revoked"),
        _ => T.T("BusinessInvitationsAllLabel")
    };
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("UsersFilterUnconfirmed"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
}

<div id="support-queue-failed-emails" class="card h-100">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("RecentFailedEmailEvents")</span>
        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
          hx-get="@GlobalSupportQueueFailedEmailsFragmentUrl()"
                    hx-target="#support-queue-failed-emails"
                    hx-swap="outerHTML">
                @T.T("Refresh")
            </button>
            <a asp-controller="BusinessCommunications"
               asp-action="EmailAudits"
               asp-route-status="Failed"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@EmailAuditsUrl(status: "Failed")"
               hx-target="#business-support-queue-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("FailedEmails")</a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-muted">@T.T("NoFailedEmailEventsQueued")</div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var item in Model)
                {
                    <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between gap-2">
                            <div>
                                <div class="fw-semibold">@FlowLabel(item.FlowKey)</div>
                    <div class="small text-muted">@item.AttemptedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                                @if (item.BusinessId.HasValue && !string.IsNullOrWhiteSpace(item.BusinessName))
                                {
                                    <div class="small mt-1">
                                        <a asp-action="Edit"
                                           asp-controller="Businesses"
                                           asp-route-id="@item.BusinessId"
                                           class="text-decoration-none"
                                           hx-get="@BusinessEditUrl(item.BusinessId)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.BusinessName</a>
                                    </div>
                                }
                            </div>
                            @if (item.BusinessId.HasValue)
                            {
                                <a asp-controller="BusinessCommunications"
                                   asp-action="Details"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessCommunicationsDetailsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationOps")</a>
                            }
                        </div>
                        <div class="small mt-2">
                            <a asp-controller="Users"
                               asp-action="Index"
                               asp-route-q="@item.RecipientEmail"
                               class="text-decoration-none"
                               hx-get="@UsersUrl(item.RecipientEmail)"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.RecipientEmail</a>
                        </div>
                        <div class="small text-muted">@item.Subject</div>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="small text-danger mt-2">@item.FailureMessage</div>
                        }
                        <div class="small mt-2">@item.RecommendedAction</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="@item.FlowKey"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: item.FlowKey)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("FailedEmails")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-retryBlockedOnly="true"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, retryBlockedOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("RetryBlocked")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-chainFollowUpOnly="true"
                                   asp-route-recipientEmail="@item.RecipientEmail"
                                   asp-route-flowKey="@item.FlowKey"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, chainFollowUpOnly: true, recipientEmail: item.RecipientEmail, flowKey: item.FlowKey)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("HeavyChains")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-repeatedFailuresOnly="true"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, repeatedFailuresOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("RepeatedFailures")</a>
                            @if (item.BusinessId.HasValue)
                            {
                                <a asp-controller="Businesses"
                                   asp-action="Invitations"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessInvitationsUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)</a>
                                <a asp-controller="Businesses"
                                   asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
                                <a asp-controller="Businesses"
                                   asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
                                <a asp-controller="Businesses"
                                   asp-action="Edit"
                                   asp-route-id="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessEditUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Edit")</a>
                                <a asp-controller="Businesses"
                                   asp-action="Setup"
                                   asp-route-id="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSetupUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Setup")</a>
                                <a asp-controller="Businesses"
                                   asp-action="Locations"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessLocationsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Locations")</a>
                                <a asp-controller="Businesses"
                                   asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="Details"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessCommunicationsDetailsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationOps")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-communications-policy"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationPolicy")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("EmailDeliveryAudits")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-retryBlockedOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, retryBlockedOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("RetryBlocked")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AccountActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: "AccountActivation")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AdminCommunicationTest"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: "AdminCommunicationTest")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("FailedAdminTests")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="PasswordReset"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: "PasswordReset")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ChannelAuditsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-phoneVerificationOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ChannelAuditsUrl(item.BusinessId, phoneVerificationOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("PhoneVerification")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-actionBlockedOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ChannelAuditsUrl(item.BusinessId, actionBlockedOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("ActionBlocked")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-escalationCandidatesOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ChannelAuditsUrl(item.BusinessId, escalationCandidatesOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("EscalationCandidates")</a>
                                <a asp-action="MerchantReadiness"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMerchantReadinessUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="Payments"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@PaymentsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Payments")</a>
                                <a asp-controller="Businesses"
                                   asp-action="Subscription"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSubscriptionUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Subscription")</a>
                                <a asp-controller="Businesses"
                                   asp-action="SubscriptionInvoices"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSubscriptionInvoicesUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SubscriptionInvoicesTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="TaxCompliance"
                                   class="btn btn-sm btn-outline-secondary"
                                       hx-get="@GlobalTaxComplianceUrl()"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("TaxComplianceTitle")</a>
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="Overdue"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmInvoicesUrl("Overdue")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Overdue")</a>
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="DueSoon"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmInvoicesUrl("DueSoon")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("DueSoon")</a>
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="Draft"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmInvoicesUrl("Draft")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Draft")</a>
                                <a asp-controller="Billing"
                                   asp-action="Refunds"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@RefundsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Refunds")</a>
                                <a asp-controller="Billing"
                                   asp-action="FinancialAccounts"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@FinancialAccountsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("FinancialAccountsTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="Expenses"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ExpensesUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("ExpensesTitle")</a>
                                <a asp-controller="Billing"
                                   asp-action="JournalEntries"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@JournalEntriesUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("JournalEntriesTitle")</a>
                                <a asp-action="OwnerOverrideAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessOwnerOverrideAuditsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OwnerOverrideAuditTitle")</a>
                            }
                            @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-action="Invitations"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@BusinessInvitationsUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)</a>
                                <a asp-action="MerchantReadiness"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMerchantReadinessUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AccountActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: "AccountActivation")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AdminCommunicationTest"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.BusinessId, status: "Failed", flowKey: "AdminCommunicationTest")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("FailedAdminTests")</a>
                            }
                            else if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-query="@item.RecipientEmail"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation, item.RecipientEmail)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenMembers")</a>
                                <a asp-action="Members"
                                   asp-route-businessId="@item.BusinessId"
                                   asp-route-query="@item.RecipientEmail"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation, item.RecipientEmail)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                            <a asp-action="MerchantReadiness"
                               asp-route-businessId="@item.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            }
                            else if (string.Equals(item.FlowKey, "PasswordReset", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-q="@item.RecipientEmail"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@UsersUrl(item.RecipientEmail)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenUsers")</a>
                                @if (item.BusinessId.HasValue)
                                {
                                    <a asp-action="Members"
                                       asp-route-businessId="@item.BusinessId"
                                       asp-route-query="@item.RecipientEmail"
                                       asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@BusinessMembersUrl(item.BusinessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked, item.RecipientEmail)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
                                }
                                else
                                {
                                    <a asp-controller="Users"
                                       asp-action="Index"
                                       asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                                       asp-route-q="@item.RecipientEmail"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@UsersUrl(item.RecipientEmail, Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
                                }
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-communications-policy"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationPolicy")</a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-businessId="@item.BusinessId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                            <a asp-action="MerchantReadiness"
                               asp-route-businessId="@item.BusinessId"
                               class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(item.BusinessId)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
