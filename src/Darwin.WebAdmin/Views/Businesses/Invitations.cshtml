@model Darwin.WebAdmin.ViewModels.Businesses.BusinessInvitationsListVm
@using System.Globalization
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessInvitationsTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
    string GlobalBusinessInvitationsUrl() => Url.Action("Invitations", "Businesses") ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId) => Url.Action("Index", "MobileOperations", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessEditUrl(Guid? id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string CreateInvitationUrl(Guid? businessId, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter) =>
        Url.Action("CreateInvitation", "Businesses", new { businessId, page, pageSize, query, filter }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string InvitationEmailAuditsUrl(Guid? businessId, string? recipientEmail = null) =>
        Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status = "Failed", flowKey = "BusinessInvitation", recipientEmail }) ?? string.Empty;
    string LocalizeBusinessInvitationRole(object? role) => role is null ? "-" : T.T(role.ToString() ?? string.Empty);

    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired => T.T("Expired"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Accepted => T.T("Accepted"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Revoked => T.T("Revoked"),
        _ => T.T("BusinessInvitationsAllLabel")
    };

    string InvitationStatusLabel(Darwin.Domain.Enums.BusinessInvitationStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessInvitationStatus.Pending => T.T("Pending"),
        Darwin.Domain.Enums.BusinessInvitationStatus.Accepted => T.T("Accepted"),
        Darwin.Domain.Enums.BusinessInvitationStatus.Revoked => T.T("Revoked"),
        Darwin.Domain.Enums.BusinessInvitationStatus.Expired => T.T("Expired"),
        _ => T.T("BusinessInvitationsAllLabel")
    };

    string MemberWorkspaceLabel() => T.T("Members");
}

<div id="business-invitations-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope me-2"></i>@T.T("BusinessInvitationsTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="MobileOperations"
           asp-action="Index"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@MobileOperationsUrl(Model.Business.Id)"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@(Model.Business.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Business.Id, Model.Business.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberWorkspaceLabel()</a>
        @if (isFullAdmin)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@BusinessEditUrl(Model.Business.Id)"
               hx-target="#business-invitations-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
            <a asp-action="Setup"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@BusinessSetupUrl(Model.Business.Id)"
               hx-target="#business-invitations-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Setup")</a>
        }
        <a asp-action="CreateInvitation"
           asp-route-businessId="@Model.Business.Id"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-primary"
           hx-get="@CreateInvitationUrl(Model.Business.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-plus"></i> @T.T("BusinessInvitationsInviteUserAction")
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("CommonTotal")</div>
            <div class="fw-semibold mt-1">@Model.Summary.TotalCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessInvitationsUrl(Model.Business.Id)"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonTotal")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open)</div>
            <div class="fw-semibold mt-1">@Model.Summary.OpenCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@BusinessInvitationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open)"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open)</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)</div>
            <div class="fw-semibold mt-1">@Model.Summary.PendingCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@BusinessInvitationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired)</div>
            <div class="fw-semibold mt-1">@Model.Summary.ExpiredCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@BusinessInvitationsUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired)"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired)</a>
            </div>
        </div>
    </div>
</div>

<form method="get"
      class="row g-2 mb-3"
          hx-get="@GlobalBusinessInvitationsUrl()"
      hx-target="#business-invitations-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessInvitationsSearchPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessInvitationsUrl(Model.Business.Id)"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("BusinessSubscriptionQueueColumn")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("CommonActions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-invitations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.QueueLabel</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#business-invitations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.WhyItMatters</a>
                        </td>
                        <td>
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-invitations-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.OperatorAction</a>
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-invitations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-invitations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Email")</th>
                <th>@T.T("Role")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("BusinessInvitationsInvitedByColumn")</th>
                <th>@T.T("BusinessInvitationsExpiresUtcColumn")</th>
                        <th class="text-end admin-w-320">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <div>@T.T("BusinessInvitationsEmptyState")</div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center mt-3">
                        <a asp-action="CreateInvitation"
                           asp-route-businessId="@Model.Business.Id"
                           asp-route-page="@Model.Page"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-query="@Model.Query"
                           asp-route-filter="@Model.Filter"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CreateInvitationUrl(Model.Business.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessInvitationsInviteUserAction")</a>
                        <a asp-action="Setup"
                           asp-route-id="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSetupUrl(Model.Business.Id)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Setup")</a>
                        <a asp-action="SupportQueue"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSupportQueueUrl(Model.Business.Id)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                        <a asp-action="MerchantReadiness"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div>@item.Email</div>
                        @if (!string.IsNullOrWhiteSpace(item.Note))
                        {
                            <div class="small text-muted">@item.Note</div>
                        }
                    </td>
                    <td>@LocalizeBusinessInvitationRole(item.Role)</td>
                    <td>
                        @switch (item.Status)
                        {
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Pending:
                                <span class="badge text-bg-primary">@InvitationStatusLabel(item.Status)</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Accepted:
                                <span class="badge text-bg-success">@InvitationStatusLabel(item.Status)</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Revoked:
                                <span class="badge text-bg-secondary">@InvitationStatusLabel(item.Status)</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Expired:
                                <span class="badge text-bg-warning">@InvitationStatusLabel(item.Status)</span>
                                break;
                        }
                    </td>
                    <td>@item.InvitedByDisplayName</td>
                                <td>@item.ExpiresAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                    <td class="text-end">
                        @if (item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Pending || item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Expired)
                        {
                            <form asp-action="ResendInvitation"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("ResendInvitation", "Businesses")"
                                  hx-target="#business-invitations-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="query" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-paper-plane"></i> @T.T("Resend")
                                </button>
                            </form>
                        }
                        @if (item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Pending || item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Expired)
                        {
                            <form asp-action="RevokeInvitation"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("RevokeInvitation", "Businesses")"
                                  hx-target="#business-invitations-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                <input type="hidden" name="page" value="@Model.Page" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="query" value="@Model.Query" />
                                <input type="hidden" name="filter" value="@Model.Filter" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-ban"></i> @T.T("Revoke")
                                </button>
                            </form>
                        }
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-businessId="@item.BusinessId"
                           asp-route-status="Failed"
                           asp-route-flowKey="BusinessInvitation"
                           asp-route-recipientEmail="@item.Email"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@InvitationEmailAuditsUrl(item.BusinessId, item.Email)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-envelope-circle-check"></i> @T.T("OpenFailedInvitationEmails")
                        </a>
                        <a asp-action="SupportQueue"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessSupportQueueUrl(Model.Business.Id)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-life-ring"></i> @T.T("BusinessSupportQueueTitle")
                        </a>
                        <a asp-action="MerchantReadiness"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
                           hx-target="#business-invitations-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-list-check"></i> @T.T("MerchantReadinessTitle")
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Invitations"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#business-invitations-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>
</div>
