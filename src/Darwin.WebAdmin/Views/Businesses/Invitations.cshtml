@model Darwin.WebAdmin.ViewModels.Businesses.BusinessInvitationsListVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessInvitationsTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
}

<div id="business-invitations-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-envelope me-2"></i>@T.T("BusinessInvitationsTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="MobileOperations"
           asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "MobileOperations")"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Members")</a>
        @if (isFullAdmin)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Business.Id })"
               hx-target="#business-invitations-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
            <a asp-action="Setup"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Business.Id })"
               hx-target="#business-invitations-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Setup")</a>
        }
        <a asp-action="CreateInvitation"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-primary"
           hx-get="@Url.Action("CreateInvitation", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-plus"></i> @T.T("BusinessInvitationsInviteUserAction")
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("CommonTotal")</div>
            <div class="fw-semibold mt-1">@Model.Summary.TotalCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id })"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonTotal")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("OpenInvitations")</div>
            <div class="fw-semibold mt-1">@Model.Summary.OpenCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open })"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenInvitations")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("Pending")</div>
            <div class="fw-semibold mt-1">@Model.Summary.PendingCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending })"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Pending")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("Expired")</div>
            <div class="fw-semibold mt-1">@Model.Summary.ExpiredCount</div>
            <div class="mt-2">
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired })"
                   hx-target="#business-invitations-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Expired")</a>
            </div>
        </div>
    </div>
</div>

<form method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("Invitations", "Businesses")"
      hx-target="#business-invitations-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessInvitationsSearchPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-invitations-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("BusinessSubscriptionQueueColumn")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("CommonActions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.QueueLabel</td>
                        <td>@playbook.WhyItMatters</td>
                        <td>@playbook.OperatorAction</td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-invitations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-invitations-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Email")</th>
                <th>@T.T("Role")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("BusinessInvitationsInvitedByColumn")</th>
                <th>@T.T("BusinessInvitationsExpiresUtcColumn")</th>
                <th class="text-end" style="width:320px">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">@T.T("BusinessInvitationsEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div>@item.Email</div>
                        @if (!string.IsNullOrWhiteSpace(item.Note))
                        {
                            <div class="small text-muted">@item.Note</div>
                        }
                    </td>
                    <td>@item.Role</td>
                    <td>
                        @switch (item.Status)
                        {
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Pending:
                                <span class="badge text-bg-primary">@T.T("Pending")</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Accepted:
                                <span class="badge text-bg-success">@T.T("Accepted")</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Revoked:
                                <span class="badge text-bg-secondary">@T.T("Revoked")</span>
                                break;
                            case Darwin.Domain.Enums.BusinessInvitationStatus.Expired:
                                <span class="badge text-bg-warning">@T.T("Expired")</span>
                                break;
                        }
                    </td>
                    <td>@item.InvitedByDisplayName</td>
                    <td>@item.ExpiresAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        @if (item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Pending || item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Expired)
                        {
                            <form asp-action="ResendInvitation"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("ResendInvitation", "Businesses")"
                                  hx-target="#business-invitations-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-paper-plane"></i> @T.T("Resend")
                                </button>
                            </form>
                        }
                        @if (item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Pending || item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Expired)
                        {
                            <form asp-action="RevokeInvitation"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("RevokeInvitation", "Businesses")"
                                  hx-target="#business-invitations-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-ban"></i> @T.T("Revoke")
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Invitations"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#business-invitations-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>
</div>
