@model Darwin.WebAdmin.ViewModels.Businesses.BusinessInvitationCreateVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div id="business-invitation-editor-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@T.T("BusinessInvitationCreateTitle")</h1>
            <p class="text-muted mb-0">@Model.Business.Name</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Invitations"
               asp-route-businessId="@Model.BusinessId"
               asp-route-page="@Model.Page"
               asp-route-pageSize="@Model.PageSize"
               asp-route-query="@Model.Query"
               asp-route-filter="@Model.Filter"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, page = Model.Page, pageSize = Model.PageSize, query = Model.Query, filter = Model.Filter })"
               hx-target="#business-invitation-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessInvitationBackToInvitations")</a>
            <a asp-action="SupportQueue"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("SupportQueue", "Businesses")"
               hx-target="#business-invitation-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
            <a asp-action="MerchantReadiness"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("MerchantReadiness", "Businesses")"
               hx-target="#business-invitation-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
        </div>
    </div>

    <form asp-action="CreateInvitation"
          method="post"
          hx-post="@Url.Action("CreateInvitation", "Businesses")"
          hx-target="#business-invitation-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BusinessId" />
        <input type="hidden" asp-for="Page" />
        <input type="hidden" asp-for="PageSize" />
        <input type="hidden" asp-for="Query" />
        <input type="hidden" asp-for="Filter" />

        <partial name="_BusinessInvitationForm" model="Model" />
    </form>

    <div class="d-flex gap-2 flex-wrap mt-4">
        <a asp-action="Invitations"
           asp-route-businessId="@Model.BusinessId"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, page = Model.Page, pageSize = Model.PageSize, query = Model.Query, filter = Model.Filter })"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessInvitationBackToInvitations")</a>
        <a asp-action="SupportQueue"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-action="MerchantReadiness"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
    </div>
</div>
