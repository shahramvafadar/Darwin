@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSetupInvitationsPreviewVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string LocalizeBusinessInvitationRole(object? role) => role is null ? "-" : T.T(role.ToString() ?? string.Empty);
    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired => T.T("Expired"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Accepted => T.T("Accepted"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Revoked => T.T("Revoked"),
        _ => T.T("BusinessInvitationsAllLabel")
    };
    var invitationWorkspaceFilter = Model.PendingCount > 0
        ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending
        : Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open;
    var invitationWorkspaceCountLabel = Model.PendingCount > 0
        ? string.Format(T.T("BusinessSetupInvitationsPreviewPendingCount"), Model.PendingCount)
        : string.Format(T.T("BusinessSetupInvitationsPreviewOpenCount"), Model.OpenCount);
}

@if (Model.OpenCount == 0)
{
    <div class="text-success">@T.T("BusinessSetupInvitationsPreviewNoAttention")</div>
    <div class="d-flex gap-2 flex-wrap mt-3">
        <a asp-action="Invitations"
           asp-route-businessId="@Model.BusinessId"
           asp-route-filter="@invitationWorkspaceFilter"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, filter = invitationWorkspaceFilter })"
           hx-target="#business-setup-shell"
           hx-swap="outerHTML">@InvitationQueueLabel(invitationWorkspaceFilter)</a>
        <a asp-controller="MobileOperations"
           asp-action="Index"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Index", "MobileOperations")"
           hx-target="#business-setup-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="fw-semibold">@invitationWorkspaceCountLabel</div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Invitations"
               asp-route-businessId="@Model.BusinessId"
               asp-route-filter="@invitationWorkspaceFilter"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, filter = invitationWorkspaceFilter })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML">@InvitationQueueLabel(invitationWorkspaceFilter)</a>
            <a asp-controller="MobileOperations"
               asp-action="Index"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Index", "MobileOperations")"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>@T.T("Email")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("Role")</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">
                            <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-status="Failed"
                               asp-route-flowKey="BusinessInvitation"
                               asp-route-recipientEmail="@item.Email"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.BusinessId, status = "Failed", flowKey = "BusinessInvitation", recipientEmail = item.Email })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.Email</a>
                        </div>
                    <div class="small text-muted">@string.Format(T.T("BusinessSetupInvitationsPreviewExpiresAt"), item.ExpiresAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                        <div class="d-flex gap-2 flex-wrap mt-2">
                            <a asp-action="Invitations"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-filter="@invitationWorkspaceFilter"
                               asp-route-query="@item.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, filter = invitationWorkspaceFilter, query = item.Email })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@InvitationQueueLabel(invitationWorkspaceFilter)</a>
                           <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-status="Failed"
                               asp-route-flowKey="BusinessInvitation"
                               asp-route-recipientEmail="@item.Email"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.BusinessId, status = "Failed", flowKey = "BusinessInvitation", recipientEmail = item.Email })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
                        </div>
                    </td>
                    <td>
                        @if (item.Status == Darwin.Domain.Enums.BusinessInvitationStatus.Pending)
                        {
                            <a asp-action="Invitations"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                               asp-route-query="@item.Email"
                               class="badge text-bg-primary text-decoration-none"
                               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending, query = item.Email })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)</a>
                        }
                        else
                        {
                            <a asp-action="Invitations"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired"
                               asp-route-query="@item.Email"
                               class="badge text-bg-warning text-decoration-none"
                               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired, query = item.Email })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired)</a>
                        }
                    </td>
                    <td>@LocalizeBusinessInvitationRole(item.Role)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
