@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportSummaryVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div id="support-queue-summary" class="position-relative">
    <div class="d-flex justify-content-end mb-2">
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                hx-get="@Url.Action("SupportQueueSummaryFragment", "Businesses")"
                hx-target="#support-queue-summary"
                hx-swap="outerHTML">
            @T.T("RefreshSummary")
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@Model.AttentionBusinessCount</div>
                <a asp-action="Index"
                   asp-route-attentionOnly="true"
                   class="small"
                   hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML">@T.T("OpenBusinessQueue")</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("PendingApproval")</div>
                <div class="fs-4 fw-semibold">@Model.PendingApprovalBusinessCount</div>
                <a asp-action="Index"
                   asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval"
                   class="small"
                   hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval })"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML">@T.T("OpenPendingApprovals")</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("Invitations")</div>
                <div class="fs-4 fw-semibold">@Model.OpenInvitationCount</div>
                <a asp-controller="BusinessCommunications"
                   asp-action="EmailAudits"
                   asp-route-status="Failed"
                   asp-route-flowKey="BusinessInvitation"
                   class="small"
                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "BusinessInvitation" })"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML">@T.T("OpenFailedInvitationEmails")</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">@T.T("PendingActivation")</div>
                <div class="fs-4 fw-semibold">@Model.PendingActivationMemberCount</div>
                <a asp-controller="BusinessCommunications"
                   asp-action="EmailAudits"
                   asp-route-status="Failed"
                   asp-route-flowKey="AccountActivation"
                   class="small"
                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation" })"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML">@T.T("OpenFailedActivationEmails")</a>
            </div>
        </div>
    </div>

    <div class="small text-muted mb-4">
        @T.T("SuspendedBusinesses"): <strong>@Model.SuspendedBusinessCount</strong>
        <span class="mx-2">|</span>
        @T.T("BusinessesMissingOwner"): <strong>@Model.MissingOwnerBusinessCount</strong>
        <span class="mx-2">|</span>
        @T.T("LockedMembers"): <strong>@Model.LockedMemberCount</strong>
        <span class="mx-2">|</span>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-status="Failed"
           asp-route-flowKey="PasswordReset"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset" })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML">@T.T("OpenFailedPasswordResets")</a>
    </div>
</div>
