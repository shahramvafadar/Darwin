@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportSummaryVm

<div id="support-queue-summary" class="position-relative">
    <div class="d-flex justify-content-end mb-2">
        <button type="button"
                class="btn btn-sm btn-outline-secondary"
                hx-get="@Url.Action("SupportQueueSummaryFragment", "Businesses")"
                hx-target="#support-queue-summary"
                hx-swap="outerHTML">
            Refresh Summary
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Needs Attention</div>
                <div class="fs-4 fw-semibold">@Model.AttentionBusinessCount</div>
                <a asp-action="Index" asp-route-attentionOnly="true" class="small">Open business queue</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Pending Approval</div>
                <div class="fs-4 fw-semibold">@Model.PendingApprovalBusinessCount</div>
                <a asp-action="Index" asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval" class="small">Open pending approvals</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Open Invitations</div>
                <div class="fs-4 fw-semibold">@Model.OpenInvitationCount</div>
                <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="BusinessInvitation" class="small">Open failed invitation emails</a>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small">Pending Activation</div>
                <div class="fs-4 fw-semibold">@Model.PendingActivationMemberCount</div>
                <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="AccountActivation" class="small">Open failed activation emails</a>
            </div>
        </div>
    </div>

    <div class="small text-muted mb-4">
        Suspended businesses: <strong>@Model.SuspendedBusinessCount</strong>
        <span class="mx-2">|</span>
        Businesses missing owner: <strong>@Model.MissingOwnerBusinessCount</strong>
        <span class="mx-2">|</span>
        Locked members: <strong>@Model.LockedMemberCount</strong>
        <span class="mx-2">|</span>
        <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="PasswordReset">Open failed password resets</a>
    </div>
</div>
