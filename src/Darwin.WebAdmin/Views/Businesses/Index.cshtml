       hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-envelope-circle-check"></i> @T.T("MissingContactEmail")
    </a>
    <a asp-action="Index"
       asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
       class="btn btn-sm @(Model.ReadinessFilter == Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-file-signature"></i> @T.T("MissingLegalName")
    </a>
    <a asp-action="Index"
       asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites"
       class="btn btn-sm @(Model.ReadinessFilter == Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
