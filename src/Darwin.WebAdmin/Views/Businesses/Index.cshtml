</div>

<form method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "Businesses")"
      hx-target="#businesses-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="readinessFilter" value="@Model.ReadinessFilter" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchBusinessesPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="operationalStatus" asp-items="Model.OperationalStatusItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check mt-2">
            <input type="checkbox" name="attentionOnly" value="true" class="form-check-input" id="attentionOnly" checked="@(Model.AttentionOnly ? "checked" : null)" />
            <label class="form-check-label" for="attentionOnly">@T.T("NeedsAttentionOnly")</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Business")</th>
                <th>@T.T("Category")</th>
                <th class="text-center">@T.T("Status")</th>
                <th class="text-center">@T.T("Owners")</th>
                <th class="text-center">@T.T("Members")</th>
                <th class="text-center">@T.T("Locations")</th>
                <th>@T.T("Attention")</th>
                <th class="text-end" style="width:360px">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-4">@T.T("NoBusinessesFound")</td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="text-decoration-none"
                               hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.Name</a>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.LegalName))
                        {
                            <div class="text-muted small">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@item.LegalName</a>
                            </div>
                        }
                    </td>
                    <td>@item.Category</td>
                    <td class="text-center">
                        @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                        {
                            <a asp-action="Index"
                               asp-route-operationalStatus="PendingApproval"
                               class="badge text-bg-warning text-decoration-none"
                               hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "PendingApproval" })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("PendingApproval")</a>
                        }
                        else if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                        {
                            <a asp-action="Index"
                               asp-route-operationalStatus="Suspended"
                               class="badge text-bg-danger text-decoration-none"
                               hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "Suspended" })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Suspended")</a>
                        }
                        else if (item.IsActive)
                        {
                            <a asp-action="Index"
                               class="badge text-bg-success text-decoration-none"
                               hx-get="@Url.Action("Index", "Businesses")"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Active")</a>
                        }
                        else
                        {
                            <a asp-action="Index"
                               asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
                               class="badge text-bg-secondary text-decoration-none"
                               hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("ApprovedInactive")</a>
                        }
                    </td>
                    <td class="text-center">
                        @if (item.ActiveOwnerCount > 0)
                        {
                            <a asp-action="Members"
                               asp-route-businessId="@item.Id"
                               class="badge text-bg-success text-decoration-none"
                               hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.ActiveOwnerCount</a>
                        }
                        else
                        {
                            <a asp-action="Members"
                               asp-route-businessId="@item.Id"
                               class="badge text-bg-warning text-decoration-none"
                               hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MissingText")</a>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Members"
                           asp-route-businessId="@item.Id"
                           class="text-decoration-none"
                           hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@item.MemberCount</a>
                    </td>
                    <td class="text-center">
                        @if (item.LocationCount > 0)
                        {
                            <a asp-action="Locations"
                               asp-route-businessId="@item.Id"
                               class="text-decoration-none"
                               hx-get="@Url.Action("Locations", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@item.LocationCount</a>
                        }
                        else
                        {
                            <a asp-action="Locations"
                               asp-route-businessId="@item.Id"
                               class="badge text-bg-warning text-decoration-none"
                               hx-get="@Url.Action("Locations", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MissingText")</a>
                        }
                    </td>
                    <td>
                        @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                        {
                            <div class="small"><span class="badge text-bg-warning">@T.T("ApprovalPending")</span></div>
                        }
                        @if (item.ActiveOwnerCount == 0)
                        {
                            <div class="small">
                                <a asp-action="Index"
                                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MissingActiveOwner")</a>
                            </div>
                        }
                        @if (item.PrimaryLocationCount == 0)
                        {
                            <div class="small">
                                <a asp-action="Index"
                                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MissingPrimaryLocation")</a>
                            </div>
                        }
                        @if (!item.HasContactEmailConfigured)
                        {
                            <div class="small">
                                <a asp-action="Index"
                                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MissingContactEmail")</a>
                            </div>
                        }
                        @if (!item.HasLegalNameConfigured)
                        {
                            <div class="small">
                                <a asp-action="Index"
                                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MissingLegalName")</a>
                            </div>
                        }
                        @if (item.InvitationCount > 0)
                        {
                            <div class="small">
                                <a asp-action="Index"
                                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites"
                                   class="text-muted text-decoration-none"
                                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites })"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@item.InvitationCount @T.T("PendingInvites")</a>
                            </div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Members"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-user-group"></i> @T.T("Members")
                        </a>
                        <a asp-action="Subscription"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Subscription", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-credit-card"></i> @T.T("Subscription")
                        </a>
                        <a asp-action="SubscriptionInvoices"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-file-invoice-dollar"></i> @T.T("SubscriptionInvoicesTitle")
                        </a>
                        <a asp-action="Invitations"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-envelope"></i> @T.T("Invitations")
                        </a>
                        @if (isFullAdmin)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-pen"></i> @T.T("Edit")
                            </a>
                            <a asp-action="Setup"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Setup", "Businesses", new { id = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-sliders"></i> @T.T("Setup")
                            </a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="Details"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-envelope-open-text"></i> @T.T("CommunicationOps")
                            </a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-envelope-circle-check"></i> @T.T("EmailDeliveryAudits")
                            </a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="ChannelAudits"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-message"></i> @T.T("SmsWhatsAppAuditsTitle")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="Payments"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-money-bill-wave"></i> @T.T("Payments")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="Refunds"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Refunds", "Billing", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-reply"></i> @T.T("Refunds")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="FinancialAccounts"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-landmark"></i> @T.T("FinancialAccountsTitle")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="Expenses"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Expenses", "Billing", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-receipt"></i> @T.T("ExpensesTitle")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="JournalEntries"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-book"></i> @T.T("JournalEntriesTitle")
                            </a>
                            <a asp-controller="Billing"
                               asp-action="TaxCompliance"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("TaxCompliance", "Billing")"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-scale-balanced"></i> @T.T("TaxComplianceTitle")
                            </a>
                            <a asp-action="OwnerOverrideAudits"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-clipboard-check"></i> @T.T("OwnerOverrideAuditTitle")
                            </a>
                            <a asp-action="Locations"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Locations", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-location-dot"></i> @T.T("Locations")
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#confirmDeleteModal"
                                    data-action="@Url.Action("Delete", "Businesses")"
                                    data-id="@item.Id"
                                    data-name="@item.Name"
                                    data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                    data-hx-target="#businesses-workspace-shell"
                                    data-hx-swap="outerHTML"
                                    data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                                <i class="fa-solid fa-box-archive"></i> @T.T("Archive")
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-operationalStatus="@Model.OperationalStatus"
       asp-route-attentionOnly="@Model.AttentionOnly"
       asp-route-readinessFilter="@Model.ReadinessFilter"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
