    <a asp-action="Index"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("Index", "Businesses")"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-rotate-left"></i> @T.T("ClearQueueFilters")
