@model Darwin.WebAdmin.ViewModels.Businesses.BusinessesListVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessesTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
}

<div id="businesses-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-building me-2"></i>@T.T("BusinessesTitle")</h1>
        <p class="text-muted mb-0">@T.T("BusinessesIntro")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="MerchantReadiness"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-store"></i> @T.T("MerchantReadinessTitle")
        </a>
        <a asp-action="SupportQueue"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-life-ring"></i> @T.T("SupportQueue")
        </a>
        @if (isFullAdmin)
        {
            <a asp-action="Create"
               class="btn btn-primary"
               hx-get="@Url.Action("Create", "Businesses")"
               hx-target="#businesses-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-plus"></i> @T.T("CreateBusiness")
            </a>
        }
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("NeedsAttention")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AttentionBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-attentionOnly="true"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("NeedsAttention")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("PendingApproval")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingApprovalBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-operationalStatus="PendingApproval"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "PendingApproval" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("PendingApproval")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("SuspendedBusinesses")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.SuspendedBusinessCount</div>
            <a asp-action="Index"
               asp-route-operationalStatus="Suspended"
               class="btn btn-sm btn-outline-secondary mt-auto"
               hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "Suspended" })"
               hx-target="#businesses-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenBusinessQueue")</a>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("BusinessesMissingOwner")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingOwnerBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessesMissingOwner")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("MissingPrimaryLocation")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingPrimaryLocationBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MissingPrimaryLocation")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("PendingInvites")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OpenInvitationCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("PendingInvites")</a>
                <a asp-controller="BusinessCommunications"
                   asp-action="EmailAudits"
                   asp-route-status="Failed"
                   asp-route-flowKey="BusinessInvitation"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "BusinessInvitation" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("PendingActivation")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingActivationMemberCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="Unconfirmed"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Users", new { filter = "Unconfirmed" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                <a asp-controller="BusinessCommunications"
                   asp-action="EmailAudits"
                   asp-route-status="Failed"
                   asp-route-flowKey="AccountActivation"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                <a asp-controller="MobileOperations"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "MobileOperations")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("LockedMembers")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.LockedMemberCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="Locked"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Users", new { filter = "Locked" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterLocked")</a>
                <a asp-controller="BusinessCommunications"
                   asp-action="EmailAudits"
                   asp-route-status="Failed"
                   asp-route-flowKey="PasswordReset"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset" })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                <a asp-controller="MobileOperations"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "MobileOperations")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-4 col-md-6">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("ApprovedInactive")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ApprovedInactiveBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
