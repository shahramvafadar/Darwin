@model Darwin.WebAdmin.ViewModels.Businesses.BusinessesListVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessesTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
}

<div id="businesses-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-building me-2"></i>@T.T("BusinessesTitle")</h1>
        <p class="text-muted mb-0">@T.T("BusinessesIntro")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="MerchantReadiness"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-store"></i> @T.T("MerchantReadinessTitle")
        </a>
        <a asp-action="SupportQueue"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-life-ring"></i> @T.T("SupportQueue")
        </a>
        @if (isFullAdmin)
        {
            <a asp-action="Create"
               class="btn btn-primary"
               hx-get="@Url.Action("Create", "Businesses")"
               hx-target="#businesses-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-plus"></i> @T.T("CreateBusiness")
            </a>
        }
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Index"
       asp-route-attentionOnly="true"
       class="btn btn-sm @(Model.AttentionOnly ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-triangle-exclamation"></i> @T.T("NeedsAttention")
    </a>
    <a asp-action="Index"
       asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval"
       class="btn btn-sm @(Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-hourglass-half"></i> @T.T("PendingApproval")
    </a>
    <a asp-action="Index"
       asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.Suspended"
       class="btn btn-sm @(Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.Suspended })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-ban"></i> @T.T("Suspended")
    </a>
    <a asp-action="Index"
       class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("Index", "Businesses")"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-rotate-left"></i> @T.T("ClearQueueFilters")
    </a>
</div>

<form method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "Businesses")"
      hx-target="#businesses-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchBusinessesPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="operationalStatus" asp-items="Model.OperationalStatusItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select">
            @foreach (var item in Model.PageSizeItems)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check mt-2">
            <input type="checkbox" name="attentionOnly" value="true" class="form-check-input" id="attentionOnly" checked="@(Model.AttentionOnly ? "checked" : null)" />
            <label class="form-check-label" for="attentionOnly">@T.T("NeedsAttentionOnly")</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses")"
           hx-target="#businesses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Business")</th>
                <th>@T.T("Category")</th>
                <th class="text-center">@T.T("Status")</th>
                <th class="text-center">@T.T("Owners")</th>
                <th class="text-center">@T.T("Members")</th>
                <th class="text-center">@T.T("Locations")</th>
                <th>@T.T("Attention")</th>
                <th class="text-end" style="width:360px">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-4">@T.T("NoBusinessesFound")</td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        @if (!string.IsNullOrWhiteSpace(item.LegalName))
                        {
                            <div class="text-muted small">@item.LegalName</div>
                        }
                    </td>
                    <td>@item.Category</td>
                    <td class="text-center">
                        @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                        {
                            <span class="badge text-bg-warning">@T.T("PendingApproval")</span>
                        }
                        else if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                        {
                            <span class="badge text-bg-danger">@T.T("Suspended")</span>
                        }
                        else if (item.IsActive)
                        {
                            <span class="badge text-bg-success">@T.T("Active")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@T.T("ApprovedInactive")</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (item.ActiveOwnerCount > 0)
                        {
                            <span class="badge text-bg-success">@item.ActiveOwnerCount</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">@T.T("MissingText")</span>
                        }
                    </td>
                    <td class="text-center">@item.MemberCount</td>
                    <td class="text-center">
                        @if (item.LocationCount > 0)
                        {
                            <span>@item.LocationCount</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">@T.T("MissingText")</span>
                        }
                    </td>
                    <td>
                        @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                        {
                            <div class="small"><span class="badge text-bg-warning">@T.T("ApprovalPending")</span></div>
                        }
                        @if (item.ActiveOwnerCount == 0)
                        {
                            <div class="small text-muted">@T.T("MissingActiveOwner")</div>
                        }
                        @if (item.PrimaryLocationCount == 0)
                        {
                            <div class="small text-muted">@T.T("MissingPrimaryLocation")</div>
                        }
                        @if (!item.HasContactEmailConfigured)
                        {
                            <div class="small text-muted">@T.T("MissingContactEmail")</div>
                        }
                        @if (!item.HasLegalNameConfigured)
                        {
                            <div class="small text-muted">@T.T("MissingLegalName")</div>
                        }
                        @if (item.InvitationCount > 0)
                        {
                            <div class="small text-muted">@item.InvitationCount @T.T("PendingInvites")</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Members"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-user-group"></i> @T.T("Members")
                        </a>
                        <a asp-action="Subscription"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Subscription", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-credit-card"></i> @T.T("Subscription")
                        </a>
                        <a asp-action="Invitations"
                           asp-route-businessId="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.Id })"
                           hx-target="#businesses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-envelope"></i> @T.T("Invitations")
                        </a>
                        @if (isFullAdmin)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-pen"></i> @T.T("Edit")
                            </a>
                            <a asp-action="Setup"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Setup", "Businesses", new { id = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-sliders"></i> @T.T("Setup")
                            </a>
                            <a asp-action="Locations"
                               asp-route-businessId="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Locations", "Businesses", new { businessId = item.Id })"
                               hx-target="#businesses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-location-dot"></i> @T.T("Locations")
                            </a>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#confirmDeleteModal"
                                    data-action="@Url.Action("Delete", "Businesses")"
                                    data-id="@item.Id"
                                    data-name="@item.Name"
                                    data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                    data-hx-target="#businesses-workspace-shell"
                                    data-hx-swap="outerHTML"
                                    data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                                <i class="fa-solid fa-box-archive"></i> @T.T("Archive")
                            </button>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-operationalStatus="@Model.OperationalStatus"
       asp-route-attentionOnly="@Model.AttentionOnly"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
