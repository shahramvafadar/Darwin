                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Payments", "Billing")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Payments")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("MissingContactEmail")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingContactEmailBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MissingContactEmail")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@T.T("MissingLegalName")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingLegalNameBusinessCount</div>
            <div class="mt-auto d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName })"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MissingLegalName")</a>
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#businesses-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("TaxComplianceScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>
                            <div class="mb-2">@playbook.OperatorAction</div>
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.FollowUpUrl))
                            {
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#businesses-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Index"
       asp-route-attentionOnly="true"
       class="btn btn-sm @(Model.AttentionOnly ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
       hx-target="#businesses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-triangle-exclamation"></i> @T.T("NeedsAttention")
    </a>
    <a asp-action="Index"
       asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval"
       class="btn btn-sm @(Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval ? "btn-warning" : "btn-outline-warning")"
