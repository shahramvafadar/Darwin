@model Darwin.WebAdmin.ViewModels.Businesses.BusinessMembersListVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessMembersTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
    string GlobalBusinessMembersUrl() => Url.Action("Members", "Businesses") ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessEditUrl(Guid? id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessOwnerOverrideAuditsUrl(Guid? businessId) => Url.Action("OwnerOverrideAudits", "Businesses", new { businessId }) ?? string.Empty;
    string CreateMemberUrl(Guid? businessId, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter) =>
        Url.Action("CreateMember", "Businesses", new { businessId, page, pageSize, query, filter }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string EmailAuditsUrl(Guid? businessId, string? status = null, string? flowKey = null) =>
        Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status, flowKey }) ?? string.Empty;
    string StaffAccessBadgeUrl(Guid? id) => Url.Action("StaffAccessBadge", "Businesses", new { id }) ?? string.Empty;
    string EditMemberUrl(Guid id, int page, int pageSize, string? query, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter) =>
        Url.Action("EditMember", "Businesses", new { id, page, pageSize, query, filter }) ?? string.Empty;
    string UserEditUrl(Guid? id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string LoyaltyAccountsUrl(string? q) => Url.Action("Accounts", "Loyalty", new { q }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string LocalizeBusinessMemberRole(object? role) => role is null ? "-" : T.T(role.ToString() ?? string.Empty);
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("CommonMembers")
    };
    string InvitationWorkspaceLabel() => T.T("Invitations");
    string MemberConfirmationStatusLabel(bool emailConfirmed) => emailConfirmed
        ? T.T("Confirmed")
        : MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation);
    string MemberActiveStatusLabel(bool isActive) => isActive ? T.T("Yes") : T.T("No");
}

<div id="business-members-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-user-group me-2"></i>@T.T("BusinessMembersTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="MobileOperations"
           asp-action="Index"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@MobileOperationsUrl(Model.Business.Id)"
           hx-target="#business-members-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@(Model.Business.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           class="btn btn-outline-secondary"
           hx-get="@BusinessInvitationsUrl(Model.Business.Id, Model.Business.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           hx-target="#business-members-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@InvitationWorkspaceLabel()</a>
        @if (isFullAdmin)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@BusinessEditUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
            <a asp-action="Setup"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@BusinessSetupUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Setup")</a>
            <a asp-action="OwnerOverrideAudits"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@BusinessOwnerOverrideAuditsUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersOwnerOverrideAuditAction")</a>
           <a asp-action="CreateMember"
               asp-route-businessId="@Model.Business.Id"
               asp-route-page="@Model.Page"
               asp-route-pageSize="@Model.PageSize"
               asp-route-query="@Model.Query"
               asp-route-filter="@Model.Filter"
               class="btn btn-primary"
               hx-get="@CreateMemberUrl(Model.Business.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-plus"></i> @T.T("BusinessMembersAssignMemberAction")
            </a>
        }
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@T.T("CommonTotal")</div>
            <div class="fw-semibold mt-1">@Model.Summary.TotalCount</div>
            <div class="mt-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Business.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessMembersUrl(Model.Business.Id)"
                   hx-target="#business-members-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonTotal")</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</div>
            <div class="fw-semibold mt-1">@Model.Summary.PendingActivationCount</div>
            <div class="mt-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@BusinessMembersUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                   hx-target="#business-members-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</div>
            <div class="fw-semibold mt-1">@Model.Summary.LockedCount</div>
            <div class="mt-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@BusinessMembersUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)"
                   hx-target="#business-members-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</div>
            <div class="fw-semibold mt-1">@Model.Summary.AttentionCount</div>
            <div class="mt-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessMembersUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                   hx-target="#business-members-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
            </div>
        </div>
    </div>
</div>

@if (Model.Business.ActiveOwnerCount == 0)
{
    <div class="alert alert-warning">
        <div>@T.T("BusinessMembersNoActiveOwnerWarning")</div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="OwnerOverrideAudits"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessOwnerOverrideAuditsUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersOwnerOverrideAuditAction")</a>
            <a asp-action="MerchantReadiness"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            <a asp-action="Setup"
               asp-route-id="@Model.Business.Id"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessSetupUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Setup")</a>
        </div>
    </div>
}

@if (Model.Items.Exists(x => !x.EmailConfirmed))
{
    <div class="alert alert-info">
        @T.T("BusinessMembersPendingActivationNote")
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Members"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessMembersUrl(Model.Business.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
            <a asp-controller="BusinessCommunications"
               asp-action="EmailAudits"
               asp-route-businessId="@Model.Business.Id"
               asp-route-status="Failed"
               asp-route-flowKey="AccountActivation"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@EmailAuditsUrl(Model.Business.Id, status: "Failed", flowKey: "AccountActivation")"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
            <a asp-controller="MobileOperations"
               asp-action="Index"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@MobileOperationsUrl(Model.Business.Id)"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        </div>
    </div>
}

<form method="get"
      class="row g-2 mb-3"
          hx-get="@GlobalBusinessMembersUrl()"
      hx-target="#business-members-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessMembersSearchPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")</button>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Business.Id)"
           hx-target="#business-members-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("BusinessSubscriptionQueueColumn")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("CommonActions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-members-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.QueueLabel</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#business-members-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.WhyItMatters</a>
                        </td>
                        <td>
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-members-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.OperatorAction</a>
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("User")</th>
                <th>@T.T("Email")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Role")</th>
                <th class="text-center">@T.T("Active")</th>
                        <th class="text-end admin-w-440">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">@T.T("BusinessMembersEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.UserDisplayName</td>
                    <td>@item.UserEmail</td>
                    <td>
                        @if (!item.EmailConfirmed)
                        {
                            <span class="badge text-bg-warning">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">@MemberConfirmationStatusLabel(item.EmailConfirmed)</span>
                        }

                        @if (item.LockoutEndUtc.HasValue && item.LockoutEndUtc.Value > DateTime.UtcNow)
                        {
                            <span class="badge text-bg-danger ms-1">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</span>
                        }
                    </td>
                    <td>@LocalizeBusinessMemberRole(item.Role)</td>
                    <td class="text-center">
                        @if (item.IsActive)
                        {
                            <span class="badge text-bg-success">@MemberActiveStatusLabel(item.IsActive)</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@MemberActiveStatusLabel(item.IsActive)</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-flex flex-wrap justify-content-end gap-2">
                            <a asp-action="StaffAccessBadge"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@StaffAccessBadgeUrl(item.Id)"
                               hx-target="#business-members-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa-solid fa-qrcode"></i> @T.T("BusinessMembersBadgeAction")
                            </a>
                            @if (isFullAdmin)
                            {
                                <a asp-action="EditMember"
                                   asp-route-id="@item.Id"
                                   asp-route-page="@Model.Page"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-query="@Model.Query"
                                   asp-route-filter="@Model.Filter"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@EditMemberUrl(item.Id, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-pen"></i> @T.T("CommonEdit")
                                </a>
                                <a asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@item.UserId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@UserEditUrl(item.UserId)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
                                </a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-businessId="@Model.Business.Id"
                                   asp-route-q="@item.UserEmail"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@MobileOperationsUrl(Model.Business.Id, item.UserEmail)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                                </a>
                                <a asp-controller="Loyalty"
                                   asp-action="Accounts"
                                   asp-route-q="@item.UserEmail"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@LoyaltyAccountsUrl(item.UserEmail)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-star"></i> @T.T("Loyalty")
                                </a>
                                <a asp-action="SupportQueue"
                                   asp-route-businessId="@Model.Business.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSupportQueueUrl(Model.Business.Id)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-life-ring"></i> @T.T("BusinessSupportQueueTitle")
                                </a>
                                <a asp-action="MerchantReadiness"
                                   asp-route-businessId="@Model.Business.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-list-check"></i> @T.T("MerchantReadinessTitle")
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("DeleteMember", "Businesses")"
                                        data-id="@item.Id"
                                        data-name="@item.UserDisplayName"
                                        data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                        data-userid="@Model.Business.Id"
                                        data-hx-target="#business-members-workspace-shell"
                                        data-hx-swap="outerHTML"
                                               >
                                    <i class="fa-solid fa-user-minus"></i> @T.T("Remove")
                                </button>
                            }
                        </div>
                        <div class="d-flex flex-wrap justify-content-end gap-2 mt-2">
                            @if (!item.EmailConfirmed)
                            {
                                <form asp-action="SendMemberActivationEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("SendMemberActivationEmail", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-paper-plane"></i> @T.T("BusinessMemberSendActivationAction")
                                    </button>
                                </form>
                                <form asp-action="ConfirmMemberEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("ConfirmMemberEmail", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa-solid fa-check"></i> @T.T("BusinessMemberConfirmEmailAction")
                                    </button>
                                </form>
                            }
                            <form asp-action="SendMemberPasswordReset"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("SendMemberPasswordReset", "Businesses")"
                                  hx-target="#business-members-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    <i class="fa-solid fa-key"></i> @T.T("BusinessMemberSendResetAction")
                                </button>
                            </form>
                            @if (item.LockoutEndUtc.HasValue && item.LockoutEndUtc.Value > DateTime.UtcNow)
                            {
                                <form asp-action="UnlockMemberUser"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("UnlockMemberUser", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa-solid fa-lock-open"></i> @T.T("UsersUnlockAction")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="LockMemberUser"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("LockMemberUser", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-lock"></i> @T.T("UsersLockAction")
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Members"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#business-members-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
