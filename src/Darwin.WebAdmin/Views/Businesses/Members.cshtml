@model Darwin.WebAdmin.ViewModels.Businesses.BusinessMembersListVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@{
    ViewData["Title"] = "Business Members";
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
}

<div id="business-members-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-user-group me-2"></i>Business Members</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-members-workspace-shell"
           hx-swap="outerHTML">Invitations</a>
        @if (isFullAdmin)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Business.Id })"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML">Back to business</a>
            <a asp-action="Setup"
               asp-route-id="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Business.Id })"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML">Setup</a>
            <a asp-action="OwnerOverrideAudits"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = Model.Business.Id })"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML">Owner override audit</a>
            <a asp-action="CreateMember"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-primary"
               hx-get="@Url.Action("CreateMember", "Businesses", new { businessId = Model.Business.Id })"
               hx-target="#business-members-workspace-shell"
               hx-swap="outerHTML">
                <i class="fa-solid fa-plus"></i> Assign member
            </a>
        }
    </div>
</div>

@if (Model.Business.ActiveOwnerCount == 0)
{
    <div class="alert alert-warning">
        This business currently has no active owner. Assign one before go-live.
    </div>
}

@if (Model.Items.Exists(x => !x.EmailConfirmed))
{
    <div class="alert alert-info">
        Some members are still pending activation. Use the inline support actions below to resend activation or confirm the email manually when support policy allows it.
    </div>
}

<form method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("Members", "Businesses")"
      hx-target="#business-members-workspace-shell"
      hx-swap="outerHTML">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by user name, email or role" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-members-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>User</th>
                <th>Email</th>
                <th>Status</th>
                <th>Role</th>
                <th class="text-center">Active</th>
                <th class="text-end" style="width:440px">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted py-4">No members assigned.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.UserDisplayName</td>
                    <td>@item.UserEmail</td>
                    <td>
                        @if (!item.EmailConfirmed)
                        {
                            <span class="badge text-bg-warning">Pending activation</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Confirmed</span>
                        }

                        @if (item.LockoutEndUtc.HasValue && item.LockoutEndUtc.Value > DateTime.UtcNow)
                        {
                            <span class="badge text-bg-danger ms-1">Locked</span>
                        }
                    </td>
                    <td>@item.Role</td>
                    <td class="text-center">
                        @if (item.IsActive)
                        {
                            <span class="badge text-bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">No</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-flex flex-wrap justify-content-end gap-2">
                            <a asp-action="StaffAccessBadge"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("StaffAccessBadge", "Businesses", new { id = item.Id })"
                               hx-target="#business-members-workspace-shell"
                               hx-swap="outerHTML">
                                <i class="fa-solid fa-qrcode"></i> Badge
                            </a>
                            @if (isFullAdmin)
                            {
                                <a asp-action="EditMember"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("EditMember", "Businesses", new { id = item.Id })"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </a>
                                <a asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@item.UserId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "Users", new { id = item.UserId })"
                                   hx-target="#business-members-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-user"></i> Open User
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-action="@Url.Action("DeleteMember", "Businesses")"
                                        data-id="@item.Id"
                                        data-name="@item.UserDisplayName"
                                        data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                        data-userid="@Model.Business.Id">
                                    <i class="fa-solid fa-user-minus"></i> Remove
                                </button>
                            }
                        </div>
                        <div class="d-flex flex-wrap justify-content-end gap-2 mt-2">
                            @if (!item.EmailConfirmed)
                            {
                                <form asp-action="SendMemberActivationEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("SendMemberActivationEmail", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-paper-plane"></i> Send activation
                                    </button>
                                </form>
                                <form asp-action="ConfirmMemberEmail"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("ConfirmMemberEmail", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa-solid fa-check"></i> Confirm email
                                    </button>
                                </form>
                            }
                            <form asp-action="SendMemberPasswordReset"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@Url.Action("SendMemberPasswordReset", "Businesses")"
                                  hx-target="#business-members-workspace-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="businessId" value="@item.BusinessId" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    <i class="fa-solid fa-key"></i> Send reset
                                </button>
                            </form>
                            @if (item.LockoutEndUtc.HasValue && item.LockoutEndUtc.Value > DateTime.UtcNow)
                            {
                                <form asp-action="UnlockMemberUser"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("UnlockMemberUser", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="fa-solid fa-lock-open"></i> Unlock
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="LockMemberUser"
                                      method="post"
                                      class="d-inline"
                                      hx-post="@Url.Action("LockMemberUser", "Businesses")"
                                      hx-target="#business-members-workspace-shell"
                                      hx-swap="outerHTML">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="businessId" value="@item.BusinessId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-lock"></i> Lock
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="Members"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
