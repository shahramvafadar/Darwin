@model Darwin.WebAdmin.ViewModels.Businesses.BusinessOwnerOverrideAuditsListVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessOwnerOverrideAuditsTitle");
    string ActorDisplayName(string? actorDisplayName) => string.IsNullOrWhiteSpace(actorDisplayName)
        ? T.T("CommonSystemUnknown")
        : actorDisplayName;
}

<div id="business-owner-override-audits-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-clipboard-list me-2"></i>@T.T("BusinessOwnerOverrideAuditsTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Setup"
           asp-route-id="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Business.Id })"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonSetup")</a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention })"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonMembers")</a>
    </div>
</div>

<div class="alert alert-warning">
    <div>@T.T("BusinessOwnerOverrideAuditsIntro")</div>
    <div class="d-flex gap-2 flex-wrap mt-3">
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention })"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonMembers")</a>
        <a asp-action="MerchantReadiness"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
        <a asp-action="SupportQueue"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
    </div>
</div>

<form method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("OwnerOverrideAudits", "Businesses")"
      hx-target="#business-owner-override-audits-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessOwnerOverrideAuditsSearchPlaceholder")" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("CommonSearch")</button>
        <a asp-action="OwnerOverrideAudits"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-owner-override-audits-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonReset")</a>
    </div>
</form>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("BusinessSubscriptionQueueColumn")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("CommonActions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.QueueLabel</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.WhyItMatters</a>
                        </td>
                        <td>
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.OperatorAction</a>
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-owner-override-audits-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-owner-override-audits-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("CommonWhen")</th>
                <th>@T.T("BusinessOwnerOverrideAffectedUser")</th>
                <th>@T.T("CommonAction")</th>
                <th>@T.T("CommonActor")</th>
                <th>@T.T("CommonReason")</th>
                <th class="text-end">@T.T("CommonActions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <div>@T.T("BusinessOwnerOverrideAuditsEmptyState")</div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center mt-3">
                        <a asp-action="Members"
                           asp-route-businessId="@Model.Business.Id"
                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention })"
                           hx-target="#business-owner-override-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonMembers")</a>
                        <a asp-action="Setup"
                           asp-route-id="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Setup", "Businesses", new { id = Model.Business.Id })"
                           hx-target="#business-owner-override-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonSetup")</a>
                        <a asp-action="MerchantReadiness"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                           hx-target="#business-owner-override-audits-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                    <td>
                        <div class="fw-semibold">@item.AffectedUserDisplayName</div>
                        <div class="text-muted small">@item.AffectedUserEmail</div>
                    </td>
                    <td>
                        @if (item.ActionKind == Darwin.Domain.Enums.BusinessOwnerOverrideActionKind.ForceRemove)
                        {
                            <span class="badge text-bg-danger">@T.T("BusinessOwnerOverrideForceRemove")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">@T.T("BusinessOwnerOverrideDemoteDeactivate")</span>
                        }
                    </td>
                    <td>@ActorDisplayName(item.ActorDisplayName)</td>
                    <td>@item.Reason</td>
                    <td class="text-end">
                        <div class="d-flex flex-wrap justify-content-end gap-2">
                            <a asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@item.AffectedUserId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "Users", new { id = item.AffectedUserId })"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenUserAction")</a>
                            <a asp-action="Members"
                               asp-route-businessId="@Model.Business.Id"
                               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Business.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention })"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("CommonMembers")</a>
                            <a asp-action="EditMember"
                               asp-route-id="@item.BusinessMemberId"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EditMember", "Businesses", new { id = item.BusinessMemberId })"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("EditMemberTitle")</a>
                            <a asp-action="SupportQueue"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("SupportQueue", "Businesses")"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                            <a asp-action="MerchantReadiness"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                               hx-target="#business-owner-override-audits-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="OwnerOverrideAudits"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query"
       hx-target="#business-owner-override-audits-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>
</div>
