@model Darwin.WebAdmin.ViewModels.Businesses.BusinessOwnerOverrideAuditsListVm
@{
    ViewData["Title"] = "Owner Override Audit";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-clipboard-list me-2"></i>Owner Override Audit</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Setup" asp-route-id="@Model.Business.Id" class="btn btn-outline-secondary">Setup</a>
        <a asp-action="Members" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">Members</a>
    </div>
</div>

<div class="alert alert-warning">
    These records show exceptional actions where a FullAdmin bypassed the rule that the last active owner must remain assigned.
</div>

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="businessId" value="@Model.Business.Id" />
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by actor, affected user, email, or reason" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
        <a asp-action="OwnerOverrideAudits" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>When</th>
                <th>Affected User</th>
                <th>Action</th>
                <th>Actor</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">No override audit rows exist for this business.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm 'UTC'")</td>
                    <td>
                        <div class="fw-semibold">@item.AffectedUserDisplayName</div>
                        <div class="text-muted small">@item.AffectedUserEmail</div>
                    </td>
                    <td>
                        @if (item.ActionKind == Darwin.Domain.Enums.BusinessOwnerOverrideActionKind.ForceRemove)
                        {
                            <span class="badge text-bg-danger">Force remove</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Demote / deactivate</span>
                        }
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(item.ActorDisplayName) ? "System / unknown" : item.ActorDisplayName)</td>
                    <td>@item.Reason</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Businesses"
       asp-action="OwnerOverrideAudits"
       asp-route-businessId="@Model.Business.Id"
       asp-route-query="@Model.Query">
</pager>
