@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSetupMembersPreviewVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

@if (Model.AttentionCount == 0)
{
    <div class="text-success">@T.T("BusinessSetupMembersPreviewNoAttention")</div>
    <div class="d-flex gap-2 flex-wrap mt-3">
        <a asp-action="Members"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.BusinessId })"
           hx-target="#business-setup-shell"
           hx-swap="outerHTML">@T.T("BusinessSetupOpenMembersAction")</a>
        <a asp-controller="MobileOperations"
           asp-action="Index"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Index", "MobileOperations")"
           hx-target="#business-setup-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="fw-semibold">@string.Format(T.T("BusinessSetupMembersPreviewAttentionCount"), Model.AttentionCount)</div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Members"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.BusinessId })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML">@T.T("BusinessSetupOpenMembersAction")</a>
            <a asp-controller="MobileOperations"
               asp-action="Index"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Index", "MobileOperations")"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>@T.T("User")</th>
                    <th>@T.T("Status")</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.UserDisplayName</div>
                        <div class="small text-muted">@item.UserEmail</div>
                        <div class="d-flex gap-2 flex-wrap mt-2">
                            <a asp-controller="MobileOperations"
                               asp-action="Index"
                               asp-route-q="@item.UserEmail"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "MobileOperations", new { q = item.UserEmail })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                            <a asp-controller="Loyalty"
                               asp-action="Accounts"
                               asp-route-q="@item.UserEmail"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Accounts", "Loyalty", new { q = item.UserEmail })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Loyalty")</a>
                        </div>
                    </td>
                    <td>
                        @if (!item.EmailConfirmed)
                        {
                            <span class="badge text-bg-warning">@T.T("PendingActivation")</span>
                        }
                        @if (item.LockoutEndUtc.HasValue && item.LockoutEndUtc.Value > DateTime.UtcNow)
                        {
                            <span class="badge text-bg-danger ms-1">@T.T("Locked")</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
