@model Darwin.WebAdmin.ViewModels.Businesses.BusinessInvitationCreateVm

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="alert alert-info">
    Use this flow when the intended owner or staff member does not yet have a platform account. A token email will be sent immediately.
</div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Role" class="form-label">Role</label>
        <select asp-for="Role" asp-items="Model.RoleOptions" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="ExpiresInDays" class="form-label">Expires in (days)</label>
        <input asp-for="ExpiresInDays" class="form-control" min="1" max="30" />
    </div>
    <div class="col-12">
        <label asp-for="Note" class="form-label">Internal note</label>
        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-paper-plane"></i> Send invitation
    </button>
    <a asp-action="Invitations"
       asp-route-businessId="@Model.BusinessId"
       class="btn btn-outline-secondary"
       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId })"
       hx-target="#business-invitation-editor-shell"
       hx-swap="outerHTML">Cancel</a>
</div>
