@model Darwin.WebAdmin.ViewModels.Businesses.BusinessInvitationCreateVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired => T.T("Expired"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Accepted => T.T("Accepted"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Revoked => T.T("Revoked"),
        _ => T.T("BusinessInvitationsAllLabel")
    };
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="alert alert-info">
    <div>@T.T("BusinessInvitationCreateHelp")</div>
    <div class="d-flex gap-2 flex-wrap mt-3">
        <a asp-action="Invitations"
           asp-route-businessId="@Model.BusinessId"
           asp-route-page="@Model.Page"
           asp-route-pageSize="@Model.PageSize"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, page = Model.Page, pageSize = Model.PageSize, query = Model.Query, filter = Model.Filter })"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@InvitationQueueLabel(Model.Filter)</a>
        <a asp-action="Setup"
           asp-route-id="@Model.BusinessId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Setup", "Businesses", new { id = Model.BusinessId })"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Setup")</a>
        <a asp-action="SupportQueue"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-businessId="@Model.BusinessId"
           asp-route-status="Failed"
           asp-route-flowKey="BusinessInvitation"
           asp-route-recipientEmail="@Model.Email"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.BusinessId, status = "Failed", flowKey = "BusinessInvitation", recipientEmail = Model.Email })"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
        <a asp-action="MerchantReadiness"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#business-invitation-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Email" class="form-label">@T.T("BusinessInvitationEmail")</label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Role" class="form-label">@T.T("BusinessInvitationRole")</label>
        <select asp-for="Role" asp-items="Model.RoleOptions" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="ExpiresInDays" class="form-label">@T.T("BusinessInvitationExpiresInDays")</label>
        <input asp-for="ExpiresInDays" class="form-control" min="1" max="30" />
    </div>
    <div class="col-12">
        <label asp-for="Note" class="form-label">@T.T("BusinessInvitationInternalNote")</label>
        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-paper-plane"></i> @T.T("BusinessInvitationSend")
    </button>
    <a asp-action="Invitations"
       asp-route-businessId="@Model.BusinessId"
       asp-route-page="@Model.Page"
       asp-route-pageSize="@Model.PageSize"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       class="btn btn-outline-secondary"
       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.BusinessId, page = Model.Page, pageSize = Model.PageSize, query = Model.Query, filter = Model.Filter })"
       hx-target="#business-invitation-editor-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Cancel")</a>
</div>
