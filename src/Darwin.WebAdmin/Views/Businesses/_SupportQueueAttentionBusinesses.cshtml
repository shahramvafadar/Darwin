@model IReadOnlyList<Darwin.WebAdmin.ViewModels.Businesses.BusinessListItemVm>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalSupportQueueAttentionFragmentUrl() => Url.Action("SupportQueueAttentionFragment", "Businesses") ?? string.Empty;
    string BusinessesAttentionUrl() => Url.Action("Index", "Businesses", new { attentionOnly = true }) ?? string.Empty;
    string BusinessEditUrl(Guid? id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessLocationsUrl(Guid? businessId) => Url.Action("Locations", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessCommunicationsDetailsUrl(Guid? businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string BusinessesByReadinessUrl(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter readinessFilter) =>
        Url.Action("Index", "Businesses", new { readinessFilter }) ?? string.Empty;
    string BusinessesByOperationalStatusUrl(Darwin.Domain.Enums.BusinessOperationalStatus operationalStatus) =>
        Url.Action("Index", "Businesses", new { operationalStatus }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string EmailAuditsUrl(Guid? businessId = null, string? status = null, string? flowKey = null, bool? retryBlockedOnly = null) =>
        Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status, flowKey, retryBlockedOnly }) ?? string.Empty;
    string ChannelAuditsUrl(Guid? businessId, bool? phoneVerificationOnly = null, bool? actionBlockedOnly = null, bool? escalationCandidatesOnly = null) =>
        Url.Action("ChannelAudits", "BusinessCommunications", new { businessId, phoneVerificationOnly, actionBlockedOnly, escalationCandidatesOnly }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string PaymentsUrl(Guid? businessId) => Url.Action("Payments", "Billing", new { businessId }) ?? string.Empty;
    string RefundsUrl(Guid? businessId) => Url.Action("Refunds", "Billing", new { businessId }) ?? string.Empty;
    string FinancialAccountsUrl(Guid? businessId) => Url.Action("FinancialAccounts", "Billing", new { businessId }) ?? string.Empty;
    string ExpensesUrl(Guid? businessId) => Url.Action("Expenses", "Billing", new { businessId }) ?? string.Empty;
    string JournalEntriesUrl(Guid? businessId) => Url.Action("JournalEntries", "Billing", new { businessId }) ?? string.Empty;
    string BusinessSubscriptionUrl(Guid? businessId) => Url.Action("Subscription", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSubscriptionInvoicesUrl(Guid? businessId) => Url.Action("SubscriptionInvoices", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessOwnerOverrideAuditsUrl(Guid? businessId) => Url.Action("OwnerOverrideAudits", "Businesses", new { businessId }) ?? string.Empty;
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
    string InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites => T.T("PendingInvites"),
        _ => T.T("Invitations")
    };
    string BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive => T.T("ApprovedInactive"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner => T.T("BusinessesMissingOwner"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation => T.T("MissingPrimaryLocation"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail => T.T("MissingContactEmail"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName => T.T("MissingLegalName"),
        _ => T.T("Readiness")
    };
    string BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("Suspended"),
        _ => T.T(status.ToString())
    };
}

<div id="support-queue-attention" class="card h-100">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("AttentionBusinesses")</span>
        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
          hx-get="@GlobalSupportQueueAttentionFragmentUrl()"
                    hx-target="#support-queue-attention"
                    hx-swap="outerHTML">
                @T.T("Refresh")
            </button>
            <a asp-action="Index"
               asp-route-attentionOnly="true"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessesAttentionUrl()"
               hx-target="#business-support-queue-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("BusinessLabel")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Signals")</th>
                        <th class="text-end">@T.T("Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">@T.T("NoAttentionBusinessesQueued")</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="text-decoration-none"
                                       hx-get="@BusinessEditUrl(item.Id)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.Name</a>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.LegalName))
                                {
                                    <div class="small text-muted">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessEditUrl(item.Id)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.LegalName</a>
                                    </div>
                                }
                            </td>
                            <td>
                                @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                                {
                                    <a asp-action="Index"
                                       asp-route-operationalStatus="PendingApproval"
                                       class="badge text-bg-warning text-decoration-none"
                                       hx-get="@BusinessesByOperationalStatusUrl(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)</a>
                                }
                                else if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                                {
                                    <a asp-action="Index"
                                       asp-route-operationalStatus="Suspended"
                                       class="badge text-bg-danger text-decoration-none"
                                       hx-get="@BusinessesByOperationalStatusUrl(Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)</a>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">@BusinessOperationalStatusLabel(item.OperationalStatus)</span>
                                }
                                @if (!item.IsActive)
                                {
                                    <a asp-action="Index"
                                       asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
                                       class="badge text-bg-warning ms-1 text-decoration-none"
                                       hx-get="@BusinessesByReadinessUrl(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)</a>
                                }
                            </td>
                            <td>
                                @if (item.ActiveOwnerCount == 0)
                                {
                                    <div class="small">
                                        <a asp-action="Members"
                                           asp-route-businessId="@item.Id"
                                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner)</a>
                                    </div>
                                }
                                @if (item.PrimaryLocationCount == 0)
                                {
                                    <div class="small">
                                        <a asp-action="Locations"
                                           asp-route-businessId="@item.Id"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessLocationsUrl(item.Id)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation)</a>
                                    </div>
                                }
                                @if (!item.HasContactEmailConfigured)
                                {
                                    <div class="small">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessEditUrl(item.Id)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail)</a>
                                    </div>
                                }
                                @if (!item.HasLegalNameConfigured)
                                {
                                    <div class="small">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessEditUrl(item.Id)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName)</a>
                                    </div>
                                }
                                @if (item.InvitationCount > 0)
                                {
                                    <div class="small">
                                        <a asp-action="Invitations"
                                           asp-route-businessId="@item.Id"
                                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                                           class="text-muted text-decoration-none"
                                           hx-get="@BusinessInvitationsUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.InvitationCount @InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</a>
                                    </div>
                                }
                                @if (!item.HasContactEmailConfigured)
                                {
                                    <div class="small">
                                        <a asp-controller="SiteSettings"
                                           asp-action="Edit"
                                           asp-fragment="site-settings-communications-policy"
                                           class="text-muted text-decoration-none"
                                           hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                           hx-target="#business-support-queue-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("CommunicationPolicy")</a>
                                    </div>
                                }
                                <div class="small">
                                    <a asp-action="Members"
                                       asp-route-businessId="@item.Id"
                                       asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                                       class="text-muted text-decoration-none"
                                       hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("PasswordReset")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="ChannelAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-phoneVerificationOnly="true"
                                       class="text-muted text-decoration-none"
                                       hx-get="@ChannelAuditsUrl(item.Id, phoneVerificationOnly: true)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("PhoneVerification")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-retryBlockedOnly="true"
                                       class="text-muted text-decoration-none"
                                       hx-get="@EmailAuditsUrl(item.Id, retryBlockedOnly: true)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("RetryBlocked")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="AccountActivation"
                                       class="text-muted text-decoration-none"
                                       hx-get="@EmailAuditsUrl(item.Id, status: "Failed", flowKey: "AccountActivation")"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="AdminCommunicationTest"
                                       class="text-muted text-decoration-none"
                                       hx-get="@EmailAuditsUrl(item.Id, status: "Failed", flowKey: "AdminCommunicationTest")"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("FailedAdminTests")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="ChannelAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-actionBlockedOnly="true"
                                       class="text-muted text-decoration-none"
                                       hx-get="@ChannelAuditsUrl(item.Id, actionBlockedOnly: true)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("ActionBlocked")</a>
                                </div>
                                <div class="small">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="ChannelAudits"
                                       asp-route-businessId="@item.Id"
                                       asp-route-escalationCandidatesOnly="true"
                                       class="text-muted text-decoration-none"
                                       hx-get="@ChannelAuditsUrl(item.Id, escalationCandidatesOnly: true)"
                                       hx-target="#business-support-queue-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("EscalationCandidates")</a>
                                </div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessEditUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Edit")</a>
                                <a asp-action="Setup"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@BusinessSetupUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Setup")</a>
                                <a asp-action="MerchantReadiness"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMerchantReadinessUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                                <a asp-action="Members"
                                   asp-route-businessId="@item.Id"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
                                <a asp-action="Members"
                                   asp-route-businessId="@item.Id"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
                                <a asp-action="Members"
                                   asp-route-businessId="@item.Id"
                                   asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessMembersUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
                                <a asp-action="Invitations"
                                    asp-route-businessId="@item.Id"
                                    asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                                    class="btn btn-sm btn-outline-secondary"
                                    hx-get="@BusinessInvitationsUrl(item.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                                    hx-target="#business-support-queue-workspace-shell"
                                    hx-swap="outerHTML"
                                    hx-push-url="true">@InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.Id"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="PasswordReset"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.Id, status: "Failed", flowKey: "PasswordReset")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
                                <a asp-action="Locations"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessLocationsUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Locations")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="Details"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessCommunicationsDetailsUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationOps")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-communications-policy"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@SiteSettingsUrl("site-settings-communications-policy")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("CommunicationPolicy")</a>
                                <a asp-controller="Billing"
                                   asp-action="Payments"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@PaymentsUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Payments")</a>
                                <a asp-action="Subscription"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSubscriptionUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Subscription")</a>
                                <a asp-action="SubscriptionInvoices"
                                   asp-route-businessId="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@BusinessSubscriptionInvoicesUrl(item.Id)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SubscriptionInvoicesTitle")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.Id"
                                   asp-route-retryBlockedOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.Id, retryBlockedOnly: true)"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("RetryBlocked")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.Id"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AccountActivation"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.Id, status: "Failed", flowKey: "AccountActivation")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="EmailAudits"
                                   asp-route-businessId="@item.Id"
                                   asp-route-status="Failed"
                                   asp-route-flowKey="AdminCommunicationTest"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EmailAuditsUrl(item.Id, status: "Failed", flowKey: "AdminCommunicationTest")"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("FailedAdminTests")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@item.Id"
                                   asp-route-phoneVerificationOnly="true"
