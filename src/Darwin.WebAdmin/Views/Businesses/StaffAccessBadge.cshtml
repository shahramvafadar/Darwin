@model Darwin.WebAdmin.ViewModels.Businesses.BusinessStaffAccessBadgeVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessStaffAccessBadgeTitle");
    var isLocked = Model.LockoutEndUtc.HasValue && Model.LockoutEndUtc.Value > DateTime.UtcNow;
    Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? backToMembersFilter =
        isLocked ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked :
        !Model.EmailConfirmed ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation :
        !Model.IsActive ? Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention :
        null;
    string EditMemberUrl(Guid? id) => Url.Action("EditMember", "Businesses", new { id }) ?? string.Empty;
    string UserEditUrl(Guid? id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId, string? q = null) => Url.Action("Index", "MobileOperations", new { businessId, q }) ?? string.Empty;
    string LoyaltyAccountsUrl(string? q) => Url.Action("Accounts", "Loyalty", new { q }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string StaffAccessBadgeUrl(Guid? id) => Url.Action("StaffAccessBadge", "Businesses", new { id }) ?? string.Empty;
    string UsersUrl(string? q = null, Darwin.Application.Identity.DTOs.UserQueueFilter? filter = null) =>
        Url.Action("Index", "Users", new { q, filter }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string LocalizeBusinessMemberRole(object? role) => role is null ? "-" : T.T(role.ToString() ?? string.Empty);
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("CommonMembers")
    };
}

<div id="business-staff-access-badge-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("BusinessStaffAccessBadgeTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name | @Model.UserDisplayName</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="EditMember"
           asp-route-id="@Model.MembershipId"
           class="btn btn-outline-secondary"
           hx-get="@EditMemberUrl(Model.MembershipId)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML">
            <i class="fa-solid fa-user-pen"></i> @T.T("EditMemberAction")
        </a>
        <a asp-controller="Users"
           asp-action="Edit"
           asp-route-id="@Model.UserId"
           class="btn btn-outline-secondary"
           hx-get="@UserEditUrl(Model.UserId)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
        </a>
        <a asp-controller="MobileOperations"
           asp-action="Index"
           asp-route-businessId="@Model.Business.Id"
           asp-route-q="@Model.UserEmail"
           class="btn btn-outline-secondary"
           hx-get="@MobileOperationsUrl(Model.Business.Id, Model.UserEmail)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
        </a>
        <a asp-controller="Loyalty"
           asp-action="Accounts"
           asp-route-q="@Model.UserEmail"
           class="btn btn-outline-secondary"
           hx-get="@LoyaltyAccountsUrl(Model.UserEmail)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-star"></i> @T.T("Loyalty")
        </a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@backToMembersFilter"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Business.Id, backToMembersFilter)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML">
            <i class="fa-solid fa-arrow-left"></i> @T.T("BackToMembersAction")
        </a>
        <a asp-action="StaffAccessBadge"
           asp-route-id="@Model.MembershipId"
           class="btn btn-primary"
           hx-get="@StaffAccessBadgeUrl(Model.MembershipId)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML">
            <i class="fa-solid fa-rotate"></i> @T.T("RefreshBadgeAction")
        </a>
    </div>
</div>

<div class="alert alert-info">
    <div>@T.T("BusinessStaffAccessBadgeIntro")</div>
    <div class="d-flex gap-2 flex-wrap mt-3">
        <a asp-action="EditMember"
           asp-route-id="@Model.MembershipId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@EditMemberUrl(Model.MembershipId)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML">
            <i class="fa-solid fa-user-pen"></i> @T.T("EditMemberAction")
        </a>
        <a asp-controller="Users"
           asp-action="Edit"
           asp-route-id="@Model.UserId"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@UserEditUrl(Model.UserId)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
        </a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Business.Id"
           asp-route-filter="@backToMembersFilter"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Business.Id, backToMembersFilter)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-users"></i> @T.T("CommonMembers")
        </a>
        <a asp-action="MerchantReadiness"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
           hx-target="#business-staff-access-badge-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-list-check"></i> @T.T("MerchantReadinessTitle")
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header">@T.T("BusinessStaffAccessBadgePreviewTitle")</div>
            <div class="card-body text-center">
                    <img src="@Model.BadgeImageDataUrl" alt="@T.T("BusinessStaffAccessBadgeQrAlt")" class="img-fluid border rounded p-3 bg-white admin-qr" />
                <div class="mt-3 fw-semibold">@Model.UserDisplayName</div>
                <div class="text-muted small">@Model.UserEmail</div>
                <div class="small text-muted mt-2">@T.T("BusinessStaffAccessBadgeMemberRoleLabel"): @LocalizeBusinessMemberRole(Model.Role)</div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header">@T.T("BusinessStaffAccessBadgeContextTitle")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("Business")</div>
                        <div class="fw-semibold">@Model.Business.Name</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("BusinessStaffAccessBadgeMemberRoleLabel")</div>
                        <div class="fw-semibold">@LocalizeBusinessMemberRole(Model.Role)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("BusinessStaffAccessBadgeIssuedAtLabel")</div>
                <div class="fw-semibold">@Model.IssuedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("BusinessStaffAccessBadgeExpiresAtLabel")</div>
                <div class="fw-semibold">@Model.ExpiresAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("BusinessStaffAccessBadgeEmailStateLabel")</div>
                        <div class="fw-semibold">@(Model.EmailConfirmed ? T.T("BusinessStaffAccessBadgeConfirmed") : T.T("BusinessStaffAccessBadgePendingActivation"))</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted text-uppercase">@T.T("BusinessStaffAccessBadgeAccessStateLabel")</div>
                        <div class="fw-semibold">
                            @(Model.IsActive ? T.T("BusinessStaffAccessBadgeMembershipActive") : T.T("BusinessStaffAccessBadgeMembershipInactive"))
                            @if (isLocked)
                            {
                                <span class="text-danger"> | @MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</span>
                            }
                        </div>
                    </div>
                </div>

                @if (!Model.EmailConfirmed || !Model.IsActive || isLocked)
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        <div>@T.T("BusinessStaffAccessBadgeConstraintWarning")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            @if (!Model.EmailConfirmed)
                            {
                                <a asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@Model.UserId"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@UserEditUrl(Model.UserId)"
                                   hx-target="#business-staff-access-badge-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
                                </a>
                            }
                            @if (!Model.IsActive)
                            {
                                <a asp-action="EditMember"
                                   asp-route-id="@Model.MembershipId"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@EditMemberUrl(Model.MembershipId)"
                                   hx-target="#business-staff-access-badge-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-user-pen"></i> @T.T("EditMemberAction")
                                </a>
                            }
                            @if (isLocked)
                            {
                                <a asp-controller="Users"
                                   asp-action="Index"
                                   asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                                   asp-route-q="@Model.UserEmail"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@UsersUrl(Model.UserEmail, Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
                                   hx-target="#business-staff-access-badge-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-user-lock"></i> @MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)
                                </a>
                            }
                            @if (!Model.EmailConfirmed || isLocked)
                            {
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   asp-route-businessId="@Model.Business.Id"
                                   asp-route-q="@Model.UserEmail"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@MobileOperationsUrl(Model.Business.Id, Model.UserEmail)"
                                   hx-target="#business-staff-access-badge-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    <i class="fa-solid fa-mobile-screen"></i> @T.T("MobileOperationsTitle")
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">@T.T("BusinessStaffAccessBadgePayloadTitle")</div>
    <div class="card-body">
        <p class="text-muted">
            @T.T("BusinessStaffAccessBadgePayloadNote")
        </p>
        <div class="d-flex gap-2 flex-wrap mb-3">
            <a asp-action="EditMember"
               asp-route-id="@Model.MembershipId"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@EditMemberUrl(Model.MembershipId)"
               hx-target="#business-staff-access-badge-shell"
               hx-swap="outerHTML">
                <i class="fa-solid fa-user-pen"></i> @T.T("EditMemberAction")
            </a>
            <a asp-controller="Users"
               asp-action="Edit"
               asp-route-id="@Model.UserId"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@UserEditUrl(Model.UserId)"
               hx-target="#business-staff-access-badge-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-user"></i> @T.T("OpenUserAction")
            </a>
            <a asp-action="Members"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@backToMembersFilter"
               class="btn btn-sm btn-outline-secondary"
                hx-get="@BusinessMembersUrl(Model.Business.Id, backToMembersFilter)"
               hx-target="#business-staff-access-badge-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-users"></i> @T.T("CommonMembers")
            </a>
            <a asp-action="MerchantReadiness"
               asp-route-businessId="@Model.Business.Id"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessMerchantReadinessUrl(Model.Business.Id)"
               hx-target="#business-staff-access-badge-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-list-check"></i> @T.T("MerchantReadinessTitle")
            </a>
        </div>
        <textarea class="form-control font-monospace" rows="10" readonly>@Model.BadgePayload</textarea>
    </div>
</div>
</div>
