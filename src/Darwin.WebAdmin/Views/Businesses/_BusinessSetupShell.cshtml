@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSetupTitle");
    var checklistComplete = Model.ActiveOwnerCount > 0 &&
                            Model.PrimaryLocationCount > 0 &&
                            Model.HasContactEmailConfigured &&
                            Model.HasLegalNameConfigured;
}

<div id="business-setup-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@T.T("BusinessSetupTitle")</h1>
            <p class="text-muted mb-0">@Model.Name</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-pen"></i> @T.T("EditBusiness")
            </a>
            <a asp-action="Members"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-user-group"></i> @T.T("Members")
            </a>
            <a asp-action="Locations"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Locations", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-location-dot"></i> @T.T("Locations")
            </a>
            <a asp-action="Invitations"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-envelope"></i> @T.T("Invitations")
            </a>
            <a asp-action="Subscription"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-credit-card"></i> @T.T("Subscription")
            </a>
            <a asp-action="OwnerOverrideAudits"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-clipboard-list"></i> @T.T("OverrideAudit")
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("OperationalStatus")</div>
                <div class="fw-semibold mt-1">@Model.OperationalStatus</div>
                <div class="small text-muted mt-2">@(Model.IsActive ? T.T("BusinessIsActive") : T.T("BusinessIsInactive"))</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("Checklist")</div>
                <div class="fw-semibold mt-1">@(checklistComplete ? T.T("Complete") : T.T("Incomplete"))</div>
                <div class="small text-muted mt-2">@Model.ActiveOwnerCount owner(s), @Model.PrimaryLocationCount primary location(s)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("Defaults")</div>
                <div class="fw-semibold mt-1">@Model.DefaultCulture / @Model.DefaultCurrency</div>
                <div class="small text-muted mt-2">@Model.DefaultTimeZoneId</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("GoLiveReadiness")</div>
                <div class="fw-semibold mt-1">@(checklistComplete && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved ? T.T("OperationallyReady") : T.T("StillPendingSetup"))</div>
                <div class="small text-muted mt-2">@T.T("ApprovalChecklistRequirement")</div>
            </div>
        </div>
    </div>

    @if (!checklistComplete)
    {
        <div class="alert alert-warning">
            @T.T("SetupIncompleteWarning")
        </div>
    }

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@T.T("SettingsOwnership")</span>
            <a asp-controller="SiteSettings"
               asp-action="Edit"
               asp-fragment="site-settings-communications-policy"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenGlobalSettings")</a>
        </div>
        <div class="card-body">
            <div class="small text-muted mb-3">
                @T.T("BusinessSetupOwnershipIntro")
            </div>
            <div class="row g-3">
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("BusinessOwnedHere")</div>
                        <ul class="small mb-0">
                            <li>@T.T("BusinessOwnedBranding")</li>
                            <li>@T.T("BusinessOwnedLocaleDefaults")</li>
                            <li>@T.T("BusinessOwnedSupportIdentity")</li>
                            <li>@T.T("BusinessOwnedCommunicationFlags")</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("GlobalDependencies")</div>
                        <ul class="small mb-0">
                            <li>@T.T("GlobalDependenciesProviders")</li>
                            <li>@T.T("GlobalDependenciesTemplates")</li>
                            <li>@T.T("GlobalDependenciesPaymentsShipping")</li>
                            <li>@T.T("GlobalDependenciesTaxIssuer")</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">@T.T("DirectHandoff")</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-business-app" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-business-app" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessApp")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-localization" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-localization" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Localization")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("CommunicationPolicy")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-payments" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Payments")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Tax")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-shipping" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Shipping")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("AdminAlerts")</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Setup"
          method="post"
          hx-post="@Url.Action("Setup", "Businesses")"
          hx-target="#business-setup-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="OperationalStatus" />
        <input type="hidden" asp-for="ApprovedAtUtc" />
        <input type="hidden" asp-for="SuspendedAtUtc" />
        <input type="hidden" asp-for="SuspensionReason" />
        <input type="hidden" asp-for="MemberCount" />
        <input type="hidden" asp-for="ActiveOwnerCount" />
        <input type="hidden" asp-for="LocationCount" />
        <input type="hidden" asp-for="PrimaryLocationCount" />
        <input type="hidden" asp-for="InvitationCount" />
        <input type="hidden" asp-for="HasContactEmailConfigured" />
        <input type="hidden" asp-for="HasLegalNameConfigured" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="card mb-4" id="business-profile-settings">
            <div class="card-header">@T.T("BusinessProfile")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">@T.T("BusinessName")</label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LegalName" class="form-label">@T.T("LegalName")</label>
                        <input asp-for="LegalName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TaxId" class="form-label">@T.T("TaxVatId")</label>
                        <input asp-for="TaxId" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Category" class="form-label">@T.T("Category")</label>
                        <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="WebsiteUrl" class="form-label">@T.T("Website")</label>
                        <input asp-for="WebsiteUrl" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactPhoneE164" class="form-label">@T.T("ContactPhoneE164")</label>
                        <input asp-for="ContactPhoneE164" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactEmail" class="form-label">@T.T("ContactEmail")</label>
                        <input asp-for="ContactEmail" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="ShortDescription" class="form-label">@T.T("ShortDescription")</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("LocalizationOperationalDefaults")</div>
            <div class="card-body">
                <div class="alert alert-light border small">
                    Business setup owns the tenant-facing override for culture, currency, and time zone. Change these only when this business must differ from the platform fallback. If every tenant should inherit a new baseline, change Site Settings instead.
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-localization"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-localization" })"
                           hx-target="#business-setup-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenGlobalLocalization")</a>
                        <a asp-controller="CRM"
                           asp-action="Customers"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Customers", "Crm")"
                           hx-target="#business-setup-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CustomerLocaleReview")</a>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="DefaultCulture" class="form-label">@T.T("DefaultCulture")</label>
                        <input asp-for="DefaultCulture" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DefaultCurrency" class="form-label">@T.T("DefaultCurrency")</label>
                        <input asp-for="DefaultCurrency" class="form-control" maxlength="3" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DefaultTimeZoneId" class="form-label">@T.T("DefaultTimeZone")</label>
                        <input asp-for="DefaultTimeZoneId" class="form-control" />
                        <div class="form-text">@T.T("DefaultTimeZoneHelp")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="IsActive" class="form-check-input" disabled="@(Model.OperationalStatus != Darwin.Domain.Enums.BusinessOperationalStatus.Approved)" />
                            <label asp-for="IsActive" class="form-check-label">@T.T("BusinessIsActive")</label>
                        </div>
                        @if (Model.OperationalStatus != Darwin.Domain.Enums.BusinessOperationalStatus.Approved)
                        {
                            <div class="form-text">@T.T("BusinessActivationBlockedUntilApproved")</div>
                        }
                    </div>
                    <div class="col-12">
                        <label asp-for="AdminTextOverridesJson" class="form-label">@T.T("BusinessAdminTextOverridesJson")</label>
                        <textarea asp-for="AdminTextOverridesJson" class="form-control font-monospace" rows="5" placeholder='{"de-DE":{"BusinessSetupTitle":"Betriebs-Setup"},"en-US":{"BusinessSetupTitle":"Business setup"}}'></textarea>
                        <span asp-validation-for="AdminTextOverridesJson" class="text-danger"></span>
                        <div class="form-text">
                            @T.T("BusinessAdminTextOverridesHelp")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("Branding")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="BrandDisplayName" class="form-label">@T.T("BrandDisplayName")</label>
                        <input asp-for="BrandDisplayName" class="form-control" />
                        <div class="form-text">@T.T("BrandDisplayNameHelp")</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BrandLogoUrl" class="form-label">@T.T("BrandLogoUrl")</label>
                        <input asp-for="BrandLogoUrl" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BrandPrimaryColorHex" class="form-label">@T.T("PrimaryBrandColor")</label>
                        <input asp-for="BrandPrimaryColorHex" class="form-control" placeholder="#0055AA" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BrandSecondaryColorHex" class="form-label">@T.T("SecondaryBrandColor")</label>
                        <input asp-for="BrandSecondaryColorHex" class="form-control" placeholder="#FFCC00" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("BusinessCommunicationDefaults")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="SupportEmail" class="form-label">@T.T("SupportEmail")</label>
                        <input asp-for="SupportEmail" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CommunicationSenderName" class="form-label">@T.T("SenderDisplayName")</label>
                        <input asp-for="CommunicationSenderName" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CommunicationReplyToEmail" class="form-label">@T.T("ReplyToEmail")</label>
                        <input asp-for="CommunicationReplyToEmail" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="CustomerEmailNotificationsEnabled" class="form-check-input" />
                            <label asp-for="CustomerEmailNotificationsEnabled" class="form-check-label">@T.T("CustomerTransactionalEmailsEnabled")</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="CustomerMarketingEmailsEnabled" class="form-check-input" />
                            <label asp-for="CustomerMarketingEmailsEnabled" class="form-check-label">@T.T("CustomerMarketingEmailsEnabled")</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="OperationalAlertEmailsEnabled" class="form-check-input" />
                            <label asp-for="OperationalAlertEmailsEnabled" class="form-check-label">@T.T("OperationalAlertEmailsEnabled")</label>
                        </div>
                    </div>
                </div>
                <div class="form-text mt-2">
                    @T.T("BusinessCommunicationDefaultsHelp")
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("CommunicationReadiness")</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-lg-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-semibold">@T.T("EmailDelivery")</div>
                                <span class="badge @(Model.CommunicationReadiness.EmailTransportConfigured ? "bg-success" : "bg-warning text-dark")">
                                    @(Model.CommunicationReadiness.EmailTransportConfigured ? T.T("Ready") : T.T("NeedsSetup"))
                                </span>
                            </div>
                            <div class="small text-muted">@Model.CommunicationReadiness.EmailTransportSummary</div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-semibold">@T.T("SmsDelivery")</div>
                                <span class="badge @(Model.CommunicationReadiness.SmsTransportConfigured ? "bg-success" : "bg-secondary")">
                                    @(Model.CommunicationReadiness.SmsTransportConfigured ? T.T("Ready") : T.T("NotReady"))
                                </span>
                            </div>
                            <div class="small text-muted">@Model.CommunicationReadiness.SmsTransportSummary</div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-semibold">@T.T("WhatsAppDelivery")</div>
                                <span class="badge @(Model.CommunicationReadiness.WhatsAppTransportConfigured ? "bg-success" : "bg-secondary")">
                                    @(Model.CommunicationReadiness.WhatsAppTransportConfigured ? T.T("Ready") : T.T("NotReady"))
                                </span>
                            </div>
                            <div class="small text-muted">@Model.CommunicationReadiness.WhatsAppTransportSummary</div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-semibold">@T.T("AdminAlertRouting")</div>
                                <span class="badge @((Model.CommunicationReadiness.AdminAlertEmailsConfigured || Model.CommunicationReadiness.AdminAlertSmsConfigured) ? "bg-success" : "bg-warning text-dark")">
                                    @((Model.CommunicationReadiness.AdminAlertEmailsConfigured || Model.CommunicationReadiness.AdminAlertSmsConfigured) ? T.T("Configured") : T.T("Missing"))
                                </span>
                            </div>
                            <div class="small text-muted">@Model.CommunicationReadiness.AdminRoutingSummary</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("BusinessSubscriptionSnapshot")</div>
            <div class="card-body">
                @if (Model.Subscription.HasSubscription)
                {
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small text-uppercase">@T.T("Plan")</div>
                                <div class="fw-semibold mt-1">@Model.Subscription.PlanName</div>
                                <div class="small text-muted mt-2">@Model.Subscription.Provider</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small text-uppercase">@T.T("Status")</div>
                                <div class="fw-semibold mt-1">@Model.Subscription.Status</div>
                                <div class="small text-muted mt-2">
                                    @if (Model.Subscription.CancelAtPeriodEnd)
                                    {
                                        <span>@T.T("CancelsAtPeriodEnd")</span>
                                    }
                                    else
                                    {
                                        <span>@T.T("RenewsNormally")</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small text-uppercase">@T.T("Amount")</div>
                                <div class="fw-semibold mt-1">@Model.Subscription.Currency @((Model.Subscription.UnitPriceMinor / 100M).ToString("0.00"))</div>
                                <div class="small text-muted mt-2">@T.T("CurrentPeriodEnd"): @(Model.Subscription.CurrentPeriodEndUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                            </div>
                        </div>
                    </div>
                    <div class="small text-muted mt-3">
                        @T.T("Started"): @(Model.Subscription.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                        @if (Model.Subscription.TrialEndsAtUtc.HasValue)
                        {
                            <span> | @T.T("TrialEnds"): @Model.Subscription.TrialEndsAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-0">
                        @T.T("NoActiveSubscriptionSnapshot")
                    </div>
                }
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-controller="Billing"
                       asp-action="Payments"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenPayments")</a>
                    <a asp-action="Subscription"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Subscription")</a>
                    <a asp-action="SubscriptionInvoices"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSubscriptionInvoicesTitle")</a>
                    <a asp-controller="SiteSettings"
                       asp-action="Edit"
                       asp-fragment="site-settings-business-app"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-business-app" })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessApp")</a>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("OperationalSetupActions")</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="CreateMember"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@Url.Action("CreateMember", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-user-plus"></i> @T.T("BusinessMembersAssignMemberAction")
                    </a>
                    <a asp-action="CreateLocation"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@Url.Action("CreateLocation", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-location-dot"></i> @T.T("BusinessLocationsAddLocationAction")
                    </a>
                    <a asp-action="CreateInvitation"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("CreateInvitation", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-envelope"></i> @T.T("BusinessInvitationsInviteUserAction")
                    </a>
                    <a asp-action="Members"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Members", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-user-group"></i> @T.T("Members")
                    </a>
                    <a asp-action="Invitations"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-list-check"></i> @T.T("Invitations")
                    </a>
                    <a asp-action="OwnerOverrideAudits"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-clipboard-list"></i> @T.T("BusinessSetupReviewOverrideAuditAction")
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">@T.T("BusinessSetupMembersRequiringAttentionTitle")</div>
                    <div class="card-body"
                         hx-get="@Url.Action("SetupMembersPreview", "Businesses", new { businessId = Model.Id })"
                         hx-trigger="load"
                         hx-target="this"
                         hx-swap="innerHTML">
                        <div class="text-muted">@T.T("BusinessSetupLoadingMemberStatus")</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">@T.T("OpenInvitations")</div>
                    <div class="card-body"
                         hx-get="@Url.Action("SetupInvitationsPreview", "Businesses", new { businessId = Model.Id })"
                         hx-trigger="load"
                         hx-target="this"
                         hx-swap="innerHTML">
                        <div class="text-muted">@T.T("BusinessSetupLoadingInvitationStatus")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">@T.T("BusinessSetupPlatformDependenciesTitle")</div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    @T.T("BusinessSetupPlatformDependenciesIntro")
                </p>
                <div class="alert alert-light border small">
                    @T.T("BusinessSetupPlatformDependenciesRule")
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold">@T.T("BusinessSetupSecurityMobileAccessTitle")</div>
                            <div class="small text-muted mt-2">@T.T("BusinessSetupSecurityMobileAccessNote")</div>
                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-security"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-security" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Security")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-mobile"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-mobile" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Mobile")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold">@T.T("Communications")</div>
                            <div class="small text-muted mt-2">@T.T("BusinessSetupCommunicationsDependencyNote")</div>
                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-smtp"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-smtp" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SMTP")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-sms"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-sms" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SMS")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-whatsapp"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-whatsapp" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("WhatsApp")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-admin-routing"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-admin-routing" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("AdminAlerts")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold">@T.T("BusinessSetupPaymentsShippingTitle")</div>
                            <div class="small text-muted mt-2">@T.T("BusinessSetupPaymentsShippingNote")</div>
                            <a asp-controller="SiteSettings"
                               asp-action="Edit"
                               class="btn btn-sm btn-outline-secondary mt-3"
                               hx-get="@Url.Action("Edit", "SiteSettings")"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenSiteSettingsAction")</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i> @T.T("BusinessSetupSaveAction")
            </button>
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
        </div>
    </form>
</div>
