@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSetupTitle");
    var checklistComplete = Model.ActiveOwnerCount > 0 &&
                            Model.PrimaryLocationCount > 0 &&
                            Model.HasContactEmailConfigured &&
                            Model.HasLegalNameConfigured;
    var setupOverrideCultures = Darwin.Application.Settings.DTOs.SiteSettingDto.SupportedCulturesCsvDefault
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var setupPrimaryCulture = setupOverrideCultures.Length > 0
        ? setupOverrideCultures[0]
        : Darwin.WebAdmin.Localization.AdminCultureCatalog.DefaultCulture;
    var setupSecondaryCulture = setupOverrideCultures.Length > 1 ? setupOverrideCultures[1] : setupPrimaryCulture;
    string MemberSupportFilterLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
    string MemberWorkspaceLabel() => T.T("Members");
    string InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Open => T.T("OpenInvitations"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending => T.T("Pending"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Expired => T.T("Expired"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Accepted => T.T("Accepted"),
        Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Revoked => T.T("Revoked"),
        _ => T.T("BusinessInvitationsAllLabel")
    };
    string BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner => T.T("BusinessesMissingOwner"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation => T.T("MissingPrimaryLocation"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail => T.T("MissingContactEmail"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName => T.T("MissingLegalName"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive => T.T("ApprovedInactive"),
        _ => T.T("Readiness")
    };
    string CommunicationChannelLabel(string channel) => string.Equals(channel, "WhatsApp", StringComparison.OrdinalIgnoreCase)
        ? T.T("BusinessCommunicationWhatsAppShort")
        : T.T("SMS");
    string DependencyStatusLabel(bool configured, string configuredLabel, string missingLabel) => configured
        ? T.T(configuredLabel)
        : T.T(missingLabel);
    string BusinessLifecycleStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("BusinessEditorPendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Approved => T.T("BusinessEditorApproved"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("BusinessEditorSuspended"),
        _ => T.T(status.ToString())
    };
    string SubscriptionStatusLabel(string? status) => string.IsNullOrWhiteSpace(status) ? "-" : T.T(status);
    string SetupDependencyBadgeClass(bool configured) => configured
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string SetupDependencyStatusText(bool configured) => configured
        ? T.T("Configured")
        : T.T("NeedsAttention");
    string ConfiguredBusinessValueText(string? value) => string.IsNullOrWhiteSpace(value) ? T.T("NotConfigured") : value.Trim();
    bool businessEmailIdentityReady = !string.IsNullOrWhiteSpace(Model.SupportEmail)
        && !string.IsNullOrWhiteSpace(Model.CommunicationSenderName)
        && !string.IsNullOrWhiteSpace(Model.CommunicationReplyToEmail);
    bool businessTransactionalReady = Model.CustomerEmailNotificationsEnabled
        && Model.CommunicationReadiness.EmailTransportConfigured
        && businessEmailIdentityReady;
    bool businessMarketingReady = Model.CustomerMarketingEmailsEnabled
        && Model.CommunicationReadiness.EmailTransportConfigured
        && businessEmailIdentityReady;
    bool businessOperationalAlertsReady = Model.OperationalAlertEmailsEnabled
        && (Model.CommunicationReadiness.AdminAlertEmailsConfigured || Model.CommunicationReadiness.AdminAlertSmsConfigured);
    bool businessInvitationDefaultsReady = Model.CustomerEmailNotificationsEnabled
        && businessTransactionalReady
        && !string.IsNullOrWhiteSpace(Model.SupportEmail);
    bool businessActivationDefaultsReady = businessTransactionalReady;
    bool businessPasswordResetDefaultsReady = businessTransactionalReady;
    bool businessPhoneVerificationDefaultsReady = Model.CommunicationReadiness.SmsTransportConfigured
        || Model.CommunicationReadiness.WhatsAppTransportConfigured;
    bool businessCommunicationDeliveryVisibilityReady = Model.CommunicationReadiness.EmailTransportConfigured
        && (Model.CommunicationReadiness.AdminAlertEmailsConfigured || Model.CommunicationReadiness.AdminAlertSmsConfigured)
        && (Model.CommunicationReadiness.SmsTransportConfigured || Model.CommunicationReadiness.WhatsAppTransportConfigured);
    bool businessCommunicationRuntimeExecutionReady = businessInvitationDefaultsReady
        && businessActivationDefaultsReady
        && businessPasswordResetDefaultsReady
        && businessPhoneVerificationDefaultsReady;
    bool businessCommunicationDefaultsReady = businessInvitationDefaultsReady
        && businessActivationDefaultsReady
        && businessPasswordResetDefaultsReady
        && businessPhoneVerificationDefaultsReady;
    bool businessTaxProfileReady = !string.IsNullOrWhiteSpace(Model.LegalName)
        && !string.IsNullOrWhiteSpace(Model.TaxId);
    bool businessLocationReady = Model.PrimaryLocationCount > 0;
    bool businessSetupCoreReady = checklistComplete
        && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved
        && Model.IsActive;
    bool businessCommerceReady = businessTaxProfileReady
        && businessLocationReady
        && Model.Subscription.HasSubscription;
    var setupOverridePlaceholder =
        "{\"" + setupPrimaryCulture + "\":{\"BusinessSetupTitle\":\"" + T.T("BusinessSetupTitleExampleGerman") + "\"},\"" +
        setupSecondaryCulture + "\":{\"BusinessSetupTitle\":\"" + T.T("BusinessSetupTitleExampleEnglish") + "\"}}";
}

<div id="business-setup-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@T.T("BusinessSetupTitle")</h1>
            <p class="text-muted mb-0">@Model.Name</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-pen"></i> @T.T("EditBusiness")
            </a>
            <a asp-action="Members"
               asp-route-businessId="@Model.Id"
               asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
               class="btn btn-outline-secondary"
               hx-get="@(Model.ActiveOwnerCount > 0
                   ? Url.Action("Members", "Businesses", new { businessId = Model.Id })
                   : Url.Action("Members", "Businesses", new { businessId = Model.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention }))"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-user-group"></i> @MemberWorkspaceLabel()
            </a>
            <a asp-action="Locations"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Locations", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-location-dot"></i> @T.T("Locations")
            </a>
            <a asp-action="Invitations"
               asp-route-businessId="@Model.Id"
               asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Invitations", "Businesses", new { businessId = Model.Id, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-envelope"></i> @InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)
            </a>
            <a asp-action="Subscription"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-credit-card"></i> @T.T("Subscription")
            </a>
            <a asp-action="OwnerOverrideAudits"
               asp-route-businessId="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("OwnerOverrideAudits", "Businesses", new { businessId = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">
                <i class="fa-solid fa-clipboard-list"></i> @T.T("OverrideAudit")
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("OperationalStatus")</div>
                <div class="fw-semibold mt-1">@BusinessLifecycleStatusLabel(Model.OperationalStatus)</div>
                <div class="small text-muted mt-2">@(Model.IsActive ? T.T("BusinessIsActive") : T.T("BusinessIsInactive"))</div>
                @if (Model.ApprovedAtUtc.HasValue)
                {
                    <div class="small text-muted mt-2">@string.Format(T.T("BusinessEditorApprovedAt"), Model.ApprovedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                }
                @if (Model.SuspendedAtUtc.HasValue)
                {
                    <div class="small text-muted mt-1">@string.Format(T.T("BusinessEditorSuspendedAt"), Model.SuspendedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SuspensionReason))
                {
                    <div class="small text-muted mt-1">@string.Format(T.T("BusinessEditorReasonValue"), Model.SuspensionReason)</div>
                }
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-action="Index"
                       asp-route-operationalStatus="@Model.OperationalStatus"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Model.OperationalStatus })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OperationalStatus")</a>
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("EditBusiness")</a>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    @if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <input type="hidden" name="returnToSetup" value="true" />
                            <button type="submit" class="btn btn-sm btn-success">@T.T("BusinessEditorApprove")</button>
                        </form>
                    }
                    else if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Reactivate" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <input type="hidden" name="returnToSetup" value="true" />
                            <button type="submit" class="btn btn-sm btn-success">@T.T("BusinessEditorReactivate")</button>
                        </form>
                    }
                    @if (Model.OperationalStatus != Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Suspend" method="post" class="d-flex gap-2 flex-wrap">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <input type="hidden" name="returnToSetup" value="true" />
                            <input type="text"
                                   name="note"
                                   class="form-control form-control-sm"
                                   style="min-width: 220px;"
                                   placeholder="@T.T("BusinessEditorOptionalSuspensionReason")" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("BusinessEditorSuspend")</button>
                        </form>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("Checklist")</div>
                <div class="fw-semibold mt-1">@(checklistComplete ? T.T("Complete") : T.T("Incomplete"))</div>
                <div class="small text-muted mt-2">@string.Format(T.T("BusinessSetupChecklistCounts"), Model.ActiveOwnerCount, Model.PrimaryLocationCount)</div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-action="Members"
                       asp-route-businessId="@Model.Id"
                       asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@(Model.ActiveOwnerCount > 0
                           ? Url.Action("Members", "Businesses", new { businessId = Model.Id })
                           : Url.Action("Members", "Businesses", new { businessId = Model.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention }))"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@MemberWorkspaceLabel()</a>
                    <a asp-action="Locations"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Locations", "Businesses", new { businessId = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Locations")</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("Defaults")</div>
                <div class="fw-semibold mt-1">@Model.DefaultCulture / @Model.DefaultCurrency</div>
                <div class="small text-muted mt-2">@Model.DefaultTimeZoneId</div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-controller="SiteSettings"
                       asp-action="Edit"
                       asp-fragment="site-settings-localization"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-localization" })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("OpenGlobalLocalization")</a>
                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("EditBusiness")</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("GoLiveReadiness")</div>
                <div class="fw-semibold mt-1">@(checklistComplete && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved ? T.T("OperationallyReady") : T.T("StillPendingSetup"))</div>
                <div class="small text-muted mt-2">@T.T("ApprovalChecklistRequirement")</div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-action="MerchantReadiness"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    <a asp-action="SupportQueue"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                       hx-target="#business-setup-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("GoLiveReadiness")</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@T.T("OperationalStatus")</div>
                            <span class="@SetupDependencyBadgeClass(businessSetupCoreReady)">@SetupDependencyStatusText(businessSetupCoreReady)</span>
                        </div>
                        <div class="small mb-2">@BusinessLifecycleStatusLabel(Model.OperationalStatus)</div>
                        <div class="small text-muted mb-3">@string.Format(T.T("BusinessSetupChecklistCounts"), Model.ActiveOwnerCount, Model.PrimaryLocationCount)</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="MerchantReadiness"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                            <a asp-action="SupportQueue"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("SupportQueue", "Businesses")"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@T.T("TaxComplianceTitle")</div>
                            <span class="@SetupDependencyBadgeClass(businessTaxProfileReady)">@SetupDependencyStatusText(businessTaxProfileReady)</span>
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("LegalName"):</span>
                            @ConfiguredBusinessValueText(Model.LegalName)
                        </div>
                        <div class="small text-muted mb-3">
                            <span class="fw-semibold">@T.T("TaxVatId"):</span>
                            @ConfiguredBusinessValueText(Model.TaxId)
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Billing"
                               asp-action="TaxCompliance"
                               asp-route-businessId="@Model.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("TaxCompliance", "Billing", new { businessId = Model.Id })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("TaxComplianceTitle")</a>
                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("EditBusiness")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@T.T("CommunicationReadiness")</div>
                            <span class="@SetupDependencyBadgeClass(businessTransactionalReady && businessOperationalAlertsReady)">@SetupDependencyStatusText(businessTransactionalReady && businessOperationalAlertsReady)</span>
                        </div>
                        <div class="small mb-2">@Model.CommunicationReadiness.EmailTransportSummary</div>
                        <div class="small mb-3">@Model.CommunicationReadiness.AdminRoutingSummary</div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("CommunicationPolicy"):</span>
                            @SetupDependencyStatusText(businessTransactionalReady && businessOperationalAlertsReady)
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("RetryBlocked"):</span>
                            @SetupDependencyStatusText(businessCommunicationDeliveryVisibilityReady)
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("UsersFilterUnconfirmed"):</span>
                            @SetupDependencyStatusText(businessActivationDefaultsReady)
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@InvitationQueueLabel(Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending):</span>
                            @SetupDependencyStatusText(businessInvitationDefaultsReady)
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("PasswordReset"):</span>
                            @SetupDependencyStatusText(businessPasswordResetDefaultsReady)
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("OpenFailedPasswordResets"):</span>
                            @SetupDependencyStatusText(businessPasswordResetDefaultsReady)
                        </div>
                        <div class="small mb-3">
                            <span class="fw-semibold">@T.T("PhoneVerification"):</span>
                            @SetupDependencyStatusText(businessPhoneVerificationDefaultsReady)
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="BusinessCommunications"
                               asp-action="Details"
                               asp-route-businessId="@Model.Id"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Details", "BusinessCommunications", new { businessId = Model.Id })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessCommunicationProfileTitle")</a>
                            <a asp-controller="SiteSettings"
                               asp-action="Edit"
                               asp-fragment="site-settings-communications-policy"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-communications-policy" })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("CommunicationPolicy")</a>
                            <a asp-controller="Users"
                               asp-action="Index"
                               asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                            <a asp-controller="BusinessCommunications"
                               asp-action="EmailAudits"
                               asp-route-businessId="@Model.Id"
                               asp-route-retryBlockedOnly="true"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { businessId = Model.Id, retryBlockedOnly = true })"
                               hx-target="#business-setup-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("RetryBlocked")</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@T.T("Subscription")</div>
                            <span class="@SetupDependencyBadgeClass(businessCommerceReady)">@SetupDependencyStatusText(businessCommerceReady)</span>
                        </div>
                        <div class="small mb-2">
                            <span class="fw-semibold">@T.T("Locations"):</span>
