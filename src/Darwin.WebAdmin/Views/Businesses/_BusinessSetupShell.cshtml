                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("SmsWhatsAppAuditsTitle")</a>
                                <a asp-controller="BusinessCommunications"
                                   asp-action="ChannelAudits"
                                   asp-route-businessId="@Model.Id"
                                   asp-route-phoneVerificationOnly="true"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { businessId = Model.Id, phoneVerificationOnly = true })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("PhoneVerification")</a>
                                <a asp-controller="MobileOperations"
                                   asp-action="Index"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "MobileOperations")"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("MobileOperationsTitle")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold">@T.T("BusinessSetupPaymentsShippingTitle")</div>
                            <div class="small text-muted mt-2">@T.T("BusinessSetupPaymentsShippingNote")</div>
                            <div class="d-flex gap-2 mt-3 flex-wrap">
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-payments"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Payments")</a>
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-shipping"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Shipping")</a>
                                <a asp-controller="Billing"
                                   asp-action="Payments"
                                   asp-route-businessId="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.Id })"
                                   hx-target="#business-setup-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("OpenPayments")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i> @T.T("BusinessSetupSaveAction")
            </button>
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Edit", "Businesses", new { id = Model.Id })"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessMembersBackToBusinessAction")</a>
            <a asp-action="MerchantReadiness"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("MerchantReadiness", "Businesses")"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            <a asp-action="SupportQueue"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("SupportQueue", "Businesses")"
               hx-target="#business-setup-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        </div>
    </form>
</div>
