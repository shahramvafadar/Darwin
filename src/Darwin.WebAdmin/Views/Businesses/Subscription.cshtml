@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionWorkspaceVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSubscriptionTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
    string SubscriptionStatusText(string? status) => string.IsNullOrWhiteSpace(status) ? "-" : T.T(status);
    string SubscriptionInvoiceStatusText(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string SubscriptionValueText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    bool SubscriptionUserHasFullAdminAccess() => isFullAdmin;
    string SubscriptionWorkspaceTitleText() => T.T("BusinessSubscriptionTitle");
    string SubscriptionWorkspaceBusinessNameText() => Model.Business.Name;
string SubscriptionEditActionText() => T.T("CommonEditBusiness");
string SubscriptionSetupActionText() => T.T("CommonSetup");
string SubscriptionPaymentsActionText() => T.T("CommonPayments");
string SubscriptionInvoiceQueueActionText() => T.T("BusinessSubscriptionOpenInvoiceQueue");
string SubscriptionMerchantReadinessActionText() => T.T("MerchantReadinessTitle");
string SubscriptionSupportQueueActionText() => T.T("BusinessSupportQueueTitle");
    string SubscriptionRenewalStatusText(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? T.T("BusinessSubscriptionCancelAtPeriodEnd") : T.T("BusinessSubscriptionRenewsNormally");
    string SubscriptionBillingReadinessStatusText(bool isConfigured) => isConfigured ? T.T("CommonConfigured") : T.T("CommonMissingBadge");
string SubscriptionRenewalToggleActionText(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? T.T("BusinessSubscriptionRestoreRenewal") : T.T("BusinessSubscriptionCancelAtPeriodEndAction");
    string SubscriptionRenewalToggleActionToneClass(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? "btn-outline-success" : "btn-outline-danger";
    string SubscriptionRenewalToggleActionButtonClass(bool cancelAtPeriodEnd) => $"btn {SubscriptionRenewalToggleActionToneClass(cancelAtPeriodEnd)}";
    string SubscriptionOverviewPlanText(bool hasSubscription, string? planName) => hasSubscription ? planName ?? string.Empty : T.T("BusinessSubscriptionNoActivePlan");
    string SubscriptionDateTimeText(DateTime? value) => value?.ToString("yyyy-MM-dd HH:mm") ?? "-";
    string SubscriptionTrialText(int? trialDays) => trialDays.HasValue ? string.Format(T.T("BusinessSubscriptionTrialDays"), trialDays.Value) : "-";
    string SubscriptionMoneyText(string currency, long amountMinor) => $"{currency} {(amountMinor / 100M).ToString("0.00")}";
    string SubscriptionTimelineText(string labelKey, DateTime? value) => string.Format(T.T(labelKey), SubscriptionDateTimeText(value));
    string SubscriptionIntervalText(int intervalCount, string interval) => string.Format(T.T("BusinessSubscriptionEveryInterval"), intervalCount, interval);
    string SubscriptionInvoiceStatusBadgeToneClass(Darwin.Domain.Enums.SubscriptionInvoiceStatus status) => status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary";
    string SubscriptionPlanCheckoutBadgeToneClass(bool checkoutReady) => checkoutReady ? "bg-success" : "bg-warning text-dark";
    string SubscriptionInvoiceQueueSignalFilterToneClass(Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter filter) => filter == Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter.Overdue || filter == Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter.Uncollectible ? "btn-outline-danger" : "btn-outline-warning";
    string SubscriptionInvoiceQueueSignalFilterButtonClass(Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter filter) => $"btn btn-sm {SubscriptionInvoiceQueueSignalFilterToneClass(filter)}";
    string SubscriptionInvoiceFollowUpBadgeToneClass(bool isWarning) => isWarning ? "bg-warning text-dark mt-1" : "bg-danger mt-1";
    string SubscriptionCurrentPlanBadgeToneClass() => "bg-primary mt-1";
    string SubscriptionTopRailActionButtonClass() => "btn btn-outline-secondary";
