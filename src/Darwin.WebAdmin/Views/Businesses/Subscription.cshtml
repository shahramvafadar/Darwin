<div class="@SubscriptionSectionCardClass()">
    <div class="@SubscriptionSectionTitleBarClass()">@SubscriptionPlansSectionTitleText()</div>
    <div class="@SubscriptionTableCardBodyClass()">
        <div class="@SubscriptionTableViewportClass()">
            <table class="@SubscriptionSectionDataTableClass()">
                <thead class="@SubscriptionSectionDataTableHeaderClass()">
                    <tr>
                    <th>@SubscriptionPlanColumnLabelText()</th>
                    <th>@SubscriptionPriceColumnLabelText()</th>
                    <th>@SubscriptionIntervalColumnLabelText()</th>
                    <th>@SubscriptionTrialColumnLabelText()</th>
                    <th>@SubscriptionCheckoutColumnLabelText()</th>
                    <th class="@SubscriptionSectionTableActionsColumnClass()">@SubscriptionActionsColumnLabelText()</th>
                    </tr>
                </thead>
                <tbody>
        @if (!SubscriptionHasAvailablePlanRows())
                    {
                        <tr>
                            <td colspan="6" class="@SubscriptionEmptyStateCellClass()">
                                <div>@SubscriptionPlansEmptyStateMessageText()</div>
                                <div class="@SubscriptionEmptyStateActionsClass()">
                                    <a href="@SubscriptionSetupWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                       hx-get="@SubscriptionSetupWorkspaceActionHref()"
                                       hx-target="@SubscriptionWorkspaceRootTarget()"
                                       hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSetupActionText()</a>
                                    <a href="@SubscriptionMerchantReadinessWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                       hx-get="@SubscriptionMerchantReadinessWorkspaceActionHref()"
                                       hx-target="@SubscriptionWorkspaceRootTarget()"
                                       hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                                    <a href="@SubscriptionSupportQueueWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                       hx-get="@SubscriptionSupportQueueWorkspaceActionHref()"
                                       hx-target="@SubscriptionWorkspaceRootTarget()"
                                       hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSupportQueueActionText()</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var plan in Model.Plans)
                        {
                            <tr>
                                <td>
                                        <div class="@SubscriptionRowPrimaryTextClass()">@SubscriptionPlanRowNameText(plan)</div>
                                        <div class="@SubscriptionRowSecondaryTextClass()">@SubscriptionPlanRowCodeText(plan)</div>
                                    @if (SubscriptionPlanHasCurrentBadge(plan.IsCurrentPlan))
                                    {
                                    <div><span class="@SubscriptionBadgeClass() @SubscriptionCurrentPlanBadgeToneClass()">@SubscriptionCurrentPlanBadgeLabelText()</span></div>
                                    }
                                    @if (SubscriptionPlanShowsDescription(plan.Description))
                                    {
                                        <div class="@SubscriptionPlanRowSupportingTextClass()">@SubscriptionPlanRowDescriptionText(plan)</div>
                                    }
                                </td>
                                <td>@SubscriptionMoneyText(plan.Currency, plan.PriceMinor)</td>
                                <td>@SubscriptionIntervalText(plan.IntervalCount, plan.Interval)</td>
                                <td>@SubscriptionTrialText(plan.TrialDays)</td>
                                <td>
                                    <span class="@SubscriptionBadgeClass() @SubscriptionPlanCheckoutBadgeToneClass(plan.CheckoutReady)">@SubscriptionPlanRowCheckoutText(plan)</span>
                                    <div class="@SubscriptionPlanRowSupportingTextClass()">@SubscriptionPlanRowHandoffText(plan)</div>
                                </td>
                                <td class="@SubscriptionSectionTableActionsColumnClass()">
                                    @if (SubscriptionPlanCanOpenManagementWebsiteLink(plan.CanOpenManagementWebsite))
                                    {
                                        <a href="@SubscriptionPlanRowManagementLinkHref(plan)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionSecondaryButtonClass()">
                                        @SubscriptionPlanRowManagementActionText(plan)
                                        </a>
                                    }
                                    else if (!Model.ManagementWebsiteConfigured)
                                    {
                                        <a href="@SubscriptionConfigureWebsiteWorkspaceActionHref()" class="@SubscriptionWarningButtonClass()"
                                           hx-get="@SubscriptionConfigureWebsiteWorkspaceActionHref()"
                                           hx-target="@SubscriptionWorkspaceRootTarget()"
                                           hx-swap="@SubscriptionWorkspaceSwapValue()"
                                           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
                                @SubscriptionConfigureWebsiteActionText()
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="@SubscriptionResolvePrerequisitesActionRailClass()">
                                            <span class="@SubscriptionResolvePrerequisitesTextClass()">@SubscriptionResolvePrerequisitesCaptionText()</span>
                                            <a href="@SubscriptionSetupWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                               hx-get="@SubscriptionSetupWorkspaceActionHref()"
                                               hx-target="@SubscriptionWorkspaceRootTarget()"
                                               hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSetupActionText()</a>
                                            <a href="@SubscriptionMerchantReadinessWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                               hx-get="@SubscriptionMerchantReadinessWorkspaceActionHref()"
                                               hx-target="@SubscriptionWorkspaceRootTarget()"
                                               hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                                            <a href="@SubscriptionSupportQueueWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                               hx-get="@SubscriptionSupportQueueWorkspaceActionHref()"
                                               hx-target="@SubscriptionWorkspaceRootTarget()"
                                               hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSupportQueueActionText()</a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="@SubscriptionRecentInvoicesCardClass()">
    <div class="@SubscriptionRecentInvoicesHeaderClass()">
        <span>@SubscriptionRecentInvoicesSectionTitleText()</span>
        <a href="@SubscriptionInvoicesWorkspaceActionHref()"
           class="@SubscriptionSecondaryButtonClass()"
           hx-get="@SubscriptionInvoicesWorkspaceActionHref()"
           hx-target="@SubscriptionWorkspaceRootTarget()"
           hx-swap="@SubscriptionWorkspaceSwapValue()"
           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
                    @SubscriptionInvoiceQueueActionText()
        </a>
    </div>
    <div class="@SubscriptionTableCardBodyClass()">
        <div class="@SubscriptionTableViewportClass()">
            <table class="@SubscriptionSectionDataTableClass()">
                <thead class="@SubscriptionSectionDataTableHeaderClass()">
                    <tr>
                    <th>@SubscriptionInvoiceProviderColumnLabelText()</th>
                    <th>@SubscriptionPlanColumnLabelText()</th>
                    <th>@SubscriptionInvoiceStatusColumnLabelText()</th>
                    <th>@SubscriptionInvoiceAmountColumnLabelText()</th>
                    <th>@SubscriptionInvoiceTimelineColumnLabelText()</th>
                    <th class="@SubscriptionSectionTableActionsColumnClass()">@SubscriptionActionsColumnLabelText()</th>
                    </tr>
                </thead>
                <tbody>
                @if (!SubscriptionHasRecentInvoiceRows())
                {
                    <tr>
                        <td colspan="6" class="@SubscriptionEmptyStateCellClass()">
                            <div>@SubscriptionRecentInvoicesEmptyStateMessageText()</div>
                            <div class="@SubscriptionEmptyStateActionsClass()">
                                <a href="@SubscriptionInvoicesWorkspaceActionHref()"
                                   class="@SubscriptionSecondaryButtonClass()"
                                   hx-get="@SubscriptionInvoicesWorkspaceActionHref()"
                                   hx-target="@SubscriptionWorkspaceRootTarget()"
                                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionInvoiceQueueActionText()</a>
                                <a href="@SubscriptionPaymentsWorkspaceActionHref()"
                                   class="@SubscriptionSecondaryButtonClass()"
                                   hx-get="@SubscriptionPaymentsWorkspaceActionHref()"
                                   hx-target="@SubscriptionWorkspaceRootTarget()"
                                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionPaymentsActionText()</a>
                                <a href="@SubscriptionMerchantReadinessWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                                   hx-get="@SubscriptionMerchantReadinessWorkspaceActionHref()"
                                   hx-target="@SubscriptionWorkspaceRootTarget()"
                                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                                   hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var invoice in Model.RecentInvoices)
                    {
                        <tr>
                            <td>
                                <div class="@SubscriptionRowPrimaryTextClass()">@SubscriptionInvoiceRowProviderText(invoice)</div>
                                <div class="@SubscriptionRowSecondaryTextClass()">@SubscriptionInvoiceRowProviderIdText(invoice)</div>
                                @if (SubscriptionInvoiceHasStripeBadge(invoice.IsStripe))
                                {
                                    <div><span class="@SubscriptionBadgeClass() @SubscriptionStripeBadgeClass()">@SubscriptionStripeBadgeLabelText()</span></div>
                                }
                            </td>
                            <td>
                                <div class="@SubscriptionRowPrimaryTextClass()">@SubscriptionInvoiceRowPlanText(invoice.PlanName)</div>
                                <div class="@SubscriptionRowSecondaryTextClass()">@SubscriptionInvoiceRowPlanCodeText(invoice)</div>
                            </td>
                            <td>
                                <span class="@SubscriptionBadgeClass() @SubscriptionInvoiceStatusBadgeToneClass(invoice.Status)">
                                    @SubscriptionInvoiceStatusText(invoice.Status)
                                </span>
                                @if (SubscriptionInvoiceShowsFailureText(invoice.FailureReason))
                                {
                                    <div class="@SubscriptionInvoiceFailureTextClass()">@SubscriptionInvoiceRowFailureText(invoice)</div>
                                }
                                @if (SubscriptionInvoiceHasOverdueBadge(invoice.IsOverdue))
                                {
                                    <div><span class="@SubscriptionBadgeClass() @SubscriptionInvoiceFollowUpBadgeToneClass(isWarning: false)">@SubscriptionOverdueBadgeLabelText()</span></div>
                                }
                                @if (SubscriptionInvoiceHasPdfMissingBadge(invoice.HasPdfUrl))
                                {
                                    <div><span class="@SubscriptionBadgeClass() @SubscriptionInvoiceFollowUpBadgeToneClass(isWarning: true)">@SubscriptionPdfMissingBadgeLabelText()</span></div>
                                }
                            </td>
                            <td>@SubscriptionMoneyText(invoice.Currency, invoice.TotalMinor)</td>
                            <td>
                                <div>@SubscriptionTimelineText("CommonIssuedAt", invoice.IssuedAtUtc)</div>
                                <div class="@SubscriptionRowSecondaryTextClass()">@SubscriptionTimelineText("CommonDueAt", invoice.DueAtUtc)</div>
                                <div class="@SubscriptionRowSecondaryTextClass()">@SubscriptionTimelineText("CommonPaidAt", invoice.PaidAtUtc)</div>
                            </td>
                            <td class="@SubscriptionSectionTableActionsColumnClass()">
                                <div class="@SubscriptionInvoiceActionsGroupClass()">
                                    @if (SubscriptionInvoiceHasHostedLink(invoice.HasHostedInvoiceUrl))
                                    {
                                        <a href="@SubscriptionInvoiceRowHostedLinkHref(invoice)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionSecondaryButtonClass()">@SubscriptionInvoiceHostedActionText()</a>
                                    }
                                    @if (SubscriptionInvoiceHasPdfLink(invoice.HasPdfUrl))
                                    {
                                        <a href="@SubscriptionInvoiceRowPdfLinkHref(invoice)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionSecondaryButtonClass()">@SubscriptionInvoicePdfActionText()</a>
                                    }
                                    <a href="@SubscriptionPaymentsFilteredWorkspaceActionHref(invoice.ProviderInvoiceId)" class="@SubscriptionSecondaryButtonClass()"
                                       hx-get="@SubscriptionPaymentsFilteredWorkspaceActionHref(invoice.ProviderInvoiceId)"
                                       hx-target="@SubscriptionWorkspaceRootTarget()"
                                       hx-swap="@SubscriptionWorkspaceSwapValue()"
                                       hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionPaymentsActionText()</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

