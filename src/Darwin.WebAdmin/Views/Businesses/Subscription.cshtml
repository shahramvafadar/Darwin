<div id="@SubscriptionWorkspaceRootId()">
<div class="@SubscriptionWorkspaceHeaderLayoutClass()">
    <div>
        <h1 class="@SubscriptionWorkspaceTitleHeadingClass()">@SubscriptionWorkspaceTitleText()</h1>
        <p class="@SubscriptionWorkspaceSubtitleTextClass()">@SubscriptionWorkspaceBusinessNameText()</p>
    </div>
    <div class="@SubscriptionTopRailActionRailClass()">
            <a href="@SubscriptionEditWorkspaceActionHref()" class="@SubscriptionTopRailActionButtonClass()"
           hx-get="@SubscriptionEditWorkspaceActionHref()"
           hx-target="@SubscriptionWorkspaceRootTarget()"
           hx-swap="@SubscriptionWorkspaceSwapValue()"
           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-pen")"></i> @SubscriptionEditActionText()
        </a>
            <a href="@SubscriptionSetupWorkspaceActionHref()" class="@SubscriptionTopRailActionButtonClass()"
           hx-get="@SubscriptionSetupWorkspaceActionHref()"
           hx-target="@SubscriptionWorkspaceRootTarget()"
           hx-swap="@SubscriptionWorkspaceSwapValue()"
           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-sliders")"></i> @SubscriptionSetupActionText()
        </a>
            <a href="@SubscriptionPaymentsWorkspaceActionHref()" class="@SubscriptionTopRailActionButtonClass()"
           hx-get="@SubscriptionPaymentsWorkspaceActionHref()"
           hx-target="@SubscriptionWorkspaceRootTarget()"
           hx-swap="@SubscriptionWorkspaceSwapValue()"
           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-money-bill-wave")"></i> @SubscriptionPaymentsActionText()
        </a>
        <a href="@SubscriptionInvoicesWorkspaceActionHref()"
           class="@SubscriptionTopRailActionButtonClass()"
           hx-get="@SubscriptionInvoicesWorkspaceActionHref()"
           hx-target="@SubscriptionWorkspaceRootTarget()"
           hx-swap="@SubscriptionWorkspaceSwapValue()"
           hx-push-url="@SubscriptionWorkspacePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-file-invoice-dollar")"></i> @SubscriptionInvoiceQueueActionText()
        </a>
    </div>
</div>

<div class="@SubscriptionOverviewMetricsGridClass()">
    <div class="@SubscriptionOverviewMetricColumnClass()">
        <div class="@SubscriptionOverviewMetricCardClass()">
            <div class="@SubscriptionOverviewMetricCardBodyClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionOverviewPlanLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionOverviewPlanText(Model.Subscription.HasSubscription, Model.Subscription.PlanName)</div>
                <div class="@SubscriptionMetricHelpTextClass()">@SubscriptionStatusText(Model.Subscription.Status)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewMetricColumnClass()">
        <div class="@SubscriptionOverviewMetricCardClass()">
            <div class="@SubscriptionOverviewMetricCardBodyClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionOverviewProviderLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionValueText(Model.Subscription.Provider)</div>
                <div class="@SubscriptionMetricHelpTextClass()">@SubscriptionValueText(Model.Subscription.PlanCode)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewMetricColumnClass()">
        <div class="@SubscriptionOverviewMetricCardClass()">
            <div class="@SubscriptionOverviewMetricCardBodyClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionOverviewRenewalLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionRenewalStatusText(Model.Subscription.CancelAtPeriodEnd)</div>
                <div class="@SubscriptionMetricHelpTextClass()">@SubscriptionTimelineDisplayText("BusinessSubscriptionCurrentPeriodEnd", Model.Subscription.CurrentPeriodEndUtc)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewMetricColumnClass()">
        <div class="@SubscriptionOverviewMetricCardClass()">
            <div class="@SubscriptionOverviewMetricCardBodyClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionOverviewBillingLabelText()</div>
                    <div class="@SubscriptionMetricValueClass()">@SubscriptionBillingReadinessStatusText(Model.ManagementWebsiteConfigured)</div>
                    <div class="@SubscriptionMetricHelpTextClass()">@SubscriptionOverviewBillingHelpLabelText()</div>
            </div>
        </div>
    </div>
</div>

<div class="@SubscriptionSectionCardClass()">
    <div class="@SubscriptionSectionTitleBarClass()">@SubscriptionBillingReadinessSectionTitleText()</div>
    <div class="@SubscriptionSectionCardBodyClass()">
        <div class="@SubscriptionBillingReadinessMetricGridClass()">
            <div class="@SubscriptionBillingReadinessMetricColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionBillingReadinessPlansCountLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionCountText(Model.HandoffSummary.TotalPlans)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessMetricColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionBillingReadinessReadyCountLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionCountText(Model.HandoffSummary.ReadyPlanCount)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessMetricColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionBillingReadinessBlockedCountLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionCountText(Model.HandoffSummary.BlockedPlanCount)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessMetricColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricLabelClass()">@SubscriptionBillingReadinessCurrentCountLabelText()</div>
                <div class="@SubscriptionMetricValueClass()">@SubscriptionCountText(Model.HandoffSummary.CurrentPlanCount)</div>
                </div>
            </div>
        </div>
        <div class="@SubscriptionSectionHelpLabelClass()">
            @SubscriptionBillingReadinessSectionHelpLabelText()
        </div>
    </div>
</div>

<div class="@SubscriptionSectionCardClass()">
    <div class="@SubscriptionSectionTitleBarClass()">@SubscriptionActiveSubscriptionSectionTitleText()</div>
    <div class="@SubscriptionSectionCardBodyClass()">
        @if (SubscriptionHasActiveSubscriptionData())
        {
            <div class="@SubscriptionActiveSubscriptionMetricGridClass()">
                <div class="@SubscriptionActiveSubscriptionMetricColumnClass()">
                    <div class="@SubscriptionMetricCaptionClass()">@SubscriptionActiveSubscriptionPlanLabelText()</div>
                    <div class="@SubscriptionMetricTextClass()">@SubscriptionActiveSubscriptionPlanText()</div>
                </div>
                <div class="@SubscriptionActiveSubscriptionMetricColumnClass()">
                    <div class="@SubscriptionMetricCaptionClass()">@SubscriptionActiveSubscriptionAmountLabelText()</div>
                    <div class="@SubscriptionMetricTextClass()">@SubscriptionActiveSubscriptionAmountText()</div>
                </div>
                <div class="@SubscriptionActiveSubscriptionMetricColumnClass()">
                    <div class="@SubscriptionMetricCaptionClass()">@SubscriptionActiveSubscriptionStartedLabelText()</div>
                    <div class="@SubscriptionMetricTextClass()">@SubscriptionActiveSubscriptionStartedText()</div>
                </div>
            </div>

            <div class="@SubscriptionTimelineRailClass()">
                @SubscriptionTimelineDisplayText("BusinessSubscriptionTrialEnds", Model.Subscription.TrialEndsAtUtc)
                <span class="@SubscriptionTimelineDividerClass()">|</span>
                @SubscriptionTimelineDisplayText("BusinessSubscriptionCanceledAt", Model.Subscription.CanceledAtUtc)
            </div>

            @if (SubscriptionUserHasFullAdminAccess())
            {
                <form action="@SubscriptionRenewalTogglePostActionHref()"
                      method="post"
                      hx-post="@SubscriptionRenewalTogglePostActionHref()"
                      hx-target="@SubscriptionWorkspaceRootTarget()"
                      hx-swap="@SubscriptionWorkspaceSwapValue()"
                      class="@SubscriptionInlineActionRailClass()">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="businessId" value="@SubscriptionRenewalFormBusinessIdValue()" />
                    <input type="hidden" name="subscriptionId" value="@SubscriptionRenewalFormSubscriptionIdValue()" />
                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.Subscription.RowVersion)" />
                    <input type="hidden" name="cancelAtPeriodEnd" value="@((!Model.Subscription.CancelAtPeriodEnd).ToString().ToLowerInvariant())" />
                    <button type="submit" class="@SubscriptionRenewalToggleActionButtonClass(Model.Subscription.CancelAtPeriodEnd)">
                    @SubscriptionRenewalToggleActionText(Model.Subscription.CancelAtPeriodEnd)
                    </button>
                    @if (SubscriptionCanOpenBillingWebsiteLink())
                    {
                        <a href="@SubscriptionBillingWebsiteActionHref()" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionTopRailActionButtonClass()">
                    @SubscriptionBillingWebsiteActionText()
                        </a>
                    }
                </form>
            }
        }
        else
        {
            <div class="@SubscriptionActiveSubscriptionEmptyStateAlertClass()">
                <div>@SubscriptionActiveSubscriptionEmptyStateText()</div>
                <div class="@SubscriptionInlineActionRailClass()">
                    <a href="@SubscriptionSetupWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                       hx-get="@SubscriptionSetupWorkspaceActionHref()"
                   hx-target="@SubscriptionWorkspaceRootTarget()"
                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSetupActionText()</a>
                    <a href="@SubscriptionMerchantReadinessWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                       hx-get="@SubscriptionMerchantReadinessWorkspaceActionHref()"
                   hx-target="@SubscriptionWorkspaceRootTarget()"
                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                    <a href="@SubscriptionSupportQueueWorkspaceActionHref()" class="@SubscriptionSecondaryButtonClass()"
                       hx-get="@SubscriptionSupportQueueWorkspaceActionHref()"
                   hx-target="@SubscriptionWorkspaceRootTarget()"
                   hx-swap="@SubscriptionWorkspaceSwapValue()"
                    hx-push-url="@SubscriptionWorkspacePushUrlValue()">@SubscriptionSupportQueueActionText()</a>
                </div>
            </div>
        }
    </div>
</div>

