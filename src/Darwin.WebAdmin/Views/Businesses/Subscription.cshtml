                                   hx-target="@SubscriptionWorkspaceFrameTarget()"
                                   hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionPaymentsActionText()</a>
                                <a href="@SubscriptionMerchantReadinessActionHref()" class="@SubscriptionUtilityActionClass()"
                                   hx-get="@SubscriptionMerchantReadinessActionHref()"
                                   hx-target="@SubscriptionWorkspaceFrameTarget()"
                                   hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                                   hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var invoice in Model.RecentInvoices)
                    {
                        <tr>
                            <td>
                                <div class="@SubscriptionPanelTableRowPrimaryTextClass()">@SubscriptionRecentInvoicesTableRowProviderDisplayText(invoice)</div>
                                <div class="@SubscriptionPanelTableRowSecondaryTextClass()">@SubscriptionRecentInvoicesTableRowProviderIdDisplayText(invoice)</div>
                                @if (SubscriptionRecentInvoicesTableRowShowsStripeBadge(invoice.IsStripe))
                                {
                                    <div><span class="@SubscriptionStatusBadgeClass() @SubscriptionStripeProviderBadgeClass()">@SubscriptionStripeBadgeText()</span></div>
                                }
                            </td>
                            <td>
                                <div class="@SubscriptionPanelTableRowPrimaryTextClass()">@SubscriptionRecentInvoicesTableRowPlanDisplayText(invoice.PlanName)</div>
                                <div class="@SubscriptionPanelTableRowSecondaryTextClass()">@SubscriptionRecentInvoicesTableRowPlanCodeDisplayText(invoice)</div>
                            </td>
                            <td>
                                <span class="@SubscriptionStatusBadgeClass() @SubscriptionInvoiceStatusBadgeStateClass(invoice.Status)">
                                    @SubscriptionInvoiceStatusDisplayText(invoice.Status)
                                </span>
                                @if (SubscriptionRecentInvoicesTableRowShowsFailureText(invoice.FailureReason))
                                {
                                    <div class="@SubscriptionAlertMessageTextClass()">@SubscriptionRecentInvoicesTableRowFailureDisplayText(invoice)</div>
                                }
                                @if (SubscriptionRecentInvoicesTableRowShowsOverdueBadge(invoice.IsOverdue))
                                {
                                    <div><span class="@SubscriptionStatusBadgeClass() @SubscriptionInvoiceFollowUpBadgeStateClass(isWarning: false)">@SubscriptionOverdueBadgeText()</span></div>
                                }
                                @if (SubscriptionRecentInvoicesTableRowShowsPdfMissingBadge(invoice.HasPdfUrl))
                                {
                                    <div><span class="@SubscriptionStatusBadgeClass() @SubscriptionInvoiceFollowUpBadgeStateClass(isWarning: true)">@SubscriptionPdfMissingBadgeText()</span></div>
                                }
                            </td>
                            <td>@SubscriptionMoneyDisplayText(invoice.Currency, invoice.TotalMinor)</td>
                            <td>
                                <div>@SubscriptionTimelineDisplayText("CommonIssuedAt", invoice.IssuedAtUtc)</div>
                                <div class="@SubscriptionPanelTableRowSecondaryTextClass()">@SubscriptionTimelineDisplayText("CommonDueAt", invoice.DueAtUtc)</div>
                                <div class="@SubscriptionPanelTableRowSecondaryTextClass()">@SubscriptionTimelineDisplayText("CommonPaidAt", invoice.PaidAtUtc)</div>
                            </td>
                            <td class="@SubscriptionPanelTableActionsColumnClass()">
                                <div class="@SubscriptionRecentInvoicesTableRowActionsClass()">
                                    @if (SubscriptionRecentInvoicesTableRowCanOpenHostedInvoice(invoice.HasHostedInvoiceUrl))
                                    {
                                        <a href="@SubscriptionRecentInvoicesTableRowHostedInvoiceActionHref(invoice)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionUtilityActionClass()">@SubscriptionInvoiceHostedActionText()</a>
                                    }
                                    @if (SubscriptionRecentInvoicesTableRowCanOpenPdf(invoice.HasPdfUrl))
                                    {
                                        <a href="@SubscriptionRecentInvoicesTableRowPdfActionHref(invoice)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionUtilityActionClass()">@SubscriptionInvoicePdfActionText()</a>
                                    }
                                    <a href="@SubscriptionPaymentsSearchActionHref(invoice.ProviderInvoiceId)" class="@SubscriptionUtilityActionClass()"
                                       hx-get="@SubscriptionPaymentsSearchActionHref(invoice.ProviderInvoiceId)"
                                       hx-target="@SubscriptionWorkspaceFrameTarget()"
                                       hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                                       hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionPaymentsActionText()</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
