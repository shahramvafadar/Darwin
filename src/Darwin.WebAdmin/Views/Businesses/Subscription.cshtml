<div class="@SubscriptionPanelClass()">
    <div class="@SubscriptionPanelHeaderClass()">@SubscriptionAvailablePlansTableTitleText()</div>
    <div class="@SubscriptionPanelTableBodyClass()">
        <div class="@SubscriptionPanelTableViewportClass()">
            <table class="@SubscriptionPanelTableClass()">
                <thead class="@SubscriptionPanelTableHeaderClass()">
                    <tr>
                    <th>@SubscriptionAvailablePlansTablePlanColumnTitleText()</th>
                    <th>@SubscriptionAvailablePlansTablePriceColumnTitleText()</th>
                    <th>@SubscriptionAvailablePlansTableIntervalColumnTitleText()</th>
                    <th>@SubscriptionAvailablePlansTableTrialColumnTitleText()</th>
                    <th>@SubscriptionAvailablePlansTableCheckoutColumnTitleText()</th>
                    <th class="@SubscriptionPanelTableActionsColumnClass()">@SubscriptionActionsColumnTitleText()</th>
                    </tr>
                </thead>
                <tbody>
        @if (!SubscriptionHasPlanCatalogRows())
                    {
                        <tr>
                            <td colspan="6" class="@SubscriptionEmptyStateCellClass()">
                                <div>@SubscriptionAvailablePlansTableEmptyStateText()</div>
                                <div class="@SubscriptionEmptyStateActionRailClass()">
                                    <a href="@SubscriptionSetupActionHref()" class="@SubscriptionUtilityActionClass()"
                                       hx-get="@SubscriptionSetupActionHref()"
                                       hx-target="@SubscriptionWorkspaceFrameTarget()"
                                       hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionSetupActionText()</a>
                                    <a href="@SubscriptionMerchantReadinessActionHref()" class="@SubscriptionUtilityActionClass()"
                                       hx-get="@SubscriptionMerchantReadinessActionHref()"
                                       hx-target="@SubscriptionWorkspaceFrameTarget()"
                                       hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                                    <a href="@SubscriptionSupportQueueActionHref()" class="@SubscriptionUtilityActionClass()"
                                       hx-get="@SubscriptionSupportQueueActionHref()"
                                       hx-target="@SubscriptionWorkspaceFrameTarget()"
                                       hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionSupportQueueActionText()</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var plan in Model.Plans)
                        {
                            <tr>
                                <td>
                                        <div class="@SubscriptionPanelTableRowPrimaryTextClass()">@SubscriptionAvailablePlansTableRowNameDisplayText(plan)</div>
                                        <div class="@SubscriptionPanelTableRowSecondaryTextClass()">@SubscriptionAvailablePlansTableRowCodeDisplayText(plan)</div>
                                    @if (SubscriptionAvailablePlansTableRowShowsCurrentBadge(plan.IsCurrentPlan))
                                    {
                                    <div><span class="@SubscriptionStatusBadgeClass() @SubscriptionCurrentPlanBadgeStateClass()">@SubscriptionCurrentPlanBadgeText()</span></div>
                                    }
                                    @if (SubscriptionAvailablePlansTableRowShowsDescription(plan.Description))
                                    {
                                        <div class="@SubscriptionAvailablePlansTableRowMetaTextClass()">@SubscriptionAvailablePlansTableRowDescriptionDisplayText(plan)</div>
                                    }
                                </td>
                                <td>@SubscriptionMoneyDisplayText(plan.Currency, plan.PriceMinor)</td>
                                <td>@SubscriptionIntervalDisplayText(plan.IntervalCount, plan.Interval)</td>
                                <td>@SubscriptionTrialDisplayText(plan.TrialDays)</td>
                                <td>
                                    <span class="@SubscriptionStatusBadgeClass() @SubscriptionPlanCheckoutBadgeStateClass(plan.CheckoutReady)">@SubscriptionAvailablePlansTableRowCheckoutDisplayText(plan)</span>
                                    <div class="@SubscriptionAvailablePlansTableRowMetaTextClass()">@SubscriptionAvailablePlansTableRowHandoffDisplayText(plan)</div>
                                </td>
                                <td class="@SubscriptionPanelTableActionsColumnClass()">
                                    @if (SubscriptionAvailablePlansTableRowCanOpenManagementWebsite(plan.CanOpenManagementWebsite))
                                    {
                                        <a href="@SubscriptionAvailablePlansTableRowManagementWebsiteActionHref(plan)" target="@SubscriptionExternalLinkTargetValue()" rel="@SubscriptionExternalLinkRelValue()" class="@SubscriptionUtilityActionClass()">
                                        @SubscriptionAvailablePlansTableRowManagementActionText(plan)
                                        </a>
                                    }
                                    else if (!Model.ManagementWebsiteConfigured)
                                    {
                                        <a href="@SubscriptionConfigureWebsiteActionHref()" class="@SubscriptionRemediationActionClass()"
                                           hx-get="@SubscriptionConfigureWebsiteActionHref()"
                                           hx-target="@SubscriptionWorkspaceFrameTarget()"
                                           hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                                           hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">
                                @SubscriptionConfigureWebsiteActionText()
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="@SubscriptionAvailablePlansTableRemediationActionsClass()">
                                            <span class="@SubscriptionRemediationHintTextClass()">@SubscriptionResolvePrerequisitesHintText()</span>
                                            <a href="@SubscriptionSetupActionHref()" class="@SubscriptionUtilityActionClass()"
                                               hx-get="@SubscriptionSetupActionHref()"
                                               hx-target="@SubscriptionWorkspaceFrameTarget()"
                                               hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionSetupActionText()</a>
                                            <a href="@SubscriptionMerchantReadinessActionHref()" class="@SubscriptionUtilityActionClass()"
                                               hx-get="@SubscriptionMerchantReadinessActionHref()"
                                               hx-target="@SubscriptionWorkspaceFrameTarget()"
                                               hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionMerchantReadinessActionText()</a>
                                            <a href="@SubscriptionSupportQueueActionHref()" class="@SubscriptionUtilityActionClass()"
                                               hx-get="@SubscriptionSupportQueueActionHref()"
                                               hx-target="@SubscriptionWorkspaceFrameTarget()"
                                               hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
                    hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">@SubscriptionSupportQueueActionText()</a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="@SubscriptionRecentInvoicesTableCardClass()">
