@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionWorkspaceVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@{
    ViewData["Title"] = "Business Subscription";
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">Business Subscription</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-pen"></i> Edit Business
        </a>
        <a asp-action="Setup" asp-route-id="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-sliders"></i> Setup
        </a>
        <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-money-bill-wave"></i> Payments
        </a>
        <a asp-action="SubscriptionInvoices" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-file-invoice-dollar"></i> Subscription Invoices
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Subscription</div>
                <div class="fw-semibold mt-1">@(Model.Subscription.HasSubscription ? Model.Subscription.PlanName : "No active plan")</div>
                <div class="small text-muted mt-2">@Model.Subscription.Status</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Provider</div>
                <div class="fw-semibold mt-1">@(string.IsNullOrWhiteSpace(Model.Subscription.Provider) ? "-" : Model.Subscription.Provider)</div>
                <div class="small text-muted mt-2">@Model.Subscription.PlanCode</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Renewal</div>
                <div class="fw-semibold mt-1">@(Model.Subscription.CancelAtPeriodEnd ? "Cancel at period end" : "Renews normally")</div>
                <div class="small text-muted mt-2">Current period end: @(Model.Subscription.CurrentPeriodEndUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Billing Handoff</div>
                <div class="fw-semibold mt-1">@(Model.ManagementWebsiteConfigured ? "Configured" : "Missing")</div>
                <div class="small text-muted mt-2">Phase-1 billing changes are handled through the external management website.</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header">Current Subscription</div>
    <div class="card-body">
        @if (Model.Subscription.HasSubscription)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase">Plan</div>
                    <div class="fw-semibold">@Model.Subscription.PlanName</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase">Amount</div>
                    <div class="fw-semibold">@Model.Subscription.Currency @((Model.Subscription.UnitPriceMinor / 100M).ToString("0.00"))</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted text-uppercase">Started</div>
                    <div class="fw-semibold">@(Model.Subscription.StartedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                </div>
            </div>

            <div class="mt-3 small text-muted">
                Trial ends: @(Model.Subscription.TrialEndsAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                <span class="mx-2">|</span>
                Canceled at: @(Model.Subscription.CanceledAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")
            </div>

            @if (isFullAdmin)
            {
                <form asp-action="SetSubscriptionCancelAtPeriodEnd" method="post" class="d-flex gap-2 flex-wrap mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="businessId" value="@Model.Business.Id" />
                    <input type="hidden" name="subscriptionId" value="@Model.Subscription.SubscriptionId" />
                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.Subscription.RowVersion)" />
                    <input type="hidden" name="cancelAtPeriodEnd" value="@((!Model.Subscription.CancelAtPeriodEnd).ToString().ToLowerInvariant())" />
                    <button type="submit" class="btn @(Model.Subscription.CancelAtPeriodEnd ? "btn-outline-success" : "btn-outline-danger")">
                        @(Model.Subscription.CancelAtPeriodEnd ? "Restore Renewal" : "Cancel At Period End")
                    </button>
                    @if (Model.ManagementWebsiteConfigured)
                    {
                        <a href="@Model.ManagementWebsiteUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">
                            Open Billing Website
                        </a>
                    }
                </form>
            }
        }
        else
        {
            <div class="alert alert-secondary mb-0">No active subscription snapshot is available for this business yet.</div>
        }
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header">Subscription Invoice Signals</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Total</div>
                    <div class="fw-semibold mt-1">@Model.InvoiceSummary.TotalCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Open</div>
                    <div class="fw-semibold mt-1">@Model.InvoiceSummary.OpenCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Paid</div>
                    <div class="fw-semibold mt-1">@Model.InvoiceSummary.PaidCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Draft</div>
                    <div class="fw-semibold mt-1">@Model.InvoiceSummary.DraftCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">Uncollectible</div>
                    <div class="fw-semibold mt-1">@Model.InvoiceSummary.UncollectibleCount</div>
                </div>
            </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">Hosted Link Missing</div>
            <div class="fw-semibold mt-1">@Model.InvoiceSummary.HostedLinkMissingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">Overdue</div>
            <div class="fw-semibold mt-1">@Model.InvoiceSummary.OverdueCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small text-uppercase">PDF Missing</div>
            <div class="fw-semibold mt-1">@Model.InvoiceSummary.PdfMissingCount</div>
        </div>
    </div>
</div>
        <div class="small text-muted mt-3">
            These provider invoice signals help finance support distinguish open Stripe billing work from historical subscription snapshots.
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header">Available Billing Plans</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Plan</th>
                        <th>Price</th>
                        <th>Interval</th>
                        <th>Trial</th>
                        <th>Checkout Readiness</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Plans.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No active billing plans found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var plan in Model.Plans)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@plan.Name</div>
                                    <div class="small text-muted">@plan.Code</div>
                                    @if (!string.IsNullOrWhiteSpace(plan.Description))
                                    {
                                        <div class="small text-muted mt-1">@plan.Description</div>
                                    }
                                </td>
                                <td>@plan.Currency @((plan.PriceMinor / 100M).ToString("0.00"))</td>
                                <td>Every @plan.IntervalCount @plan.Interval</td>
                                <td>@(plan.TrialDays.HasValue ? $"{plan.TrialDays} days" : "-")</td>
                                <td>
                                    @if (plan.CheckoutReady)
                                    {
                                        <span class="badge bg-success">@plan.CheckoutReadinessLabel</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@plan.CheckoutReadinessLabel</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Recent Subscription Invoices</span>
        <a asp-action="SubscriptionInvoices" asp-route-businessId="@Model.Business.Id" class="btn btn-sm btn-outline-secondary">
            Open Invoice Queue
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Provider</th>
                        <th>Plan</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Timeline</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentInvoices.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No subscription invoices found for this business.</td>
                    </tr>
                }
                else
                {
                    foreach (var invoice in Model.RecentInvoices)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@invoice.Provider</div>
                                <div class="small text-muted">@invoice.ProviderInvoiceId</div>
                                @if (invoice.IsStripe)
                                {
                                    <div><span class="badge bg-info text-dark mt-1">Stripe</span></div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(invoice.PlanName) ? "-" : invoice.PlanName)</div>
                                <div class="small text-muted">@invoice.PlanCode</div>
                            </td>
                            <td>
                                <span class="badge @(invoice.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : invoice.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary")">
                                    @invoice.Status
                                </span>
                                @if (!string.IsNullOrWhiteSpace(invoice.FailureReason))
                                {
                                    <div class="small text-danger mt-1">@invoice.FailureReason</div>
                                }
                                @if (invoice.IsOverdue)
                                {
                                    <div><span class="badge bg-danger mt-1">Overdue</span></div>
                                }
                                @if (!invoice.HasPdfUrl)
                                {
                                    <div><span class="badge bg-warning text-dark mt-1">PDF missing</span></div>
                                }
                            </td>
                            <td>@invoice.Currency @((invoice.TotalMinor / 100M).ToString("0.00"))</td>
                            <td>
                                <div>Issued: @invoice.IssuedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                                <div class="small text-muted">Due: @(invoice.DueAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                                <div class="small text-muted">Paid: @(invoice.PaidAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    @if (invoice.HasHostedInvoiceUrl)
                                    {
                                        <a href="@invoice.HostedInvoiceUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">Hosted</a>
                                    }
                                    @if (invoice.HasPdfUrl)
                                    {
                                        <a href="@invoice.PdfUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">PDF</a>
                                    }
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" asp-route-q="@invoice.ProviderInvoiceId" class="btn btn-outline-secondary">Payments</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-header">Subscription Operations Playbooks</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Queue</th>
                        <th>Why It Matters</th>
                        <th>Operator Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var playbook in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@playbook.QueueLabel</td>
                            <td>@playbook.WhyItMatters</td>
                            <td>@playbook.OperatorAction</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
