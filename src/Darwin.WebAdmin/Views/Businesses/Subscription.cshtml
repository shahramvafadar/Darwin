<div id="@SubscriptionWorkspaceFrameId()">
<div class="@SubscriptionTitleBarLayoutClass()">
    <div>
        <h1 class="@SubscriptionTitleBarHeadingClass()">@SubscriptionPageTitleText()</h1>
        <p class="@SubscriptionTitleBarSubtitleClass()">@SubscriptionPageBusinessNameText()</p>
    </div>
    <div class="@SubscriptionTitleBarActionRailClass()">
            <a href="@SubscriptionEditActionHref()" class="@SubscriptionTitleBarActionClass()"
           hx-get="@SubscriptionEditActionHref()"
           hx-target="@SubscriptionWorkspaceFrameTarget()"
           hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
           hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-pen")"></i> @SubscriptionEditActionText()
        </a>
            <a href="@SubscriptionSetupActionHref()" class="@SubscriptionTitleBarActionClass()"
           hx-get="@SubscriptionSetupActionHref()"
           hx-target="@SubscriptionWorkspaceFrameTarget()"
           hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
           hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-sliders")"></i> @SubscriptionSetupActionText()
        </a>
            <a href="@SubscriptionPaymentsActionHref()" class="@SubscriptionTitleBarActionClass()"
           hx-get="@SubscriptionPaymentsActionHref()"
           hx-target="@SubscriptionWorkspaceFrameTarget()"
           hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
           hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-money-bill-wave")"></i> @SubscriptionPaymentsActionText()
        </a>
        <a href="@SubscriptionInvoiceQueueActionHref()"
           class="@SubscriptionTitleBarActionClass()"
           hx-get="@SubscriptionInvoiceQueueActionHref()"
           hx-target="@SubscriptionWorkspaceFrameTarget()"
           hx-swap="@SubscriptionWorkspaceFrameSwapValue()"
           hx-push-url="@SubscriptionWorkspaceFramePushUrlValue()">
            <i class="@SubscriptionActionIconClass("fa-file-invoice-dollar")"></i> @SubscriptionInvoiceQueueActionText()
        </a>
    </div>
</div>

<div class="@SubscriptionOverviewSummaryLayoutClass()">
    <div class="@SubscriptionOverviewSummaryColumnClass()">
    <div class="@SubscriptionOverviewSummarySurfaceClass()">
        <div class="@SubscriptionOverviewSummaryContentClass()">
        <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionOverviewPlanMetricText()</div>
        <div class="@SubscriptionMetricCardValueClass()">@SubscriptionOverviewPlanDisplayText(Model.Subscription.HasSubscription, Model.Subscription.PlanName)</div>
        <div class="@SubscriptionMetricCardHelpTextClass()">@SubscriptionStatusDisplayText(Model.Subscription.Status)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewSummaryColumnClass()">
    <div class="@SubscriptionOverviewSummarySurfaceClass()">
        <div class="@SubscriptionOverviewSummaryContentClass()">
        <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionOverviewProviderMetricText()</div>
        <div class="@SubscriptionMetricCardValueClass()">@SubscriptionDisplayText(Model.Subscription.Provider)</div>
        <div class="@SubscriptionMetricCardHelpTextClass()">@SubscriptionDisplayText(Model.Subscription.PlanCode)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewSummaryColumnClass()">
    <div class="@SubscriptionOverviewSummarySurfaceClass()">
        <div class="@SubscriptionOverviewSummaryContentClass()">
        <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionOverviewRenewalMetricText()</div>
        <div class="@SubscriptionMetricCardValueClass()">@SubscriptionRenewalDisplayText(Model.Subscription.CancelAtPeriodEnd)</div>
        <div class="@SubscriptionMetricCardHelpTextClass()">@SubscriptionTimelineDisplayText("BusinessSubscriptionCurrentPeriodEnd", Model.Subscription.CurrentPeriodEndUtc)</div>
            </div>
        </div>
    </div>
    <div class="@SubscriptionOverviewSummaryColumnClass()">
    <div class="@SubscriptionOverviewSummarySurfaceClass()">
        <div class="@SubscriptionOverviewSummaryContentClass()">
        <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionOverviewBillingMetricText()</div>
        <div class="@SubscriptionMetricCardValueClass()">@SubscriptionBillingReadinessDisplayText(Model.ManagementWebsiteConfigured)</div>
        <div class="@SubscriptionMetricCardHelpTextClass()">@SubscriptionOverviewBillingHelpText()</div>
            </div>
        </div>
    </div>
</div>

<div class="@SubscriptionPanelClass()">
    <div class="@SubscriptionPanelHeaderClass()">@SubscriptionBillingReadinessOverviewTitleText()</div>
    <div class="@SubscriptionPanelBodyClass()">
        <div class="@SubscriptionBillingReadinessOverviewLayoutClass()">
            <div class="@SubscriptionBillingReadinessOverviewColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionBillingReadinessOverviewPlansMetricText()</div>
                    <div class="@SubscriptionMetricCardValueClass()">@SubscriptionMetricCardCountText(Model.HandoffSummary.TotalPlans)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessOverviewColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionBillingReadinessOverviewReadyMetricText()</div>
                    <div class="@SubscriptionMetricCardValueClass()">@SubscriptionMetricCardCountText(Model.HandoffSummary.ReadyPlanCount)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessOverviewColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionBillingReadinessOverviewBlockedMetricText()</div>
                    <div class="@SubscriptionMetricCardValueClass()">@SubscriptionMetricCardCountText(Model.HandoffSummary.BlockedPlanCount)</div>
                </div>
            </div>
            <div class="@SubscriptionBillingReadinessOverviewColumnClass()">
                <div class="@SubscriptionMetricCardClass()">
                    <div class="@SubscriptionMetricCardLabelClass()">@SubscriptionBillingReadinessOverviewCurrentMetricText()</div>
                    <div class="@SubscriptionMetricCardValueClass()">@SubscriptionMetricCardCountText(Model.HandoffSummary.CurrentPlanCount)</div>
                </div>
            </div>
        </div>
        <div class="@SubscriptionPanelSupportTextClass()">
            @SubscriptionBillingReadinessOverviewHelpText()
        </div>
    </div>
</div>

<div class="@SubscriptionPanelClass()">
    <div class="@SubscriptionPanelHeaderClass()">@SubscriptionActiveSubscriptionSectionTitleText()</div>
    <div class="@SubscriptionPanelBodyClass()">
        @if (SubscriptionHasActiveSubscription())
        {
        <div class="@SubscriptionActiveSubscriptionOverviewLayoutClass()">
            <div class="@SubscriptionActiveSubscriptionOverviewColumnClass()">
                    <div class="@SubscriptionMetricCardCaptionClass()">@SubscriptionActiveSubscriptionPlanMetricText()</div>
                    <div class="@SubscriptionMetricCardTextClass()">@SubscriptionActiveSubscriptionPlanDisplayText()</div>
            </div>
            <div class="@SubscriptionActiveSubscriptionOverviewColumnClass()">
                    <div class="@SubscriptionMetricCardCaptionClass()">@SubscriptionActiveSubscriptionAmountMetricText()</div>
                    <div class="@SubscriptionMetricCardTextClass()">@SubscriptionActiveSubscriptionAmountDisplayText()</div>
