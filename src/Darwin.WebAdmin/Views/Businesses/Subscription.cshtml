@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionWorkspaceVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSubscriptionTitle");
    var isFullAdmin = await Perms.HasAsync("FullAdminAccess");
    var subscriptionCulture = CultureInfo.CurrentCulture;
    string SubscriptionStatusDisplayText(string? status) => string.IsNullOrWhiteSpace(status) ? "-" : T.T(status);
    string SubscriptionInvoiceStatusDisplayText(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string SubscriptionDisplayText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    string SubscriptionFallbackDisplayText(string? value) => SubscriptionDisplayText(value);
    bool SubscriptionCanManageSubscription() => isFullAdmin;
    string SubscriptionPageTitleText() => T.T("BusinessSubscriptionTitle");
    string SubscriptionPageBusinessNameText() => Model.Business.Name;
string SubscriptionEditActionText() => T.T("CommonEditBusiness");
string SubscriptionSetupActionText() => T.T("CommonSetup");
string SubscriptionPaymentsActionText() => T.T("CommonPayments");
string SubscriptionInvoiceQueueActionText() => T.T("BusinessSubscriptionOpenInvoiceQueue");
string SubscriptionMerchantReadinessActionText() => T.T("MerchantReadinessTitle");
string SubscriptionSupportQueueActionText() => T.T("BusinessSupportQueueTitle");
    string SubscriptionRenewalDisplayText(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? T.T("BusinessSubscriptionCancelAtPeriodEnd") : T.T("BusinessSubscriptionRenewsNormally");
    string SubscriptionBillingReadinessDisplayText(bool isConfigured) => isConfigured ? T.T("CommonConfigured") : T.T("CommonMissingBadge");
string SubscriptionRenewalToggleActionText(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? T.T("BusinessSubscriptionRestoreRenewal") : T.T("BusinessSubscriptionCancelAtPeriodEndAction");
    string SubscriptionRenewalToggleButtonStateClass(bool cancelAtPeriodEnd) => cancelAtPeriodEnd ? "btn-outline-success" : "btn-outline-danger";
    string SubscriptionRenewalToggleButtonClass(bool cancelAtPeriodEnd) => $"btn {SubscriptionRenewalToggleButtonStateClass(cancelAtPeriodEnd)}";
    string SubscriptionOverviewPlanDisplayText(bool hasSubscription, string? planName) => hasSubscription ? planName ?? string.Empty : T.T("BusinessSubscriptionNoActivePlan");
    string SubscriptionDateTimeDisplayText(DateTime? value) => value?.ToString("g", subscriptionCulture) ?? "-";
    string SubscriptionTrialDisplayText(int? trialDays) => trialDays.HasValue ? string.Format(subscriptionCulture, T.T("BusinessSubscriptionTrialDays"), trialDays.Value) : "-";
    string SubscriptionMoneyDisplayText(string currency, long amountMinor) => string.Format(subscriptionCulture, "{0} {1:N2}", currency, amountMinor / 100M);
    string SubscriptionTimelineDisplayText(string labelKey, DateTime? value) => string.Format(subscriptionCulture, T.T(labelKey), SubscriptionDateTimeDisplayText(value));
    string SubscriptionIntervalDisplayText(int intervalCount, string interval) => string.Format(subscriptionCulture, T.T("BusinessSubscriptionEveryInterval"), intervalCount, interval);
    string SubscriptionInvoiceStatusBadgeStateClass(Darwin.Domain.Enums.SubscriptionInvoiceStatus status) => status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary";
    string SubscriptionPlanCheckoutBadgeStateClass(bool checkoutReady) => checkoutReady ? "bg-success" : "bg-warning text-dark";
    string SubscriptionInvoiceQueueSignalButtonStateClass(Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter filter) => filter == Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter.Overdue || filter == Darwin.Application.Billing.BusinessSubscriptionInvoiceQueueFilter.Uncollectible ? "btn-outline-danger" : "btn-outline-warning";
