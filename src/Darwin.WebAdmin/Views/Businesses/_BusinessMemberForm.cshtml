@model Darwin.WebAdmin.ViewModels.Businesses.BusinessMemberEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("CommonMembers")
    };
    string BusinessMembersUrl(Guid? businessId, int? page = null, int? pageSize = null, string? query = null, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, page, pageSize, query, filter }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("BusinessMemberIdentitySection")</h2>
    <div class="row g-3">
    @if (isCreate)
    {
        <div class="col-12">
            <label asp-for="UserId" class="form-label">@T.T("User")</label>
            <field-help title="@T.T("User")" content="@T.T("BusinessMemberUserHelp")" placement="right"></field-help>
            <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select>
            <div class="form-text">
                <div>@T.T("BusinessMemberAssignmentHelp")</div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-action="Members"
                       asp-route-businessId="@Model.BusinessId"
                       asp-route-filter="@(Model.Business.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMembersUrl(Model.BusinessId, filter: Model.Business.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("CommonMembers")</a>
                    <a asp-action="Members"
                       asp-route-businessId="@Model.BusinessId"
                       asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMembersUrl(Model.BusinessId, filter: Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.BusinessId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.BusinessId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.BusinessId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
                       hx-target="#business-member-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-6">
            <label class="form-label">@T.T("User")</label>
            <field-help title="@T.T("User")" content="@T.T("BusinessMemberReadonlyUserHelp")" placement="right"></field-help>
            <input class="form-control" value="@Model.UserDisplayName" readonly />
        </div>
        <div class="col-md-6">
            <label class="form-label">@T.T("Email")</label>
            <field-help title="@T.T("Email")" content="@T.T("BusinessMemberEmailHelp")" placement="right"></field-help>
            <input class="form-control" value="@Model.UserEmail" readonly />
        </div>
    }
    <div class="col-md-6">
        <label asp-for="Role" class="form-label">@T.T("Role")</label>
        <field-help title="@T.T("Role")" content="@T.T("BusinessMemberRoleHelp")" placement="right"></field-help>
        <select asp-for="Role" asp-items="Model.RoleOptions" class="form-select"></select>
    </div>
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">@T.T("BusinessMemberIsActiveLabel")</label>
            <field-help title="@T.T("BusinessMemberIsActiveLabel")" content="@T.T("BusinessMemberIsActiveHelp")" placement="right"></field-help>
        </div>
    </div>
    </div>
</section>

@if (!isCreate && Model.IsLastActiveOwner)
{
    <section class="admin-form-section">
        <h2 class="admin-form-section-title">@T.T("BusinessMemberLastOwnerOverrideSection")</h2>
        <div class="border border-danger rounded p-3">
            <div class="form-check mb-2">
                <input asp-for="AllowLastOwnerOverride" class="form-check-input" />
                <label asp-for="AllowLastOwnerOverride" class="form-check-label">@T.T("BusinessMemberAllowLastOwnerOverrideLabel")</label>
                <field-help title="@T.T("BusinessMemberAllowLastOwnerOverrideLabel")" content="@T.T("BusinessMemberAllowLastOwnerOverrideHelp")" placement="right"></field-help>
            </div>
            <label asp-for="OverrideReason" class="form-label">@T.T("BusinessMemberOverrideReasonLabel")</label>
            <field-help title="@T.T("BusinessMemberOverrideReasonLabel")" content="@T.T("BusinessMemberOverrideReasonHelp")" placement="right"></field-help>
            <textarea asp-for="OverrideReason" class="form-control" rows="3" placeholder="@T.T("BusinessMemberLastOwnerOverrideRequiredPlaceholder")"></textarea>
            <span asp-validation-for="OverrideReason" class="text-danger"></span>
        </div>
    </section>
}

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-floppy-disk"></i> @T.T("Save")
    </button>
    <a asp-action="Members"
       asp-route-businessId="@Model.BusinessId"
       asp-route-page="@Model.Page"
       asp-route-pageSize="@Model.PageSize"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       class="btn btn-outline-secondary"
       hx-get="@BusinessMembersUrl(Model.BusinessId, Model.Page, Model.PageSize, Model.Query, Model.Filter)"
       hx-target="#business-member-editor-shell"
       hx-swap="outerHTML">@T.T("Cancel")</a>
</div>
