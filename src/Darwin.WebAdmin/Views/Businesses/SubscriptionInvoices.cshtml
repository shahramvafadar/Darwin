@using Darwin.Application.Billing
@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoicesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string InvoiceTitleText() => T.T("BusinessSubscriptionInvoicesTitle");
    string InvoiceBusinessNameText() => Model.Business.Name;
    string InvoiceSubtitleText() => InvoiceBusinessNameText();
    string InvoicePlaybookSectionTitleText() => T.T("BusinessSubscriptionBillingPlaybooksTitle");
    string InvoiceEmptyStateMessageText() => T.T("BusinessSubscriptionInvoicesEmptyState");
    string InvoiceSummaryTotalLabelText() => T.T("CommonTotal");
    string InvoiceSummaryCountText(int count) => count.ToString();
    string InvoiceSummaryTotalCountText() => InvoiceSummaryCountText(Model.Summary.TotalCount);
    string InvoiceSummaryOpenCountText() => InvoiceSummaryCountText(Model.Summary.OpenCount);
    string InvoiceSummaryPaidCountText() => InvoiceSummaryCountText(Model.Summary.PaidCount);
    string InvoiceSummaryDraftCountText() => InvoiceSummaryCountText(Model.Summary.DraftCount);
    string InvoiceSummaryUncollectibleCountText() => InvoiceSummaryCountText(Model.Summary.UncollectibleCount);
    string InvoiceSummaryStripeCountText() => InvoiceSummaryCountText(Model.Summary.StripeCount);
    string InvoiceSummaryOverdueCountText() => InvoiceSummaryCountText(Model.Summary.OverdueCount);
    string InvoiceSummaryPdfMissingCountText() => InvoiceSummaryCountText(Model.Summary.PdfMissingCount);
    string InvoiceTitleHeadingText() => InvoiceTitleText();
    string InvoiceSubtitleHeadingText() => InvoiceSubtitleText();
    ViewData["Title"] = InvoiceTitleText();
    string InvoiceStatusText(Darwin.Domain.Enums.SubscriptionInvoiceStatus status) => T.T(status.ToString());
    string InvoiceRowPlanNameText(string? planName) => string.IsNullOrWhiteSpace(planName) ? "-" : planName;
    string InvoiceRowProviderText(string? provider) => string.IsNullOrWhiteSpace(provider) ? "-" : provider;
    string InvoiceRowPlanCodeText(string? planCode) => string.IsNullOrWhiteSpace(planCode) ? "-" : planCode;
    string InvoiceRowProviderInvoiceIdText(string? providerInvoiceId) => string.IsNullOrWhiteSpace(providerInvoiceId) ? "-" : providerInvoiceId;
    string InvoiceRowFailureReasonText(string? failureReason) => string.IsNullOrWhiteSpace(failureReason) ? "-" : failureReason;
    string InvoiceRowStatusText(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoiceStatusText(item.Status);
    string InvoiceRowStatusBadgeClass(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => $"{InvoiceBadgeClass()} {InvoiceBadgeToneClass(item.Status)}";
    string InvoiceRowAmountText(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoiceAmountText(item.Currency, item.TotalMinor);
    string InvoiceRowIssuedTimelineText(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoiceIssuedTimelineText(item.IssuedAtUtc);
    string InvoiceRowDueTimelineText(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoiceDueTimelineText(item.DueAtUtc);
    string InvoiceRowPaidTimelineText(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoicePaidTimelineText(item.PaidAtUtc);
    bool InvoiceRowHasFailureReason(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => !string.IsNullOrWhiteSpace(item.FailureReason);
    bool InvoiceRowHasStripeSignal(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => item.IsStripe;
    bool InvoiceRowHasOverdueSignal(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => item.IsOverdue;
    bool InvoiceRowHasPdfMissingSignal(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => !item.HasPdfUrl;
    bool InvoiceRowHasHostedAction(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => item.HasHostedInvoiceUrl;
    bool InvoiceRowHasPdfAction(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => item.HasPdfUrl;
    string InvoiceRowPaymentsHref(Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm item) => InvoiceRowPaymentsActionHref(item.ProviderInvoiceId);
    string InvoiceRowHostedActionHref(string? hostedInvoiceUrl) => string.IsNullOrWhiteSpace(hostedInvoiceUrl) ? string.Empty : hostedInvoiceUrl;
    string InvoiceRowPdfActionHref(string? pdfUrl) => string.IsNullOrWhiteSpace(pdfUrl) ? string.Empty : pdfUrl;
    string InvoiceToolbarSecondaryButtonClass() => "btn btn-outline-secondary";
    string InvoiceToolbarDangerButtonClass() => "btn btn-outline-danger";
    string InvoiceToolbarActionsRailClass() => "d-flex gap-2 flex-wrap";
string InvoicePageHeaderClass() => "d-flex justify-content-between align-items-start mb-3";
string InvoicePageTitleClass() => "mb-1";
string InvoicePageSubtitleClass() => "text-muted mb-0";
string InvoiceSummaryGridClass() => "row g-3 mb-3";
string InvoiceSummaryColumnClass() => "col-md-2";
string InvoiceSummaryTileClass() => "border rounded p-3 h-100";
string InvoiceSummaryLabelClass() => "text-muted small";
string InvoiceSummaryValueClass() => "fs-4 fw-semibold";
string InvoiceSummaryActionsClass() => "mt-2";
string InvoicePlaybookCardClass() => "card mb-3";
string InvoicePlaybookHeaderClass() => "card-header";
string InvoicePlaybookBodyClass() => "card-body";
    string InvoiceQueueChipBaseClass() => "btn btn-sm";
    string InvoiceRowButtonClass() => "btn btn-outline-secondary";
    string InvoiceEmptyStateButtonClass() => "btn btn-sm btn-outline-secondary";
    string InvoiceFilterSubmitButtonClass() => "btn btn-outline-secondary";
    string InvoiceFailureTextClass() => "small text-danger mt-1";
    string InvoiceOverdueSignalBadgeShellClass() => "badge bg-danger mt-1";
    string InvoicePdfMissingSignalBadgeShellClass() => "badge bg-warning text-dark mt-1";
    string InvoiceStripeSignalBadgeShellClass() => "badge text-bg-info mt-1";
    string InvoiceRowActionsClass() => "btn-group btn-group-sm";
    string InvoiceBadgeClass() => "badge";
    string InvoiceBadgeToneClass(Darwin.Domain.Enums.SubscriptionInvoiceStatus status) => status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary";
string InvoiceTimelineTextClass() => "small text-muted";
string InvoiceMetaTextClass() => "small text-muted";
string InvoiceValueTextClass() => "fw-semibold";
string InvoiceTableWrapperClass() => "table-responsive";
string InvoiceTableClass() => "table table-sm table-striped align-middle";
string InvoiceTableHeaderClass() => "table-light";
int InvoiceTableColumnTotal() => 6;
string InvoiceEmptyStateButtonsRailClass() => "d-flex gap-2 flex-wrap justify-content-center mt-3";
string InvoicePlaybookButtonsRailClass() => "d-flex gap-2 flex-wrap";
string InvoiceQueueFilterRailClass() => "d-flex gap-2 flex-wrap mb-3";
string InvoiceFilterFieldsRailClass() => "d-flex gap-2";
    string InvoiceFilterMethod() => "get";
    string InvoiceFilterBusinessFieldName() => "businessId";
    string InvoiceFilterQueryName() => "query";
    string InvoiceFilterQueueName() => "filter";
    string InvoiceHiddenFieldType() => "hidden";
    string InvoiceQueryFieldType() => "text";
    string InvoiceSubmitButtonType() => "submit";
string InvoiceFilterToolbarClass() => "d-flex justify-content-between align-items-center mb-3";
string InvoiceTableActionsClass() => "text-end";
    string InvoiceEmptyTableStateCellClass() => "text-center text-muted py-4";
    string InvoiceFilterQueryClass() => "form-control";
    string InvoiceFilterSelectClass() => "form-select";
    Guid InvoicePageBusinessIdValue() => Model.Business.Id;
    Guid InvoiceFilterBusinessIdValue() => InvoicePageBusinessIdValue();
    System.Collections.Generic.IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> InvoiceFilterQueueItems() => Model.FilterItems;
    string InvoiceFilterQueryValue() => Model.Query ?? string.Empty;
    BusinessSubscriptionInvoiceQueueFilter InvoiceSelectedQueueFilter() => Model.Filter;
    bool InvoiceHasRows() => Model.Items.Count > 0;
    System.Collections.Generic.IReadOnlyList<Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoiceListItemVm> InvoiceRowItems() => Model.Items;
    string InvoiceRootId() => "business-subscription-invoices-workspace-shell";
    string InvoiceRootTarget() => $"#{InvoiceRootId()}";
    string InvoiceRootSwap() => "outerHTML";
    string InvoicePushUrlValue() => "true";
    string InvoiceExternalTarget() => "_blank";
    string InvoiceExternalRel() => "noopener noreferrer";
    string InvoiceToolbarIconGlyphClass(string iconName) => $"fa-solid {iconName}";
    string InvoiceAmountText(string currency, long totalMinor) => $"{currency} {(totalMinor / 100M).ToString("0.00")}";
    string InvoiceTimestampText(DateTime? timestampUtc) => timestampUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? "-";
    string InvoiceIssuedTimelineText(DateTime? timestampUtc) => string.Format(T.T("CommonIssuedAt"), InvoiceTimestampText(timestampUtc));
    string InvoiceDueTimelineText(DateTime? timestampUtc) => string.Format(T.T("CommonDueAt"), InvoiceTimestampText(timestampUtc));
    string InvoicePaidTimelineText(DateTime? timestampUtc) => string.Format(T.T("CommonPaidAt"), InvoiceTimestampText(timestampUtc));
    string InvoiceSubscriptionActionText() => T.T("BusinessSubscriptionShort");
    string InvoicePaymentsActionText() => T.T("CommonPayments");
    string InvoiceRefundsActionText() => T.T("RefundQueue");
    string InvoicePaymentSettingsActionText() => T.T("PaymentSettings");
    string InvoiceSupportQueueActionText() => T.T("BusinessSupportQueueTitle");
    string InvoiceMerchantReadinessActionText() => T.T("MerchantReadinessTitle");
    string InvoiceHostedActionText() => T.T("CommonHosted");
    string InvoicePdfActionText() => T.T("CommonPdf");
    string InvoiceProviderColumnHeaderText() => T.T("CommonProvider");
    string InvoicePlanColumnHeaderText() => T.T("CommonPlan");
    string InvoiceStatusColumnHeaderText() => T.T("CommonStatus");
    string InvoiceAmountColumnHeaderText() => T.T("CommonAmount");
    string InvoiceTimelineColumnHeaderText() => T.T("CommonTimeline");
    string InvoiceActionsColumnHeaderText() => T.T("CommonActions");
    string InvoiceFilterPlaceholderText() => T.T("BusinessSubscriptionInvoicesSearchPlaceholder");
    string InvoiceFilterSubmitText() => T.T("CommonFilter");
    string InvoiceFilterResetText() => T.T("CommonReset");
    string InvoiceQueueFilterText(BusinessSubscriptionInvoiceQueueFilter filter) => filter switch
    {
        BusinessSubscriptionInvoiceQueueFilter.All => T.T("CommonAll"),
        BusinessSubscriptionInvoiceQueueFilter.Open => T.T("CommonOpen"),
        BusinessSubscriptionInvoiceQueueFilter.Paid => T.T("CommonPaid"),
        BusinessSubscriptionInvoiceQueueFilter.Draft => T.T("CommonDraft"),
        BusinessSubscriptionInvoiceQueueFilter.Uncollectible => T.T("CommonUncollectible"),
        _ => InvoiceSignalFilterText(filter)
    };
    string InvoicePlaybookActionText(BusinessSubscriptionInvoiceQueueFilter filter) => filter switch
    {
        BusinessSubscriptionInvoiceQueueFilter.Open => T.T("BusinessSubscriptionBillingPlaybookOpenInvoices"),
        BusinessSubscriptionInvoiceQueueFilter.Uncollectible => T.T("BusinessSubscriptionBillingPlaybookUncollectible"),
        BusinessSubscriptionInvoiceQueueFilter.HostedLinkMissing => T.T("BusinessSubscriptionBillingPlaybookMissingHostedLink"),
        BusinessSubscriptionInvoiceQueueFilter.Overdue => T.T("BusinessSubscriptionBillingPlaybookOverdue"),
        BusinessSubscriptionInvoiceQueueFilter.PdfMissing => T.T("BusinessSubscriptionBillingPlaybookMissingPdf"),
        _ => InvoiceQueueFilterText(filter)
    };
    string InvoiceQueueButtonClass(BusinessSubscriptionInvoiceQueueFilter filter) => filter switch
    {
        BusinessSubscriptionInvoiceQueueFilter.Paid => "btn btn-sm btn-outline-success",
        BusinessSubscriptionInvoiceQueueFilter.Open => "btn btn-sm btn-outline-warning",
        BusinessSubscriptionInvoiceQueueFilter.PdfMissing => "btn btn-sm btn-outline-warning",
        BusinessSubscriptionInvoiceQueueFilter.Uncollectible => "btn btn-sm btn-outline-danger",
        BusinessSubscriptionInvoiceQueueFilter.Overdue => "btn btn-sm btn-outline-danger",
        BusinessSubscriptionInvoiceQueueFilter.Stripe => "btn btn-sm btn-outline-info",
        _ => "btn btn-sm btn-outline-secondary"
    };
    string InvoiceQueueChipClass(BusinessSubscriptionInvoiceQueueFilter activeFilter, BusinessSubscriptionInvoiceQueueFilter filter) => filter switch
    {
        BusinessSubscriptionInvoiceQueueFilter.All => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-dark" : "btn-outline-dark")}",
        BusinessSubscriptionInvoiceQueueFilter.Open => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-warning" : "btn-outline-warning")}",
        BusinessSubscriptionInvoiceQueueFilter.PdfMissing => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-warning" : "btn-outline-warning")}",
        BusinessSubscriptionInvoiceQueueFilter.Overdue => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-danger" : "btn-outline-danger")}",
        BusinessSubscriptionInvoiceQueueFilter.Uncollectible => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-danger" : "btn-outline-danger")}",
        BusinessSubscriptionInvoiceQueueFilter.Stripe => $"{InvoiceQueueChipBaseClass()} {(activeFilter == filter ? "btn-info text-dark" : "btn-outline-info")}",
        _ => InvoiceQueueChipBaseClass()
    };
    string InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter filter) => filter switch
    {
        BusinessSubscriptionInvoiceQueueFilter.Stripe => T.T("CommonStripe"),
        BusinessSubscriptionInvoiceQueueFilter.Overdue => T.T("CommonOverdue"),
        BusinessSubscriptionInvoiceQueueFilter.PdfMissing => T.T("CommonPdfMissing"),
        _ => T.T("CommonStatus")
    };
    string InvoiceSubscriptionActionHref() => Url.Action("Subscription", "Businesses", new { businessId = InvoicePageBusinessIdValue() }) ?? string.Empty;
    string InvoiceQueueActionHref() => Url.Action("SubscriptionInvoices", "Businesses", new { businessId = InvoicePageBusinessIdValue() }) ?? string.Empty;
    string InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter filter) => Url.Action("SubscriptionInvoices", "Businesses", new { businessId = InvoicePageBusinessIdValue(), filter }) ?? string.Empty;
    string InvoicePaymentsActionHref() => Url.Action("Payments", "Billing", new { businessId = InvoicePageBusinessIdValue() }) ?? string.Empty;
    string InvoiceRowPaymentsActionHref(string? providerInvoiceId) => Url.Action("Payments", "Billing", new { businessId = InvoicePageBusinessIdValue(), q = providerInvoiceId }) ?? string.Empty;
    string InvoiceRefundsActionHref() => Url.Action("Refunds", "Billing", new { businessId = InvoicePageBusinessIdValue() }) ?? string.Empty;
    string InvoicePaymentSettingsActionFragment() => "site-settings-payments";
    string InvoicePaymentSettingsActionHref() => Url.Action("Edit", "SiteSettings", new { fragment = InvoicePaymentSettingsActionFragment() }) ?? string.Empty;
    string InvoiceSupportQueueActionHref() => Url.Action("SupportQueue", "Businesses") ?? string.Empty;
    string InvoiceMerchantReadinessActionHref() => Url.Action("MerchantReadiness", "Businesses") ?? string.Empty;
}

<div id="@InvoiceRootId()">
<div class="@InvoicePageHeaderClass()">
    <div>
<h1 class="@InvoicePageTitleClass()">@InvoiceTitleHeadingText()</h1>
<p class="@InvoicePageSubtitleClass()">@InvoiceSubtitleHeadingText()</p>
    </div>
    <div class="@InvoiceToolbarActionsRailClass()">
        <a href="@InvoiceSubscriptionActionHref()"
           class="@InvoiceToolbarSecondaryButtonClass()"
           hx-get="@InvoiceSubscriptionActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">
            <i class="@InvoiceToolbarIconGlyphClass("fa-credit-card")"></i> @InvoiceSubscriptionActionText()
        </a>
        <a href="@InvoicePaymentsActionHref()" class="@InvoiceToolbarSecondaryButtonClass()"
           hx-get="@InvoicePaymentsActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">
            <i class="@InvoiceToolbarIconGlyphClass("fa-money-bill-wave")"></i> @InvoicePaymentsActionText()
        </a>
        <a href="@InvoiceRefundsActionHref()" class="@InvoiceToolbarDangerButtonClass()"
           hx-get="@InvoiceRefundsActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">
            <i class="@InvoiceToolbarIconGlyphClass("fa-rotate-left")"></i> @InvoiceRefundsActionText()
        </a>
        <a href="@InvoicePaymentSettingsActionHref()" class="@InvoiceToolbarSecondaryButtonClass()"
           hx-get="@InvoicePaymentSettingsActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">
            <i class="@InvoiceToolbarIconGlyphClass("fa-sliders")"></i> @InvoicePaymentSettingsActionText()
        </a>
    </div>
</div>

