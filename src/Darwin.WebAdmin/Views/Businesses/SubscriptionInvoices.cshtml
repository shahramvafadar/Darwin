@using Darwin.Application.Billing
@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoicesListVm
@{
    ViewData["Title"] = "Subscription Invoices";
}

<div id="business-subscription-invoices-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">Subscription Invoices</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Subscription" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-credit-card"></i> Subscription
        </a>
        <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">
            <i class="fa-solid fa-money-bill-wave"></i> Payments
        </a>
        <a asp-controller="Billing" asp-action="Refunds" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-danger">
            <i class="fa-solid fa-rotate-left"></i> Refund Queue
        </a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-payments" class="btn btn-outline-secondary">
            <i class="fa-solid fa-sliders"></i> Payment Settings
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Open</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OpenCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Paid</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PaidCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Draft</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Uncollectible</div>
            <div class="fs-4 fw-semibold">@Model.Summary.UncollectibleCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Stripe</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Overdue</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OverdueCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">PDF Missing</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PdfMissingCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Subscription Billing Playbooks</div>
    <div class="card-body">
        <ul class="mb-0">
            <li>Open invoices normally indicate a billing follow-up or payment failure path that finance support should verify before changing subscription lifecycle flags.</li>
            <li>Uncollectible invoices usually require provider-side review, customer outreach, or cancel-at-period-end confirmation before manual escalation.</li>
            <li>Missing hosted invoice links mean provider synchronization is incomplete, so operators should use payment settings and provider references before escalating.</li>
            <li>Overdue invoices need customer follow-up or payment reconciliation before operators make subscription-lifecycle decisions.</li>
            <li>Missing PDFs are a document-visibility gap; use hosted links and payment history first, then escalate if download artifacts are required.</li>
        </ul>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="SubscriptionInvoices"
          method="get"
          hx-get="@Url.Action("SubscriptionInvoices", "Businesses")"
          hx-target="#business-subscription-invoices-workspace-shell"
          hx-swap="outerHTML"
          class="d-flex gap-2">
        <input type="hidden" name="businessId" value="@Model.Business.Id" />
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search provider invoice, plan, or failure reason">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> Filter</button>
        <a asp-action="SubscriptionInvoices" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary">Reset</a>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>Provider</th>
                <th>Plan</th>
                <th>Status</th>
                <th>Amount</th>
                <th>Timeline</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No subscription invoices found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Provider</div>
                        <div class="small text-muted">@item.ProviderInvoiceId</div>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">Stripe</span></div>
                        }
                    </td>
                    <td>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.PlanName) ? "-" : item.PlanName)</div>
                        <div class="small text-muted">@item.PlanCode</div>
                    </td>
                    <td>
                        <span class="badge @(item.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : item.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary")">
                            @item.Status
                        </span>
                        @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                        {
                            <div class="small text-danger mt-1">@item.FailureReason</div>
                        }
                        @if (item.IsOverdue)
                        {
                            <div><span class="badge bg-danger mt-1">Overdue</span></div>
                        }
                        @if (!item.HasPdfUrl)
                        {
                            <div><span class="badge bg-warning text-dark mt-1">PDF missing</span></div>
                        }
                    </td>
                    <td>@item.Currency @((item.TotalMinor / 100M).ToString("0.00"))</td>
                    <td>
                        <div>Issued: @item.IssuedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="small text-muted">Due: @(item.DueAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                        <div class="small text-muted">Paid: @(item.PaidAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            @if (item.HasHostedInvoiceUrl)
                            {
                                <a href="@item.HostedInvoiceUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">Hosted</a>
                            }
                            @if (item.HasPdfUrl)
                            {
                                <a href="@item.PdfUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">PDF</a>
                            }
                            <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" asp-route-q="@item.ProviderInvoiceId" class="btn btn-outline-secondary">Payments</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
</div>
