       hx-push-url="@InvoicePushUrlValue()">@InvoiceQueueFilterText(BusinessSubscriptionInvoiceQueueFilter.Uncollectible)</a>
</div>

<div class="@InvoiceTableWrapperClass()">
    <table class="@InvoiceTableClass()">
<thead class="@InvoiceTableHeaderClass()">
            <tr>
                <th>@InvoiceProviderColumnHeaderText()</th>
                <th>@InvoicePlanColumnHeaderText()</th>
                <th>@InvoiceStatusColumnHeaderText()</th>
                <th>@InvoiceAmountColumnHeaderText()</th>
                <th>@InvoiceTimelineColumnHeaderText()</th>
<th class="@InvoiceTableActionsClass()">@InvoiceActionsColumnHeaderText()</th>
            </tr>
        </thead>
        <tbody>
        @if (!InvoiceHasRows())
        {
            <tr>
                <td colspan="@InvoiceTableColumnTotal()" class="@InvoiceEmptyTableStateCellClass()">
                    <div>@InvoiceEmptyStateMessageText()</div>
<div class="@InvoiceEmptyStateButtonsRailClass()">
                        <a href="@InvoiceSubscriptionActionHref()"
                           class="@InvoiceEmptyStateButtonClass()"
                           hx-get="@InvoiceSubscriptionActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">@InvoiceSubscriptionActionText()</a>
                        <a href="@InvoicePaymentsActionHref()"
                           class="@InvoiceEmptyStateButtonClass()"
                           hx-get="@InvoicePaymentsActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">@InvoicePaymentsActionText()</a>
                        <a href="@InvoiceSupportQueueActionHref()"
                           class="@InvoiceEmptyStateButtonClass()"
                           hx-get="@InvoiceSupportQueueActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">@InvoiceSupportQueueActionText()</a>
                        <a href="@InvoiceMerchantReadinessActionHref()"
                           class="@InvoiceEmptyStateButtonClass()"
                           hx-get="@InvoiceMerchantReadinessActionHref()"
           hx-target="@InvoiceRootTarget()"
           hx-swap="@InvoiceRootSwap()"
           hx-push-url="@InvoicePushUrlValue()">@InvoiceMerchantReadinessActionText()</a>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var item in InvoiceRowItems())
            {
                <tr>
                    <td>
<div class="@InvoiceValueTextClass()">@InvoiceRowProviderText(item.Provider)</div>
<div class="@InvoiceMetaTextClass()">@InvoiceRowProviderInvoiceIdText(item.ProviderInvoiceId)</div>
                        @if (InvoiceRowHasStripeSignal(item))
                        {
                            <div><span class="@InvoiceStripeSignalBadgeShellClass()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.Stripe)</span></div>
                        }
                    </td>
                    <td>
<div class="@InvoiceValueTextClass()">@InvoiceRowPlanNameText(item.PlanName)</div>
<div class="@InvoiceMetaTextClass()">@InvoiceRowPlanCodeText(item.PlanCode)</div>
                    </td>
                    <td>
                        <span class="@InvoiceRowStatusBadgeClass(item)">
                            @InvoiceRowStatusText(item)
                        </span>
                        @if (InvoiceRowHasFailureReason(item))
                        {
                            <div class="@InvoiceFailureTextClass()">@InvoiceRowFailureReasonText(item.FailureReason)</div>
                        }
                        @if (InvoiceRowHasOverdueSignal(item))
                        {
                            <div><span class="@InvoiceOverdueSignalBadgeShellClass()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.Overdue)</span></div>
                        }
                        @if (InvoiceRowHasPdfMissingSignal(item))
                        {
                            <div><span class="@InvoicePdfMissingSignalBadgeShellClass()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.PdfMissing)</span></div>
                        }
                    </td>
                    <td>@InvoiceRowAmountText(item)</td>
                    <td>
                        <div>@InvoiceRowIssuedTimelineText(item)</div>
<div class="@InvoiceTimelineTextClass()">@InvoiceRowDueTimelineText(item)</div>
<div class="@InvoiceTimelineTextClass()">@InvoiceRowPaidTimelineText(item)</div>
                    </td>
<td class="@InvoiceTableActionsClass()">
                        <div class="@InvoiceRowActionsClass()">
                            @if (InvoiceRowHasHostedAction(item))
                            {
                                <a href="@InvoiceRowHostedActionHref(item.HostedInvoiceUrl)" target="@InvoiceExternalTarget()" rel="@InvoiceExternalRel()" class="@InvoiceRowButtonClass()">@InvoiceHostedActionText()</a>
                            }
                            @if (InvoiceRowHasPdfAction(item))
                            {
                                <a href="@InvoiceRowPdfActionHref(item.PdfUrl)" target="@InvoiceExternalTarget()" rel="@InvoiceExternalRel()" class="@InvoiceRowButtonClass()">@InvoicePdfActionText()</a>
                            }
                            <a href="@InvoiceRowPaymentsHref(item)" class="@InvoiceRowButtonClass()"
                               hx-get="@InvoiceRowPaymentsHref(item)"
                           hx-target="@InvoiceRootTarget()"
                           hx-swap="@InvoiceRootSwap()"
                           hx-push-url="@InvoicePushUrlValue()">@InvoicePaymentsActionText()</a>
                            <a href="@InvoiceSupportQueueActionHref()"
                               class="@InvoiceRowButtonClass()"
                               hx-get="@InvoiceSupportQueueActionHref()"
                           hx-target="@InvoiceRootTarget()"
                           hx-swap="@InvoiceRootSwap()"
                           hx-push-url="@InvoicePushUrlValue()">@InvoiceSupportQueueActionText()</a>
                            <a href="@InvoiceMerchantReadinessActionHref()"
                               class="@InvoiceRowButtonClass()"
                               hx-get="@InvoiceMerchantReadinessActionHref()"
                           hx-target="@InvoiceRootTarget()"
                           hx-swap="@InvoiceRootSwap()"
                           hx-push-url="@InvoicePushUrlValue()">@InvoiceMerchantReadinessActionText()</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
</div>










