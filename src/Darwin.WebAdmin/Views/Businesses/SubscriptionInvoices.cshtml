@using Darwin.Application.Billing
@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSubscriptionInvoicesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSubscriptionInvoicesTitle");
    string LocalizeSubscriptionInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
}

<div id="business-subscription-invoices-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("BusinessSubscriptionInvoicesTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Subscription"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-subscription-invoices-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-credit-card"></i> @T.T("BusinessSubscriptionShort")
        </a>
        <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.Business.Id })"
           hx-target="#business-subscription-invoices-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-money-bill-wave"></i> @T.T("CommonPayments")
        </a>
        <a asp-controller="Billing" asp-action="Refunds" asp-route-businessId="@Model.Business.Id" class="btn btn-outline-danger"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.Business.Id })"
           hx-target="#business-subscription-invoices-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-rotate-left"></i> @T.T("RefundQueue")
        </a>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-payments" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
           hx-target="#business-subscription-invoices-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-sliders"></i> @T.T("PaymentSettings")
        </a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonTotal")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonAll")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonOpen")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OpenCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Open"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Open })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonOpen")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonPaid")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PaidCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Paid"
                   class="btn btn-sm btn-outline-success"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Paid })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonPaid")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonDraft")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Draft"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Draft })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonDraft")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonUncollectible")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.UncollectibleCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Uncollectible"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Uncollectible })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonUncollectible")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonStripe")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Stripe"
                   class="btn btn-sm btn-outline-info"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Stripe })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonStripe")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonOverdue")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OverdueCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Overdue"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Overdue })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonOverdue")</a>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonPdfMissing")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PdfMissingCount</div>
            <div class="mt-2">
                <a asp-action="SubscriptionInvoices"
                   asp-route-businessId="@Model.Business.Id"
                   asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.PdfMissing"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.PdfMissing })"
                   hx-target="#business-subscription-invoices-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommonPdfMissing")</a>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessSubscriptionBillingPlaybooksTitle")</div>
    <div class="card-body">
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SubscriptionInvoices"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Open"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Open })"
               hx-target="#business-subscription-invoices-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSubscriptionBillingPlaybookOpenInvoices")</a>
            <a asp-action="SubscriptionInvoices"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Uncollectible"
               class="btn btn-sm btn-outline-danger"
               hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Uncollectible })"
               hx-target="#business-subscription-invoices-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSubscriptionBillingPlaybookUncollectible")</a>
            <a asp-action="SubscriptionInvoices"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.HostedLinkMissing"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.HostedLinkMissing })"
               hx-target="#business-subscription-invoices-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSubscriptionBillingPlaybookMissingHostedLink")</a>
            <a asp-action="SubscriptionInvoices"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Overdue"
               class="btn btn-sm btn-outline-danger"
               hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Overdue })"
               hx-target="#business-subscription-invoices-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSubscriptionBillingPlaybookOverdue")</a>
            <a asp-action="SubscriptionInvoices"
               asp-route-businessId="@Model.Business.Id"
               asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.PdfMissing"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.PdfMissing })"
               hx-target="#business-subscription-invoices-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSubscriptionBillingPlaybookMissingPdf")</a>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="SubscriptionInvoices"
          method="get"
          hx-get="@Url.Action("SubscriptionInvoices", "Businesses")"
          hx-target="#business-subscription-invoices-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true"
          class="d-flex gap-2">
        <input type="hidden" name="businessId" value="@Model.Business.Id" />
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("BusinessSubscriptionInvoicesSearchPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> @T.T("CommonFilter")</button>
        <a asp-action="SubscriptionInvoices"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id })"
           hx-target="#business-subscription-invoices-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonReset")</a>
    </form>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.All ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonAll")</a>
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Open"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.Open ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Open })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonOpen")</a>
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Overdue"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.Overdue ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Overdue })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonOverdue")</a>
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.PdfMissing"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.PdfMissing ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.PdfMissing })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonPdfMissing")</a>
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Stripe"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.Stripe ? "btn-info text-dark" : "btn-outline-info")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Stripe })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonStripe")</a>
    <a asp-action="SubscriptionInvoices"
       asp-route-businessId="@Model.Business.Id"
       asp-route-filter="@BusinessSubscriptionInvoiceQueueFilter.Uncollectible"
       class="btn btn-sm @(Model.Filter == BusinessSubscriptionInvoiceQueueFilter.Uncollectible ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("SubscriptionInvoices", "Businesses", new { businessId = Model.Business.Id, filter = BusinessSubscriptionInvoiceQueueFilter.Uncollectible })"
       hx-target="#business-subscription-invoices-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CommonUncollectible")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("CommonProvider")</th>
                <th>@T.T("CommonPlan")</th>
                <th>@T.T("CommonStatus")</th>
                <th>@T.T("CommonAmount")</th>
                <th>@T.T("CommonTimeline")</th>
                <th class="text-end">@T.T("CommonActions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <div>@T.T("BusinessSubscriptionInvoicesEmptyState")</div>
                    <div class="d-flex gap-2 flex-wrap justify-content-center mt-3">
                        <a asp-action="Subscription"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Subscription", "Businesses", new { businessId = Model.Business.Id })"
                           hx-target="#business-subscription-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessSubscriptionShort")</a>
                        <a asp-controller="Billing"
                           asp-action="Payments"
                           asp-route-businessId="@Model.Business.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.Business.Id })"
                           hx-target="#business-subscription-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonPayments")</a>
                        <a asp-action="SupportQueue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("SupportQueue", "Businesses")"
                           hx-target="#business-subscription-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                        <a asp-action="MerchantReadiness"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                           hx-target="#business-subscription-invoices-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    </div>
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Provider</div>
                        <div class="small text-muted">@item.ProviderInvoiceId</div>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("CommonStripe")</span></div>
                        }
                    </td>
                    <td>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.PlanName) ? "-" : item.PlanName)</div>
                        <div class="small text-muted">@item.PlanCode</div>
                    </td>
                    <td>
                        <span class="badge @(item.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Paid ? "bg-success" : item.Status == Darwin.Domain.Enums.SubscriptionInvoiceStatus.Uncollectible ? "bg-danger" : "bg-secondary")">
                            @LocalizeSubscriptionInvoiceStatus(item.Status)
                        </span>
                        @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                        {
                            <div class="small text-danger mt-1">@item.FailureReason</div>
                        }
                        @if (item.IsOverdue)
                        {
                            <div><span class="badge bg-danger mt-1">@T.T("CommonOverdue")</span></div>
                        }
                        @if (!item.HasPdfUrl)
                        {
                            <div><span class="badge bg-warning text-dark mt-1">@T.T("CommonPdfMissing")</span></div>
                        }
                    </td>
                    <td>@item.Currency @((item.TotalMinor / 100M).ToString("0.00"))</td>
                    <td>
                        <div>@string.Format(T.T("CommonIssuedAt"), item.IssuedAtUtc.ToString("yyyy-MM-dd HH:mm"))</div>
                        <div class="small text-muted">@string.Format(T.T("CommonDueAt"), item.DueAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                        <div class="small text-muted">@string.Format(T.T("CommonPaidAt"), item.PaidAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            @if (item.HasHostedInvoiceUrl)
                            {
                                <a href="@item.HostedInvoiceUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">@T.T("CommonHosted")</a>
                            }
                            @if (item.HasPdfUrl)
                            {
                                <a href="@item.PdfUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">@T.T("CommonPdf")</a>
                            }
                            <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.Business.Id" asp-route-q="@item.ProviderInvoiceId" class="btn btn-outline-secondary"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.Business.Id, q = item.ProviderInvoiceId })"
                               hx-target="#business-subscription-invoices-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("CommonPayments")</a>
                            <a asp-action="SupportQueue"
                               class="btn btn-outline-secondary"
                               hx-get="@Url.Action("SupportQueue", "Businesses")"
                               hx-target="#business-subscription-invoices-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                            <a asp-action="MerchantReadiness"
                               class="btn btn-outline-secondary"
                               hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                               hx-target="#business-subscription-invoices-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
</div>
