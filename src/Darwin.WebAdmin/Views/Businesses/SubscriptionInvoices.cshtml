<div class="@InvoiceFilterToolbarClass()">
    <form action="@InvoiceQueueActionHref()"
          method="@InvoiceFilterMethod()"
          hx-get="@InvoiceQueueActionHref()"
      hx-target="@InvoiceRootTarget()"
      hx-swap="@InvoiceRootSwap()"
      hx-push-url="@InvoicePushUrlValue()"
class="@InvoiceFilterFieldsRailClass()">
        <input type="@InvoiceHiddenFieldType()" name="@InvoiceFilterBusinessFieldName()" value="@InvoiceFilterBusinessIdValue()" />
        <input type="@InvoiceQueryFieldType()" name="@InvoiceFilterQueryName()" value="@InvoiceFilterQueryValue()" class="@InvoiceFilterQueryClass()" placeholder="@InvoiceFilterPlaceholderText()">
        <select name="@InvoiceFilterQueueName()" asp-items="@InvoiceFilterQueueItems()" class="@InvoiceFilterSelectClass()"></select>
        <button class="@InvoiceFilterSubmitButtonClass()" type="@InvoiceSubmitButtonType()"><i class="@InvoiceToolbarIconGlyphClass("fa-filter")"></i> @InvoiceFilterSubmitText()</button>
        <a href="@InvoiceQueueActionHref()"
           class="@InvoiceFilterSubmitButtonClass()"
           hx-get="@InvoiceQueueActionHref()"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceFilterResetText()</a>
    </form>
</div>

<div class="@InvoiceQueueFilterRailClass()">
    <a href="@InvoiceQueueActionHref()"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.All)"
       hx-get="@InvoiceQueueActionHref()"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceQueueFilterText(BusinessSubscriptionInvoiceQueueFilter.All)</a>
    <a href="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Open)"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.Open)"
       hx-get="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Open)"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceQueueFilterText(BusinessSubscriptionInvoiceQueueFilter.Open)</a>
    <a href="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Overdue)"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.Overdue)"
       hx-get="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Overdue)"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.Overdue)</a>
    <a href="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.PdfMissing)"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.PdfMissing)"
       hx-get="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.PdfMissing)"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.PdfMissing)</a>
    <a href="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Stripe)"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.Stripe)"
       hx-get="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Stripe)"
       hx-target="@InvoiceRootTarget()"
       hx-swap="@InvoiceRootSwap()"
       hx-push-url="@InvoicePushUrlValue()">@InvoiceSignalFilterText(BusinessSubscriptionInvoiceQueueFilter.Stripe)</a>
    <a href="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Uncollectible)"
       class="@InvoiceQueueChipClass(InvoiceSelectedQueueFilter(), BusinessSubscriptionInvoiceQueueFilter.Uncollectible)"
       hx-get="@InvoiceQueueActionHrefFor(BusinessSubscriptionInvoiceQueueFilter.Uncollectible)"
       hx-target="@InvoiceRootTarget()"
