               hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail)</a>
        </div>
    </div>
    <div class="col-lg col-md-4">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName)</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingLegalNameBusinessCount</div>
            <a asp-action="Index"
               asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
               class="btn btn-sm btn-outline-secondary mt-auto"
               hx-get="@BusinessesIndexUrl(readinessFilter: Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName)"
