    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner)</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingOwnerBusinessCount</div>
            <a asp-action="Index"
               asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner"
               class="btn btn-sm btn-outline-secondary mt-auto"
               hx-get="@BusinessesIndexUrl(readinessFilter: Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner)"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner)</a>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingActivationMemberCount</div>
            <a asp-controller="Users"
               asp-action="Index"
               asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
               class="btn btn-sm btn-outline-secondary mt-auto"
               hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed)"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
            <a asp-controller="BusinessCommunications"
               asp-action="EmailAudits"
               asp-route-status="Failed"
               asp-route-flowKey="AccountActivation"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@EmailAuditsUrl(status: "Failed", flowKey: "AccountActivation")"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</div>
            <div class="fs-4 fw-semibold">@Model.Summary.LockedMemberCount</div>
            <a asp-controller="Users"
               asp-action="Index"
               asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
               class="btn btn-sm btn-outline-secondary mt-auto"
               hx-get="@UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter.Locked)"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg col-md-4">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)</div>
