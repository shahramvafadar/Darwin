@model Darwin.WebAdmin.ViewModels.Businesses.MerchantReadinessWorkspaceVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("MerchantReadinessTitle");
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("UsersFilterUnconfirmed"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("UsersFilterLocked"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
    string MemberWorkspaceLabel() => T.T("Members");
    string InvitationWorkspaceLabel() => T.T("Invitations");
    string InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites => T.T("PendingInvites"),
        _ => T.T("Invitations")
    };
    string BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive => T.T("ApprovedInactive"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner => T.T("BusinessesMissingOwner"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation => T.T("MissingPrimaryLocation"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail => T.T("MissingContactEmail"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName => T.T("MissingLegalName"),
        _ => T.T("Readiness")
    };
    string BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("SuspendedBusinesses"),
        _ => T.T("Status")
    };
    string BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("Suspended"),
        _ => T.T(status.ToString())
    };
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalEmailAuditsUrl() => Url.Action("EmailAudits", "BusinessCommunications") ?? string.Empty;
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalBusinessCommunicationsUrl() => Url.Action("Index", "BusinessCommunications") ?? string.Empty;
    string GlobalBusinessesIndexUrl() => Url.Action("Index", "Businesses") ?? string.Empty;
    string BusinessesIndexUrl(bool? attentionOnly = null, string? operationalStatus = null, Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter? readinessFilter = null) =>
        Url.Action("Index", "Businesses", new { attentionOnly, operationalStatus, readinessFilter }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessEditUrl(Guid id) => Url.Action("Edit", "Businesses", new { id }) ?? string.Empty;
    string BusinessSetupUrl(Guid id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessLocationsUrl(Guid businessId) => Url.Action("Locations", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId = null, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessSubscriptionUrl(Guid businessId) => Url.Action("Subscription", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSubscriptionInvoicesUrl(Guid businessId) => Url.Action("SubscriptionInvoices", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessOwnerOverrideAuditsUrl(Guid businessId) => Url.Action("OwnerOverrideAudits", "Businesses", new { businessId }) ?? string.Empty;
    string UsersUrl(Darwin.Application.Identity.DTOs.UserQueueFilter filter) => Url.Action("Index", "Users", new { filter }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string SiteSettingsUrl(string fragment) => Url.Action("Edit", "SiteSettings", new { fragment }) ?? string.Empty;
    string BusinessCommunicationsDetailsUrl(Guid businessId) => Url.Action("Details", "BusinessCommunications", new { businessId }) ?? string.Empty;
    string EmailAuditsUrl(Guid? businessId = null, string? status = null, string? flowKey = null, bool? retryBlockedOnly = null) =>
        Url.Action("EmailAudits", "BusinessCommunications", new { businessId, status, flowKey, retryBlockedOnly }) ?? string.Empty;
    string ChannelAuditsUrl(Guid? businessId = null, bool? phoneVerificationOnly = null) =>
        Url.Action("ChannelAudits", "BusinessCommunications", new { businessId, phoneVerificationOnly }) ?? string.Empty;
    string MobileOperationsUrl(Guid? businessId) => Url.Action("Index", "MobileOperations", new { businessId }) ?? string.Empty;
    string PaymentsUrl(Guid businessId) => Url.Action("Payments", "Billing", new { businessId }) ?? string.Empty;
    string RefundsUrl(Guid businessId) => Url.Action("Refunds", "Billing", new { businessId }) ?? string.Empty;
    string FinancialAccountsUrl(Guid businessId) => Url.Action("FinancialAccounts", "Billing", new { businessId }) ?? string.Empty;
    string ExpensesUrl(Guid businessId) => Url.Action("Expenses", "Billing", new { businessId }) ?? string.Empty;
    string JournalEntriesUrl(Guid businessId) => Url.Action("JournalEntries", "Billing", new { businessId }) ?? string.Empty;
    string SubscriptionStatusLabel(string? status) => string.IsNullOrWhiteSpace(status) ? "-" : T.T(status);
    string SubscriptionPlanDisplay(string? planName, string? status) => !string.IsNullOrWhiteSpace(planName)
        ? planName
        : SubscriptionStatusLabel(status);
    string ReadinessBadgeClass(bool ready) => ready
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string ReadinessBadgeText(bool ready) => ready ? T.T("Configured") : T.T("NeedsAttention");
    var commerceReadyCount = Model.Items.Count(x => x.HasSubscription && x.PrimaryLocationCount > 0 && x.HasLegalNameConfigured);
    var missingCommerceCount = Model.Items.Count - commerceReadyCount;
    var communicationPolicyReadyCount = Model.Items.Count(x => x.HasContactEmailConfigured);
    var communicationPolicyAttentionCount = Model.Items.Count - communicationPolicyReadyCount;
    var communicationDeliveryVisibilityAttentionCount = Model.Summary.PendingActivationMemberCount + Model.Summary.LockedMemberCount;
    var communicationRuntimeExecutionAttentionCount = Model.Summary.PendingActivationMemberCount
        + Model.Summary.FailedInvitationCount
        + Model.Summary.FailedActivationCount
        + Model.Summary.FailedPasswordResetCount
        + Model.Summary.FailedAdminTestCount;
    var communicationReadyCount = communicationPolicyReadyCount;
    var communicationAttentionCount = communicationPolicyAttentionCount;
    var communicationFamilyReadyCount = Model.Items.Count(x => x.HasContactEmailConfigured && x.InvitationCount == 0);
    var communicationFamilyAttentionCount = Model.Items.Count - communicationFamilyReadyCount;
}

<div id="merchant-readiness-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-store me-2"></i>@T.T("MerchantReadinessTitle")</h1>
        <p class="text-muted mb-0">@T.T("MerchantReadinessIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="SupportQueue"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
           hx-target="#merchant-readiness-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-action="Index"
           asp-route-attentionOnly="true"
           class="btn btn-outline-secondary"
           hx-get="@BusinessesIndexUrl(attentionOnly: true)"
           hx-target="#merchant-readiness-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
        <a asp-controller="Billing"
           asp-action="Payments"
           class="btn btn-outline-secondary"
           hx-get="@GlobalPaymentsUrl()"
           hx-target="#merchant-readiness-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Payments")</a>
        <a asp-controller="Billing"
           asp-action="TaxCompliance"
           class="btn btn-outline-secondary"
               hx-get="@GlobalTaxComplianceUrl()"
           hx-target="#merchant-readiness-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("TaxComplianceTitle")</a>
    </div>
</div>

