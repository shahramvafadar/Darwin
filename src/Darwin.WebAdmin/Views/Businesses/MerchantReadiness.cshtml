                                           hx-target="#merchant-readiness-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("MerchantReadinessSetupMissing")</a>
                                    </div>
                                }
                                @if (item.ActiveOwnerCount == 0)
                                {
                                    <div class="small">
                                        <a asp-action="Members"
                                           asp-route-businessId="@item.Id"
                                           class="text-decoration-none"
                                           hx-get="@Url.Action("Members", "Businesses", new { businessId = item.Id })"
