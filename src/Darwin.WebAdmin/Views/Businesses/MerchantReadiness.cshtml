</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <span>@T.T("GoLiveReadiness")</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SupportQueue"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessSupportQueueUrl(Model.BusinessId)"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
            <a asp-action="Index"
               asp-route-attentionOnly="true"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@BusinessesIndexUrl(attentionOnly: true)"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("NeedsAttention")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-xl-3 col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <div class="fw-semibold">@T.T("OperationalStatus")</div>
                        <span class="@ReadinessBadgeClass(Model.Summary.PendingApprovalBusinessCount == 0 && Model.Summary.SuspendedBusinessCount == 0 && Model.Summary.ApprovedInactiveBusinessCount == 0)">@ReadinessBadgeText(Model.Summary.PendingApprovalBusinessCount == 0 && Model.Summary.SuspendedBusinessCount == 0 && Model.Summary.ApprovedInactiveBusinessCount == 0)</span>
                    </div>
                    <div class="small mb-2">@string.Format("{0} / {1} / {2}", Model.Summary.PendingApprovalBusinessCount, Model.Summary.SuspendedBusinessCount, Model.Summary.ApprovedInactiveBusinessCount)</div>
                    <div class="small text-muted mb-3">@T.T("MerchantReadinessIntro")</div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-operationalStatus="PendingApproval"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessesIndexUrl(operationalStatus: "PendingApproval")"
                           hx-target="#merchant-readiness-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PendingApproval")</a>
                        <a asp-action="Index"
                           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessesIndexUrl(readinessFilter: Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)"
                           hx-target="#merchant-readiness-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ApprovedInactive")</a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-status="Failed"
                           asp-route-flowKey="AdminCommunicationTest"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EmailAuditsUrl(status: "Failed", flowKey: "AdminCommunicationTest")"
                           hx-target="#merchant-readiness-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FailedAdminTests")</a>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <div class="fw-semibold">@T.T("TaxComplianceTitle")</div>
                        <span class="@ReadinessBadgeClass(Model.Summary.MissingLegalNameBusinessCount == 0 && Model.Summary.MissingContactEmailBusinessCount == 0)">@ReadinessBadgeText(Model.Summary.MissingLegalNameBusinessCount == 0 && Model.Summary.MissingContactEmailBusinessCount == 0)</span>
                    </div>
                    <div class="small mb-2">@string.Format("{0} / {1}", Model.Summary.MissingLegalNameBusinessCount, Model.Summary.MissingContactEmailBusinessCount)</div>
                    <div class="small text-muted mb-3">@T.T("TaxPolicyComplianceScopeNote")</div>
                    <div class="small text-muted mb-3">@T.T("CollectionReviewSubtitle"): @T.T("Overdue"), @T.T("DueSoon"), @T.T("Draft")</div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Billing"
                           asp-action="TaxCompliance"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalTaxComplianceUrl()"
                           hx-target="#merchant-readiness-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("TaxComplianceTitle")</a>
                        <a asp-action="Index"
                           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessesIndexUrl(readinessFilter: Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName)"
                           hx-target="#merchant-readiness-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MissingLegalName")</a>
                        <a asp-controller="Crm"
                           asp-action="Invoices"
                           asp-route-filter="Overdue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CrmInvoicesUrl("Overdue")"
