    </div>
    <div class="col-lg col-md-4">
        <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
            <div class="text-muted small">@InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingInvitationCount</div>
            <a asp-action="Index"
               asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites"
