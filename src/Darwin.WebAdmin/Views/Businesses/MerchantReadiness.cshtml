</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("MerchantReadinessPlaybooksTitle")</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SupportQueue"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("SupportQueue", "Businesses")"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
            <a asp-controller="Billing"
               asp-action="Payments"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Payments", "Billing")"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Payments")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("TaxComplianceScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="text-decoration-none"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#merchant-readiness-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.Title</a>
                            }
                            else
                            {
                                @playbook.Title
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.FollowUpUrl))
                            {
                                <a href="@playbook.FollowUpUrl"
                                   class="text-decoration-none"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#merchant-readiness-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.ScopeNote</a>
                            }
                            else
                            {
                                @playbook.ScopeNote
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <div class="mb-2">
                                    <a href="@playbook.QueueActionUrl"
                                       class="text-decoration-none"
                                       hx-get="@playbook.QueueActionUrl"
                                       hx-target="#merchant-readiness-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@playbook.OperatorAction</a>
                                </div>
                            }
                            else
                            {
                                <div class="mb-2">@playbook.OperatorAction</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#merchant-readiness-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.FollowUpUrl))
                            {
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#merchant-readiness-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="SupportQueue"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("SupportQueue", "Businesses")"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
            <a asp-action="Index"
               asp-route-attentionOnly="true"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
            <a asp-controller="Billing"
               asp-action="Payments"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Payments", "Billing")"
               hx-target="#merchant-readiness-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Payments")</a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("MerchantReadinessQueueTitle")</span>
        <a asp-controller="BusinessCommunications"
           asp-action="Index"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#merchant-readiness-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommunicationOps")</a>
    </div>
    <div class="card-body">
        @if (Model.Items.Count == 0)
        {
            <div class="text-muted mb-3">@T.T("MerchantReadinessEmptyState")</div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses")"
                   hx-target="#merchant-readiness-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessesTitle")</a>
                <a asp-action="SupportQueue"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("SupportQueue", "Businesses")"
                   hx-target="#merchant-readiness-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="Billing"
                   asp-action="Payments"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Payments", "Billing")"
                   hx-target="#merchant-readiness-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Payments")</a>
                <a asp-controller="BusinessCommunications"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "BusinessCommunications")"
                   hx-target="#merchant-readiness-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CommunicationOps")</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Business")</th>
                            <th>@T.T("Status")</th>
                            <th>@T.T("MerchantReadinessSetupColumn")</th>
                            <th>@T.T("MerchantReadinessSubscriptionColumn")</th>
                            <th>@T.T("Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var setupMissing = item.ActiveOwnerCount == 0 || item.PrimaryLocationCount == 0 || !item.HasContactEmailConfigured || !item.HasLegalNameConfigured;
                        <tr>
                            <td>
                                <div class="fw-semibold">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="text-decoration-none"
                                       hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                                       hx-target="#merchant-readiness-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@item.Name</a>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.LegalName))
                                {
                                    <div class="small text-muted">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="text-muted text-decoration-none"
                                           hx-get="@Url.Action("Edit", "Businesses", new { id = item.Id })"
                                           hx-target="#merchant-readiness-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.LegalName</a>
                                    </div>
                                }
                                @if (item.InvitationCount > 0)
                                {
                                    <div class="small">
                                        <a asp-action="Invitations"
                                           asp-route-businessId="@item.Id"
                                           class="text-decoration-none"
                                           hx-get="@Url.Action("Invitations", "Businesses", new { businessId = item.Id })"
                                           hx-target="#merchant-readiness-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@item.InvitationCount @InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</a>
                                    </div>
                                }
                            </td>
                            <td>
                                @if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                                {
                                    <a asp-action="Index"
                                       asp-route-operationalStatus="PendingApproval"
                                       class="badge text-bg-warning text-decoration-none"
                                       hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "PendingApproval" })"
                                       hx-target="#merchant-readiness-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)</a>
                                }
                                else if (item.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                                {
                                    <a asp-action="Index"
                                       asp-route-operationalStatus="Suspended"
                                       class="badge text-bg-danger text-decoration-none"
                                       hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = "Suspended" })"
                                       hx-target="#merchant-readiness-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@BusinessOperationalStatusLabel(Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)</a>
                                }
                                else if (!item.IsActive)
                                {
                                    <a asp-action="Index"
                                       asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
                                       class="badge text-bg-secondary text-decoration-none"
