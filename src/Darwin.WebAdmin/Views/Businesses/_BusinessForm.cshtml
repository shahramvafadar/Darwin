@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    var canToggleActive = !isCreate && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved;
    string GlobalBusinessesIndexUrl() => Url.Action("Index", "Businesses") ?? string.Empty;
    string GlobalUsersUrl() => Url.Action("Index", "Users") ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessLocationsUrl(Guid? businessId) => Url.Action("Locations", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="BrandDisplayName" />
<input type="hidden" asp-for="BrandLogoUrl" />
<input type="hidden" asp-for="BrandPrimaryColorHex" />
<input type="hidden" asp-for="BrandSecondaryColorHex" />
<input type="hidden" asp-for="DefaultTimeZoneId" />
<input type="hidden" asp-for="SupportEmail" />
<input type="hidden" asp-for="CommunicationSenderName" />
<input type="hidden" asp-for="CommunicationReplyToEmail" />
<input type="hidden" asp-for="CustomerEmailNotificationsEnabled" />
<input type="hidden" asp-for="CustomerMarketingEmailsEnabled" />
<input type="hidden" asp-for="OperationalAlertEmailsEnabled" />

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("BusinessIdentitySection")</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label">@T.T("BusinessFormBusinessName")</label>
            <field-help title="@T.T("BusinessFormBusinessName")" content="@T.T("BusinessFormBusinessNameHelp")" placement="right"></field-help>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="LegalName" class="form-label">@T.T("BusinessFormLegalName")</label>
            <field-help title="@T.T("BusinessFormLegalName")" content="@T.T("BusinessFormLegalNameHelp")" placement="right"></field-help>
            <input asp-for="LegalName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Category" class="form-label">@T.T("BusinessFormCategory")</label>
            <field-help title="@T.T("BusinessFormCategory")" content="@T.T("BusinessFormCategoryHelp")" placement="right"></field-help>
            <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="TaxId" class="form-label">@T.T("BusinessFormTaxId")</label>
            <field-help title="@T.T("BusinessFormTaxId")" content="@T.T("BusinessFormTaxIdHelp")" placement="right"></field-help>
            <input asp-for="TaxId" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="WebsiteUrl" class="form-label">@T.T("BusinessFormWebsite")</label>
            <field-help title="@T.T("BusinessFormWebsite")" content="@T.T("BusinessFormWebsiteHelp")" placement="right"></field-help>
            <input asp-for="WebsiteUrl" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="ShortDescription" class="form-label">@T.T("BusinessFormShortDescription")</label>
            <field-help title="@T.T("BusinessFormShortDescription")" content="@T.T("BusinessFormShortDescriptionHelp")" placement="right"></field-help>
            <textarea asp-for="ShortDescription" class="form-control" rows="4"></textarea>
        </div>
    </div>
</section>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("BusinessDefaultsSection")</h2>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="DefaultCurrency" class="form-label">@T.T("BusinessFormDefaultCurrency")</label>
            <field-help title="@T.T("BusinessFormDefaultCurrency")" content="@T.T("BusinessFormDefaultCurrencyHelp")" placement="right"></field-help>
            <setting-select asp-for="DefaultCurrency" setting="SupportedCurrenciesCsv"></setting-select>
        </div>
        <div class="col-md-4">
            <label asp-for="DefaultCulture" class="form-label">@T.T("BusinessFormDefaultCulture")</label>
            <field-help title="@T.T("BusinessFormDefaultCulture")" content="@T.T("BusinessFormDefaultCultureHelp")" placement="right"></field-help>
            <setting-select asp-for="DefaultCulture" setting="SupportedCulturesCsv"></setting-select>
        </div>
        <div class="col-md-4">
            <label asp-for="DefaultTimeZoneId" class="form-label">@T.T("DefaultTimeZone")</label>
            <field-help title="@T.T("DefaultTimeZone")" content="@T.T("DefaultTimeZoneHelp")" placement="right"></field-help>
            <setting-select asp-for="DefaultTimeZoneId" setting="SupportedTimezonesCsv"></setting-select>
        </div>
    </div>
</section>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("BusinessContactSection")</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="ContactEmail" class="form-label">@T.T("BusinessFormContactEmail")</label>
            <field-help title="@T.T("BusinessFormContactEmail")" content="@T.T("BusinessFormContactEmailHelp")" placement="right"></field-help>
            <input asp-for="ContactEmail" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="ContactPhoneE164" class="form-label">@T.T("BusinessFormContactPhone")</label>
            <field-help title="@T.T("BusinessFormContactPhone")" content="@T.T("BusinessFormContactPhoneHelp")" placement="right"></field-help>
            <input asp-for="ContactPhoneE164" class="form-control" />
        </div>
    </div>
</section>

<section class="admin-form-section">
    <h2 class="admin-form-section-title">@T.T("BusinessOwnershipStatusSection")</h2>
    <div class="row g-3">
    @if (isCreate)
    {
        <div class="col-md-6">
            <label asp-for="OwnerUserId" class="form-label">@T.T("BusinessFormInitialOwner")</label>
            <field-help title="@T.T("BusinessFormInitialOwner")" content="@T.T("BusinessFormInitialOwnerHelp")" placement="right"></field-help>
            <select asp-for="OwnerUserId" asp-items="Model.OwnerUserOptions" class="form-select"></select>
            <div class="form-text">
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@GlobalUsersUrl()"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Users")</a>
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <label asp-for="OwnerInviteEmail" class="form-label">@T.T("BusinessFormInitialOwnerInviteEmail")</label>
            <field-help title="@T.T("BusinessFormInitialOwnerInviteEmail")" content="@T.T("BusinessFormInitialOwnerInviteEmailHelp")" placement="right"></field-help>
            <input asp-for="OwnerInviteEmail" class="form-control" type="email" />
            <div class="form-text">
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        </div>
    }
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" disabled="@(!canToggleActive)" />
            <label asp-for="IsActive" class="form-check-label">@T.T("BusinessFormBusinessIsActive")</label>
            <field-help title="@T.T("BusinessFormBusinessIsActive")" content="@T.T("BusinessFormActiveHelp")" placement="right"></field-help>
        </div>
        @if (!canToggleActive)
        {
            <div class="form-text">
                <div>@T.T("BusinessFormActiveHelp")</div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        }
    </div>
    </div>
</section>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-floppy-disk"></i> @T.T("Save")
    </button>
    @if (isCreate)
    {
        <a asp-action="Index"
           class="btn btn-outline-secondary"
               hx-get="@GlobalBusinessesIndexUrl()"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Cancel")</a>
    }
    else
    {
        <a asp-action="Index"
           class="btn btn-outline-secondary"
               hx-get="@GlobalBusinessesIndexUrl()"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormBackToList")</a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Id"
           asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMembersUrl(Model.Id, Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageMembers")</a>
        <a asp-action="Locations"
           asp-route-businessId="@Model.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessLocationsUrl(Model.Id)"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageLocations")</a>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Id"
           asp-route-filter="@(Model.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           class="btn btn-outline-secondary"
           hx-get="@BusinessInvitationsUrl(Model.Id, Model.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageInvitations")</a>
        <a asp-action="SupportQueue"
           asp-route-businessId="@Model.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessSupportQueueUrl(Model.Id)"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-action="MerchantReadiness"
           asp-route-businessId="@Model.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
    }
</div>
