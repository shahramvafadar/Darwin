@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    var canToggleActive = !isCreate && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved;
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="BrandDisplayName" />
<input type="hidden" asp-for="BrandLogoUrl" />
<input type="hidden" asp-for="BrandPrimaryColorHex" />
<input type="hidden" asp-for="BrandSecondaryColorHex" />
<input type="hidden" asp-for="DefaultTimeZoneId" />
<input type="hidden" asp-for="SupportEmail" />
<input type="hidden" asp-for="CommunicationSenderName" />
<input type="hidden" asp-for="CommunicationReplyToEmail" />
<input type="hidden" asp-for="CustomerEmailNotificationsEnabled" />
<input type="hidden" asp-for="CustomerMarketingEmailsEnabled" />
<input type="hidden" asp-for="OperationalAlertEmailsEnabled" />

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label">@T.T("BusinessFormBusinessName")</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="LegalName" class="form-label">@T.T("BusinessFormLegalName")</label>
        <input asp-for="LegalName" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Category" class="form-label">@T.T("BusinessFormCategory")</label>
        <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="DefaultCurrency" class="form-label">@T.T("BusinessFormDefaultCurrency")</label>
        <setting-select asp-for="DefaultCurrency" setting="SupportedCurrenciesCsv"></setting-select>
    </div>
    <div class="col-md-4">
        <label asp-for="DefaultCulture" class="form-label">@T.T("BusinessFormDefaultCulture")</label>
        <setting-select asp-for="DefaultCulture" setting="SupportedCulturesCsv"></setting-select>
    </div>
    <div class="col-md-4">
        <label asp-for="DefaultTimeZoneId" class="form-label">@T.T("DefaultTimeZone")</label>
        <setting-select asp-for="DefaultTimeZoneId" setting="SupportedTimezonesCsv"></setting-select>
        <div class="form-text">@T.T("DefaultTimeZoneHelp")</div>
    </div>
    <div class="col-md-6">
        <label asp-for="TaxId" class="form-label">@T.T("BusinessFormTaxId")</label>
        <input asp-for="TaxId" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="WebsiteUrl" class="form-label">@T.T("BusinessFormWebsite")</label>
        <input asp-for="WebsiteUrl" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ContactEmail" class="form-label">@T.T("BusinessFormContactEmail")</label>
        <input asp-for="ContactEmail" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ContactPhoneE164" class="form-label">@T.T("BusinessFormContactPhone")</label>
        <input asp-for="ContactPhoneE164" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="ShortDescription" class="form-label">@T.T("BusinessFormShortDescription")</label>
        <textarea asp-for="ShortDescription" class="form-control" rows="4"></textarea>
    </div>
    @if (isCreate)
    {
        <div class="col-md-6">
            <label asp-for="OwnerUserId" class="form-label">@T.T("BusinessFormInitialOwner")</label>
            <select asp-for="OwnerUserId" asp-items="Model.OwnerUserOptions" class="form-select"></select>
            <div class="form-text">
                <div>@T.T("BusinessFormInitialOwnerHelp")</div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-controller="Users"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Users")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Users")</a>
                    <a asp-action="SupportQueue"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <label asp-for="OwnerInviteEmail" class="form-label">@T.T("BusinessFormInitialOwnerInviteEmail")</label>
            <input asp-for="OwnerInviteEmail" class="form-control" type="email" />
            <div class="form-text">
                <div>@T.T("BusinessFormInitialOwnerInviteEmailHelp")</div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-action="SupportQueue"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        </div>
    }
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" disabled="@(!canToggleActive)" />
            <label asp-for="IsActive" class="form-check-label">@T.T("BusinessFormBusinessIsActive")</label>
        </div>
        @if (!canToggleActive)
        {
            <div class="form-text">
                <div>@T.T("BusinessFormActiveHelp")</div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-action="SupportQueue"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("SupportQueue", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                    <a asp-action="MerchantReadiness"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="fa-solid fa-floppy-disk"></i> @T.T("Save")
    </button>
    @if (isCreate)
    {
        <a asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses")"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Cancel")</a>
    }
    else
    {
        <a asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses")"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormBackToList")</a>
        <a asp-action="Members"
           asp-route-businessId="@Model.Id"
           asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
           class="btn btn-outline-secondary"
           hx-get="@(Model.ActiveOwnerCount > 0
               ? Url.Action("Members", "Businesses", new { businessId = Model.Id })
               : Url.Action("Members", "Businesses", new { businessId = Model.Id, filter = Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention }))"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageMembers")</a>
        <a asp-action="Locations"
           asp-route-businessId="@Model.Id"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Locations", "Businesses", new { businessId = Model.Id })"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageLocations")</a>
        <a asp-action="Invitations"
           asp-route-businessId="@Model.Id"
           asp-route-filter="@(Model.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
           class="btn btn-outline-secondary"
           hx-get="@(Model.InvitationCount > 0
               ? Url.Action("Invitations", "Businesses", new { businessId = Model.Id, filter = Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending })
               : Url.Action("Invitations", "Businesses", new { businessId = Model.Id }))"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessFormManageInvitations")</a>
        <a asp-action="SupportQueue"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("SupportQueue", "Businesses")"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
        <a asp-action="MerchantReadiness"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#business-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
    }
</div>
