                           hx-get="@Url.Action("ChannelAudits", "BusinessCommunications", new { phoneVerificationOnly = true })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PhoneVerification")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("MerchantReadinessTitle")</div>
                        <span class="@SupportQueueHealthBadgeClass(goLiveBlockerCount == 0)">@SupportQueueHealthBadgeText(goLiveBlockerCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@goLiveBlockerCount</div>
                    <div class="small text-muted">@string.Format(T.T("BusinessSetupChecklistCounts"), Model.Summary.MissingOwnerBusinessCount, Model.Summary.MissingPrimaryLocationBusinessCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="MerchantReadiness"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                        <a asp-controller="Billing"
                           asp-action="TaxCompliance"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("TaxCompliance", "Billing")"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("TaxComplianceTitle")</a>
                        <a asp-action="Index"
                           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Locations")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("Payments")</div>
                        <span class="@SupportQueueHealthBadgeClass(financeAttentionCount == 0)">@SupportQueueHealthBadgeText(financeAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@financeAttentionCount</div>
                    <div class="small text-muted">@T.T("BusinessSetupPaymentsShippingNote")</div>
                    <div class="small text-muted">@T.T("CollectionReviewSubtitle"): @T.T("Overdue"), @T.T("DueSoon"), @T.T("Draft")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="Billing"
                           asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Payments", "Billing")"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Payments")</a>
                        <a asp-controller="Billing"
                           asp-action="Refunds"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Refunds", "Billing")"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Refunds")</a>
                        <a asp-controller="Crm"
                           asp-action="Invoices"
                           asp-route-filter="Overdue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Invoices", "Crm", new { filter = "Overdue" })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Overdue")</a>
                        <a asp-controller="Crm"
                           asp-action="Invoices"
                           asp-route-filter="DueSoon"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Invoices", "Crm", new { filter = "DueSoon" })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DueSoon")</a>
                        <a asp-controller="Crm"
                           asp-action="Invoices"
                           asp-route-filter="Draft"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Invoices", "Crm", new { filter = "Draft" })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Draft")</a>
                        <a asp-action="Index"
                           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="~/Views/Businesses/_SupportQueueSummary.cshtml" model="Model.Summary" />

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("TaxComplianceScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.Title</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.ScopeNote</a>
                        </td>
                        <td>
                            <div class="mb-2">
                                <a href="@playbook.QueueActionUrl"
                                   class="link-body-emphasis text-decoration-none"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.OperatorAction</a>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.FollowUpUrl))
                            {
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-7">
        <partial name="~/Views/Businesses/_SupportQueueAttentionBusinesses.cshtml" model="Model.AttentionBusinesses" />
    </div>
    <div class="col-xl-5">
        <partial name="~/Views/Businesses/_SupportQueueFailedEmails.cshtml" model="Model.FailedEmails" />
    </div>
</div>
</div>
