@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportQueueVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSupportQueueTitle");
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("LockedMembers"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
    string InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites => T.T("PendingInvites"),
        _ => T.T("Invitations")
    };
    string BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive => T.T("ApprovedInactive"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner => T.T("BusinessesMissingOwner"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation => T.T("MissingPrimaryLocation"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail => T.T("MissingContactEmail"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName => T.T("MissingLegalName"),
        _ => T.T("Readiness")
    };
    string BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("SuspendedBusinesses"),
        _ => T.T("Status")
    };
}

<div id="business-support-queue-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-life-ring me-2"></i>@T.T("BusinessSupportQueueTitle")</h1>
        <p class="text-muted mb-0">@T.T("BusinessSupportQueueIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="MerchantReadiness"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("MerchantReadiness", "Businesses")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
        <a asp-action="Index"
           asp-route-attentionOnly="true"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
        <a asp-controller="BusinessCommunications"
           asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "BusinessCommunications")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Communications")</a>
        <a asp-controller="Billing"
           asp-action="Payments"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Payments", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Payments")</a>
        <a asp-controller="Billing"
           asp-action="TaxCompliance"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("TaxCompliance", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("TaxComplianceTitle")</a>
        <a asp-controller="Billing"
           asp-action="Refunds"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Refunds", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Refunds")</a>
        <a asp-controller="Billing"
           asp-action="FinancialAccounts"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("FinancialAccounts", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("FinancialAccountsTitle")</a>
        <a asp-controller="Billing"
           asp-action="Expenses"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Expenses", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("ExpensesTitle")</a>
        <a asp-controller="Billing"
           asp-action="JournalEntries"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("JournalEntries", "Billing")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("JournalEntriesTitle")</a>
        <a asp-action="OwnerOverrideAudits"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("OwnerOverrideAudits", "Businesses")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OwnerOverrideAuditTitle")</a>
        <a asp-controller="MobileOperations"
           asp-action="Index"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "MobileOperations")"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("MobileOperationsTitle")</a>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-status="Failed"
           class="btn btn-outline-danger"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed" })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("FailedEmails")</a>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-status="Failed"
           asp-route-flowKey="BusinessInvitation"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "BusinessInvitation" })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenFailedInvitationEmails")</a>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-status="Failed"
           asp-route-flowKey="AccountActivation"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AccountActivation" })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
        <a asp-controller="BusinessCommunications"
           asp-action="EmailAudits"
           asp-route-status="Failed"
           asp-route-flowKey="PasswordReset"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset" })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenFailedPasswordResets")</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive)</a>
        <a asp-action="Index"
           asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)</a>
        <a asp-action="Index"
           asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.Suspended"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.Suspended })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner)</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation)</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail)</a>
        <a asp-action="Index"
           asp-route-readinessFilter="@Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Businesses", new { readinessFilter = Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName)</a>
        <a asp-controller="Users"
           asp-action="Index"
           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation)</a>
        <a asp-controller="Users"
           asp-action="Index"
           asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Locked })"
           hx-target="#business-support-queue-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked)</a>
</div>
</div>

<partial name="~/Views/Businesses/_SupportQueueSummary.cshtml" model="Model.Summary" />

<div class="card mb-3">
    <div class="card-header">@T.T("BusinessesOperationsPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("TaxComplianceScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("UsersPlaybooksFollowUpColumn")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="@playbook.QueueActionUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.QueueActionUrl"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.Title</a>
                        </td>
                        <td>
                            <a href="@playbook.FollowUpUrl"
                               class="link-body-emphasis text-decoration-none"
                               hx-get="@playbook.FollowUpUrl"
                               hx-target="#business-support-queue-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@playbook.ScopeNote</a>
                        </td>
                        <td>
                            <div class="mb-2">
                                <a href="@playbook.QueueActionUrl"
                                   class="link-body-emphasis text-decoration-none"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.OperatorAction</a>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(playbook.QueueActionUrl))
                            {
                                <a href="@playbook.QueueActionUrl"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@playbook.QueueActionUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.QueueActionLabel</a>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(playbook.FollowUpUrl))
                            {
                                <a href="@playbook.FollowUpUrl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@playbook.FollowUpUrl"
                                   hx-target="#business-support-queue-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@playbook.FollowUpLabel</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-7">
        <partial name="~/Views/Businesses/_SupportQueueAttentionBusinesses.cshtml" model="Model.AttentionBusinesses" />
    </div>
    <div class="col-xl-5">
        <partial name="~/Views/Businesses/_SupportQueueFailedEmails.cshtml" model="Model.FailedEmails" />
    </div>
</div>
</div>
