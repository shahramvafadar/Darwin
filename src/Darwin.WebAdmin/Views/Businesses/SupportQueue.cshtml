@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportQueueVm
@{
    ViewData["Title"] = "Business Support Queue";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-life-ring me-2"></i>Business Support Queue</h1>
        <p class="text-muted mb-0">Unified onboarding, activation, invitation, and failed-email triage surface for support operators.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" asp-route-attentionOnly="true" class="btn btn-outline-secondary">Businesses</a>
        <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-outline-secondary">Communications</a>
        <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" class="btn btn-outline-danger">Failed Emails</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Needs Attention</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AttentionBusinessCount</div>
            <a asp-action="Index" asp-route-attentionOnly="true" class="small">Open business queue</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Pending Approval</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingApprovalBusinessCount</div>
            <a asp-action="Index" asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval" class="small">Open pending approvals</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Open Invitations</div>
            <div class="fs-4 fw-semibold">@Model.Summary.OpenInvitationCount</div>
            <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="BusinessInvitation" class="small">Open failed invitation emails</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Pending Activation</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingActivationMemberCount</div>
            <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="AccountActivation" class="small">Open failed activation emails</a>
        </div>
    </div>
</div>

<div class="small text-muted mb-4">
    Suspended businesses: <strong>@Model.Summary.SuspendedBusinessCount</strong>
    <span class="mx-2">|</span>
    Businesses missing owner: <strong>@Model.Summary.MissingOwnerBusinessCount</strong>
    <span class="mx-2">|</span>
    Locked members: <strong>@Model.Summary.LockedMemberCount</strong>
    <span class="mx-2">|</span>
    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" asp-route-flowKey="PasswordReset">Open failed password resets</a>
</div>

<div class="row g-3">
    <div class="col-xl-7">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Attention Businesses</span>
                <a asp-action="Index" asp-route-attentionOnly="true" class="btn btn-sm btn-outline-secondary">Full Queue</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Business</th>
                                <th>Status</th>
                                <th>Signals</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.AttentionBusinesses.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No attention businesses are currently queued.</td></tr>
                        }
                        else
                        {
                            foreach (var item in Model.AttentionBusinesses)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(item.LegalName))
                                        {
                                            <div class="small text-muted">@item.LegalName</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge text-bg-secondary">@item.OperationalStatus</span>
                                        @if (!item.IsActive)
                                        {
                                            <span class="badge text-bg-warning ms-1">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.ActiveOwnerCount == 0)
                                        {
                                            <div class="small text-muted">Missing owner</div>
                                        }
                                        @if (item.PrimaryLocationCount == 0)
                                        {
                                            <div class="small text-muted">Missing primary location</div>
                                        }
                                        @if (!item.HasContactEmailConfigured)
                                        {
                                            <div class="small text-muted">Missing contact email</div>
                                        }
                                        @if (!item.HasLegalNameConfigured)
                                        {
                                            <div class="small text-muted">Missing legal name</div>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Setup" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Setup</a>
                                        <a asp-action="Members" asp-route-businessId="@item.Id" asp-route-filter="Attention" class="btn btn-sm btn-outline-secondary">Members</a>
                                        <a asp-action="Invitations" asp-route-businessId="@item.Id" asp-route-filter="Open" class="btn btn-sm btn-outline-secondary">Invites</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Recent Failed Email Events</span>
                <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-status="Failed" class="btn btn-sm btn-outline-secondary">Full Audit Log</a>
            </div>
            <div class="card-body">
                @if (Model.FailedEmails.Count == 0)
                {
                    <div class="text-muted">No failed phase-1 email events are currently queued.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var item in Model.FailedEmails)
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between gap-2">
                                    <div>
                                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.FlowKey) ? "Unclassified" : item.FlowKey)</div>
                                        <div class="small text-muted">@item.AttemptedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                                    </div>
                                    @if (item.BusinessId.HasValue)
                                    {
                                        <a asp-controller="BusinessCommunications" asp-action="Details" asp-route-businessId="@item.BusinessId" class="btn btn-sm btn-outline-secondary">Business</a>
                                    }
                                </div>
                                <div class="small mt-2">@item.RecipientEmail</div>
                                <div class="small text-muted">@item.Subject</div>
                                @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                                {
                                    <div class="small text-danger mt-2">@item.FailureMessage</div>
                                }
                                <div class="small mt-2">@item.RecommendedAction</div>
                                <div class="d-flex gap-2 flex-wrap mt-3">
                                    <a asp-controller="BusinessCommunications"
                                       asp-action="EmailAudits"
                                       asp-route-status="Failed"
                                       asp-route-flowKey="@item.FlowKey"
                                       asp-route-businessId="@item.BusinessId"
                                       class="btn btn-sm btn-outline-secondary">Open Similar Failures</a>
                                    @if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "BusinessInvitation", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="Invitations" asp-route-businessId="@item.BusinessId" asp-route-filter="Open" class="btn btn-sm btn-outline-primary">Open Invitations</a>
                                    }
                                    else if (item.BusinessId.HasValue && string.Equals(item.FlowKey, "AccountActivation", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a asp-action="Members" asp-route-businessId="@item.BusinessId" asp-route-filter="PendingActivation" class="btn btn-sm btn-outline-primary">Open Members</a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
