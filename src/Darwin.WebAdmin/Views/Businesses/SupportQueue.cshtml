<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("BusinessSupportQueueTitle")</h2>
                <p class="text-muted mb-0">@T.T("BusinessSetupChecklistDependencyNote")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="MerchantReadiness"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("MerchantReadiness", "Businesses")"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                <a asp-action="Index"
                   asp-route-attentionOnly="true"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
                   hx-target="#business-support-queue-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("NeedsAttention")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("OperationalStatus")</div>
                        <span class="@SupportQueueHealthBadgeClass(lifecycleAttentionCount == 0)">@SupportQueueHealthBadgeText(lifecycleAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@lifecycleAttentionCount</div>
                    <div class="small text-muted">@string.Format(T.T("BusinessSetupChecklistCounts"), Model.Summary.AttentionBusinessCount, Model.Summary.PendingApprovalBusinessCount)</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Index"
                           asp-route-attentionOnly="true"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Businesses", new { attentionOnly = true })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)</a>
                        <a asp-action="Index"
                           asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)</a>
                        <a asp-action="Index"
                           asp-route-operationalStatus="@Darwin.Domain.Enums.BusinessOperationalStatus.Suspended"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Index", "Businesses", new { operationalStatus = Darwin.Domain.Enums.BusinessOperationalStatus.Suspended })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("Communications")</div>
                        <span class="@SupportQueueHealthBadgeClass(communicationPolicyAttentionCount == 0 && communicationDeliveryVisibilityAttentionCount == 0 && communicationRuntimeExecutionAttentionCount == 0 && communicationFamilyAttentionCount == 0)">@SupportQueueHealthBadgeText(communicationPolicyAttentionCount == 0 && communicationDeliveryVisibilityAttentionCount == 0 && communicationRuntimeExecutionAttentionCount == 0 && communicationFamilyAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@communicationAttentionCount</div>
                    <div class="small text-muted">@T.T("BusinessSetupCommunicationsDependencyNote")</div>
                    <div class="small text-muted">@T.T("CommunicationPolicy"): @communicationPolicyAttentionCount</div>
                    <div class="small text-muted">@T.T("Communications"): @communicationDeliveryVisibilityAttentionCount</div>
                    <div class="small text-muted">@T.T("RetryBlocked") / @T.T("ActionBlocked") / @T.T("EscalationCandidates"): @communicationDeliveryVisibilityAttentionCount</div>
                    <div class="small text-muted">@T.T("CommunicationTemplateInventoryTitle"): @communicationFamilyAttentionCount</div>
                    <div class="small text-muted">@T.T("RuntimeExecution"): @communicationRuntimeExecutionAttentionCount (@T.T("OpenFailedInvitationEmails"): @failedInvitationAttentionCount / @T.T("UsersFilterUnconfirmed"): @Model.Summary.PendingActivationMemberCount / @T.T("OpenFailedActivationEmails"): @failedActivationAttentionCount / @T.T("FailedAdminTests"): @failedAdminTestAttentionCount / @T.T("OpenFailedPasswordResets"): @failedPasswordResetAttentionCount)</div>
