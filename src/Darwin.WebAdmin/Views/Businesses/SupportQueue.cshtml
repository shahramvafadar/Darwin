                           hx-push-url="true">@T.T("OpenFailedActivationEmails")</a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-status="Failed"
                           asp-route-flowKey="AdminCommunicationTest"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "AdminCommunicationTest" })"
                           hx-target="#business-support-queue-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FailedAdminTests")</a>
                        <a asp-controller="BusinessCommunications"
                           asp-action="EmailAudits"
                           asp-route-status="Failed"
                           asp-route-flowKey="PasswordReset"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EmailAudits", "BusinessCommunications", new { status = "Failed", flowKey = "PasswordReset" })"
                           hx-target="#business-support-queue-workspace-shell"
