@model Darwin.WebAdmin.ViewModels.Businesses.BusinessSupportQueueVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessSupportQueueTitle");
    string MemberSupportLabel(Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation => T.T("PendingActivation"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked => T.T("LockedMembers"),
        Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention => T.T("NeedsAttention"),
        _ => T.T("Members")
    };
    string InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites => T.T("PendingInvites"),
        _ => T.T("Invitations")
    };
    string BusinessReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.ApprovedInactive => T.T("ApprovedInactive"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingOwner => T.T("BusinessesMissingOwner"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingPrimaryLocation => T.T("MissingPrimaryLocation"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingContactEmail => T.T("MissingContactEmail"),
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.MissingLegalName => T.T("MissingLegalName"),
        _ => T.T("Readiness")
    };
    string BusinessOperationalQueueLabel(Darwin.Domain.Enums.BusinessOperationalStatus status) => status switch
    {
        Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval => T.T("PendingApproval"),
        Darwin.Domain.Enums.BusinessOperationalStatus.Suspended => T.T("SuspendedBusinesses"),
        _ => T.T("Status")
    };
    string SupportQueueHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string SupportQueueHealthBadgeText(bool healthy) => healthy ? T.T("Configured") : T.T("NeedsAttention");
    var goLiveBlockerCount = Model.Summary.PendingApprovalBusinessCount
        + Model.Summary.ApprovedInactiveBusinessCount
        + Model.Summary.MissingOwnerBusinessCount
        + Model.Summary.MissingPrimaryLocationBusinessCount
        + Model.Summary.MissingContactEmailBusinessCount
        + Model.Summary.MissingLegalNameBusinessCount;
    var lifecycleAttentionCount = Model.Summary.AttentionBusinessCount
        + Model.Summary.PendingApprovalBusinessCount
        + Model.Summary.SuspendedBusinessCount;
    var communicationFailureCount = Model.FailedEmails.Count;
    var communicationPolicyAttentionCount = Model.Summary.MissingContactEmailBusinessCount;
    var communicationDeliveryVisibilityAttentionCount = communicationFailureCount;
    var failedInvitationAttentionCount = Model.Summary.FailedInvitationCount;
    var failedActivationAttentionCount = Model.Summary.FailedActivationCount;
    var failedPasswordResetAttentionCount = Model.Summary.FailedPasswordResetCount;
    var failedAdminTestAttentionCount = Model.Summary.FailedAdminTestCount;
    var communicationRuntimeExecutionAttentionCount = Model.Summary.PendingActivationMemberCount
        + failedInvitationAttentionCount
        + failedActivationAttentionCount
        + failedPasswordResetAttentionCount
        + failedAdminTestAttentionCount;
    var communicationFamilyAttentionCount = Model.Summary.PendingInvitationCount
        + Model.Summary.PendingActivationMemberCount
        + Model.Summary.LockedMemberCount;
    var communicationAttentionCount = communicationPolicyAttentionCount
        + communicationDeliveryVisibilityAttentionCount
        + communicationRuntimeExecutionAttentionCount
        + communicationFamilyAttentionCount;
    var financeAttentionCount = Model.Summary.ApprovedInactiveBusinessCount + Model.Summary.SuspendedBusinessCount;
}

