@model Darwin.WebAdmin.ViewModels.Inventory.StockTransfersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("StockTransfersTitle");
    var inventoryCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeStockTransferStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string InventoryDateTimeText(DateTime utc) => utc.ToString("g", inventoryCulture);
    string StockTransferOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string StockTransferStaleBadgeClass(bool isStale) => isStale
        ? "badge bg-danger-subtle text-danger-emphasis"
        : "badge bg-success-subtle text-success-emphasis";
    string StockTransferOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var stockTransferAttentionCount = Model.Summary.DraftCount + Model.Summary.InTransitCount;
    string StockTransfersUrl(object? businessId = null, object? warehouseId = null, string? q = null, string? filter = null) => Url.Action("StockTransfers", "Inventory", new { businessId, warehouseId, q, filter }) ?? string.Empty;
    string CreateStockTransferUrl(object? businessId = null, object? warehouseId = null) => Url.Action("CreateStockTransfer", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
    string StockLevelsUrl(object? businessId = null, object? warehouseId = null) => Url.Action("StockLevels", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
    string EditStockTransferUrl(Guid id) => Url.Action("EditStockTransfer", "Inventory", new { id }) ?? string.Empty;
    string UpdateStockTransferLifecycleUrl(Guid id) => Url.Action("UpdateStockTransferLifecycle", "Inventory", new { id }) ?? string.Empty;
    var businessId = Model.BusinessId;
}

<div id="inventory-stock-transfers-workspace-shell">
<h1 class="mb-3">@T.T("StockTransfersTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="StockTransfers" method="get" class="d-flex gap-2"
          hx-get="@StockTransfersUrl()"
          hx-target="#inventory-stock-transfers-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="hidden" name="businessId" value="@businessId" />
        <select name="warehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchTransfersPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId)"
           hx-target="#inventory-stock-transfers-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreateStockTransfer" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-primary"
       hx-get="@CreateStockTransferUrl(businessId, Model.WarehouseId)"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewTransfer")</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Draft" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.Draft ? "btn-outline-secondary" : "btn-outline-dark")"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "Draft")"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Draft")</a>
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="InTransit" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.InTransit ? "btn-warning" : "btn-outline-warning")"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "InTransit")"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("InTransit")</a>
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Completed" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.Completed ? "btn-success" : "btn-outline-success")"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "Completed")"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Completed")</a>
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="StaleInTransit" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.StaleInTransit ? "btn-danger" : "btn-outline-danger")"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "StaleInTransit")"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("StaleInTransit")</a>
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Cancelled" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.Cancelled ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "Cancelled")"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Cancelled")</a>
    <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
       hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query)"
       hx-target="#inventory-stock-transfers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl-2">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">@T.T("Total")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="card h-100 border-secondary-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Draft")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("InTransit")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InTransitCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="card h-100 border-success-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Completed")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.CompletedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="card h-100 border-danger-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("StaleInTransit")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.StaleInTransitCount</div>
                <div class="small text-muted">@T.T("InventoryAgingWindow14Days")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="card h-100 border-secondary-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Cancelled")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.CancelledCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@StockTransferOpsHealthBadgeClass(stockTransferAttentionCount == 0)">@StockTransferOpsHealthBadgeText(stockTransferAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("StockTransferOpsPlaybooks")
                    @if (stockTransferAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @stockTransferAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreateStockTransfer" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-primary"
                   hx-get="@CreateStockTransferUrl(businessId, Model.WarehouseId)"
                   hx-target="#inventory-stock-transfers-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("NewTransfer")</a>
                <a asp-action="StockLevels" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
                   hx-get="@StockLevelsUrl(businessId, Model.WarehouseId)"
                   hx-target="#inventory-stock-transfers-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("StockLevels")</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Draft")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@StockTransferOpsHealthBadgeClass(Model.Summary.DraftCount == 0)">@Model.Summary.DraftCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryTransfersPlaybookDraftAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Draft" class="btn btn-sm btn-outline-dark"
                           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "Draft")"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Draft")</a>
                        <a asp-action="CreateStockTransfer" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-primary"
                           hx-get="@CreateStockTransferUrl(businessId, Model.WarehouseId)"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NewTransfer")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("InTransit")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@StockTransferOpsHealthBadgeClass(Model.Summary.InTransitCount == 0)">@Model.Summary.InTransitCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryTransfersPlaybookInTransitAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="InTransit" class="btn btn-sm btn-outline-warning"
                           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "InTransit")"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("InTransit")</a>
                        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="StaleInTransit" class="btn btn-sm btn-outline-danger"
                           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "StaleInTransit")"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StaleInTransit")</a>
                        <a asp-action="StockLevels" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@StockLevelsUrl(businessId, Model.WarehouseId)"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StockLevels")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Completed")</div>
                            <div class="small text-muted mt-1">@T.T("Queue")</div>
                        </div>
                        <span class="@StockTransferOpsHealthBadgeClass(Model.Summary.CompletedCount > 0)">@Model.Summary.CompletedCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryTransfersPlaybookInTransitScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Completed" class="btn btn-sm btn-outline-success"
                           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query, "Completed")"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Completed")</a>
                        <a asp-action="StockLevels" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@StockLevelsUrl(businessId, Model.WarehouseId)"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StockLevels")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("StockTransfersTitle")</div>
                            <div class="small text-muted mt-1">@T.T("StockLevels")</div>
                        </div>
                        <span class="@StockTransferOpsHealthBadgeClass(Model.Summary.TotalCount == 0)">@Model.Summary.TotalCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryTransfersPlaybookDraftScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="StockLevels" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@StockLevelsUrl(businessId, Model.WarehouseId)"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StockLevels")</a>
                        <a asp-action="StockTransfers" asp-route-businessId="@businessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-primary"
                           hx-get="@StockTransfersUrl(businessId, Model.WarehouseId, Model.Query)"
                           hx-target="#inventory-stock-transfers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StockTransfersTitle")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">@T.T("StockTransferOpsPlaybooks")</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>@T.T("Playbook")</th>
                    <th>@T.T("WhenItApplies")</th>
                    <th>@T.T("OperatorAction")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("From")</th><th>@T.T("To")</th><th>@T.T("Status")</th><th>@T.T("Lines")</th><th>@T.T("Created")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">@T.T("NoStockTransfersFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var rowVersion = Convert.ToBase64String(item.RowVersion);
                <tr>
                    <td>@item.FromWarehouseName</td>
                    <td>@item.ToWarehouseName</td>
                    <td>
                        @if (string.Equals(item.Status, "InTransit", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning">@T.T("InTransit")</span>
                        }
                        else if (string.Equals(item.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">@T.T("Completed")</span>
                        }
                        else if (string.Equals(item.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-secondary">@T.T("Cancelled")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@LocalizeStockTransferStatus(item.Status)</span>
                        }
                        @if (item.IsStale)
                        {
                            <span class="@StockTransferStaleBadgeClass(item.IsStale) ms-1">@T.T("StaleInTransit")</span>
                        }
                    </td>
                    <td>@item.LineCount</td>
                    <td>@InventoryDateTimeText(item.CreatedAtUtc)</td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                            @if (string.Equals(item.Status, "Draft", StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="UpdateStockTransferLifecycle" asp-route-id="@item.Id" method="post" class="d-inline"
                                      hx-post="@UpdateStockTransferLifecycleUrl(item.Id)"
                                      hx-target="#inventory-stock-transfers-workspace-shell"
                                      hx-swap="outerHTML">
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="MarkInTransit" />
                                    <input type="hidden" name="businessId" value="@businessId" />
                                    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("MarkInTransit")</button>
                                </form>
                                <form asp-action="UpdateStockTransferLifecycle" asp-route-id="@item.Id" method="post" class="d-inline"
                                      hx-post="@UpdateStockTransferLifecycleUrl(item.Id)"
                                      hx-target="#inventory-stock-transfers-workspace-shell"
                                      hx-swap="outerHTML">
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Cancel" />
                                    <input type="hidden" name="businessId" value="@businessId" />
                                    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Cancel")</button>
                                </form>
                            }
                            else if (string.Equals(item.Status, "InTransit", StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="UpdateStockTransferLifecycle" asp-route-id="@item.Id" method="post" class="d-inline"
                                      hx-post="@UpdateStockTransferLifecycleUrl(item.Id)"
                                      hx-target="#inventory-stock-transfers-workspace-shell"
                                      hx-swap="outerHTML">
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Complete" />
                                    <input type="hidden" name="businessId" value="@businessId" />
                                    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">@T.T("Complete")</button>
                                </form>
                                <form asp-action="UpdateStockTransferLifecycle" asp-route-id="@item.Id" method="post" class="d-inline"
                                      hx-post="@UpdateStockTransferLifecycleUrl(item.Id)"
                                      hx-target="#inventory-stock-transfers-workspace-shell"
                                      hx-swap="outerHTML">
                                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                                    <input type="hidden" name="action" value="Cancel" />
                                    <input type="hidden" name="businessId" value="@businessId" />
                                    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="q" value="@Model.Query" />
                                    <input type="hidden" name="filter" value="@Model.Filter" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("Cancel")</button>
                                </form>
                            }
                            <a asp-action="EditStockTransfer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                               hx-get="@EditStockTransferUrl(item.Id)"
                               hx-target="#inventory-stock-transfers-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Edit")</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

