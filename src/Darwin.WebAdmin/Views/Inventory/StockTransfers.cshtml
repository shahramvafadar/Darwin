@model Darwin.WebAdmin.ViewModels.Inventory.StockTransfersListVm
@{
    ViewData["Title"] = "Stock Transfers";
}

<h1 class="mb-3">Stock Transfers</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="StockTransfers" method="get" class="d-flex gap-2">
        <input type="hidden" name="businessId" value="@ViewBag.BusinessId" />
        <select name="warehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search transfers">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreateStockTransfer" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-primary">New Transfer</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Draft" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.Draft ? "btn-outline-secondary" : "btn-outline-dark")">Draft</a>
    <a asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="InTransit" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.InTransit ? "btn-warning" : "btn-outline-warning")">In Transit</a>
    <a asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Completed" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.StockTransferQueueFilter.Completed ? "btn-success" : "btn-outline-success")">Completed</a>
    <a asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-secondary-subtle">
            <div class="card-body">
                <div class="text-muted small">Draft</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">In Transit</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InTransitCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-success-subtle">
            <div class="card-body">
                <div class="text-muted small">Completed</div>
                <div class="fs-4 fw-semibold">@Model.Summary.CompletedCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Stock Transfer Ops Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>Playbook</th>
                    <th>When It Applies</th>
                    <th>Operator Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>From</th><th>To</th><th>Status</th><th>Lines</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No stock transfers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.FromWarehouseName</td>
                    <td>@item.ToWarehouseName</td>
                    <td>
                        @if (string.Equals(item.Status, "InTransit", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning">In Transit</span>
                        }
                        else if (string.Equals(item.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>@item.LineCount</td>
                    <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end"><a asp-action="EditStockTransfer" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="StockTransfers" asp-route-businessId="@ViewBag.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter"></pager>
