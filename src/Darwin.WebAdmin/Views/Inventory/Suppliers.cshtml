@model Darwin.WebAdmin.ViewModels.Inventory.SuppliersListVm
@{
    ViewData["Title"] = "Suppliers";
}

<h1 class="mb-3">Suppliers</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Suppliers" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search suppliers">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreateSupplier" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Supplier</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="MissingAddress" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.SupplierQueueFilter.MissingAddress ? "btn-warning" : "btn-outline-warning")">Missing Address</a>
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.SupplierQueueFilter.HasPurchaseOrders ? "btn-primary" : "btn-outline-primary")">Has Purchase Orders</a>
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">Missing Address</div>
                <div class="fs-4 fw-semibold">@Model.Summary.MissingAddressCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-primary-subtle">
            <div class="card-body">
                <div class="text-muted small">Has Purchase Orders</div>
                <div class="fs-4 fw-semibold">@Model.Summary.HasPurchaseOrdersCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Supplier Ops Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>Playbook</th>
                    <th>When It Applies</th>
                    <th>Operator Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Address</th><th>Purchase Orders</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No suppliers found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.Address))
                        {
                            <span class="badge text-bg-warning">Missing address</span>
                        }
                        else
                        {
                            @item.Address
                        }
                    </td>
                    <td>
                        @item.PurchaseOrderCount
                        @if (item.PurchaseOrderCount > 0)
                        {
                            <div><span class="badge text-bg-primary mt-1">Active</span></div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="PurchaseOrders"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-q="@item.Name"
                           class="btn btn-sm btn-outline-primary">Purchase Orders</a>
                        <a asp-action="EditSupplier" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter"></pager>
