@model Darwin.WebAdmin.ViewModels.Inventory.SuppliersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Suppliers");
    string SupplierOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string SupplierOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var supplierAttentionCount = Model.Summary.MissingAddressCount + Model.Summary.HasPurchaseOrdersCount;
    string SuppliersUrl(object? businessId = null, string? q = null, string? filter = null) => Url.Action("Suppliers", "Inventory", new { businessId, q, filter }) ?? string.Empty;
    string CreateSupplierUrl(object? businessId = null) => Url.Action("CreateSupplier", "Inventory", new { businessId }) ?? string.Empty;
    string PurchaseOrdersUrl(object? businessId = null, string? q = null) => Url.Action("PurchaseOrders", "Inventory", new { businessId, q }) ?? string.Empty;
    string EditSupplierUrl(Guid id) => Url.Action("EditSupplier", "Inventory", new { id }) ?? string.Empty;
}

<div id="inventory-suppliers-workspace-shell">
<h1 class="mb-3">@T.T("Suppliers")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Suppliers" method="get" class="d-flex gap-2"
          hx-get="@SuppliersUrl()"
          hx-target="#inventory-suppliers-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchSuppliersPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@SuppliersUrl(Model.BusinessId)"
           hx-target="#inventory-suppliers-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreateSupplier" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@CreateSupplierUrl(Model.BusinessId)"
       hx-target="#inventory-suppliers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewSupplier")</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="MissingAddress" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.SupplierQueueFilter.MissingAddress ? "btn-warning" : "btn-outline-warning")"
       hx-get="@SuppliersUrl(Model.BusinessId, Model.Query, "MissingAddress")"
       hx-target="#inventory-suppliers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("MissingAddress")</a>
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.SupplierQueueFilter.HasPurchaseOrders ? "btn-primary" : "btn-outline-primary")"
       hx-get="@SuppliersUrl(Model.BusinessId, Model.Query, "HasPurchaseOrders")"
       hx-target="#inventory-suppliers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("HasPurchaseOrders")</a>
    <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@SuppliersUrl(Model.BusinessId, Model.Query)"
       hx-target="#inventory-suppliers-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">@T.T("Total")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("MissingAddress")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.MissingAddressCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-primary-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("HasPurchaseOrders")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.HasPurchaseOrdersCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@SupplierOpsHealthBadgeClass(supplierAttentionCount == 0)">@SupplierOpsHealthBadgeText(supplierAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("SupplierOpsPlaybooks")
                    @if (supplierAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @supplierAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreateSupplier" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                   hx-get="@CreateSupplierUrl(Model.BusinessId)"
                   hx-target="#inventory-suppliers-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("NewSupplier")</a>
                <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                   hx-get="@PurchaseOrdersUrl(Model.BusinessId)"
                   hx-target="#inventory-suppliers-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("PurchaseOrders")</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("MissingAddress")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@SupplierOpsHealthBadgeClass(Model.Summary.MissingAddressCount == 0)">@Model.Summary.MissingAddressCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("SupplierPlaybookContactHygieneAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="MissingAddress" class="btn btn-sm btn-outline-warning"
                           hx-get="@SuppliersUrl(Model.BusinessId, Model.Query, "MissingAddress")"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("MissingAddress")</a>
                        <a asp-action="CreateSupplier" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@CreateSupplierUrl(Model.BusinessId)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NewSupplier")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("HasPurchaseOrders")</div>
                            <div class="small text-muted mt-1">@T.T("Queue")</div>
                        </div>
                        <span class="@SupplierOpsHealthBadgeClass(Model.Summary.HasPurchaseOrdersCount == 0)">@Model.Summary.HasPurchaseOrdersCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("SupplierPlaybookActiveReviewAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm btn-outline-primary"
                           hx-get="@SuppliersUrl(Model.BusinessId, Model.Query, "HasPurchaseOrders")"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("HasPurchaseOrders")</a>
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@PurchaseOrdersUrl(Model.BusinessId)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PurchaseOrders")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Suppliers")</div>
                            <div class="small text-muted mt-1">@T.T("PurchaseOrders")</div>
                        </div>
                        <span class="@SupplierOpsHealthBadgeClass(Model.Summary.TotalCount == 0)">@Model.Summary.TotalCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("SupplierPlaybookActiveReviewScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@PurchaseOrdersUrl(Model.BusinessId)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PurchaseOrders")</a>
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@SuppliersUrl(Model.BusinessId, Model.Query)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Suppliers")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">@T.T("SupplierOpsPlaybooks")</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>@T.T("Playbook")</th>
                    <th>@T.T("WhenItApplies")</th>
                    <th>@T.T("OperatorAction")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("Name")</th><th>@T.T("Email")</th><th>@T.T("Phone")</th><th>@T.T("Address")</th><th>@T.T("PurchaseOrders")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">@T.T("NoSuppliersFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.Address))
                        {
                            <span class="badge text-bg-warning">@T.T("MissingAddressBadge")</span>
                        }
                        else
                        {
                            @item.Address
                        }
                    </td>
                    <td>
                        @item.PurchaseOrderCount
                        @if (item.PurchaseOrderCount > 0)
                        {
                            <div><span class="badge text-bg-primary mt-1">@T.T("Active")</span></div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="PurchaseOrders"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-q="@item.Name"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@PurchaseOrdersUrl(Model.BusinessId, item.Name)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PurchaseOrders")</a>
                        <a asp-action="EditSupplier" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditSupplierUrl(item.Id)"
                           hx-target="#inventory-suppliers-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Edit")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-suppliers-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
