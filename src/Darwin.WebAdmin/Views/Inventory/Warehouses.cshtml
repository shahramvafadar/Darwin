@model Darwin.WebAdmin.ViewModels.Inventory.WarehousesListVm
@{
    ViewData["Title"] = "Warehouses";
}

<h1 class="mb-3">Warehouses</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Warehouses" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search warehouses">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreateWarehouse" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Warehouse</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-filter="Default" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.WarehouseQueueFilter.Default ? "btn-primary" : "btn-outline-primary")">Default</a>
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-filter="NoStockLevels" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.WarehouseQueueFilter.NoStockLevels ? "btn-warning" : "btn-outline-warning")">No Stock Levels</a>
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-primary-subtle">
            <div class="card-body">
                <div class="text-muted small">Default</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DefaultCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">No Stock Levels</div>
                <div class="fs-4 fw-semibold">@Model.Summary.NoStockLevelsCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Warehouse Ops Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>Playbook</th>
                    <th>When It Applies</th>
                    <th>Operator Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Name</th><th>Location</th><th>Default</th><th>Stock Levels</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">No warehouses found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Location</td>
                    <td>
                        @if (item.IsDefault)
                        {
                            <span class="badge text-bg-primary">Default</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Standard</span>
                        }
                    </td>
                    <td>
                        @item.StockLevelCount
                        @if (item.StockLevelCount == 0)
                        {
                            <div><span class="badge text-bg-warning mt-1">Empty</span></div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="StockLevels"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-warehouseId="@item.Id"
                           class="btn btn-sm btn-outline-primary">Stock Levels</a>
                        <a asp-action="EditWarehouse" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter"></pager>
