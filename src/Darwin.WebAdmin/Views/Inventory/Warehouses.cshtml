@model Darwin.WebAdmin.ViewModels.Inventory.WarehousesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("WarehousesTitle");
}

<div id="inventory-warehouses-workspace-shell">
<h1 class="mb-3">@T.T("WarehousesTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Warehouses" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("Warehouses", "Inventory")"
          hx-target="#inventory-warehouses-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchWarehousesPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Warehouses", "Inventory", new { businessId = Model.BusinessId })"
           hx-target="#inventory-warehouses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreateWarehouse" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreateWarehouse", "Inventory", new { businessId = Model.BusinessId })"
       hx-target="#inventory-warehouses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewWarehouse")</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-filter="Default" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.WarehouseQueueFilter.Default ? "btn-primary" : "btn-outline-primary")"
       hx-get="@Url.Action("Warehouses", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Default" })"
       hx-target="#inventory-warehouses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Default")</a>
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-filter="NoStockLevels" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.WarehouseQueueFilter.NoStockLevels ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Warehouses", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "NoStockLevels" })"
       hx-target="#inventory-warehouses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NoStockLevels")</a>
    <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("Warehouses", "Inventory", new { businessId = Model.BusinessId, q = Model.Query })"
       hx-target="#inventory-warehouses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">@T.T("Total")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-primary-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Default")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DefaultCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("NoStockLevels")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.NoStockLevelsCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">@T.T("WarehouseOpsPlaybooks")</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>@T.T("Playbook")</th>
                    <th>@T.T("WhenItApplies")</th>
                    <th>@T.T("OperatorAction")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("Name")</th><th>@T.T("Location")</th><th>@T.T("Default")</th><th>@T.T("StockLevels")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">@T.T("NoWarehousesFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Location</td>
                    <td>
                        @if (item.IsDefault)
                        {
                            <span class="badge text-bg-primary">@T.T("Default")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@T.T("Standard")</span>
                        }
                    </td>
                    <td>
                        @item.StockLevelCount
                        @if (item.StockLevelCount == 0)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("Empty")</span></div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="StockLevels"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-warehouseId="@item.Id"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("StockLevels", "Inventory", new { businessId = Model.BusinessId, warehouseId = item.Id })"
                           hx-target="#inventory-warehouses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("StockLevels")</a>
                        <a asp-action="EditWarehouse" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditWarehouse", "Inventory", new { id = item.Id })"
                           hx-target="#inventory-warehouses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Edit")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-warehouses-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
