@model Darwin.WebAdmin.ViewModels.Inventory.PurchaseOrderEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true;
    ViewData["Title"] = isCreate ? T.T("CreatePurchaseOrder") : T.T("EditPurchaseOrder");
}

<div id="inventory-purchase-order-editor-shell">
    <h1 class="mb-3">@(isCreate ? T.T("CreatePurchaseOrder") : T.T("EditPurchaseOrder"))</h1>

    <form asp-action="@(isCreate ? "CreatePurchaseOrder" : "EditPurchaseOrder")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreatePurchaseOrder" : "EditPurchaseOrder", "Inventory")"
          hx-target="#inventory-purchase-order-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        }
        <partial name="_PurchaseOrderForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
        </div>
    </form>
</div>
