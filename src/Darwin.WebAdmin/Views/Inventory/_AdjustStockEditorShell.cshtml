@model Darwin.WebAdmin.ViewModels.Inventory.InventoryAdjustActionVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("InventoryAdjustStockTitle");
    string StockLevelsUrl(Guid? businessId, Guid? warehouseId) => Url.Action("StockLevels", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
}

<div id="inventory-adjust-stock-editor-shell">
<h1 class="mb-3">@T.T("InventoryAdjustStockTitle")</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <section class="admin-form-section">
            <h2 class="admin-form-section-title">@T.T("InventoryStockSnapshotSection")</h2>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">@T.T("Warehouse")</label>
                    <field-help title="@T.T("Warehouse")" content="@T.T("InventoryActionWarehouseHelp")" placement="right"></field-help>
                    <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select" disabled></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">@T.T("InventoryVariantLabel")</label>
                    <field-help title="@T.T("InventoryVariantLabel")" content="@T.T("InventoryActionVariantHelp")" placement="right"></field-help>
                    <select asp-for="ProductVariantId" asp-items="Model.VariantOptions" class="form-select" disabled></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">@T.T("InventoryAvailableLabel")</label>
                    <field-help title="@T.T("InventoryAvailableLabel")" content="@T.T("InventoryActionAvailableHelp")" placement="right"></field-help>
                    <input value="@Model.AvailableQuantity" class="form-control" disabled />
                </div>
                <div class="col-md-3">
                    <label class="form-label">@T.T("Reserved")</label>
                    <field-help title="@T.T("Reserved")" content="@T.T("InventoryActionReservedHelp")" placement="right"></field-help>
                    <input value="@Model.ReservedQuantity" class="form-control" disabled />
                </div>
            </div>
        </section>

        <form asp-action="AdjustStock" method="post"
              hx-post="@Url.Action("AdjustStock", "Inventory")"
              hx-target="#inventory-adjust-stock-editor-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input asp-for="StockLevelId" type="hidden" />
            <input asp-for="BusinessId" type="hidden" />
            <input asp-for="WarehouseId" type="hidden" />
            <input asp-for="ProductVariantId" type="hidden" />
            <input asp-for="AvailableQuantity" type="hidden" />
            <input asp-for="ReservedQuantity" type="hidden" />

            <section class="admin-form-section">
                <h2 class="admin-form-section-title">@T.T("InventoryAdjustmentSection")</h2>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="QuantityDelta" class="form-label"></label>
                        <field-help title="@T.T("QuantityDelta")" content="@T.T("InventoryAdjustQuantityHelp")" placement="right"></field-help>
                        <input asp-for="QuantityDelta" class="form-control" />
                        <span asp-validation-for="QuantityDelta" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Reason" class="form-label"></label>
                        <field-help title="@T.T("Reason")" content="@T.T("InventoryActionReasonHelp")" placement="right"></field-help>
                        <input asp-for="Reason" class="form-control" />
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ReferenceId" class="form-label"></label>
                        <field-help title="@T.T("ReferenceId")" content="@T.T("InventoryReferenceIdAuditHelp")" placement="right"></field-help>
                        <input asp-for="ReferenceId" class="form-control" />
                        <span asp-validation-for="ReferenceId" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">@T.T("InventoryApplyAdjustment")</button>
                <a asp-action="StockLevels" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
                   hx-get="@StockLevelsUrl(Model.BusinessId, Model.WarehouseId)"
                   hx-target="#inventory-adjust-stock-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("InventoryBackToStockLevels")</a>
            </div>
        </form>
    </div>
</div>
</div>
