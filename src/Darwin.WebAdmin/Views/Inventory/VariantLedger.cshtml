@model Darwin.WebAdmin.ViewModels.Inventory.InventoryLedgerListVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Darwin.WebAdmin

@{
    ViewData["Title"] = "Inventory Ledger";
}

<h2 class="mb-3">Inventory Ledger</h2>

<form asp-action="VariantLedger" method="get" class="d-flex gap-2 mb-3">
    <input type="hidden" name="variantId" value="@Model.VariantId" />
    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
    <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    <button class="btn btn-outline-secondary" type="submit">Filter</button>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary">Reset</a>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Inbound" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Inbound ? "btn-success" : "btn-outline-success")">Inbound</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Outbound" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Outbound ? "btn-danger" : "btn-outline-danger")">Outbound</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Reservations" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Reservations ? "btn-warning" : "btn-outline-warning")">Reservations</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th style="width:140px;">When (UTC)</th>
                <th style="width:220px;">Warehouse</th>
                <th style="width:120px;" class="text-end">? Qty</th>
                <th>Reason</th>
                <th style="width:320px;">Reference</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items?.Count > 0)
            {
                foreach (var r in Model.Items)
                {
                    <tr>
                        <td>@r.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@r.WarehouseName</td>
                        <td class="text-end">@r.QuantityDelta</td>
                        <td>@r.Reason</td>
                        <td>@(r.ReferenceId?.ToString() ?? "-")</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center text-muted">No ledger entries.</td></tr>
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Inventory"
       asp-action="VariantLedger"
       asp-route-variantId="@Model.VariantId"
       asp-route-warehouseId="@Model.WarehouseId"
       asp-route-filter="@Model.Filter">
</pager>

<div class="mt-3">
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left"></i> Back
    </a>
</div>
