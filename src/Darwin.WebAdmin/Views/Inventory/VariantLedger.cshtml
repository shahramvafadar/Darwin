@model Darwin.WebAdmin.ViewModels.Inventory.InventoryLedgerListVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Darwin.WebAdmin
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

@{
    ViewData["Title"] = T.T("InventoryLedger");
}

<div id="inventory-ledger-workspace-shell">
<h2 class="mb-3">@T.T("InventoryLedger")</h2>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Inbound")</div><div class="fs-4 fw-semibold">@Model.Summary.InboundCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Outbound")</div><div class="fs-4 fw-semibold">@Model.Summary.OutboundCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Reservations")</div><div class="fs-4 fw-semibold">@Model.Summary.ReservationCount</div></div></div>
</div>

<div class="card mb-3">
        <div class="card-header">@T.T("LedgerOpsPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form asp-action="VariantLedger" method="get" class="d-flex gap-2 mb-3"
      hx-get="@Url.Action("VariantLedger", "Inventory")"
      hx-target="#inventory-ledger-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="hidden" name="variantId" value="@Model.VariantId" />
    <input type="hidden" name="warehouseId" value="@Model.WarehouseId" />
    <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
       hx-get="@Url.Action("VariantLedger", "Inventory", new { variantId = Model.VariantId, warehouseId = Model.WarehouseId })"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Reset")</a>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Inbound" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Inbound ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("VariantLedger", "Inventory", new { variantId = Model.VariantId, warehouseId = Model.WarehouseId, filter = "Inbound" })"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Inbound")</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Outbound" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Outbound ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("VariantLedger", "Inventory", new { variantId = Model.VariantId, warehouseId = Model.WarehouseId, filter = "Outbound" })"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Outbound")</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Reservations" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.InventoryLedgerQueueFilter.Reservations ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("VariantLedger", "Inventory", new { variantId = Model.VariantId, warehouseId = Model.WarehouseId, filter = "Reservations" })"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Reservations")</a>
    <a asp-action="VariantLedger" asp-route-variantId="@Model.VariantId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("VariantLedger", "Inventory", new { variantId = Model.VariantId, warehouseId = Model.WarehouseId })"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th style="width:140px;">@T.T("WhenUtc")</th>
                <th style="width:220px;">@T.T("Warehouse")</th>
                <th style="width:120px;" class="text-end">@T.T("QtyDelta")</th>
                <th>@T.T("Reason")</th>
                <th style="width:320px;">@T.T("Reference")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items?.Count > 0)
            {
                foreach (var r in Model.Items)
                {
                    <tr>
                        <td>@r.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@r.WarehouseName</td>
                        <td class="text-end">@r.QuantityDelta</td>
                        <td>@r.Reason</td>
                        <td>@(r.ReferenceId?.ToString() ?? "-")</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center text-muted">@T.T("NoLedgerEntries")</td></tr>
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Inventory"
       asp-action="VariantLedger"
       asp-route-variantId="@Model.VariantId"
       asp-route-warehouseId="@Model.WarehouseId"
       asp-route-filter="@Model.Filter"
       hx-target="#inventory-ledger-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>

<div class="mt-3">
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left"></i> @T.T("Back")
    </a>
</div>
</div>
