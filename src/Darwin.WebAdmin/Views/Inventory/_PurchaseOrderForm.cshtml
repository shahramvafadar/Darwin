@model Darwin.WebAdmin.ViewModels.Inventory.PurchaseOrderEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div class="row g-3">
    <div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="SupplierId" class="form-label"></label><select asp-for="SupplierId" asp-items="Model.SupplierOptions" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="Status" class="form-label"></label><input asp-for="Status" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="OrderNumber" class="form-label"></label><input asp-for="OrderNumber" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="OrderedAtUtc" class="form-label"></label><input asp-for="OrderedAtUtc" type="datetime-local" class="form-control" /></div>
</div>

<div class="d-flex justify-content-between align-items-center mt-4">
    <h3 class="mb-0">@T.T("PurchaseOrderLines")</h3>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="addPurchaseOrderLine">@T.T("AddLine")</button>
</div>

<div id="purchaseOrderLines" class="mt-3">
@for (var i = 0; i < Model.Lines.Count; i++)
{
    <div class="card mb-3 line-row"><div class="card-body">
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Lines[i].ProductVariantId" class="form-label"></label><select asp-for="Lines[i].ProductVariantId" asp-items="Model.VariantOptions" class="form-select"></select></div>
            <div class="col-md-2"><label asp-for="Lines[i].Quantity" class="form-label"></label><input asp-for="Lines[i].Quantity" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="Lines[i].UnitCostMinor" class="form-label"></label><input asp-for="Lines[i].UnitCostMinor" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="Lines[i].TotalCostMinor" class="form-label"></label><input asp-for="Lines[i].TotalCostMinor" class="form-control" /></div>
        </div>
        <div class="text-end mt-3"><button type="button" class="btn btn-sm btn-outline-danger remove-line">@T.T("Remove")</button></div>
    </div></div>
}
</div>

<template id="purchaseOrderLineTemplate">
    <div class="card mb-3 line-row"><div class="card-body">
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">@T.T("ProductVariant")</label><select class="form-select" name="Lines[__index__].ProductVariantId">@foreach (var option in Model.VariantOptions){<option value="@option.Value">@option.Text</option>}</select></div>
            <div class="col-md-2"><label class="form-label">@T.T("Quantity")</label><input class="form-control" name="Lines[__index__].Quantity" value="1" /></div>
            <div class="col-md-2"><label class="form-label">@T.T("UnitCost")</label><input class="form-control" name="Lines[__index__].UnitCostMinor" value="0" /></div>
            <div class="col-md-2"><label class="form-label">@T.T("TotalCost")</label><input class="form-control" name="Lines[__index__].TotalCostMinor" value="0" /></div>
        </div>
        <div class="text-end mt-3"><button type="button" class="btn btn-sm btn-outline-danger remove-line">@T.T("Remove")</button></div>
    </div></div>
</template>
