@model Darwin.WebAdmin.ViewModels.Inventory.SupplierEditVm
@{
    ViewData["Title"] = "Edit Supplier";
}
<h1 class="mb-3">Edit Supplier</h1>
<form asp-action="EditSupplier" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <partial name="_SupplierForm" model="Model" />
    <div class="mt-4"><button type="submit" class="btn btn-primary">Save</button><a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Back</a></div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
