@model Darwin.WebAdmin.ViewModels.Inventory.InventoryReserveActionVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("InventoryReserveStockTitle");
    string StockLevelsUrl(Guid? businessId, Guid? warehouseId) => Url.Action("StockLevels", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
}

<div id="inventory-reserve-stock-editor-shell">
<h1 class="mb-3">@T.T("InventoryReserveStockTitle")</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label">@T.T("Warehouse")</label>
                <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select" disabled></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">@T.T("InventoryVariantLabel")</label>
                <select asp-for="ProductVariantId" asp-items="Model.VariantOptions" class="form-select" disabled></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@T.T("InventoryAvailableLabel")</label>
                <input value="@Model.AvailableQuantity" class="form-control" disabled />
            </div>
            <div class="col-md-3">
                <label class="form-label">@T.T("Reserved")</label>
                <input value="@Model.ReservedQuantity" class="form-control" disabled />
            </div>
        </div>

        <form asp-action="ReserveStock" method="post"
              hx-post="@Url.Action("ReserveStock", "Inventory")"
              hx-target="#inventory-reserve-stock-editor-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input asp-for="StockLevelId" type="hidden" />
            <input asp-for="BusinessId" type="hidden" />
            <input asp-for="WarehouseId" type="hidden" />
            <input asp-for="ProductVariantId" type="hidden" />
            <input asp-for="AvailableQuantity" type="hidden" />
            <input asp-for="ReservedQuantity" type="hidden" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Reason" class="form-label"></label>
                    <input asp-for="Reason" class="form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ReferenceId" class="form-label"></label>
                    <input asp-for="ReferenceId" class="form-control" />
                    <div class="form-text">@T.T("InventoryReferenceIdAuditHelp")</div>
                    <span asp-validation-for="ReferenceId" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-warning">@T.T("InventoryReserveStockTitle")</button>
                <a asp-action="StockLevels" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
                   hx-get="@StockLevelsUrl(Model.BusinessId, Model.WarehouseId)"
                   hx-target="#inventory-reserve-stock-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("InventoryBackToStockLevels")</a>
            </div>
        </form>
    </div>
</div>
</div>
