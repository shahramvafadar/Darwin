@model Darwin.WebAdmin.ViewModels.Inventory.WarehouseEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true;
    ViewData["Title"] = isCreate ? T.T("CreateWarehouse") : T.T("EditWarehouse");
}

<div id="inventory-warehouse-editor-shell">
    <h1 class="mb-3">@(isCreate ? T.T("CreateWarehouse") : T.T("EditWarehouse"))</h1>

    <form asp-action="@(isCreate ? "CreateWarehouse" : "EditWarehouse")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateWarehouse" : "EditWarehouse", "Inventory")"
          hx-target="#inventory-warehouse-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }
        <partial name="_WarehouseForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            <a asp-action="Warehouses" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
               hx-get="@Url.Action("Warehouses", "Inventory", new { businessId = Model.BusinessId })"
               hx-target="#inventory-warehouse-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Back")</a>
        </div>
    </form>
</div>
