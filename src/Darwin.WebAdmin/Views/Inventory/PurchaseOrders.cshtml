@model Darwin.WebAdmin.ViewModels.Inventory.PurchaseOrdersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("PurchaseOrders");
    var inventoryCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizePurchaseOrderStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string InventoryDateTimeText(DateTime utc) => utc.ToString("g", inventoryCulture);
    string PurchaseOrderOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string PurchaseOrderOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var purchaseOrderAttentionCount = Model.Summary.DraftCount + Model.Summary.IssuedCount;
}

<div id="inventory-purchase-orders-workspace-shell">
<h1 class="mb-3">@T.T("PurchaseOrders")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="PurchaseOrders" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("PurchaseOrders", "Inventory")"
          hx-target="#inventory-purchase-orders-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchPurchaseOrdersPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId })"
           hx-target="#inventory-purchase-orders-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreatePurchaseOrder" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreatePurchaseOrder", "Inventory", new { businessId = Model.BusinessId })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewPurchaseOrder")</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Draft" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Draft ? "btn-outline-secondary" : "btn-outline-dark")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Draft" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Draft")</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Issued" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Issued ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Issued" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Issued")</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Received" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Received ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Received" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Received")</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">@T.T("Total")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-secondary-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Draft")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Issued")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.IssuedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-success-subtle">
            <div class="card-body">
                <div class="text-muted small">@T.T("Received")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.ReceivedCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@PurchaseOrderOpsHealthBadgeClass(purchaseOrderAttentionCount == 0)">@PurchaseOrderOpsHealthBadgeText(purchaseOrderAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("PurchaseOrderOpsPlaybooks")
                    @if (purchaseOrderAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @purchaseOrderAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreatePurchaseOrder" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("CreatePurchaseOrder", "Inventory", new { businessId = Model.BusinessId })"
                   hx-target="#inventory-purchase-orders-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("NewPurchaseOrder")</a>
                <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Suppliers", "Inventory", new { businessId = Model.BusinessId, filter = "HasPurchaseOrders" })"
                   hx-target="#inventory-purchase-orders-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Suppliers")</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Draft")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@PurchaseOrderOpsHealthBadgeClass(Model.Summary.DraftCount == 0)">@Model.Summary.DraftCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryPurchaseOrdersPlaybookDraftAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Draft" class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Draft" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Draft")</a>
                        <a asp-action="CreatePurchaseOrder" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("CreatePurchaseOrder", "Inventory", new { businessId = Model.BusinessId })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NewPurchaseOrder")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Issued")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@PurchaseOrderOpsHealthBadgeClass(Model.Summary.IssuedCount == 0)">@Model.Summary.IssuedCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryPurchaseOrdersPlaybookIssuedAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Issued" class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Issued" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Issued")</a>
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Suppliers", "Inventory", new { businessId = Model.BusinessId, filter = "HasPurchaseOrders" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Suppliers")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Received")</div>
                            <div class="small text-muted mt-1">@T.T("Queue")</div>
                        </div>
                        <span class="@PurchaseOrderOpsHealthBadgeClass(Model.Summary.ReceivedCount > 0)">@Model.Summary.ReceivedCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryPurchaseOrdersPlaybookIssuedScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Received" class="btn btn-sm btn-outline-success"
                           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Received" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Received")</a>
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Suppliers", "Inventory", new { businessId = Model.BusinessId, filter = "HasPurchaseOrders" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Suppliers")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Suppliers")</div>
                            <div class="small text-muted mt-1">@T.T("HasPurchaseOrders")</div>
                        </div>
                        <span class="@PurchaseOrderOpsHealthBadgeClass(Model.Summary.TotalCount == 0)">@Model.Summary.TotalCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("InventoryPurchaseOrdersPlaybookDraftScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Suppliers" asp-route-businessId="@Model.BusinessId" asp-route-filter="HasPurchaseOrders" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Suppliers", "Inventory", new { businessId = Model.BusinessId, filter = "HasPurchaseOrders" })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Suppliers")</a>
                        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PurchaseOrders")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">@T.T("PurchaseOrderOpsPlaybooks")</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>@T.T("Playbook")</th>
                    <th>@T.T("WhenItApplies")</th>
                    <th>@T.T("OperatorAction")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("OrderNumber")</th><th>@T.T("Supplier")</th><th>@T.T("Status")</th><th>@T.T("Lines")</th><th>@T.T("Ordered")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">@T.T("NoPurchaseOrdersFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.OrderNumber</td>
                    <td>@item.SupplierName</td>
                    <td>
                        @if (string.Equals(item.Status, "Issued", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning">@T.T("Issued")</span>
                        }
                        else if (string.Equals(item.Status, "Received", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">@T.T("Received")</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@LocalizePurchaseOrderStatus(item.Status)</span>
                        }
                    </td>
                    <td>@item.LineCount</td>
                    <td>@InventoryDateTimeText(item.OrderedAtUtc)</td>
                    <td class="text-end"><a asp-action="EditPurchaseOrder" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditPurchaseOrder", "Inventory", new { id = item.Id })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Edit")</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-purchase-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
