@model Darwin.WebAdmin.ViewModels.Inventory.PurchaseOrdersListVm
@{
    ViewData["Title"] = "Purchase Orders";
}

<h1 class="mb-3">Purchase Orders</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="PurchaseOrders" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search purchase orders">
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreatePurchaseOrder" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Purchase Order</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Order Number</th><th>Supplier</th><th>Status</th><th>Ordered</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">No purchase orders found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.OrderNumber</td>
                    <td>@item.SupplierName</td>
                    <td>@item.Status</td>
                    <td>@item.OrderedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end"><a asp-action="EditPurchaseOrder" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query"></pager>
