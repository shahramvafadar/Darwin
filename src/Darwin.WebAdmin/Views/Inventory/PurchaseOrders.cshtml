@model Darwin.WebAdmin.ViewModels.Inventory.PurchaseOrdersListVm
@{
    ViewData["Title"] = "Purchase Orders";
}

<div id="inventory-purchase-orders-workspace-shell">
<h1 class="mb-3">Purchase Orders</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="PurchaseOrders" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("PurchaseOrders", "Inventory")"
          hx-target="#inventory-purchase-orders-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search purchase orders">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId })"
           hx-target="#inventory-purchase-orders-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Reset</a>
    </form>
    <a asp-action="CreatePurchaseOrder" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreatePurchaseOrder", "Inventory", new { businessId = Model.BusinessId })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">New Purchase Order</a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Draft" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Draft ? "btn-outline-secondary" : "btn-outline-dark")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Draft" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">Draft</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Issued" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Issued ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Issued" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">Issued</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-filter="Received" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.PurchaseOrderQueueFilter.Received ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query, filter = "Received" })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">Received</a>
    <a asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("PurchaseOrders", "Inventory", new { businessId = Model.BusinessId, q = Model.Query })"
       hx-target="#inventory-purchase-orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">Clear Queue Filters</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-secondary-subtle">
            <div class="card-body">
                <div class="text-muted small">Draft</div>
                <div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small">Issued</div>
                <div class="fs-4 fw-semibold">@Model.Summary.IssuedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 border-success-subtle">
            <div class="card-body">
                <div class="text-muted small">Received</div>
                <div class="fs-4 fw-semibold">@Model.Summary.ReceivedCount</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Playbooks.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header">Purchase Order Ops Playbooks</div>
        <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                <tr>
                    <th>Playbook</th>
                    <th>When It Applies</th>
                    <th>Operator Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Order Number</th><th>Supplier</th><th>Status</th><th>Lines</th><th>Ordered</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No purchase orders found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.OrderNumber</td>
                    <td>@item.SupplierName</td>
                    <td>
                        @if (string.Equals(item.Status, "Issued", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-warning">Issued</span>
                        }
                        else if (string.Equals(item.Status, "Received", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge text-bg-success">Received</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>@item.LineCount</td>
                    <td>@item.OrderedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end"><a asp-action="EditPurchaseOrder" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditPurchaseOrder", "Inventory", new { id = item.Id })"
                           hx-target="#inventory-purchase-orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">Edit</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="PurchaseOrders" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-purchase-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
