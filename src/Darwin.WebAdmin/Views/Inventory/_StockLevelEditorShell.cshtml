@model Darwin.WebAdmin.ViewModels.Inventory.StockLevelEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = ViewData["IsCreate"] as bool? == true;
    ViewData["Title"] = isCreate ? T.T("InventoryCreateStockLevelTitle") : T.T("InventoryEditStockLevelTitle");
    string StockLevelsUrl(Guid? warehouseId) => Url.Action("StockLevels", "Inventory", new { warehouseId }) ?? string.Empty;
}

<div id="inventory-stock-level-editor-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">@(isCreate ? T.T("InventoryCreateStockLevelTitle") : T.T("InventoryEditStockLevelTitle"))</h1>
        <div class="text-muted">@T.T("InventoryStockLevelEditorIntro")</div>
    </div>
</div>

<form asp-action="@(isCreate ? "CreateStockLevel" : "EditStockLevel")" method="post"
      hx-post="@Url.Action(isCreate ? "CreateStockLevel" : "EditStockLevel", "Inventory")"
      hx-target="#inventory-stock-level-editor-shell"
      hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    @if (!isCreate)
    {
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
    }
    <partial name="_StockLevelForm" model="Model" />
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">@(isCreate ? T.T("Create") : T.T("Save"))</button>
        <a asp-action="StockLevels" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
           hx-get="@StockLevelsUrl(Model.WarehouseId)"
           hx-target="#inventory-stock-level-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Back")</a>
    </div>
</form>
</div>
