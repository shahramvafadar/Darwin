@model Darwin.WebAdmin.ViewModels.Inventory.InventoryReturnReceiptActionVm
@{
    ViewData["Title"] = "Process Return Receipt";
}

<div id="inventory-return-receipt-editor-shell">
<h1 class="mb-3">Process Return Receipt</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="form-label">Warehouse</label>
                <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select" disabled></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Variant</label>
                <select asp-for="ProductVariantId" asp-items="Model.VariantOptions" class="form-select" disabled></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Available</label>
                <input value="@Model.AvailableQuantity" class="form-control" disabled />
            </div>
            <div class="col-md-3">
                <label class="form-label">Reserved</label>
                <input value="@Model.ReservedQuantity" class="form-control" disabled />
            </div>
        </div>

        <form asp-action="ReturnReceipt" method="post"
              hx-post="@Url.Action("ReturnReceipt", "Inventory")"
              hx-target="#inventory-return-receipt-editor-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input asp-for="StockLevelId" type="hidden" />
            <input asp-for="BusinessId" type="hidden" />
            <input asp-for="WarehouseId" type="hidden" />
            <input asp-for="ProductVariantId" type="hidden" />
            <input asp-for="AvailableQuantity" type="hidden" />
            <input asp-for="ReservedQuantity" type="hidden" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Reason" class="form-label"></label>
                    <input asp-for="Reason" class="form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ReferenceId" class="form-label"></label>
                    <input asp-for="ReferenceId" class="form-control" />
                    <div class="form-text">Optional return/case id for idempotency.</div>
                    <span asp-validation-for="ReferenceId" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-dark">Process Return</button>
                <a asp-action="StockLevels" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
                   hx-get="@Url.Action("StockLevels", "Inventory", new { businessId = Model.BusinessId, warehouseId = Model.WarehouseId })"
                   hx-target="#inventory-return-receipt-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">Back to Stock Levels</a>
            </div>
        </form>
    </div>
</div>
</div>
