@using Darwin.Application.Billing.DTOs
@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Billing.PaymentEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string ScopedPaymentsUrl(PaymentQueueFilter queue) => Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue }) ?? string.Empty;
    string UpdatePaymentDisputeReviewUrl(Guid id) => Url.Action("UpdatePaymentDisputeReview", "Billing", new { id }) ?? string.Empty;
    string ScopedRefundsUrl() => Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter queue) => Url.Action("Webhooks", "Billing", new { queue }) ?? string.Empty;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
    string AddRefundUrl(Guid orderId, Guid paymentId) => Url.Action("AddRefund", "Orders", new { orderId, paymentId }) ?? string.Empty;
    string CrmEditCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string CrmEditInvoiceUrl(Guid id) => Url.Action("EditInvoice", "Crm", new { id }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string UserEditUrl(Guid id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string PaymentSettingsUrl() => Url.Action("PaymentSettings", "Settings") ?? string.Empty;
    string LocalizePaymentStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeRefundStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeDisputeReviewState(string? state) => state switch
    {
        "UnderReview" => T.T("PaymentDisputeUnderReview"),
        "EvidenceSubmitted" => T.T("PaymentDisputeEvidenceSubmitted"),
        "Won" => T.T("PaymentDisputeWon"),
        "Lost" => T.T("PaymentDisputeLost"),
        _ => string.IsNullOrWhiteSpace(state) ? T.T("PaymentDisputeOpen") : T.T(state)
    };
    var paymentStatusOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.PaymentStatus>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) });
    string LocalizeProviderReferenceState(string? state) => state switch
    {
        "Stripe ref missing" => T.T("BillingProviderStripeRefMissing"),
        "Reference missing" => T.T("BillingProviderReferenceMissing"),
        "Refund activity recorded" => T.T("BillingProviderRefundActivityRecorded"),
        "Waiting for provider completion" => T.T("BillingProviderWaitingForCompletion"),
        "Authorized on provider" => T.T("BillingProviderAuthorized"),
        "Captured on provider" => T.T("BillingProviderCaptured"),
        "Completed on provider" => T.T("BillingProviderCompleted"),
        "Provider failure recorded" => T.T("BillingProviderFailureRecorded"),
        "Refunded against provider ref" => T.T("BillingProviderRefundedAgainstReference"),
        "Voided on provider" => T.T("BillingProviderVoided"),
        "Provider reference linked" => T.T("BillingProviderReferenceLinked"),
        _ => string.IsNullOrWhiteSpace(state) ? "-" : T.T(state)
    };
    string LocalizeProviderEventType(string? eventType) => eventType switch
    {
        "StripeWebhook:checkout.session.completed" => T.T("PaymentProviderEventCheckoutSessionCompleted"),
        "StripeWebhook:payment_intent.succeeded" => T.T("PaymentProviderEventPaymentIntentSucceeded"),
        "StripeWebhook:payment_intent.payment_failed" => T.T("PaymentProviderEventPaymentIntentFailed"),
        "StripeWebhook:payment_intent.canceled" => T.T("PaymentProviderEventPaymentIntentCanceled"),
        "StripeWebhook:charge.refunded" => T.T("PaymentProviderEventChargeRefunded"),
        "StripeWebhook:invoice.paid" => T.T("PaymentProviderEventInvoicePaid"),
        "StripeWebhook:invoice.payment_failed" => T.T("PaymentProviderEventInvoicePaymentFailed"),
        "StripeWebhook:customer.subscription.updated" => T.T("PaymentProviderEventSubscriptionUpdated"),
        "StripeWebhook:customer.subscription.deleted" => T.T("PaymentProviderEventSubscriptionDeleted"),
        _ => string.IsNullOrWhiteSpace(eventType) ? "-" : T.T("PaymentProviderEventStripeWebhook")
    };
    string LocalizeProviderEventCorrelation(string? correlationKind) => correlationKind switch
    {
        "PaymentIntent" => T.T("PaymentProviderEventCorrelationPaymentIntent"),
        "CheckoutSession" => T.T("PaymentProviderEventCorrelationCheckoutSession"),
        "ProviderTransaction" => T.T("PaymentProviderEventCorrelationProviderTransaction"),
        "Multiple" => T.T("PaymentProviderEventCorrelationMultiple"),
        _ => T.T("PaymentProviderEventCorrelationProviderReference")
    };
    string PaymentEditorOpsHealthBadgeClass(bool healthy) => healthy ? "text-bg-success" : "text-bg-warning";
    string PaymentEditorOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var paymentEditorProviderReferenceMissing = string.IsNullOrWhiteSpace(Model.ProviderTransactionRef) && string.IsNullOrWhiteSpace(Model.ProviderPaymentIntentRef) && string.IsNullOrWhiteSpace(Model.ProviderCheckoutSessionRef);
    var paymentEditorHasRefundPressure = Model.RefundedAmountMinor > 0 || Model.Refunds.Count > 0;
    var paymentEditorNeedsInvoiceFollowUp = Model.InvoiceId.HasValue || Model.InvoiceStatus.HasValue;
    var paymentEditorNeedsPendingQueueFollowUp =
        Model.Status == Darwin.Domain.Enums.PaymentStatus.Pending ||
        Model.NeedsReconciliation;
    var paymentEditorNeedsUnlinkedQueueFollowUp = !Model.InvoiceId.HasValue;
    var paymentEditorNeedsRefundedQueueFollowUp = paymentEditorHasRefundPressure;
    var paymentEditorInvoiceStatus = Model.InvoiceStatus?.ToString();
    var paymentEditorNeedsOverdueInvoiceFollowUp =
        Model.InvoiceId.HasValue &&
        string.Equals(paymentEditorInvoiceStatus, "Overdue", StringComparison.OrdinalIgnoreCase);
    var paymentEditorNeedsDueSoonInvoiceFollowUp =
        Model.InvoiceId.HasValue &&
        string.Equals(paymentEditorInvoiceStatus, "DueSoon", StringComparison.OrdinalIgnoreCase);
    var paymentEditorNeedsDraftInvoiceFollowUp =
        Model.InvoiceId.HasValue &&
        Model.InvoiceStatus == Darwin.Domain.Enums.InvoiceStatus.Draft;
    var paymentEditorAttentionCount = (paymentEditorProviderReferenceMissing ? 1 : 0)
        + (Model.NeedsReconciliation ? 1 : 0)
        + (Model.NeedsDisputeFollowUp ? 1 : 0)
        + (Model.ProviderEvents.Count == 0 ? 1 : 0);
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @PaymentEditorOpsHealthBadgeClass(paymentEditorAttentionCount == 0)">@PaymentEditorOpsHealthBadgeText(paymentEditorAttentionCount == 0)</span>
                    <span class="badge @PaymentEditorOpsHealthBadgeClass(!paymentEditorProviderReferenceMissing)">@PaymentEditorOpsHealthBadgeText(!paymentEditorProviderReferenceMissing)</span>
                </div>
                <h2 class="h5 mb-1">@T.T("ReconciliationAndDisputeSnapshot")</h2>
                <p class="text-muted mb-0">@T.T("PaymentSupportPlaybooks")</p>
            </div>
            <div class="text-md-end">
                <div class="small text-muted">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@paymentEditorAttentionCount</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("ProviderRef")</span>
                        <span class="badge @PaymentEditorOpsHealthBadgeClass(!paymentEditorProviderReferenceMissing)">@(paymentEditorProviderReferenceMissing ? 1 : 0)</span>
                    </div>
                    <p class="small text-muted mb-3">@LocalizeProviderReferenceState(Model.ProviderReferenceState)</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.MissingProviderRef"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.MissingProviderRef)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentExceptions")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("NeedsReconciliation")</span>
                        <span class="badge @PaymentEditorOpsHealthBadgeClass(!Model.NeedsReconciliation)">@(Model.NeedsReconciliation ? 1 : 0)</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("NeedsReconciliationQueue")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalPaymentsUrl()"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Payments")</a>
                        @if (paymentEditorNeedsPendingQueueFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.Pending"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Pending)"
                               hx-target="#billing-payment-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Pending")</a>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("DisputeFollowUp")</span>
                        <span class="badge @PaymentEditorOpsHealthBadgeClass(!Model.NeedsDisputeFollowUp)">@(Model.NeedsDisputeFollowUp ? 1 : 0)</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("DisputeSignals")</p>
                    <div class="small mb-2">
                        <span class="fw-semibold">@T.T("DisputeReviewState"):</span>
                        @LocalizeDisputeReviewState(Model.DisputeReviewState)
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DisputeSignals")</a>
                        @if (!string.IsNullOrWhiteSpace(Model.DisputeReviewState))
                        {
                            <form asp-action="UpdatePaymentDisputeReview"
                                  method="post"
                                  class="d-inline"
                                  hx-post="@UpdatePaymentDisputeReviewUrl(Model.Id)"
                                  hx-target="#billing-payment-editor-shell"
                                  hx-swap="outerHTML">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                                <input type="hidden" name="returnToEdit" value="true" />
                                <input type="hidden" name="action" value="Clear" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("ClearDisputeReview")</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("OpenTaxCompliance")</span>
                        <span class="badge @PaymentEditorOpsHealthBadgeClass(Model.InvoiceId.HasValue)">@(Model.InvoiceId.HasValue ? 0 : 1)</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("WebhookExceptions")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="TaxCompliance"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalTaxComplianceUrl()"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenTaxCompliance")</a>
                        @if (paymentEditorHasRefundPressure)
                        {
                            <a asp-action="Refunds"
                               asp-route-businessId="@Model.BusinessId"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@ScopedRefundsUrl()"
                               hx-target="#billing-payment-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("RefundQueueTitle")</a>
                        }
                        @if (paymentEditorNeedsRefundedQueueFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.Refunded"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Refunded)"
                               hx-target="#billing-payment-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Refunded")</a>
                        }
                        @if (paymentEditorNeedsInvoiceFollowUp && Model.InvoiceId.HasValue)
                        {
                            <a asp-controller="Crm"
                               asp-action="EditInvoice"
                               asp-route-id="@Model.InvoiceId.Value"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@CrmEditInvoiceUrl(Model.InvoiceId.Value)"
                               hx-target="#billing-payment-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Invoices")</a>
                            @if (paymentEditorNeedsOverdueInvoiceFollowUp)
                            {
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="Overdue"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@CrmInvoicesUrl("Overdue")"
                                   hx-target="#billing-payment-editor-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Overdue")</a>
                            }
                            @if (paymentEditorNeedsDueSoonInvoiceFollowUp)
                            {
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="DueSoon"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@CrmInvoicesUrl("DueSoon")"
                                   hx-target="#billing-payment-editor-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("DueSoon")</a>
                            }
                            @if (paymentEditorNeedsDraftInvoiceFollowUp)
                            {
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="Draft"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@CrmInvoicesUrl("Draft")"
                                   hx-target="#billing-payment-editor-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">@T.T("Draft")</a>
                            }
                        }
                        @if (paymentEditorNeedsUnlinkedQueueFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.Unlinked"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Unlinked)"
                               hx-target="#billing-payment-editor-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Unlinked")</a>
                        }
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                           hx-target="#billing-payment-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("WebhookExceptions")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.OrderId.HasValue || Model.InvoiceId.HasValue || Model.CustomerId.HasValue || Model.UserId.HasValue)
{
    <div class="alert alert-light border mb-3">
        <div class="fw-semibold mb-2">@T.T("RelatedRecords")</div>
        <div class="row g-2 small">
            @if (Model.OrderId.HasValue)
            {
                <div class="col-md-6">
                    <strong>@T.T("Order"):</strong>
                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId.Value" class="text-decoration-none"
                       hx-get="@OrderDetailsUrl(Model.OrderId.Value)"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.OrderNumber) ? Model.OrderId.Value.ToString() : Model.OrderNumber)
                    </a>
                </div>
            }
            @if (Model.InvoiceId.HasValue)
            {
                <div class="col-md-6">
                    <strong>@T.T("Invoice"):</strong>
                    <a asp-controller="Crm"
                       asp-action="EditInvoice"
                       asp-route-id="@Model.InvoiceId.Value"
                       class="text-decoration-none"
                       hx-get="@CrmEditInvoiceUrl(Model.InvoiceId.Value)"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <code>@Model.InvoiceId</code>
                    </a>
                    @if (Model.InvoiceStatus.HasValue)
                    {
                        <span class="text-muted">(@LocalizeInvoiceStatus(Model.InvoiceStatus))</span>
                    }
                </div>
            }
            @if (Model.CustomerId.HasValue)
            {
                <div class="col-md-6">
                    <strong>@T.T("Customer"):</strong>
                    <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@Model.CustomerId.Value" class="text-decoration-none"
                       hx-get="@CrmEditCustomerUrl(Model.CustomerId.Value)"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.CustomerDisplayName) ? Model.CustomerId.Value.ToString() : Model.CustomerDisplayName)
                    </a>
                    @if (!string.IsNullOrWhiteSpace(Model.CustomerEmail))
                    {
                        <span class="text-muted">(@Model.CustomerEmail)</span>
                    }
                </div>
            }
            @if (Model.UserId.HasValue)
            {
                <div class="col-md-6">
                    <strong>@T.T("Users"):</strong>
                    <a asp-controller="Users" asp-action="Edit" asp-route-id="@Model.UserId.Value" class="text-decoration-none"
                       hx-get="@UserEditUrl(Model.UserId.Value)"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @(string.IsNullOrWhiteSpace(Model.UserDisplayName) ? Model.UserId.Value.ToString() : Model.UserDisplayName)
                    </a>
                    @if (!string.IsNullOrWhiteSpace(Model.UserEmail))
                    {
                        <span class="text-muted">(@Model.UserEmail)</span>
                    }
                </div>
            }
        </div>
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("Lifecycle")</div>
                <div class="fs-5">@LocalizePaymentStatus(Model.Status)</div>
                <div class="small text-muted mt-1">@T.T("Created") @Model.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                @if (Model.PaidAtUtc.HasValue)
                {
                    <div class="small">@T.T("Paid") @Model.PaidAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                }
                @if (Model.LastFinancialEventAtUtc.HasValue)
                {
                    <div class="small">@T.T("LastEvent") @Model.LastFinancialEventAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                }
                @if (Model.IsStripe)
                {
                    <div><span class="badge text-bg-info mt-2">@T.T("Stripe")</span></div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("RecordedAmount")</div>
                <div class="fs-5">@Model.Currency @((Model.AmountMinor / 100M).ToString("0.00"))</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("Refunded")</div>
                <div class="fs-5 @(Model.RefundedAmountMinor > 0 ? "text-warning" : string.Empty)">
                    @Model.Currency @((Model.RefundedAmountMinor / 100M).ToString("0.00"))
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("NetCollected")</div>
                <div class="fs-5">@Model.Currency @((Model.NetCapturedAmountMinor / 100M).ToString("0.00"))</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("ReconciliationAndDisputeSnapshot")</span>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Settings" asp-action="PaymentSettings" class="btn btn-sm btn-outline-secondary"
               hx-get="@PaymentSettingsUrl()"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("PaymentSettings")</a>
            <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.NeedsReconciliation" class="btn btn-sm btn-outline-warning"
               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("NeedsReconciliationQueue")</a>
            <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.DisputeFollowUp" class="btn btn-sm btn-outline-danger"
               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("DisputeFollowUpQueue")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("ProviderRef")</div>
                <div class="fw-semibold">@LocalizeProviderReferenceState(Model.ProviderReferenceState)</div>
            </div>
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("ProviderPaymentIntentRef")</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.ProviderPaymentIntentRef) ? "-" : Model.ProviderPaymentIntentRef)</div>
            </div>
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("ProviderCheckoutSessionRef")</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.ProviderCheckoutSessionRef) ? "-" : Model.ProviderCheckoutSessionRef)</div>
            </div>
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("OpenAge")</div>
                <div class="fw-semibold">@Model.OpenAgeHours h</div>
            </div>
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("Reconciliation")</div>
                <div>
                    @if (Model.NeedsReconciliation)
                    {
                        <span class="badge text-bg-warning">@T.T("NeedsReconciliation")</span>
                    }
                    else
                    {
                        <span class="badge text-bg-success">@T.T("NoOpenReconciliationFlag")</span>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="small text-uppercase text-muted fw-semibold">@T.T("DisputeReview")</div>
                <div>
                    @if (Model.NeedsDisputeFollowUp)
                    {
                        <span class="badge text-bg-danger">@T.T("DisputeFollowUp")</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">@T.T("NoDisputeFlag")</span>
                    }
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a asp-action="Webhooks" asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions" class="btn btn-sm btn-outline-warning"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("PaymentExceptions")</a>
            <a asp-action="Webhooks" asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals" class="btn btn-sm btn-outline-danger"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("DisputeSignals")</a>
            @if (Model.OrderId.HasValue)
            {
                <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId.Value" asp-fragment="payments" class="btn btn-sm btn-outline-secondary"
                   hx-get="@OrderDetailsUrl(Model.OrderId.Value)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenOrderPayments")</a>
            }
            @if (paymentEditorHasRefundPressure)
            {
                <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-danger"
                   hx-get="@ScopedRefundsUrl()"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("RefundQueueTitle")</a>
                <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Refunded" class="btn btn-sm btn-outline-secondary"
                   hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Refunded)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Refunded")</a>
            }
            @if (paymentEditorNeedsPendingQueueFollowUp)
            {
                <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Pending" class="btn btn-sm btn-outline-warning"
                   hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Pending)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Pending")</a>
            }
            @if (paymentEditorNeedsUnlinkedQueueFollowUp)
            {
                <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Unlinked" class="btn btn-sm btn-outline-dark"
                   hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Unlinked)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Unlinked")</a>
            }
            @if (paymentEditorNeedsInvoiceFollowUp && Model.InvoiceId.HasValue)
            {
                <a asp-controller="Crm" asp-action="EditInvoice" asp-route-id="@Model.InvoiceId.Value" class="btn btn-sm btn-outline-secondary"
                   hx-get="@CrmEditInvoiceUrl(Model.InvoiceId.Value)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Invoices")</a>
                @if (paymentEditorNeedsOverdueInvoiceFollowUp)
                {
                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Overdue" class="btn btn-sm btn-outline-warning"
                       hx-get="@CrmInvoicesUrl("Overdue")"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Overdue")</a>
                }
                @if (paymentEditorNeedsDueSoonInvoiceFollowUp)
                {
                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="DueSoon" class="btn btn-sm btn-outline-warning"
                       hx-get="@CrmInvoicesUrl("DueSoon")"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("DueSoon")</a>
                }
                @if (paymentEditorNeedsDraftInvoiceFollowUp)
                {
                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Draft" class="btn btn-sm btn-outline-secondary"
                       hx-get="@CrmInvoicesUrl("Draft")"
                       hx-target="#billing-payment-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Draft")</a>
                }
            }
            <a asp-action="TaxCompliance" class="btn btn-sm btn-outline-secondary"
                               hx-get="@GlobalTaxComplianceUrl()"
               hx-target="#billing-payment-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenTaxCompliance")</a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("PaymentProviderAuditTrail")</span>
        <span class="badge text-bg-light">@Model.ProviderEvents.Count</span>
    </div>
    <div class="card-body">
        @if (Model.ProviderEvents.Count == 0)
        {
            <div class="text-muted">@T.T("PaymentProviderAuditTrailEmpty")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Occurred")</th>
                            <th>@T.T("ProviderEvent")</th>
                            <th>@T.T("Correlation")</th>
                            <th>@T.T("IdempotencyKey")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.ProviderEvents)
                    {
                        <tr>
                                <td>@item.OccurredAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                            <td>@LocalizeProviderEventType(item.EventType)</td>
                            <td>
                                <div>@LocalizeProviderEventCorrelation(item.CorrelationKind)</div>
                                <div class="small text-muted">@(string.IsNullOrWhiteSpace(item.CorrelationReference) ? "-" : item.CorrelationReference)</div>
                            </td>
                            <td><code>@(string.IsNullOrWhiteSpace(item.IdempotencyKey) ? "-" : item.IdempotencyKey)</code></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.FailureReason))
{
    <div class="alert alert-danger mb-3">
        <div class="fw-semibold">@T.T("RecordedFailureReason")</div>
        <div class="small">@Model.FailureReason</div>
    </div>
}

@if (Model.SupportPlaybooks.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header">@T.T("PaymentSupportPlaybooks")</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Queue")</th>
                            <th>@T.T("Scope")</th>
                            <th>@T.T("OperatorAction")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.SupportPlaybooks)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Title</td>
                            <td>@item.ScopeNote</td>
                            <td>@item.OperatorAction</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (Model.Refunds.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@T.T("RefundTimeline")</span>
            @if (Model.OrderId.HasValue)
            {
                <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId.Value" asp-fragment="refunds" class="btn btn-sm btn-outline-secondary"
                   hx-get="@OrderDetailsUrl(Model.OrderId.Value)"
                   hx-target="#billing-payment-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenOrderRefunds")</a>
            }
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("Created")</th>
                            <th>@T.T("Reason")</th>
                            <th>@T.T("Status")</th>
                            <th class="text-end">@T.T("Amount")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var refund in Model.Refunds)
                    {
                        <tr>
                            <td>
                                        <div>@refund.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                                @if (refund.CompletedAtUtc.HasValue)
                                {
                                            <div class="small text-muted">@T.T("Completed") @refund.CompletedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                                }
                            </td>
                            <td>@refund.Reason</td>
                            <td>@LocalizeRefundStatus(refund.Status)</td>
                            <td class="text-end">@refund.Currency @((refund.AmountMinor / 100M).ToString("0.00"))</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (Model.OrderId.HasValue)
{
    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-controller="Orders" asp-action="AddRefund" asp-route-orderId="@Model.OrderId.Value" asp-route-paymentId="@Model.Id" class="btn btn-sm btn-outline-danger"
           hx-get="@AddRefundUrl(Model.OrderId.Value, Model.Id)"
           hx-target="#billing-payment-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("AddRefundForThisPayment")</a>
        <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId.Value" asp-fragment="refunds" class="btn btn-sm btn-outline-secondary"
           hx-get="@OrderDetailsUrl(Model.OrderId.Value)"
           hx-target="#billing-payment-editor-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenOrderRefunds")</a>
    </div>
}

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="BusinessId" class="form-label"></label>
        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="CustomerId" class="form-label"></label>
        <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="UserId" class="form-label"></label>
        <select asp-for="UserId" asp-items="Model.UserOptions" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="Provider" class="form-label"></label>
        <input asp-for="Provider" class="form-control" />
        <span asp-validation-for="Provider" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="paymentStatusOptions" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="Currency" class="form-label"></label>
        <input asp-for="Currency" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="AmountMinor" class="form-label"></label>
        <input asp-for="AmountMinor" class="form-control" />
        <div class="form-text">@T.T("MinorUnits")</div>
    </div>
    <div class="col-md-4">
        <label asp-for="ProviderTransactionRef" class="form-label"></label>
        <input asp-for="ProviderTransactionRef" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ProviderPaymentIntentRef" class="form-label"></label>
        <input asp-for="ProviderPaymentIntentRef" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ProviderCheckoutSessionRef" class="form-label"></label>
        <input asp-for="ProviderCheckoutSessionRef" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="PaidAtUtc" class="form-label"></label>
        <input asp-for="PaidAtUtc" type="datetime-local" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="OrderId" class="form-label"></label>
        <input asp-for="OrderId" class="form-control" />
        @if (!string.IsNullOrWhiteSpace(Model.OrderNumber))
        {
            <div class="form-text">@T.T("LinkedOrder"): @Model.OrderNumber</div>
        }
    </div>
    <div class="col-md-6">
        <label asp-for="InvoiceId" class="form-label"></label>
        <input asp-for="InvoiceId" class="form-control" />
        @if (Model.InvoiceStatus.HasValue || Model.InvoiceTotalGrossMinor.HasValue)
        {
            <div class="form-text">
                @if (Model.InvoiceStatus.HasValue)
                {
                    <span>@T.T("Status"): @LocalizeInvoiceStatus(Model.InvoiceStatus)</span>
                }
                @if (Model.InvoiceTotalGrossMinor.HasValue)
                {
                    <span class="ms-2">@T.T("Total"): @Model.Currency @((Model.InvoiceTotalGrossMinor.Value / 100M).ToString("0.00"))</span>
                }
            </div>
        }
    </div>
</div>
