@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Billing.BillingPlansListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BillingPlansTitle");
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalBillingPlansUrl() => Url.Action("Plans", "Billing") ?? string.Empty;
    string BillingPlanOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string BillingPlanOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var billingPlanAttentionCount = Model.Summary.InactiveCount
        + Model.Summary.TrialCount
        + Model.Summary.MissingFeaturesCount;
    string CreatePlanUrl() => Url.Action("CreatePlan", "Billing") ?? string.Empty;
    string BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter? queue = null) => Url.Action("Plans", "Billing", new { queue }) ?? string.Empty;
    string EditPlanUrl(Guid id) => Url.Action("EditPlan", "Billing", new { id }) ?? string.Empty;
}

<div id="billing-plans-workspace-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1"><i class="fa-solid fa-layer-group me-2"></i>@T.T("BillingPlansTitle")</h1>
            <p class="text-muted mb-0">@T.T("BillingPlansIntro")</p>
        </div>
        <a asp-action="CreatePlan" class="btn btn-primary"
           hx-get="@CreatePlanUrl()"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa-solid fa-plus"></i> @T.T("BillingPlansCreatePlan")
        </a>
    </div>

<div class="row g-3 mb-3">
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("CommonTotal")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BillingPlansActive")</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BillingPlansInactive")</div><div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BillingPlansTrial")</div><div class="fs-4 fw-semibold">@Model.Summary.TrialCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BillingPlansMissingFeatures")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingFeaturesCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BillingPlansInUse")</div><div class="fs-4 fw-semibold">@Model.Summary.InUseCount</div></div></div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@BillingPlanOpsHealthBadgeClass(billingPlanAttentionCount == 0)">@BillingPlanOpsHealthBadgeText(billingPlanAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("BillingPlansIntro")
                    @if (billingPlanAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @billingPlanAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreatePlan"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@CreatePlanUrl()"
                   hx-target="#billing-plans-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-plus"></i> @T.T("BillingPlansCreatePlan")
                </a>
                <a asp-action="Payments"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@GlobalPaymentsUrl()"
                   hx-target="#billing-plans-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-credit-card"></i> @T.T("PaymentsLabel")
                </a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("BillingPlansInactive")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@BillingPlanOpsHealthBadgeClass(Model.Summary.InactiveCount == 0)">@Model.Summary.InactiveCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("BillingPlansPlaybookActiveAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Plans"
                           asp-route-queue="Inactive"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Inactive)"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansInactive")</a>
                        <a asp-action="CreatePlan"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreatePlanUrl()"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansCreatePlan")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("BillingPlansTrial")</div>
                            <div class="small text-muted mt-1">@T.T("BillingPlansPlaybookTrialScope")</div>
                        </div>
                        <span class="@BillingPlanOpsHealthBadgeClass(Model.Summary.TrialCount == 0)">@Model.Summary.TrialCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("BillingPlansPlaybookTrialAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Plans"
                           asp-route-queue="Trial"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Trial)"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansTrial")</a>
                        <a asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalPaymentsUrl()"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentsLabel")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("BillingPlansMissingFeatures")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@BillingPlanOpsHealthBadgeClass(Model.Summary.MissingFeaturesCount == 0)">@Model.Summary.MissingFeaturesCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("BillingPlansPlaybookActiveDependency")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Plans"
                           asp-route-queue="MissingFeatures"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.MissingFeatures)"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansMissingFeatures")</a>
                        <a asp-action="CreatePlan"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreatePlanUrl()"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansCreatePlan")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("BillingPlansInUse")</div>
                            <div class="small text-muted mt-1">@T.T("QueueScope")</div>
                        </div>
                        <span class="@BillingPlanOpsHealthBadgeClass(Model.Summary.InUseCount > 0)">@Model.Summary.InUseCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("BillingPlansPlaybookActiveScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Plans"
                           asp-route-queue="InUse"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.InUse)"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("BillingPlansInUse")</a>
                        <a asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalPaymentsUrl()"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentsLabel")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("BillingPlansPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("BillingPlansQueueColumn")</th>
                        <th>@T.T("BillingPlansScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

    <form method="get"
          class="row g-2 mb-3"
      hx-get="@GlobalBillingPlansUrl()"
          hx-target="#billing-plans-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <div class="col-md-4">
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("BillingPlansSearchPlaceholder")" />
        </div>
        <div class="col-md-3">
            <select name="queue" class="form-select">
                <option value="All" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.All)">@T.T("BillingPlansAllPlans")</option>
                <option value="Active" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Active)">@T.T("BillingPlansActive")</option>
                <option value="Inactive" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Inactive)">@T.T("BillingPlansInactive")</option>
                <option value="Trial" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Trial)">@T.T("BillingPlansTrial")</option>
                <option value="MissingFeatures" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.MissingFeatures)">@T.T("BillingPlansMissingFeatures")</option>
                <option value="InUse" selected="@(Model.QueueFilter == Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.InUse)">@T.T("BillingPlansInUse")</option>
            </select>
        </div>
        <div class="col-md-2">
            <input type="number" min="1" name="pageSize" value="@Model.PageSize" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i> @T.T("CommonSearch")</button>
            <a asp-action="Plans"
               class="btn btn-outline-secondary"
       hx-get="@GlobalBillingPlansUrl()"
               hx-target="#billing-plans-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("CommonReset")</a>
        </div>
    </form>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-action="Plans"
           asp-route-queue="Inactive"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Inactive)"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BillingPlansInactive")</a>
        <a asp-action="Plans"
           asp-route-queue="Trial"
           class="btn btn-sm btn-outline-info"
           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.Trial)"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BillingPlansTrial")</a>
        <a asp-action="Plans"
           asp-route-queue="MissingFeatures"
           class="btn btn-sm btn-outline-warning"
           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.MissingFeatures)"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BillingPlansMissingFeatures")</a>
        <a asp-action="Plans"
           asp-route-queue="InUse"
           class="btn btn-sm btn-outline-primary"
           hx-get="@BillingPlansUrl(Darwin.Application.Billing.DTOs.BillingPlanQueueFilter.InUse)"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BillingPlansInUse")</a>
        <a asp-action="Plans"
           class="btn btn-sm btn-outline-secondary"
                    hx-get="@GlobalBillingPlansUrl()"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BillingPlansClearQueueFilters")</a>
    </div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("CommonPlan")</th>
                <th>@T.T("BillingPlansPriceColumn")</th>
                <th>@T.T("BillingPlansIntervalColumn")</th>
                <th>@T.T("BillingPlansTrialColumn")</th>
                <th>@T.T("BillingPlansUsageColumn")</th>
                <th>@T.T("CommonStatus")</th>
                <th>@T.T("BillingPlansUpdatedColumn")</th>
                <th class="text-end">@T.T("CommonActions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted py-4">@T.T("BillingPlansEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        <div class="small text-muted">@item.Code</div>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <div class="small text-muted mt-1">@item.Description</div>
                        }
                    </td>
                    <td>@item.Currency @((item.PriceMinor / 100M).ToString("0.00"))</td>
                    <td>@string.Format(T.T("BillingPlansEveryInterval"), item.IntervalCount, item.Interval)</td>
                    <td>@(item.TrialDays.HasValue ? string.Format(T.T("BillingPlansTrialDays"), item.TrialDays.Value) : "-")</td>
                    <td>
                        <span class="badge @(item.ActiveSubscriptionCount > 0 ? "text-bg-primary" : "text-bg-secondary")">@string.Format(T.T("BillingPlansActiveSubscriptions"), item.ActiveSubscriptionCount)</span>
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? T.T("BillingPlansActive") : T.T("BillingPlansInactive"))</span>
                        @if (!item.HasFeatures)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("BillingPlansMissingFeatures")</span></div>
                        }
                    </td>
                    <td>@(item.ModifiedAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? "-")</td>
                    <td class="text-end">
                        <a asp-action="EditPlan" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"
                           hx-get="@EditPlanUrl(item.Id)"
                           hx-target="#billing-plans-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa-solid fa-pen"></i> @T.T("CommonEdit")
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Billing"
           asp-action="Plans"
           asp-route-q="@Model.Query"
           asp-route-queue="@Model.QueueFilter"
           hx-target="#billing-plans-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
    </pager>
</div>
