@model Darwin.WebAdmin.ViewModels.Billing.ExpensesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("ExpensesTitle");
}

<div id="billing-expenses-workspace-shell">
<h1 class="mb-3">@T.T("ExpensesTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Expenses" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("Expenses", "Billing")"
          hx-target="#billing-expenses-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchExpensesPlaceholder")">
        <button class="btn btn-outline-secondary" type="submit">@T.T("CommonSearch")</button>
        <a asp-action="Expenses" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-expenses-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonReset")</a>
    </form>
    <a asp-action="CreateExpense" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreateExpense", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-expenses-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CreateExpense")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonTotal")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ExpensesSupplierLinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.SupplierLinkedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ExpensesRecent30Days")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RecentCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("HighValue")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.HighValueCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("ExpensesReviewPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("CommonDate")</th><th>@T.T("Category")</th><th>@T.T("Description")</th><th>@T.T("Amount")</th><th class="text-end">@T.T("CommonActions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">@T.T("ExpensesEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ExpenseDateUtc.ToString("yyyy-MM-dd")</td>
                    <td>@item.Category</td>
                    <td>@item.Description</td>
                    <td>@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end">
                        <a asp-action="EditExpense" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditExpense", "Billing", new { id = item.Id })"
                           hx-target="#billing-expenses-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonEdit")</a>
                        @if (item.SupplierId.HasValue)
                        {
                            <a asp-controller="Inventory" asp-action="EditSupplier" asp-route-id="@item.SupplierId.Value" class="btn btn-sm btn-outline-info"
                               hx-get="@Url.Action("EditSupplier", "Inventory", new { id = item.SupplierId.Value })"
                               hx-target="#billing-expenses-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Supplier")</a>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="Expenses" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" hx-target="#billing-expenses-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
