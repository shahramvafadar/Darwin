@model Darwin.WebAdmin.ViewModels.Billing.ExpensesListVm
@{
    ViewData["Title"] = "Expenses";
}

<h1 class="mb-3">Expenses</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Expenses" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
    </form>
    <a asp-action="CreateExpense" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Expense</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">No expenses found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ExpenseDateUtc.ToString("yyyy-MM-dd")</td>
                    <td>@item.Category</td>
                    <td>@item.Description</td>
                    <td>EUR @((item.AmountMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end"><a asp-action="EditExpense" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="Expenses" asp-route-businessId="@Model.BusinessId"></pager>
