@model Darwin.WebAdmin.ViewModels.Billing.FinancialAccountEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true;
    ViewData["Title"] = isCreate ? T.T("CreateFinancialAccount") : T.T("EditFinancialAccount");
}

<div id="billing-financial-account-editor-shell">
    <h1 class="mb-3">@(isCreate ? T.T("CreateFinancialAccount") : T.T("EditFinancialAccount"))</h1>

    <form asp-action="@(isCreate ? "CreateFinancialAccount" : "EditFinancialAccount")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateFinancialAccount" : "EditFinancialAccount", "Billing")"
          hx-target="#billing-financial-account-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }
        <partial name="_FinancialAccountForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            <a asp-action="FinancialAccounts"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
               hx-target="#billing-financial-account-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Back")</a>
        </div>
    </form>
</div>
