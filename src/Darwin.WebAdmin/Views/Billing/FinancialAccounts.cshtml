@using Darwin.Domain.Enums
@model Darwin.WebAdmin.ViewModels.Billing.FinancialAccountsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("FinancialAccountsTitle");
    string FinancialAccountOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string FinancialAccountOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var financialAccountAttentionCount = Model.Summary.MissingCodeCount + Model.Summary.ExpenseCount;
}

@functions {
    string LocalizeAccountType(object? type) => type is null ? "-" : T.T(type.ToString() ?? string.Empty);
}

<div id="billing-financial-accounts-workspace-shell">
<h1 class="mb-3">@T.T("FinancialAccountsTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="FinancialAccounts" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("FinancialAccounts", "Billing")"
          hx-target="#billing-financial-accounts-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchFinancialAccountsPlaceholder")">
        <button class="btn btn-outline-secondary" type="submit">@T.T("CommonSearch")</button>
        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-financial-accounts-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonReset")</a>
    </form>
    <a asp-action="CreateFinancialAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreateFinancialAccount", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CreateFinancialAccount")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonTotal")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Assets")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AssetCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Revenue")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RevenueCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Expenses")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ExpenseCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("FinancialAccountsMissingCode")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingCodeCount</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@FinancialAccountOpsHealthBadgeClass(financialAccountAttentionCount == 0)">@FinancialAccountOpsHealthBadgeText(financialAccountAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("FinancialAccountsPlaybooksTitle")
                    @if (financialAccountAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @financialAccountAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreateFinancialAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("CreateFinancialAccount", "Billing", new { businessId = Model.BusinessId })"
                   hx-target="#billing-financial-accounts-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CreateFinancialAccount")</a>
                <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId })"
                   hx-target="#billing-financial-accounts-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("JournalEntriesTitle")</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Assets")</div>
                            <div class="small text-muted mt-1">@T.T("FinancialAccountPlaybookAssetsScope")</div>
                        </div>
                        <span class="@FinancialAccountOpsHealthBadgeClass(Model.Summary.AssetCount > 0)">@Model.Summary.AssetCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("FinancialAccountPlaybookAssetsAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Asset" class="btn btn-sm btn-outline-info"
                           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Asset })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Assets")</a>
                        <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("JournalEntriesTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Revenue")</div>
                            <div class="small text-muted mt-1">@T.T("Queue")</div>
                        </div>
                        <span class="@FinancialAccountOpsHealthBadgeClass(Model.Summary.RevenueCount > 0)">@Model.Summary.RevenueCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("FinancialAccountPlaybookMappingAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Revenue" class="btn btn-sm btn-outline-success"
                           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Revenue })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Revenue")</a>
                        <a asp-action="Expenses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Expenses")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Expenses")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@FinancialAccountOpsHealthBadgeClass(Model.Summary.ExpenseCount == 0)">@Model.Summary.ExpenseCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("FinancialAccountPlaybookMappingDependency")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Expense" class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Expense })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Expenses")</a>
                        <a asp-action="Expenses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ExpensesTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("FinancialAccountsMissingCode")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@FinancialAccountOpsHealthBadgeClass(Model.Summary.MissingCodeCount == 0)">@Model.Summary.MissingCodeCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("FinancialAccountPlaybookMappingScope")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, q = string.Empty })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FinancialAccountsMissingCode")</a>
                        <a asp-action="CreateFinancialAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("CreateFinancialAccount", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CreateFinancialAccount")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("FinancialAccountsPlaybooksTitle")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.QueueFilter is null ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("All")</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Asset" class="btn btn-sm @(Model.QueueFilter == AccountType.Asset ? "btn-info" : "btn-outline-info")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Asset })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Assets")</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Revenue" class="btn btn-sm @(Model.QueueFilter == AccountType.Revenue ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Revenue })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Revenue")</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Expense" class="btn btn-sm @(Model.QueueFilter == AccountType.Expense ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Expense })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Expenses")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("Code")</th><th>@T.T("Name")</th><th>@T.T("Type")</th><th class="text-end">@T.T("CommonActions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="4" class="text-center text-muted">@T.T("FinancialAccountsEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@LocalizeAccountType(item.Type)</td>
                    <td class="text-end">
                        @if (string.IsNullOrWhiteSpace(item.Code))
                        {
                            <span class="badge text-bg-warning me-1">@T.T("FinancialAccountsCodeMissing")</span>
                        }
                        <a asp-action="EditFinancialAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditFinancialAccount", "Billing", new { id = item.Id })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonEdit")</a>
                        <a asp-action="JournalEntries"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-q="@(string.IsNullOrWhiteSpace(item.Code) ? item.Name : item.Code)"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, q = string.IsNullOrWhiteSpace(item.Code) ? item.Name : item.Code })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("JournalEntriesTitle")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter" hx-target="#billing-financial-accounts-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
