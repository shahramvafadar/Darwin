@using Darwin.Domain.Enums
@model Darwin.WebAdmin.ViewModels.Billing.FinancialAccountsListVm
@{
    ViewData["Title"] = "Financial Accounts";
}

<h1 class="mb-3">Financial Accounts</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="FinancialAccounts" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search accounts">
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreateFinancialAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Account</a>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.QueueFilter is null ? "btn-dark" : "btn-outline-dark")">All</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Asset" class="btn btn-sm @(Model.QueueFilter == AccountType.Asset ? "btn-info" : "btn-outline-info")">Assets</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Revenue" class="btn btn-sm @(Model.QueueFilter == AccountType.Revenue ? "btn-success" : "btn-outline-success")">Revenue</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Expense" class="btn btn-sm @(Model.QueueFilter == AccountType.Expense ? "btn-warning" : "btn-outline-warning")">Expenses</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Code</th><th>Name</th><th>Type</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="4" class="text-center text-muted">No accounts found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.Type</td>
                    <td class="text-end">
                        <a asp-action="EditFinancialAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="JournalEntries"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-q="@(string.IsNullOrWhiteSpace(item.Code) ? item.Name : item.Code)"
                           class="btn btn-sm btn-outline-info">Entries</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter"></pager>
