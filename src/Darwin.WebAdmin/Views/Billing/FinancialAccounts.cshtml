@using Darwin.Domain.Enums
@model Darwin.WebAdmin.ViewModels.Billing.FinancialAccountsListVm
@{
    ViewData["Title"] = "Financial Accounts";
}

<div id="billing-financial-accounts-workspace-shell">
<h1 class="mb-3">Financial Accounts</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="FinancialAccounts" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("FinancialAccounts", "Billing")"
          hx-target="#billing-financial-accounts-workspace-shell"
          hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search accounts">
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-financial-accounts-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </form>
    <a asp-action="CreateFinancialAccount" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreateFinancialAccount", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML">New Account</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Assets</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AssetCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Revenue</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RevenueCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Expenses</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ExpenseCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Code</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingCodeCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Financial Account Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.QueueFilter is null ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML">All</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Asset" class="btn btn-sm @(Model.QueueFilter == AccountType.Asset ? "btn-info" : "btn-outline-info")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Asset })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML">Assets</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Revenue" class="btn btn-sm @(Model.QueueFilter == AccountType.Revenue ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Revenue })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML">Revenue</a>
    <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-queue="@AccountType.Expense" class="btn btn-sm @(Model.QueueFilter == AccountType.Expense ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId, queue = AccountType.Expense })"
       hx-target="#billing-financial-accounts-workspace-shell"
       hx-swap="outerHTML">Expenses</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Code</th><th>Name</th><th>Type</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="4" class="text-center text-muted">No accounts found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Code</td>
                    <td>@item.Name</td>
                    <td>@item.Type</td>
                    <td class="text-end">
                        @if (string.IsNullOrWhiteSpace(item.Code))
                        {
                            <span class="badge text-bg-warning me-1">Code missing</span>
                        }
                        <a asp-action="EditFinancialAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditFinancialAccount", "Billing", new { id = item.Id })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML">Edit</a>
                        <a asp-action="JournalEntries"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-q="@(string.IsNullOrWhiteSpace(item.Code) ? item.Name : item.Code)"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, q = string.IsNullOrWhiteSpace(item.Code) ? item.Name : item.Code })"
                           hx-target="#billing-financial-accounts-workspace-shell"
                           hx-swap="outerHTML">Entries</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter"></pager>
</div>
