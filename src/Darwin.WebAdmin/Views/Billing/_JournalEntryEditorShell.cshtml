@model Darwin.WebAdmin.ViewModels.Billing.JournalEntryEditVm
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true;
    ViewData["Title"] = isCreate ? "Create Journal Entry" : "Edit Journal Entry";
}

<div id="billing-journal-entry-editor-shell">
    <h1 class="mb-3">@(isCreate ? "Create Journal Entry" : "Edit Journal Entry")</h1>

    <form asp-action="@(isCreate ? "CreateJournalEntry" : "EditJournalEntry")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateJournalEntry" : "EditJournalEntry", "Billing")"
          hx-target="#billing-journal-entry-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }
        <partial name="_JournalEntryForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>
