@model Darwin.WebAdmin.ViewModels.Billing.FinancialAccountEditVm

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="BusinessId" class="form-label"></label>
        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" asp-items="Html.GetEnumSelectList<Darwin.Domain.Enums.AccountType>()" class="form-select"></select>
    </div>
    <div class="col-12">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
</div>
