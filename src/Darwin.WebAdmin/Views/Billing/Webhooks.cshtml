@using System.Globalization
@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.BillingWebhooksListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("WebhookDeliveries");
    string LocalizeWebhookStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeRetrySafetyState(string? state) => string.IsNullOrWhiteSpace(state) ? "-" : T.T(state);
    string WebhookOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string WebhookOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var webhookAttentionCount = Model.Summary.FailedDeliveryCount
        + Model.Summary.RetryPendingCount
        + Model.Summary.PaymentExceptionCount
        + Model.Summary.DisputeSignalCount;
}

<div id="billing-webhooks-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3">@T.T("WebhookDeliveries")</h1>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ActiveSubscriptions")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ActiveSubscriptionCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Pending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingDeliveryCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Failed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedDeliveryCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Succeeded")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.SucceededDeliveryCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("RetryPending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RetryPendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("PaymentExceptions")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PaymentExceptionCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("DisputeSignals")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DisputeSignalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("QueueScope")</div>
            <div class="fw-semibold mt-1">@T.T("Global")</div>
            <div class="small text-muted mt-2">@T.T("WebhookPlatformScopeNote")</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("WebhookSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                        <td>@item.SettingsDependency</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("WebhookDeliveries")</h2>
                <p class="text-muted mb-0">@T.T("WebhookSupportPlaybooks")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Payments"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Payments", "Billing")"
                   hx-target="#billing-webhooks-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("PaymentsLabel")</a>
                <a asp-action="Refunds"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Refunds", "Billing")"
                   hx-target="#billing-webhooks-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("RefundQueueTitle")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("NeedsAttention")</div>
                        <span class="@WebhookOpsHealthBadgeClass(webhookAttentionCount == 0)">@WebhookOpsHealthBadgeText(webhookAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@webhookAttentionCount</div>
                    <div class="small text-muted">@T.T("Failed") / @T.T("RetryPending") / @T.T("DisputeSignals")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.Failed"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.Failed })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Failed")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.RetryPending"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.RetryPending })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RetryPending")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("PaymentExceptions")</div>
                        <span class="@WebhookOpsHealthBadgeClass(Model.Summary.PaymentExceptionCount == 0)">@WebhookOpsHealthBadgeText(Model.Summary.PaymentExceptionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.PaymentExceptionCount</div>
                    <div class="small text-muted">@T.T("NeedsReconciliation")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentExceptions")</a>
                        <a asp-action="Payments"
                           asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.NeedsReconciliation })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NeedsReconciliation")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("DisputeSignals")</div>
                        <span class="@WebhookOpsHealthBadgeClass(Model.Summary.DisputeSignalCount == 0)">@WebhookOpsHealthBadgeText(Model.Summary.DisputeSignalCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.DisputeSignalCount</div>
                    <div class="small text-muted">@T.T("DisputeQueue")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DisputeSignals")</a>
                        <a asp-action="Payments"
                           asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.DisputeFollowUp })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DisputeQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("PaymentSettings")</div>
                        <span class="@WebhookOpsHealthBadgeClass(Model.Summary.ActiveSubscriptionCount > 0)">@WebhookOpsHealthBadgeText(Model.Summary.ActiveSubscriptionCount > 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.ActiveSubscriptionCount</div>
                    <div class="small text-muted">@T.T("ActiveSubscriptions")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentSettings")</a>
                        <a asp-action="Refunds"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Refunds", "Billing")"
                           hx-target="#billing-webhooks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("RefundQueueTitle")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("ActiveWebhookSubscriptions")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("EventType")</th>
                        <th>@T.T("CallbackUrl")</th>
                        <th>@T.T("Status")</th>
                        <th>@T.T("Created")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Subscriptions.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted">@T.T("NoWebhookSubscriptionsFound")</td></tr>
                }
                else
                {
                    foreach (var item in Model.Subscriptions)
                    {
                        <tr>
                            <td class="fw-semibold">@item.EventType</td>
                            <td><code>@item.CallbackUrl</code></td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.IsActive ? T.T("Active") : T.T("Inactive"))
                                </span>
                            </td>
                            <td>@item.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Webhooks"
          method="get"
          class="d-flex gap-2"
          hx-get="@Url.Action("Webhooks", "Billing")"
          hx-target="#billing-webhooks-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchWebhookDeliveriesPlaceholder")">
        <select name="queue" class="form-select">
            <option value="@BillingWebhookDeliveryQueueFilter.All" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.All)">@T.T("AllDeliveries")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.Pending" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Pending)">@T.T("Pending")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.Failed" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Failed)">@T.T("Failed")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.Succeeded" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Succeeded)">@T.T("Succeeded")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.RetryPending" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.RetryPending)">@T.T("RetryPending")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.PaymentExceptions" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.PaymentExceptions)">@T.T("PaymentExceptions")</option>
            <option value="@BillingWebhookDeliveryQueueFilter.DisputeSignals" selected="@(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.DisputeSignals)">@T.T("DisputeSignals")</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> @T.T("Filter")</button>
        <a asp-action="Webhooks"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-webhooks-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <div class="d-flex gap-2">
        <a asp-action="Payments"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Payments", "Billing")"
           hx-target="#billing-webhooks-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-money-bill-wave"></i> @T.T("PaymentsLabel")
        </a>
        <a asp-controller="SiteSettings"
           asp-action="Edit"
           asp-fragment="site-settings-payments"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
           hx-target="#billing-webhooks-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-sliders"></i> @T.T("PaymentSettings")
        </a>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Webhooks"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.All ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("Webhooks", "Billing")"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("All")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.Pending"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Pending ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.Pending })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Pending")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.Failed"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Failed ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.Failed })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Failed")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.Succeeded"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.Succeeded ? "btn-success" : "btn-outline-success")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.Succeeded })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Succeeded")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.RetryPending"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.RetryPending ? "btn-danger" : "btn-outline-danger")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.RetryPending })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("RetryPending")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.PaymentExceptions ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("PaymentExceptions")</a>
    <a asp-action="Webhooks"
       asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
       class="btn btn-sm @(Model.QueueFilter == BillingWebhookDeliveryQueueFilter.DisputeSignals ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
       hx-target="#billing-webhooks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("DisputeSignals")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("EventType")</th>
                <th>@T.T("Callback")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Attempts")</th>
                <th>@T.T("Timeline")</th>
                <th>@T.T("Correlation")</th>
                <th>@T.T("FailureDiagnostics")</th>
                <th class="text-end">@T.T("OperatorFollowUp")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Deliveries.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted">@T.T("NoWebhookDeliveriesFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Deliveries)
            {
                var webhookIsDisputeSignal = item.EventType.Contains("dispute", StringComparison.OrdinalIgnoreCase) ||
                    item.EventType.Contains("charge.dispute", StringComparison.OrdinalIgnoreCase);
                var webhookHasPaymentEvidence = item.EventType.Contains("payment_intent", StringComparison.OrdinalIgnoreCase) ||
                    item.EventType.Contains("charge", StringComparison.OrdinalIgnoreCase) ||
                    item.EventType.Contains("refund", StringComparison.OrdinalIgnoreCase);
                var webhookNeedsRetryAttention = item.Status != "Succeeded" || item.RetryCount > 0;
                var webhookNeedsProviderCorrelationFollowUp = webhookHasPaymentEvidence &&
                    (item.FailureDiagnostics.Contains("provider", StringComparison.OrdinalIgnoreCase) ||
                     item.EscalationHint.Contains("provider", StringComparison.OrdinalIgnoreCase) ||
                     item.EscalationHint.Contains("reference", StringComparison.OrdinalIgnoreCase));
                var webhookNeedsPaymentReconciliationFollowUp = webhookHasPaymentEvidence &&
                    (item.Status == "Pending" ||
                     item.Status == "RetryPending" ||
                     item.FailureDiagnostics.Contains("reconciliation", StringComparison.OrdinalIgnoreCase));
                var webhookNeedsFailedPaymentFollowUp = webhookHasPaymentEvidence &&
                    (item.Status == "Failed" ||
                     item.FailureDiagnostics.Contains("failure", StringComparison.OrdinalIgnoreCase));
                var webhookNeedsTaxFollowUp = webhookHasPaymentEvidence &&
                    (item.FailureDiagnostics.Contains("tax", StringComparison.OrdinalIgnoreCase) ||
                     item.EscalationHint.Contains("tax", StringComparison.OrdinalIgnoreCase) ||
                     item.EventType.Contains("invoice", StringComparison.OrdinalIgnoreCase));
                var webhookNeedsRefundedInvoiceFollowUp =
                    item.EventType.Contains("refund", StringComparison.OrdinalIgnoreCase);
                var webhookNeedsVatInvoiceFollowUp = webhookNeedsTaxFollowUp &&
                    item.EventType.Contains("invoice", StringComparison.OrdinalIgnoreCase);

                <tr>
                    <td>
                        <div class="fw-semibold">@item.EventType</div>
                        @if (!item.IsActiveSubscription)
                        {
                            <div><span class="badge text-bg-secondary mt-1">@T.T("InactiveSubscription")</span></div>
                        }
                    </td>
                    <td><code>@item.CallbackUrl</code></td>
                    <td>
                        <span class="badge @(item.Status == "Succeeded" ? "bg-success" : item.Status == "Failed" ? "bg-danger" : "bg-warning text-dark")">@LocalizeWebhookStatus(item.Status)</span>
                        @if (webhookIsDisputeSignal)
                        {
                            <div><span class="badge text-bg-dark mt-1">@T.T("DisputeSignal")</span></div>
                        }
                        else if (webhookHasPaymentEvidence && webhookNeedsRetryAttention)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("PaymentException")</span></div>
                        }
                        @if (item.ResponseCode.HasValue)
                        {
                            <div class="small text-muted mt-1">@T.T("HttpStatusLabel") @item.ResponseCode</div>
                        }
                    </td>
                    <td>
                        <div>@item.RetryCount</div>
                        @if (item.RetryCount > 0)
                        {
                            <div class="small text-warning">@T.T("RetryPathUsed")</div>
                        }
                    </td>
                    <td>
                            <div class="small text-muted">@T.T("WebhookCreatedLabel") @item.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                            <div>@T.T("WebhookLastAttemptLabel") @(item.LastAttemptAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? "-")</div>
                    </td>
                    <td>
                        <div class="small text-muted">@T.T("SubscriptionLabel") @item.SubscriptionId</div>
                        <div class="small text-muted">@item.IdempotencyKey</div>
                        <div class="small mt-1">
                            <span class="badge text-bg-light">@LocalizeRetrySafetyState(item.RetrySafetyState)</span>
                        </div>
                        @if (webhookIsDisputeSignal)
                        {
                            <div class="small text-danger mt-1">@T.T("WebhookDisputeEscalationNote")</div>
                        }
                        else if (webhookHasPaymentEvidence)
                        {
                            <div class="small text-muted mt-1">@T.T("WebhookPaymentEvidenceNote")</div>
                        }
                    </td>
                    <td>
                        <div>@T.T(item.FailureDiagnostics)</div>
                        <div class="small text-muted mt-1">@T.T(item.EscalationHint)</div>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                            @if (item.SuggestedQueueTarget == "Payments")
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="NeedsReconciliation"
                                   class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = "NeedsReconciliation" })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @item.SuggestedOperatorAction
                                </a>
                            }
                            else if (item.SuggestedQueueTarget == "Refunds")
                            {
                                <a asp-action="Refunds"
                                   asp-route-queue="NeedsSupport"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Refunds", "Billing", new { queue = "NeedsSupport" })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @item.SuggestedOperatorAction
                                </a>
                            }
                            else if (item.SuggestedQueueTarget == "DisputeSignals")
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                                   class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.DisputeFollowUp })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @item.SuggestedOperatorAction
                                </a>
                            }
                            @if (webhookNeedsProviderCorrelationFollowUp || item.SuggestedQueueTarget == "Payments")
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="@PaymentQueueFilter.MissingProviderRef"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.MissingProviderRef })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("MissingProviderRef")
                                </a>
                            }
                            @if (webhookNeedsPaymentReconciliationFollowUp)
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.NeedsReconciliation })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("NeedsReconciliation")
                                </a>
                            }
                            @if (webhookNeedsFailedPaymentFollowUp)
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="@PaymentQueueFilter.Failed"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.Failed })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("Failed")
                                </a>
                            }
                            @if (webhookIsDisputeSignal)
                            {
                                <a asp-action="Payments"
                                   asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                                   class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("Payments", "Billing", new { queue = PaymentQueueFilter.DisputeFollowUp })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("DisputeQueue")
                                </a>
                            }
                            @if (webhookNeedsTaxFollowUp)
                            {
                                <a asp-action="TaxCompliance"
                                   class="btn btn-sm btn-outline-warning"
                                   hx-get="@Url.Action("TaxCompliance", "Billing")"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("TaxCompliance")
                                </a>
                            }
                            @if (webhookNeedsVatInvoiceFollowUp)
                            {
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="MissingVatId"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Invoices", "Crm", new { filter = "MissingVatId" })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("FixVatId")
                                </a>
                            }
                            @if (item.SuggestedQueueTarget == "Refunds" || item.EventType.Contains("refund", StringComparison.OrdinalIgnoreCase))
                            {
                                <a asp-action="Refunds"
                                   asp-route-queue="@BillingRefundQueueFilter.NeedsSupport"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Refunds", "Billing", new { queue = BillingRefundQueueFilter.NeedsSupport })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("RefundQueueTitle")
                                </a>
                            }
                            @if (webhookNeedsRefundedInvoiceFollowUp)
                            {
                                <a asp-controller="Crm"
                                   asp-action="Invoices"
                                   asp-route-filter="Refunded"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Invoices", "Crm", new { filter = "Refunded" })"
                                   hx-target="#billing-webhooks-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @T.T("Refunded")
                                </a>
                            }
                            <a asp-controller="SiteSettings"
                               asp-action="Edit"
                               asp-fragment="site-settings-payments"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
                               hx-target="#billing-webhooks-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                @T.T("PaymentSettings")
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="Webhooks" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter" hx-target="#billing-webhooks-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
