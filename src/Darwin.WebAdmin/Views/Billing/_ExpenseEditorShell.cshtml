@model Darwin.WebAdmin.ViewModels.Billing.ExpenseEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true;
    ViewData["Title"] = isCreate ? T.T("CreateExpense") : T.T("EditExpense");
}

<div id="billing-expense-editor-shell">
    <h1 class="mb-3">@(isCreate ? T.T("CreateExpense") : T.T("EditExpense"))</h1>

    <form asp-action="@(isCreate ? "CreateExpense" : "EditExpense")"
          method="post"
          hx-post="@Url.Action(isCreate ? "CreateExpense" : "EditExpense", "Billing")"
          hx-target="#billing-expense-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
        }
        <partial name="_ExpenseForm" model="Model" />
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            <a asp-action="Expenses"
               asp-route-businessId="@Model.BusinessId"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
               hx-target="#billing-expense-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Back")</a>
        </div>
    </form>
</div>
