@model Darwin.WebAdmin.ViewModels.Billing.ExpenseEditVm

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="BusinessId" class="form-label"></label>
        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="SupplierId" class="form-label"></label>
        <select asp-for="SupplierId" asp-items="Model.SupplierOptions" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="ExpenseDateUtc" class="form-label"></label>
        <input asp-for="ExpenseDateUtc" type="date" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Category" class="form-label"></label>
        <input asp-for="Category" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="AmountMinor" class="form-label"></label>
        <input asp-for="AmountMinor" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>
</div>
