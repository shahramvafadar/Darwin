@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.PaymentsListVm
@{
    ViewData["Title"] = "Payments";
}

<div id="billing-payments-workspace-shell">
<h1 class="mb-3">Payments</h1>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Stripe Phase-1 Readiness</span>
        <a asp-controller="SiteSettings"
           asp-action="Edit"
           asp-fragment="site-settings-payments"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">Open Payment Settings</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Enabled</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.Enabled ? "Yes" : "No")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Publishable Key</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.PublishableKeyConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Secret Key</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.SecretKeyConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Webhook Secret</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.WebhookSecretConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Merchant Identity</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.MerchantDisplayNameConfigured ? Model.Stripe.MerchantDisplayName : "Missing")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Tax & Invoicing Readiness</span>
        <a asp-controller="SiteSettings"
           asp-action="Edit"
           asp-fragment="site-settings-tax"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">Open Tax Settings</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">VAT Enabled</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.VatEnabled ? "Yes" : "No")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Default VAT</div>
                    <div class="fw-semibold mt-1">@Model.Tax.DefaultVatRatePercent.ToString("0.##")%</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Price Mode</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.PricesIncludeVat ? "VAT Inclusive" : "VAT Exclusive")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Reverse Charge</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.AllowReverseCharge ? "Allowed" : "Disabled")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Issuer</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.IssuerConfigured ? Model.Tax.InvoiceIssuerLegalName : "Missing")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Tax ID</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.InvoiceIssuerTaxIdConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
        </div>
        <div class="small text-muted mt-3">
            This is a phase-1 compliance surface for VAT defaults and invoice issuer identity. It improves billing support visibility without claiming full tax-engine, reverse-charge automation, or e-invoicing completion.
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Webhook Lifecycle Visibility</span>
        <a asp-action="Webhooks"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">Open Webhook Queue</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Active Subscriptions</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.ActiveSubscriptionCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Pending</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PendingDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Failed</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.FailedDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Succeeded</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.SucceededDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Retry Pending</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.RetryPendingCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Payment Exceptions</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PaymentExceptionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Dispute Signals</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.DisputeSignalCount</div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">Review Payment Exceptions</a>
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
               class="btn btn-sm btn-outline-dark"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">Review Dispute Signals</a>
        </div>
        <div class="small text-muted mt-3">
            This queue gives callback visibility for phase-1 payment operations. It is intentionally read-oriented and does not claim automated resend or reconciliation completion.
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Pending</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Refunded</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RefundedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Unlinked</div>
            <div class="fs-4 fw-semibold">@Model.Summary.UnlinkedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Provider-linked</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ProviderLinkedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Stripe</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Provider Ref</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingProviderRefCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Failed Stripe</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedStripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Needs Reconciliation</div>
            <div class="fs-4 fw-semibold">@Model.Summary.NeedsReconciliationCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Dispute Follow-up</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DisputeFollowUpCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Phase-1 Payment Support Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                        <th>Settings Dependency</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                        <td>@item.SettingsDependency</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Payments"
          method="get"
          class="d-flex gap-2"
          hx-get="@Url.Action("Payments", "Billing")"
          hx-target="#billing-payments-workspace-shell"
          hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search payments">
        <select name="queue" class="form-select">
            <option value="">All queues</option>
            <option value="@PaymentQueueFilter.Pending" selected="@(Model.QueueFilter == PaymentQueueFilter.Pending)">Pending</option>
            <option value="@PaymentQueueFilter.Failed" selected="@(Model.QueueFilter == PaymentQueueFilter.Failed)">Failed</option>
            <option value="@PaymentQueueFilter.Refunded" selected="@(Model.QueueFilter == PaymentQueueFilter.Refunded)">Refunded</option>
            <option value="@PaymentQueueFilter.Unlinked" selected="@(Model.QueueFilter == PaymentQueueFilter.Unlinked)">Unlinked</option>
            <option value="@PaymentQueueFilter.ProviderLinked" selected="@(Model.QueueFilter == PaymentQueueFilter.ProviderLinked)">Provider-linked</option>
            <option value="@PaymentQueueFilter.Stripe" selected="@(Model.QueueFilter == PaymentQueueFilter.Stripe)">Stripe</option>
            <option value="@PaymentQueueFilter.MissingProviderRef" selected="@(Model.QueueFilter == PaymentQueueFilter.MissingProviderRef)">Missing Provider Ref</option>
            <option value="@PaymentQueueFilter.FailedStripe" selected="@(Model.QueueFilter == PaymentQueueFilter.FailedStripe)">Failed Stripe</option>
            <option value="@PaymentQueueFilter.NeedsReconciliation" selected="@(Model.QueueFilter == PaymentQueueFilter.NeedsReconciliation)">Needs Reconciliation</option>
            <option value="@PaymentQueueFilter.DisputeFollowUp" selected="@(Model.QueueFilter == PaymentQueueFilter.DisputeFollowUp)">Dispute Follow-up</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> Filter</button>
        <a asp-action="Payments"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </form>
    <div class="d-flex gap-2">
        <a asp-action="Webhooks"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-broadcast-tower"></i> Webhook Queue
        </a>
        <a asp-action="Refunds"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-danger"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-rotate-left"></i> Refund Queue
        </a>
        <a asp-action="CreatePayment"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-primary"
           hx-get="@Url.Action("CreatePayment", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-plus"></i> Record Payment
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Provider</th><th>Order</th><th>Invoice</th><th>Amount</th><th>Customer</th><th>Timeline</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">No payments found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var missingProviderReference = string.IsNullOrWhiteSpace(item.ProviderTransactionRef);
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Provider</div>
                        <div class="small text-muted">@item.ProviderTransactionRef</div>
                        <div class="small text-muted">@item.ProviderReferenceState</div>
                        <span class="badge text-bg-light mt-1">@item.Status</span>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">Stripe</span></div>
                        }
                        @if (item.NeedsReconciliation)
                        {
                            <div><span class="badge text-bg-warning mt-1">Reconciliation</span></div>
                        }
                        @if (item.NeedsDisputeFollowUp)
                        {
                            <div><span class="badge text-bg-dark mt-1">Dispute follow-up</span></div>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <div><span class="badge text-bg-secondary mt-1">Needs support</span></div>
                        }
                    </td>
                    <td>
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="text-decoration-none"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">
                                @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (item.InvoiceId.HasValue)
                        {
                            <div><code>@item.InvoiceId</code></div>
                            @if (item.InvoiceStatus.HasValue)
                            {
                                <div class="small text-muted">@item.InvoiceStatus</div>
                            }
                            @if (item.InvoiceTotalGrossMinor.HasValue)
                            {
                                <div class="small text-muted">@item.Currency @((item.InvoiceTotalGrossMinor.Value / 100M).ToString("0.00"))</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <div>@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</div>
                        @if (item.RefundedAmountMinor > 0)
                        {
                            <div class="small text-warning">Refunded: @item.Currency @((item.RefundedAmountMinor / 100M).ToString("0.00"))</div>
                            <div class="small text-muted">@(item.NetCapturedAmountMinor == 0 ? "Fully refunded" : "Partially refunded")</div>
                        }
                        <div class="small text-muted">Net: @item.Currency @((item.NetCapturedAmountMinor / 100M).ToString("0.00"))</div>
                    </td>
                    <td>
                        @if (item.CustomerId.HasValue)
                        {
                            <div>
                                <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none"
                                   hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                        {
                            <div>@item.CustomerDisplayName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CustomerEmail))
                        {
                            <div class="small text-muted">@item.CustomerEmail</div>
                        }
                        @if (item.UserId.HasValue)
                        {
                            <div class="small">
                                <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId.Value" class="text-decoration-none"
                                   hx-get="@Url.Action("Edit", "Users", new { id = item.UserId.Value })"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.UserDisplayName) ? "Open linked user" : item.UserDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.UserDisplayName))
                        {
                            <div class="small text-muted">@item.UserDisplayName</div>
                        }
                    </td>
                    <td>
                        <div class="small text-muted">Created @item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="small text-muted">Opened @item.OpenAgeHours h</div>
                        @if (item.PaidAtUtc.HasValue)
                        {
                            <div>Paid @item.PaidAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        else
                        {
                            <div class="text-muted">Not paid yet</div>
                        }
                        @if (item.LastFinancialEventAtUtc.HasValue)
                        {
                            <div class="small text-muted">Last event @item.LastFinancialEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                        {
                            <div class="small text-danger mt-1">@item.FailureReason</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditPayment"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditPayment", "Billing", new { id = item.Id })"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">Edit</a>
                        @if (item.NeedsReconciliation)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue = PaymentQueueFilter.NeedsReconciliation })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Reconciliation Queue</a>
                        }
                        @if (item.IsStripe && (item.NeedsReconciliation || missingProviderReference))
                        {
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Webhook Exceptions</a>
                        }
                        @if (item.IsStripe && item.NeedsDisputeFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue = PaymentQueueFilter.DisputeFollowUp })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Dispute Queue</a>
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Dispute Signals</a>
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="AddRefund" asp-route-orderId="@item.OrderId.Value" asp-route-paymentId="@item.Id" class="btn btn-sm btn-outline-danger"
                               hx-get="@Url.Action("AddRefund", "Orders", new { orderId = item.OrderId.Value, paymentId = item.Id })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Refund</a>
                        }
                        @if (item.InvoiceId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditInvoice" asp-route-id="@item.InvoiceId.Value" class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("EditInvoice", "Crm", new { id = item.InvoiceId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Invoice</a>
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" asp-fragment="payments" class="btn btn-sm btn-outline-info"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Order</a>
                        }
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" asp-fragment="customer-interactions-section" class="btn btn-sm btn-outline-success"
                               hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">Customer</a>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

