@using Darwin.Application.Billing.DTOs
@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Billing.PaymentsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Payments");
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalBillingWebhooksUrl() => Url.Action("Webhooks", "Billing") ?? string.Empty;
    string PaymentSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" }) ?? string.Empty;
    string TaxSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" }) ?? string.Empty;
    string ScopedPaymentsIndexUrl() => Url.Action("Payments", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string ScopedPaymentsUrl(PaymentQueueFilter queue) => Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue }) ?? string.Empty;
    string ScopedRefundsIndexUrl() => Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string ScopedRefundsUrl(BillingRefundQueueFilter queue) => Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue }) ?? string.Empty;
    string CreatePaymentUrl() => Url.Action("CreatePayment", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string EditPaymentUrl(Guid id) => Url.Action("EditPayment", "Billing", new { id }) ?? string.Empty;
    string BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter queue) => Url.Action("Webhooks", "Billing", new { queue }) ?? string.Empty;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
    string AddRefundUrl(Guid orderId, Guid paymentId) => Url.Action("AddRefund", "Orders", new { orderId, paymentId }) ?? string.Empty;
    string CrmEditCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string CrmEditInvoiceUrl(Guid id) => Url.Action("EditInvoice", "Crm", new { id }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string UserEditUrl(Guid id) => Url.Action("Edit", "Users", new { id }) ?? string.Empty;
    string LocalizePaymentStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeProviderReferenceState(string? state) => state switch
    {
        "Stripe ref missing" => T.T("BillingProviderStripeRefMissing"),
        "Reference missing" => T.T("BillingProviderReferenceMissing"),
        "Refund activity recorded" => T.T("BillingProviderRefundActivityRecorded"),
        "Waiting for provider completion" => T.T("BillingProviderWaitingForCompletion"),
        "Authorized on provider" => T.T("BillingProviderAuthorized"),
        "Captured on provider" => T.T("BillingProviderCaptured"),
        "Completed on provider" => T.T("BillingProviderCompleted"),
        "Provider failure recorded" => T.T("BillingProviderFailureRecorded"),
        "Refunded against provider ref" => T.T("BillingProviderRefundedAgainstReference"),
        "Voided on provider" => T.T("BillingProviderVoided"),
        "Provider reference linked" => T.T("BillingProviderReferenceLinked"),
        _ => string.IsNullOrWhiteSpace(state) ? "-" : T.T(state)
    };
    string PaymentOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string PaymentOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var paymentAttentionCount = Model.Summary.FailedCount
        + Model.Summary.MissingProviderRefCount
        + Model.Summary.NeedsReconciliationCount
        + Model.Summary.DisputeFollowUpCount;
}

<div id="billing-payments-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3">@T.T("Payments")</h1>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("StripeReadiness")</span>
        <a asp-controller="SiteSettings"
           asp-action="Edit"
           asp-fragment="site-settings-payments"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@PaymentSettingsUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">@T.T("OpenPaymentSettings")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Enabled")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.Enabled ? T.T("Yes") : T.T("No"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PublishableKey")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.PublishableKeyConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("SecretKey")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.SecretKeyConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("WebhookSecret")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.WebhookSecretConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("MerchantIdentity")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.MerchantDisplayNameConfigured ? Model.Stripe.MerchantDisplayName : T.T("Missing"))</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxInvoicingReadiness")</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="TaxCompliance"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@GlobalTaxComplianceUrl()"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenTaxCompliance")</a>
            <a asp-controller="SiteSettings"
               asp-action="Edit"
               asp-fragment="site-settings-tax"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@TaxSettingsUrl()"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("OpenTaxSettings")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("VatEnabled")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.VatEnabled ? T.T("Yes") : T.T("No"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DefaultVat")</div>
                    <div class="fw-semibold mt-1">@Model.Tax.DefaultVatRatePercent.ToString("0.##")%</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PriceMode")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.PricesIncludeVat ? T.T("VatInclusive") : T.T("VatExclusive"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ReverseCharge")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Issuer")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.IssuerConfigured ? Model.Tax.InvoiceIssuerLegalName : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("TaxId")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.InvoiceIssuerTaxIdConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
        </div>
        <div class="small text-muted mt-3">@T.T("BillingTaxReadinessNote")</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("WebhookLifecycleVisibility")</span>
        <a asp-action="Webhooks"
           class="btn btn-sm btn-outline-secondary"
                               hx-get="@GlobalBillingWebhooksUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">@T.T("OpenWebhookQueue")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ActiveSubscriptions")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.ActiveSubscriptionCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Pending")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PendingDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Failed")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.FailedDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Succeeded")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.SucceededDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RetryPending")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.RetryPendingCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PaymentExceptions")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PaymentExceptionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DisputeSignals")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.DisputeSignalCount</div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
               class="btn btn-sm btn-outline-warning"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("ReviewPaymentExceptions")</a>
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
               class="btn btn-sm btn-outline-dark"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("ReviewDisputeSignals")</a>
        </div>
        <div class="small text-muted mt-3">@T.T("BillingWebhookLifecycleNote")</div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Pending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Failed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Refunded")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RefundedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Unlinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.UnlinkedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ProviderLinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ProviderLinkedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Stripe")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingProviderRef")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingProviderRefCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("FailedStripe")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedStripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("NeedsReconciliation")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.NeedsReconciliationCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("DisputeFollowUp")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DisputeFollowUpCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("PaymentSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@T.T(item.Title)</td>
                        <td>@T.T(item.ScopeNote)</td>
                        <td>@T.T(item.OperatorAction)</td>
                        <td>@T.T(item.SettingsDependency)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("Payments")</h2>
                <p class="text-muted mb-0">@T.T("PaymentSupportPlaybooks")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Refunds"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@ScopedRefundsIndexUrl()"
                   hx-target="#billing-payments-workspace-shell"
                   hx-swap="outerHTML">@T.T("RefundQueueTitle")</a>
                <a asp-action="Webhooks"
                   class="btn btn-sm btn-outline-secondary"
                                       hx-get="@GlobalBillingWebhooksUrl()"
                   hx-target="#billing-payments-workspace-shell"
                   hx-swap="outerHTML">@T.T("WebhookQueue")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("NeedsAttention")</div>
                        <span class="@PaymentOpsHealthBadgeClass(paymentAttentionCount == 0)">@PaymentOpsHealthBadgeText(paymentAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@paymentAttentionCount</div>
                    <div class="small text-muted">@T.T("NeedsReconciliation") / @T.T("DisputeFollowUp")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("NeedsReconciliation")</a>
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("DisputeFollowUp")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("MissingProviderRef")</div>
                        <span class="@PaymentOpsHealthBadgeClass(Model.Summary.MissingProviderRefCount == 0)">@PaymentOpsHealthBadgeText(Model.Summary.MissingProviderRefCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.MissingProviderRefCount</div>
                    <div class="small text-muted">@T.T("WebhookExceptions")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.MissingProviderRef"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.MissingProviderRef)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("MissingProviderRef")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("WebhookExceptions")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("Failed")</div>
                        <span class="@PaymentOpsHealthBadgeClass(Model.Summary.FailedCount == 0)">@PaymentOpsHealthBadgeText(Model.Summary.FailedCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
                    <div class="small text-muted">@T.T("ReviewPaymentExceptions")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.Failed"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Failed)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("Failed")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("ReviewPaymentExceptions")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("ProviderLinked")</div>
                        <span class="@PaymentOpsHealthBadgeClass(Model.Summary.ProviderLinkedCount > 0)">@PaymentOpsHealthBadgeText(Model.Summary.ProviderLinkedCount > 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.ProviderLinkedCount</div>
                    <div class="small text-muted">@T.T("OpenTaxCompliance")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.ProviderLinked"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.ProviderLinked)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("ProviderLinked")</a>
                        <a asp-action="TaxCompliance"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalTaxComplianceUrl()"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("OpenTaxCompliance")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Payments"
          method="get"
          class="d-flex gap-2"
          hx-get="@GlobalPaymentsUrl()"
          hx-target="#billing-payments-workspace-shell"
          hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchPaymentsPlaceholder")">
        <select name="queue" class="form-select">
            <option value="">@T.T("AllQueues")</option>
            <option value="@PaymentQueueFilter.Pending" selected="@(Model.QueueFilter == PaymentQueueFilter.Pending)">@T.T("Pending")</option>
            <option value="@PaymentQueueFilter.Failed" selected="@(Model.QueueFilter == PaymentQueueFilter.Failed)">@T.T("Failed")</option>
            <option value="@PaymentQueueFilter.Refunded" selected="@(Model.QueueFilter == PaymentQueueFilter.Refunded)">@T.T("Refunded")</option>
            <option value="@PaymentQueueFilter.Unlinked" selected="@(Model.QueueFilter == PaymentQueueFilter.Unlinked)">@T.T("Unlinked")</option>
            <option value="@PaymentQueueFilter.ProviderLinked" selected="@(Model.QueueFilter == PaymentQueueFilter.ProviderLinked)">@T.T("ProviderLinked")</option>
            <option value="@PaymentQueueFilter.Stripe" selected="@(Model.QueueFilter == PaymentQueueFilter.Stripe)">@T.T("Stripe")</option>
            <option value="@PaymentQueueFilter.MissingProviderRef" selected="@(Model.QueueFilter == PaymentQueueFilter.MissingProviderRef)">@T.T("MissingProviderRef")</option>
            <option value="@PaymentQueueFilter.FailedStripe" selected="@(Model.QueueFilter == PaymentQueueFilter.FailedStripe)">@T.T("FailedStripe")</option>
            <option value="@PaymentQueueFilter.NeedsReconciliation" selected="@(Model.QueueFilter == PaymentQueueFilter.NeedsReconciliation)">@T.T("NeedsReconciliation")</option>
            <option value="@PaymentQueueFilter.DisputeFollowUp" selected="@(Model.QueueFilter == PaymentQueueFilter.DisputeFollowUp)">@T.T("DisputeFollowUp")</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> @T.T("Filter")</button>
        <a asp-action="Payments"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
                           hx-get="@ScopedPaymentsIndexUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">@T.T("Reset")</a>
    </form>
    <div class="d-flex gap-2">
        <a asp-action="Webhooks"
           class="btn btn-outline-secondary"
                                           hx-get="@GlobalBillingWebhooksUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-broadcast-tower"></i> @T.T("WebhookQueue")
        </a>
        <a asp-action="Refunds"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-danger"
                           hx-get="@ScopedRefundsIndexUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-rotate-left"></i> @T.T("RefundQueueTitle")
        </a>
        <a asp-action="CreatePayment"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-primary"
           hx-get="@CreatePaymentUrl()"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-plus"></i> @T.T("RecordPayment")
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("Provider")</th><th>@T.T("Order")</th><th>@T.T("Invoice")</th><th>@T.T("Amount")</th><th>@T.T("Customer")</th><th>@T.T("Timeline")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">@T.T("NoPaymentsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var missingProviderReference =
                    string.IsNullOrWhiteSpace(item.ProviderTransactionRef) &&
                    string.IsNullOrWhiteSpace(item.ProviderPaymentIntentRef) &&
                    string.IsNullOrWhiteSpace(item.ProviderCheckoutSessionRef);
                var paymentNeedsWebhookEvidence = item.IsStripe && (item.NeedsReconciliation || missingProviderReference || item.NeedsDisputeFollowUp);
                var paymentHasRefundPressure = item.RefundedAmountMinor > 0 || item.Status.ToString() == "Refunded";
                var paymentNeedsTaxFollowUp =
                    item.InvoiceId.HasValue &&
                    (item.NeedsReconciliation || item.ProviderReferenceState.Contains("Provider", StringComparison.OrdinalIgnoreCase));
                var paymentInvoiceStatus = item.InvoiceStatus?.ToString();
                var paymentNeedsOverdueInvoiceFollowUp = item.InvoiceId.HasValue && string.Equals(paymentInvoiceStatus, "Overdue", StringComparison.OrdinalIgnoreCase);
                var paymentNeedsDueSoonInvoiceFollowUp = item.InvoiceId.HasValue && string.Equals(paymentInvoiceStatus, "DueSoon", StringComparison.OrdinalIgnoreCase);
                var paymentNeedsDraftInvoiceFollowUp = item.InvoiceId.HasValue && string.Equals(paymentInvoiceStatus, "Draft", StringComparison.OrdinalIgnoreCase);
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Provider</div>
                        @if (!string.IsNullOrWhiteSpace(item.ProviderTransactionRef))
                        {
                            <div class="small text-muted">@T.T("ProviderRef"): @item.ProviderTransactionRef</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ProviderPaymentIntentRef))
                        {
                            <div class="small text-muted">@T.T("ProviderPaymentIntentRef"): @item.ProviderPaymentIntentRef</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ProviderCheckoutSessionRef))
                        {
                            <div class="small text-muted">@T.T("ProviderCheckoutSessionRef"): @item.ProviderCheckoutSessionRef</div>
                        }
                        <div class="small text-muted">@LocalizeProviderReferenceState(item.ProviderReferenceState)</div>
                        <span class="badge text-bg-light mt-1">@LocalizePaymentStatus(item.Status)</span>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("Stripe")</span></div>
                        }
                        @if (item.NeedsReconciliation)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("Reconciliation")</span></div>
                        }
                        @if (item.NeedsDisputeFollowUp)
                        {
                            <div><span class="badge text-bg-dark mt-1">@T.T("DisputeFollowUp")</span></div>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <div><span class="badge text-bg-secondary mt-1">@T.T("NeedsSupport")</span></div>
                        }
                    </td>
                    <td>
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="text-decoration-none"
                               hx-get="@OrderDetailsUrl(item.OrderId.Value)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">
                                @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (item.InvoiceId.HasValue)
                        {
                            <div><code>@item.InvoiceId</code></div>
                            @if (item.InvoiceStatus.HasValue)
                            {
                                <div class="small text-muted">@LocalizeInvoiceStatus(item.InvoiceStatus)</div>
                            }
                            @if (item.InvoiceTotalGrossMinor.HasValue)
                            {
                                <div class="small text-muted">@item.Currency @((item.InvoiceTotalGrossMinor.Value / 100M).ToString("0.00"))</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <div>@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</div>
                        @if (item.RefundedAmountMinor > 0)
                        {
                            <div class="small text-warning">@T.T("Refunded"): @item.Currency @((item.RefundedAmountMinor / 100M).ToString("0.00"))</div>
                            <div class="small text-muted">@(item.NetCapturedAmountMinor == 0 ? T.T("FullyRefunded") : T.T("PartiallyRefunded"))</div>
                        }
                        <div class="small text-muted">@T.T("Net"): @item.Currency @((item.NetCapturedAmountMinor / 100M).ToString("0.00"))</div>
                    </td>
                    <td>
                        @if (item.CustomerId.HasValue)
                        {
                            <div>
                                <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none"
                                   hx-get="@CrmEditCustomerUrl(item.CustomerId.Value)"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                        {
                            <div>@item.CustomerDisplayName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CustomerEmail))
                        {
                            <div class="small text-muted">@item.CustomerEmail</div>
                        }
                        @if (item.UserId.HasValue)
                        {
                            <div class="small">
                                <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId.Value" class="text-decoration-none"
                                   hx-get="@UserEditUrl(item.UserId.Value)"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.UserDisplayName) ? T.T("OpenLinkedUser") : item.UserDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.UserDisplayName))
                        {
                            <div class="small text-muted">@item.UserDisplayName</div>
                        }
                    </td>
                    <td>
                        <div class="small text-muted">@T.T("Created") @item.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        <div class="small text-muted">@T.T("Opened") @item.OpenAgeHours h</div>
                        @if (item.PaidAtUtc.HasValue)
                        {
                            <div>@T.T("Paid") @item.PaidAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        }
                        else
                        {
                            <div class="text-muted">@T.T("NotPaidYet")</div>
                        }
                        @if (item.LastFinancialEventAtUtc.HasValue)
                        {
                            <div class="small text-muted">@T.T("LastEvent") @item.LastFinancialEventAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                        {
                            <div class="small text-danger mt-1">@item.FailureReason</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditPayment"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditPaymentUrl(item.Id)"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("Edit")</a>
                        @if (missingProviderReference)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.MissingProviderRef"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.MissingProviderRef)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("MissingProviderRef")</a>
                        }
                        @if (item.NeedsReconciliation)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("ReconciliationQueue")</a>
                        }
                        @if (paymentNeedsWebhookEvidence)
                        {
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("WebhookExceptions")</a>
                        }
                        @if (item.IsStripe && item.NeedsDisputeFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("DisputeQueue")</a>
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("DisputeSignals")</a>
                        }
                        @if (paymentHasRefundPressure)
                        {
                            <a asp-action="Refunds"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@BillingRefundQueueFilter.NeedsSupport"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.NeedsSupport)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("RefundQueueTitle")</a>
                        }
                        @if (paymentNeedsTaxFollowUp)
                        {
                            <a asp-action="TaxCompliance"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@GlobalTaxComplianceUrl()"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("OpenTaxCompliance")</a>
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="AddRefund" asp-route-orderId="@item.OrderId.Value" asp-route-paymentId="@item.Id" class="btn btn-sm btn-outline-danger"
                               hx-get="@AddRefundUrl(item.OrderId.Value, item.Id)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Refund")</a>
                        }
                        @if (item.InvoiceId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditInvoice" asp-route-id="@item.InvoiceId.Value" class="btn btn-sm btn-outline-primary"
                               hx-get="@CrmEditInvoiceUrl(item.InvoiceId.Value)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Invoice")</a>
                            @if (paymentNeedsOverdueInvoiceFollowUp)
                            {
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Overdue" class="btn btn-sm btn-outline-warning"
                                   hx-get="@CrmInvoicesUrl("Overdue")"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">@T.T("Overdue")</a>
                            }
                            @if (paymentNeedsDueSoonInvoiceFollowUp)
                            {
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="DueSoon" class="btn btn-sm btn-outline-warning"
                                   hx-get="@CrmInvoicesUrl("DueSoon")"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">@T.T("DueSoon")</a>
                            }
                            @if (paymentNeedsDraftInvoiceFollowUp)
                            {
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Draft" class="btn btn-sm btn-outline-warning"
                                   hx-get="@CrmInvoicesUrl("Draft")"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">@T.T("Draft")</a>
                            }
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" asp-fragment="payments" class="btn btn-sm btn-outline-info"
                               hx-get="@OrderDetailsUrl(item.OrderId.Value)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Order")</a>
                        }
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" asp-fragment="customer-interactions-section" class="btn btn-sm btn-outline-success"
                               hx-get="@CrmEditCustomerUrl(item.CustomerId.Value)"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Customer")</a>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Pending" class="btn btn-sm btn-outline-warning"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Pending)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("Pending")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Failed" class="btn btn-sm btn-outline-danger"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Failed)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("Failed")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Refunded" class="btn btn-sm btn-outline-secondary"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Refunded)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("Refunded")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Unlinked" class="btn btn-sm btn-outline-dark"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Unlinked)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("Unlinked")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.ProviderLinked" class="btn btn-sm btn-outline-info"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.ProviderLinked)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("ProviderLinked")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.Stripe" class="btn btn-sm btn-outline-primary"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Stripe)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("Stripe")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.MissingProviderRef" class="btn btn-sm btn-outline-warning"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.MissingProviderRef)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("MissingProviderRef")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.FailedStripe" class="btn btn-sm btn-outline-danger"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.FailedStripe)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("FailedStripe")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.NeedsReconciliation" class="btn btn-sm btn-outline-warning"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("NeedsReconciliation")</a>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-queue="@PaymentQueueFilter.DisputeFollowUp" class="btn btn-sm btn-outline-dark"
       hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML">@T.T("DisputeFollowUp")</a>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter" hx-target="#billing-payments-workspace-shell" hx-swap="outerHTML"></pager>
</div>
