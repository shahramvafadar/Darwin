@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.PaymentsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Payments");
}

<div id="billing-payments-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3">@T.T("Payments")</h1>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("StripeReadiness")</span>
        <a asp-controller="SiteSettings"
           asp-action="Edit"
           asp-fragment="site-settings-payments"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-payments" })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">@T.T("OpenPaymentSettings")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Enabled")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.Enabled ? T.T("Yes") : T.T("No"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PublishableKey")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.PublishableKeyConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("SecretKey")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.SecretKeyConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("WebhookSecret")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.WebhookSecretConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("MerchantIdentity")</div>
                    <div class="fw-semibold mt-1">@(Model.Stripe.MerchantDisplayNameConfigured ? Model.Stripe.MerchantDisplayName : T.T("Missing"))</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxInvoicingReadiness")</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="TaxCompliance"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("TaxCompliance", "Billing")"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("OpenTaxCompliance")</a>
            <a asp-controller="SiteSettings"
               asp-action="Edit"
               asp-fragment="site-settings-tax"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("OpenTaxSettings")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("VatEnabled")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.VatEnabled ? T.T("Yes") : T.T("No"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DefaultVat")</div>
                    <div class="fw-semibold mt-1">@Model.Tax.DefaultVatRatePercent.ToString("0.##")%</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PriceMode")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.PricesIncludeVat ? T.T("VatInclusive") : T.T("VatExclusive"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ReverseCharge")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Issuer")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.IssuerConfigured ? Model.Tax.InvoiceIssuerLegalName : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("TaxId")</div>
                    <div class="fw-semibold mt-1">@(Model.Tax.InvoiceIssuerTaxIdConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
        </div>
        <div class="small text-muted mt-3">@T.T("BillingTaxReadinessNote")</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("WebhookLifecycleVisibility")</span>
        <a asp-action="Webhooks"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">@T.T("OpenWebhookQueue")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ActiveSubscriptions")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.ActiveSubscriptionCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Pending")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PendingDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Failed")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.FailedDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Succeeded")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.SucceededDeliveryCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RetryPending")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.RetryPendingCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PaymentExceptions")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.PaymentExceptionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DisputeSignals")</div>
                    <div class="fw-semibold mt-1">@Model.Webhooks.DisputeSignalCount</div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("ReviewPaymentExceptions")</a>
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
               class="btn btn-sm btn-outline-dark"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
               hx-target="#billing-payments-workspace-shell"
               hx-swap="outerHTML">@T.T("ReviewDisputeSignals")</a>
        </div>
        <div class="small text-muted mt-3">@T.T("BillingWebhookLifecycleNote")</div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Pending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Failed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Refunded")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RefundedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Unlinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.UnlinkedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ProviderLinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ProviderLinkedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Stripe")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingProviderRef")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingProviderRefCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("FailedStripe")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedStripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("NeedsReconciliation")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.NeedsReconciliationCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("DisputeFollowUp")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DisputeFollowUpCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("PaymentSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@T.T(item.Title)</td>
                        <td>@T.T(item.ScopeNote)</td>
                        <td>@T.T(item.OperatorAction)</td>
                        <td>@T.T(item.SettingsDependency)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Payments"
          method="get"
          class="d-flex gap-2"
          hx-get="@Url.Action("Payments", "Billing")"
          hx-target="#billing-payments-workspace-shell"
          hx-swap="outerHTML">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchPaymentsPlaceholder")">
        <select name="queue" class="form-select">
            <option value="">@T.T("AllQueues")</option>
            <option value="@PaymentQueueFilter.Pending" selected="@(Model.QueueFilter == PaymentQueueFilter.Pending)">@T.T("Pending")</option>
            <option value="@PaymentQueueFilter.Failed" selected="@(Model.QueueFilter == PaymentQueueFilter.Failed)">@T.T("Failed")</option>
            <option value="@PaymentQueueFilter.Refunded" selected="@(Model.QueueFilter == PaymentQueueFilter.Refunded)">@T.T("Refunded")</option>
            <option value="@PaymentQueueFilter.Unlinked" selected="@(Model.QueueFilter == PaymentQueueFilter.Unlinked)">@T.T("Unlinked")</option>
            <option value="@PaymentQueueFilter.ProviderLinked" selected="@(Model.QueueFilter == PaymentQueueFilter.ProviderLinked)">@T.T("ProviderLinked")</option>
            <option value="@PaymentQueueFilter.Stripe" selected="@(Model.QueueFilter == PaymentQueueFilter.Stripe)">@T.T("Stripe")</option>
            <option value="@PaymentQueueFilter.MissingProviderRef" selected="@(Model.QueueFilter == PaymentQueueFilter.MissingProviderRef)">@T.T("MissingProviderRef")</option>
            <option value="@PaymentQueueFilter.FailedStripe" selected="@(Model.QueueFilter == PaymentQueueFilter.FailedStripe)">@T.T("FailedStripe")</option>
            <option value="@PaymentQueueFilter.NeedsReconciliation" selected="@(Model.QueueFilter == PaymentQueueFilter.NeedsReconciliation)">@T.T("NeedsReconciliation")</option>
            <option value="@PaymentQueueFilter.DisputeFollowUp" selected="@(Model.QueueFilter == PaymentQueueFilter.DisputeFollowUp)">@T.T("DisputeFollowUp")</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit"><i class="fa fa-filter"></i> @T.T("Filter")</button>
        <a asp-action="Payments"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">Reset</a>
    </form>
    <div class="d-flex gap-2">
        <a asp-action="Webhooks"
           class="btn btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-broadcast-tower"></i> @T.T("WebhookQueue")
        </a>
        <a asp-action="Refunds"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-outline-danger"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-rotate-left"></i> @T.T("RefundQueueTitle")
        </a>
        <a asp-action="CreatePayment"
           asp-route-businessId="@Model.BusinessId"
           class="btn btn-primary"
           hx-get="@Url.Action("CreatePayment", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-payments-workspace-shell"
           hx-swap="outerHTML">
            <i class="fa fa-plus"></i> @T.T("RecordPayment")
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("Provider")</th><th>@T.T("Order")</th><th>@T.T("Invoice")</th><th>@T.T("Amount")</th><th>@T.T("Customer")</th><th>@T.T("Timeline")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">@T.T("NoPaymentsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var missingProviderReference = string.IsNullOrWhiteSpace(item.ProviderTransactionRef);
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Provider</div>
                        <div class="small text-muted">@item.ProviderTransactionRef</div>
                        <div class="small text-muted">@item.ProviderReferenceState</div>
                        <span class="badge text-bg-light mt-1">@item.Status</span>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("Stripe")</span></div>
                        }
                        @if (item.NeedsReconciliation)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("Reconciliation")</span></div>
                        }
                        @if (item.NeedsDisputeFollowUp)
                        {
                            <div><span class="badge text-bg-dark mt-1">@T.T("DisputeFollowUp")</span></div>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <div><span class="badge text-bg-secondary mt-1">@T.T("NeedsSupport")</span></div>
                        }
                    </td>
                    <td>
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" class="text-decoration-none"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">
                                @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.Value.ToString() : item.OrderNumber)
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (item.InvoiceId.HasValue)
                        {
                            <div><code>@item.InvoiceId</code></div>
                            @if (item.InvoiceStatus.HasValue)
                            {
                                <div class="small text-muted">@item.InvoiceStatus</div>
                            }
                            @if (item.InvoiceTotalGrossMinor.HasValue)
                            {
                                <div class="small text-muted">@item.Currency @((item.InvoiceTotalGrossMinor.Value / 100M).ToString("0.00"))</div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <div>@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</div>
                        @if (item.RefundedAmountMinor > 0)
                        {
                            <div class="small text-warning">@T.T("Refunded"): @item.Currency @((item.RefundedAmountMinor / 100M).ToString("0.00"))</div>
                            <div class="small text-muted">@(item.NetCapturedAmountMinor == 0 ? T.T("FullyRefunded") : T.T("PartiallyRefunded"))</div>
                        }
                        <div class="small text-muted">@T.T("Net"): @item.Currency @((item.NetCapturedAmountMinor / 100M).ToString("0.00"))</div>
                    </td>
                    <td>
                        @if (item.CustomerId.HasValue)
                        {
                            <div>
                                <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none"
                                   hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                        {
                            <div>@item.CustomerDisplayName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CustomerEmail))
                        {
                            <div class="small text-muted">@item.CustomerEmail</div>
                        }
                        @if (item.UserId.HasValue)
                        {
                            <div class="small">
                                <a asp-controller="Users" asp-action="Edit" asp-route-id="@item.UserId.Value" class="text-decoration-none"
                                   hx-get="@Url.Action("Edit", "Users", new { id = item.UserId.Value })"
                                   hx-target="#billing-payments-workspace-shell"
                                   hx-swap="outerHTML">
                                    @(string.IsNullOrWhiteSpace(item.UserDisplayName) ? T.T("OpenLinkedUser") : item.UserDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.UserDisplayName))
                        {
                            <div class="small text-muted">@item.UserDisplayName</div>
                        }
                    </td>
                    <td>
                        <div class="small text-muted">@T.T("Created") @item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="small text-muted">@T.T("Opened") @item.OpenAgeHours h</div>
                        @if (item.PaidAtUtc.HasValue)
                        {
                            <div>@T.T("Paid") @item.PaidAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        else
                        {
                            <div class="text-muted">@T.T("NotPaidYet")</div>
                        }
                        @if (item.LastFinancialEventAtUtc.HasValue)
                        {
                            <div class="small text-muted">@T.T("LastEvent") @item.LastFinancialEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                        {
                            <div class="small text-danger mt-1">@item.FailureReason</div>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditPayment"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditPayment", "Billing", new { id = item.Id })"
                           hx-target="#billing-payments-workspace-shell"
                           hx-swap="outerHTML">@T.T("Edit")</a>
                        @if (item.NeedsReconciliation)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue = PaymentQueueFilter.NeedsReconciliation })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("ReconciliationQueue")</a>
                        }
                        @if (item.IsStripe && (item.NeedsReconciliation || missingProviderReference))
                        {
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("WebhookExceptions")</a>
                        }
                        @if (item.IsStripe && item.NeedsDisputeFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue = PaymentQueueFilter.DisputeFollowUp })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("DisputeQueue")</a>
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("DisputeSignals")</a>
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="AddRefund" asp-route-orderId="@item.OrderId.Value" asp-route-paymentId="@item.Id" class="btn btn-sm btn-outline-danger"
                               hx-get="@Url.Action("AddRefund", "Orders", new { orderId = item.OrderId.Value, paymentId = item.Id })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Refund")</a>
                        }
                        @if (item.InvoiceId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditInvoice" asp-route-id="@item.InvoiceId.Value" class="btn btn-sm btn-outline-primary"
                               hx-get="@Url.Action("EditInvoice", "Crm", new { id = item.InvoiceId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Invoice")</a>
                        }
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId.Value" asp-fragment="payments" class="btn btn-sm btn-outline-info"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Order")</a>
                        }
                        @if (item.CustomerId.HasValue)
                        {
                            <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" asp-fragment="customer-interactions-section" class="btn btn-sm btn-outline-success"
                               hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                               hx-target="#billing-payments-workspace-shell"
                               hx-swap="outerHTML">@T.T("Customer")</a>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

