@model Darwin.WebAdmin.ViewModels.Billing.BillingPlanEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (ViewData["IsCreate"] as bool?) ?? false;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@(isCreate ? T.T("BillingPlanEditorCreateTitle") : T.T("BillingPlanEditorEditTitle"))</h1>
        <p class="text-muted mb-0">@T.T("BillingPlansIntro")</p>
    </div>
    <a asp-action="Plans" class="btn btn-outline-secondary"
       hx-get="@Url.Action("Plans", "Billing")"
       hx-target="#billing-plan-editor-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa-solid fa-arrow-left"></i> @T.T("BillingPlanEditorBackToPlans")
    </a>
</div>

@if (!isCreate)
{
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("BillingPlanEditorActiveSubscriptions")</div>
                <div class="fw-semibold mt-1">@Model.ActiveSubscriptionCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("CommonStatus")</div>
                <div class="fw-semibold mt-1">@(Model.IsActive ? T.T("BillingPlansActive") : T.T("BillingPlansInactive"))</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">@T.T("BillingPlansTrial")</div>
                <div class="fw-semibold mt-1">@(Model.TrialDays.HasValue ? string.Format(T.T("BillingPlansTrialDays"), Model.TrialDays.Value) : T.T("BillingPlanEditorNoTrial"))</div>
            </div>
        </div>
    </div>
}

<partial name="_BillingPlanForm" model="Model" />
