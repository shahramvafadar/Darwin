@model Darwin.WebAdmin.ViewModels.Billing.BillingPlanEditVm
@{
    var isCreate = (ViewData["IsCreate"] as bool?) ?? false;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@(isCreate ? "Create Billing Plan" : "Edit Billing Plan")</h1>
        <p class="text-muted mb-0">Manage the subscription plan catalog that powers business billing handoff.</p>
    </div>
    <a asp-action="Plans" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left"></i> Back to Plans
    </a>
</div>

@if (!isCreate)
{
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">Active subscriptions</div>
                <div class="fw-semibold mt-1">@Model.ActiveSubscriptionCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">Status</div>
                <div class="fw-semibold mt-1">@(Model.IsActive ? "Active" : "Inactive")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border rounded p-3 h-100">
                <div class="text-muted small text-uppercase">Trial</div>
                <div class="fw-semibold mt-1">@(Model.TrialDays.HasValue ? $"{Model.TrialDays} days" : "No trial")</div>
            </div>
        </div>
    </div>
}

<partial name="_BillingPlanForm" model="Model" />
