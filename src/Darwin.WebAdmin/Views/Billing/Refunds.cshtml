@using Darwin.Application.Billing.DTOs
@using System.Globalization
@model Darwin.WebAdmin.ViewModels.Billing.RefundsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("RefundQueueTitle");
    string GlobalRefundsUrl() => Url.Action("Refunds", "Billing") ?? string.Empty;
    string GlobalTaxComplianceUrl() => Url.Action("TaxCompliance", "Billing") ?? string.Empty;
    string GlobalBillingWebhooksUrl() => Url.Action("Webhooks", "Billing") ?? string.Empty;
    string ScopedRefundsIndexUrl() => Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string ScopedRefundsUrl(BillingRefundQueueFilter queue) => Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue }) ?? string.Empty;
    string ScopedPaymentsIndexUrl() => Url.Action("Payments", "Billing", new { businessId = Model.BusinessId }) ?? string.Empty;
    string ScopedPaymentsUrl(PaymentQueueFilter queue) => Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue }) ?? string.Empty;
    string BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter queue) => Url.Action("Webhooks", "Billing", new { queue }) ?? string.Empty;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
    string CrmEditCustomerUrl(Guid id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string EditPaymentUrl(Guid id) => Url.Action("EditPayment", "Billing", new { id }) ?? string.Empty;
    string CrmInvoicesUrl(Guid? q, string filter) => Url.Action("Invoices", "Crm", new { q, filter }) ?? string.Empty;
    string LocalizeRefundStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizePaymentStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeProviderReferenceState(string? state) => state switch
    {
        "Stripe ref missing" => T.T("BillingProviderStripeRefMissing"),
        "Reference missing" => T.T("BillingProviderReferenceMissing"),
        "Waiting for provider refund completion" => T.T("BillingProviderWaitingForRefundCompletion"),
        "Refund recorded against provider ref" => T.T("BillingProviderRefundRecordedAgainstReference"),
        "Provider-side refund failure needs review" => T.T("BillingProviderRefundFailureNeedsReview"),
        "Payment fully refunded on provider" => T.T("BillingProviderPaymentFullyRefunded"),
        "Provider reference linked" => T.T("BillingProviderReferenceLinked"),
        _ => string.IsNullOrWhiteSpace(state) ? "-" : T.T(state)
    };
    string RefundOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string RefundOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var refundAttentionCount = Model.Summary.PendingCount + Model.Summary.FailedCount + Model.Summary.NeedsSupportCount;
}

<div id="billing-refunds-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("RefundQueueTitle")</h1>
        <p class="text-muted mb-0">@T.T("RefundQueueIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Pending" class="btn btn-outline-warning btn-sm"
           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Pending)" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Pending")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Completed" class="btn btn-outline-success btn-sm"
           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Completed)" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Completed")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Failed" class="btn btn-outline-danger btn-sm"
           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Failed)" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Failed")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Stripe" class="btn btn-outline-primary btn-sm"
           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Stripe)" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Stripe")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.NeedsSupport" class="btn btn-outline-danger btn-sm"
           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.NeedsSupport)" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("NeedsSupport")</a>
        <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary btn-sm"
           hx-get="@ScopedPaymentsIndexUrl()" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("BackToPayments")</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("WebhookAnomalyVisibility")</span>
        <a asp-action="Webhooks"
           class="btn btn-sm btn-outline-secondary"
       hx-get="@GlobalBillingWebhooksUrl()"
           hx-target="#billing-refunds-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenWebhookQueue")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PaymentExceptions")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.PaymentExceptionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DisputeSignals")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.DisputeSignalCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RetryPending")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.RetryPendingCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("FailedDeliveries")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.FailedDeliveryCount</div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
               class="btn btn-sm btn-outline-warning"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
               hx-target="#billing-refunds-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("ReviewPaymentExceptions")</a>
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
               class="btn btn-sm btn-outline-dark"
               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
               hx-target="#billing-refunds-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("ReviewDisputeSignals")</a>
        </div>
        <div class="small text-muted mt-3">
            @T.T("RefundWebhookTriageNote")
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Pending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Completed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.CompletedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Failed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("StripeLinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("NeedsSupport")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.NeedsSupportCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("RefundSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@T.T(item.Title)</td>
                        <td>@T.T(item.ScopeNote)</td>
                        <td>@T.T(item.OperatorAction)</td>
                        <td>@T.T(item.SettingsDependency)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("RefundQueueTitle")</h2>
                <p class="text-muted mb-0">@T.T("RefundQueueIntro")</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Payments"
                   asp-route-businessId="@Model.BusinessId"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@ScopedPaymentsIndexUrl()"
                   hx-target="#billing-refunds-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenPayments")</a>
                <a asp-action="Webhooks"
                   class="btn btn-sm btn-outline-secondary"
                                           hx-get="@GlobalBillingWebhooksUrl()"
                   hx-target="#billing-refunds-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("WebhookQueue")</a>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("NeedsAttention")</div>
                        <span class="@RefundOpsHealthBadgeClass(refundAttentionCount == 0)">@RefundOpsHealthBadgeText(refundAttentionCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@refundAttentionCount</div>
                    <div class="small text-muted">@T.T("Pending") / @T.T("Failed") / @T.T("NeedsSupport")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Refunds"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@BillingRefundQueueFilter.NeedsSupport"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.NeedsSupport)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("NeedsSupport")</a>
                        <a asp-action="Refunds"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@BillingRefundQueueFilter.Pending"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Pending)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Pending")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("Failed")</div>
                        <span class="@RefundOpsHealthBadgeClass(Model.Summary.FailedCount == 0)">@RefundOpsHealthBadgeText(Model.Summary.FailedCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
                    <div class="small text-muted">@T.T("ReviewPaymentExceptions")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Refunds"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@BillingRefundQueueFilter.Failed"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Failed)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Failed")</a>
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReviewPaymentExceptions")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("DisputeSignals")</div>
                        <span class="@RefundOpsHealthBadgeClass(Model.Webhooks.DisputeSignalCount == 0)">@RefundOpsHealthBadgeText(Model.Webhooks.DisputeSignalCount == 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.DisputeSignalCount</div>
                    <div class="small text-muted">@T.T("DisputeQueue")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Webhooks"
                           asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.DisputeSignals)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReviewDisputeSignals")</a>
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                           class="btn btn-sm btn-outline-dark"
                           hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DisputeQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="border rounded p-3 h-100 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="text-muted small">@T.T("StripeLinked")</div>
                        <span class="@RefundOpsHealthBadgeClass(Model.Summary.StripeCount > 0)">@RefundOpsHealthBadgeText(Model.Summary.StripeCount > 0)</span>
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
                    <div class="small text-muted">@T.T("OpenPayments")</div>
                    <div class="d-flex gap-2 flex-wrap mt-auto">
                        <a asp-action="Refunds"
                           asp-route-businessId="@Model.BusinessId"
                           asp-route-queue="@BillingRefundQueueFilter.Stripe"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.Stripe)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Stripe")</a>
                        <a asp-action="Payments"
                           asp-route-businessId="@Model.BusinessId"
                           class="btn btn-sm btn-outline-secondary"
                            hx-get="@ScopedPaymentsIndexUrl()"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenPayments")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Refunds" method="get" class="d-flex gap-2"
          hx-get="@GlobalRefundsUrl()"
          hx-target="#billing-refunds-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchRefundsPlaceholder")" />
        <select name="queue" class="form-select">
            <option value="">@T.T("AllQueues")</option>
            <option value="@BillingRefundQueueFilter.Pending" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Pending)">@T.T("Pending")</option>
            <option value="@BillingRefundQueueFilter.Completed" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Completed)">@T.T("Completed")</option>
            <option value="@BillingRefundQueueFilter.Failed" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Failed)">@T.T("Failed")</option>
            <option value="@BillingRefundQueueFilter.Stripe" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Stripe)">@T.T("Stripe")</option>
            <option value="@BillingRefundQueueFilter.NeedsSupport" selected="@(Model.QueueFilter == BillingRefundQueueFilter.NeedsSupport)">@T.T("NeedsSupport")</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@ScopedRefundsIndexUrl()" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
       hx-get="@ScopedPaymentsIndexUrl()" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("OpenPayments")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Order")</th>
                <th>@T.T("PaymentsLabel")</th>
                <th>@T.T("Customer")</th>
                <th>@T.T("Reason")</th>
                <th>@T.T("Timeline")</th>
                <th class="text-end">@T.T("Amount")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">@T.T("NoRefundsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var refundMissingProviderReference =
                    string.IsNullOrWhiteSpace(item.PaymentProviderReference) &&
                    string.IsNullOrWhiteSpace(item.PaymentProviderPaymentIntentRef) &&
                    string.IsNullOrWhiteSpace(item.PaymentProviderCheckoutSessionRef);
                var refundNeedsWebhookEvidence = item.IsStripe && (item.NeedsSupportAttention || refundMissingProviderReference);
                var refundNeedsTaxFollowUp =
                    item.CustomerId.HasValue &&
                    (item.Status.ToString() == "Pending" ||
                     item.ProviderReferenceState.Contains("Provider", StringComparison.OrdinalIgnoreCase));
                var refundNeedsRefundedInvoiceFollowUp = item.CustomerId.HasValue;
                var refundNeedsPaymentReconciliationFollowUp =
                    string.Equals(item.Status.ToString(), "Pending", StringComparison.OrdinalIgnoreCase) ||
                    item.ProviderReferenceState.Contains("Waiting", StringComparison.OrdinalIgnoreCase);
                var refundNeedsFailedPaymentFollowUp =
                    string.Equals(item.PaymentStatus.ToString(), "Failed", StringComparison.OrdinalIgnoreCase) ||
                    item.ProviderReferenceState.Contains("failure", StringComparison.OrdinalIgnoreCase);
                <tr>
                    <td>
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="text-decoration-none fw-semibold"
                           hx-get="@OrderDetailsUrl(item.OrderId)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.ToString() : item.OrderNumber)
                        </a>
                    </td>
                    <td>
                        <div>@item.PaymentProvider</div>
                        @if (!string.IsNullOrWhiteSpace(item.PaymentProviderReference))
                        {
                            <div class="small text-muted">@T.T("ProviderRef"): @item.PaymentProviderReference</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.PaymentProviderPaymentIntentRef))
                        {
                            <div class="small text-muted">@T.T("ProviderPaymentIntentRef"): @item.PaymentProviderPaymentIntentRef</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.PaymentProviderCheckoutSessionRef))
                        {
                            <div class="small text-muted">@T.T("ProviderCheckoutSessionRef"): @item.PaymentProviderCheckoutSessionRef</div>
                        }
                        <div class="small text-muted">@LocalizeProviderReferenceState(item.ProviderReferenceState)</div>
                        <div class="small">@LocalizePaymentStatus(item.PaymentStatus)</div>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("Stripe")</span></div>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("NeedsSupport")</span></div>
                        }
                    </td>
                    <td>
                        @if (item.CustomerId.HasValue)
                        {
                            <div>
                                <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none"
                                   hx-get="@CrmEditCustomerUrl(item.CustomerId.Value)"
                                   hx-target="#billing-refunds-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                        {
                            <div>@item.CustomerDisplayName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CustomerEmail))
                        {
                            <div class="small text-muted">@item.CustomerEmail</div>
                        }
                    </td>
                    <td>
                        <div>@item.Reason</div>
                        <div class="small text-muted">@LocalizeRefundStatus(item.Status)</div>
                    </td>
                    <td>
                        <div class="small text-muted">@T.T("Created") @item.CreatedAtUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        <div class="small text-muted">@T.T("Open") @item.OpenAgeHours h</div>
                        @if (item.CompletedAtUtc.HasValue)
                        {
                            <div>@T.T("Completed") @item.CompletedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        }
                        @if (item.LastRefundEventAtUtc.HasValue)
                        {
                            <div class="small text-muted">@T.T("LastEvent") @item.LastRefundEventAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture)</div>
                        }
                    </td>
                    <td class="text-end">@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end">
                        <a asp-controller="Billing" asp-action="EditPayment" asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditPaymentUrl(item.PaymentId)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentsLabel")</a>
                        @if (refundMissingProviderReference)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.MissingProviderRef"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.MissingProviderRef)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("MissingProviderRef")</a>
                        }
                        @if (refundNeedsPaymentReconciliationFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.NeedsReconciliation"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.NeedsReconciliation)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("ReconciliationQueue")</a>
                        }
                        @if (refundNeedsFailedPaymentFollowUp)
                        {
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.Failed"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.Failed)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Failed")</a>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <a asp-action="Refunds"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@BillingRefundQueueFilter.NeedsSupport"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@ScopedRefundsUrl(BillingRefundQueueFilter.NeedsSupport)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("SupportQueue")</a>
                        }
                        @if (refundNeedsWebhookEvidence)
                        {
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@BillingWebhooksUrl(BillingWebhookDeliveryQueueFilter.PaymentExceptions)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("WebhookExceptions")</a>
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@ScopedPaymentsUrl(PaymentQueueFilter.DisputeFollowUp)"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("DisputeQueue")</a>
                        }
                        @if (refundNeedsTaxFollowUp)
                        {
                            <a asp-action="TaxCompliance"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@GlobalTaxComplianceUrl()"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("OpenTaxCompliance")</a>
                            <a asp-controller="Crm"
                               asp-action="Invoices"
                               asp-route-q="@item.CustomerId"
                               asp-route-filter="MissingVatId"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@CrmInvoicesUrl(item.CustomerId, "MissingVatId")"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("FixVatId")</a>
                        }
                        @if (refundNeedsRefundedInvoiceFollowUp)
                        {
                            <a asp-controller="Crm"
                               asp-action="Invoices"
                               asp-route-q="@item.CustomerId"
                               asp-route-filter="Refunded"
                               class="btn btn-sm btn-outline-secondary"
                               hx-get="@CrmInvoicesUrl(item.CustomerId, "Refunded")"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Refunded")</a>
                        }
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="btn btn-sm btn-outline-primary"
                           hx-get="@OrderDetailsUrl(item.OrderId)"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Order")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Billing"
       asp-action="Refunds"
       asp-route-businessId="@Model.BusinessId"
       asp-route-q="@Model.Query"
       asp-route-queue="@Model.QueueFilter"
       hx-target="#billing-refunds-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>
</div>
