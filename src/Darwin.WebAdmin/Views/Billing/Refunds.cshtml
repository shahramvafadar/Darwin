@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.RefundsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("RefundQueueTitle");
}

<div id="billing-refunds-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("RefundQueueTitle")</h1>
        <p class="text-muted mb-0">@T.T("RefundQueueIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Pending" class="btn btn-outline-warning btn-sm"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.Pending })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Pending")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Completed" class="btn btn-outline-success btn-sm"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.Completed })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Completed")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Failed" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.Failed })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Failed")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.Stripe" class="btn btn-outline-primary btn-sm"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.Stripe })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Stripe")</a>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" asp-route-queue="@BillingRefundQueueFilter.NeedsSupport" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.NeedsSupport })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("NeedsSupport")</a>
        <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("BackToPayments")</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("WebhookAnomalyVisibility")</span>
        <a asp-action="Webhooks"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Webhooks", "Billing")"
           hx-target="#billing-refunds-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("OpenWebhookQueue")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("PaymentExceptions")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.PaymentExceptionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("DisputeSignals")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.DisputeSignalCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("RetryPending")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.RetryPendingCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("FailedDeliveries")</div>
                    <div class="fs-4 fw-semibold">@Model.Webhooks.FailedDeliveryCount</div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
               class="btn btn-sm btn-outline-warning"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
               hx-target="#billing-refunds-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("ReviewPaymentExceptions")</a>
            <a asp-action="Webhooks"
               asp-route-queue="@BillingWebhookDeliveryQueueFilter.DisputeSignals"
               class="btn btn-sm btn-outline-dark"
               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.DisputeSignals })"
               hx-target="#billing-refunds-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("ReviewDisputeSignals")</a>
        </div>
        <div class="small text-muted mt-3">
            @T.T("RefundWebhookTriageNote")
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Pending")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Completed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.CompletedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Failed")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.FailedCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("StripeLinked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.StripeCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("NeedsSupport")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.NeedsSupportCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("RefundSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@T.T(item.Title)</td>
                        <td>@T.T(item.ScopeNote)</td>
                        <td>@T.T(item.OperatorAction)</td>
                        <td>@T.T(item.SettingsDependency)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Refunds" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("Refunds", "Billing")"
          hx-target="#billing-refunds-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchRefundsPlaceholder")" />
        <select name="queue" class="form-select">
            <option value="">@T.T("AllQueues")</option>
            <option value="@BillingRefundQueueFilter.Pending" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Pending)">@T.T("Pending")</option>
            <option value="@BillingRefundQueueFilter.Completed" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Completed)">@T.T("Completed")</option>
            <option value="@BillingRefundQueueFilter.Failed" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Failed)">@T.T("Failed")</option>
            <option value="@BillingRefundQueueFilter.Stripe" selected="@(Model.QueueFilter == BillingRefundQueueFilter.Stripe)">@T.T("Stripe")</option>
            <option value="@BillingRefundQueueFilter.NeedsSupport" selected="@(Model.QueueFilter == BillingRefundQueueFilter.NeedsSupport)">@T.T("NeedsSupport")</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="Refunds" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="Payments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
       hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId })" hx-target="#billing-refunds-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("OpenPayments")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Order")</th>
                <th>@T.T("PaymentsLabel")</th>
                <th>@T.T("Customer")</th>
                <th>@T.T("Reason")</th>
                <th>@T.T("Timeline")</th>
                <th class="text-end">@T.T("Amount")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">@T.T("NoRefundsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="text-decoration-none fw-semibold"
                           hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            @(string.IsNullOrWhiteSpace(item.OrderNumber) ? item.OrderId.ToString() : item.OrderNumber)
                        </a>
                    </td>
                    <td>
                        <div>@item.PaymentProvider</div>
                        @if (!string.IsNullOrWhiteSpace(item.PaymentProviderReference))
                        {
                            <div class="small text-muted">@item.PaymentProviderReference</div>
                        }
                        <div class="small text-muted">@item.ProviderReferenceState</div>
                        <div class="small">@item.PaymentStatus</div>
                        @if (item.IsStripe)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("Stripe")</span></div>
                        }
                        @if (item.NeedsSupportAttention)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("NeedsSupport")</span></div>
                        }
                    </td>
                    <td>
                        @if (item.CustomerId.HasValue)
                        {
                            <div>
                                <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none"
                                   hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                                   hx-target="#billing-refunds-workspace-shell"
                                   hx-swap="outerHTML"
                                   hx-push-url="true">
                                    @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                </a>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                        {
                            <div>@item.CustomerDisplayName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CustomerEmail))
                        {
                            <div class="small text-muted">@item.CustomerEmail</div>
                        }
                    </td>
                    <td>
                        <div>@item.Reason</div>
                        <div class="small text-muted">@item.Status</div>
                    </td>
                    <td>
                        <div class="small text-muted">@T.T("Created") @item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="small text-muted">@T.T("Open") @item.OpenAgeHours h</div>
                        @if (item.CompletedAtUtc.HasValue)
                        {
                            <div>@T.T("Completed") @item.CompletedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (item.LastRefundEventAtUtc.HasValue)
                        {
                            <div class="small text-muted">@T.T("LastEvent") @item.LastRefundEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                    </td>
                    <td class="text-end">@item.Currency @((item.AmountMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end">
                        <a asp-controller="Billing" asp-action="EditPayment" asp-route-id="@item.PaymentId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("EditPayment", "Billing", new { id = item.PaymentId })"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("PaymentsLabel")</a>
                        @if (item.NeedsSupportAttention)
                        {
                            <a asp-action="Refunds"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@BillingRefundQueueFilter.NeedsSupport"
                               class="btn btn-sm btn-outline-danger"
                               hx-get="@Url.Action("Refunds", "Billing", new { businessId = Model.BusinessId, queue = BillingRefundQueueFilter.NeedsSupport })"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("SupportQueue")</a>
                        }
                        @if (item.IsStripe && item.NeedsSupportAttention)
                        {
                            <a asp-action="Webhooks"
                               asp-route-queue="@BillingWebhookDeliveryQueueFilter.PaymentExceptions"
                               class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Webhooks", "Billing", new { queue = BillingWebhookDeliveryQueueFilter.PaymentExceptions })"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("WebhookExceptions")</a>
                            <a asp-action="Payments"
                               asp-route-businessId="@Model.BusinessId"
                               asp-route-queue="@PaymentQueueFilter.DisputeFollowUp"
                               class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Payments", "Billing", new { businessId = Model.BusinessId, queue = PaymentQueueFilter.DisputeFollowUp })"
                               hx-target="#billing-refunds-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("DisputeQueue")</a>
                        }
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })"
                           hx-target="#billing-refunds-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Order")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Billing"
       asp-action="Refunds"
       asp-route-businessId="@Model.BusinessId"
       asp-route-q="@Model.Query"
       asp-route-queue="@Model.QueueFilter"
       hx-target="#billing-refunds-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
</pager>
</div>
