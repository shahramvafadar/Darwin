@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.JournalEntriesListVm
@{
    ViewData["Title"] = "Journal Entries";
}

<h1 class="mb-3">Journal Entries</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="JournalEntries" method="get" class="d-flex gap-2">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search journal entries">
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
        <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">Reset</a>
    </form>
    <a asp-action="CreateJournalEntry" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">New Journal Entry</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Recent</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RecentCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Multi-Line</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MultiLineCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Journal Review Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.QueueFilter is null ? "btn-dark" : "btn-outline-dark")">All</a>
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.Recent" class="btn btn-sm @(Model.QueueFilter == JournalEntryQueueFilter.Recent ? "btn-primary" : "btn-outline-primary")">Recent</a>
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.MultiLine" class="btn btn-sm @(Model.QueueFilter == JournalEntryQueueFilter.MultiLine ? "btn-secondary" : "btn-outline-secondary")">Multi-Line</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>Date</th><th>Description</th><th>Lines</th><th>Debit</th><th>Credit</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No journal entries found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.EntryDateUtc.ToString("yyyy-MM-dd")</td>
                    <td>@item.Description</td>
                    <td>@item.LineCount</td>
                    <td>EUR @((item.TotalDebitMinor / 100M).ToString("0.00"))</td>
                    <td>EUR @((item.TotalCreditMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end"><a asp-action="EditJournalEntry" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter"></pager>
