@using System.Globalization
@using Darwin.Application.Billing.DTOs
@model Darwin.WebAdmin.ViewModels.Billing.JournalEntriesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("JournalEntriesTitle");
    string JournalEntryOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string JournalEntryOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var journalEntryAttentionCount = Model.Summary.RecentCount + Model.Summary.MultiLineCount;
}

<div id="billing-journal-entries-workspace-shell">
<h1 class="mb-3">@T.T("JournalEntriesTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="JournalEntries" method="get" class="d-flex gap-2"
          hx-get="@Url.Action("JournalEntries", "Billing")"
          hx-target="#billing-journal-entries-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchJournalEntriesPlaceholder")">
        <button class="btn btn-outline-secondary" type="submit">@T.T("CommonSearch")</button>
        <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId })"
           hx-target="#billing-journal-entries-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("CommonReset")</a>
    </form>
    <a asp-action="CreateJournalEntry" asp-route-businessId="@Model.BusinessId" class="btn btn-primary"
       hx-get="@Url.Action("CreateJournalEntry", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-journal-entries-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("CreateJournalEntry")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CommonTotal")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Recent")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.RecentCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("JournalEntriesMultiLine")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MultiLineCount</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h2 class="h5 mb-0">@T.T("GoLiveReadiness")</h2>
                    <span class="@JournalEntryOpsHealthBadgeClass(journalEntryAttentionCount == 0)">@JournalEntryOpsHealthBadgeText(journalEntryAttentionCount == 0)</span>
                </div>
                <p class="text-muted small mb-0 mt-2">
                    @T.T("JournalReviewPlaybooks")
                    @if (journalEntryAttentionCount > 0)
                    {
                        <span class="ms-1">@T.T("NeedsAttention"): @journalEntryAttentionCount</span>
                    }
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="CreateJournalEntry" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("CreateJournalEntry", "Billing", new { businessId = Model.BusinessId })"
                   hx-target="#billing-journal-entries-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CreateJournalEntry")</a>
                <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
                   hx-target="#billing-journal-entries-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("FinancialAccountsTitle")</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("Recent")</div>
                            <div class="small text-muted mt-1">@T.T("JournalEntryPlaybookRecentScope")</div>
                        </div>
                        <span class="@JournalEntryOpsHealthBadgeClass(Model.Summary.RecentCount == 0)">@Model.Summary.RecentCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("JournalEntryPlaybookRecentAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.Recent" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, queue = JournalEntryQueueFilter.Recent })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Recent")</a>
                        <a asp-action="Expenses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ExpensesTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("JournalEntriesMultiLine")</div>
                            <div class="small text-muted mt-1">@T.T("NeedsAttention")</div>
                        </div>
                        <span class="@JournalEntryOpsHealthBadgeClass(Model.Summary.MultiLineCount == 0)">@Model.Summary.MultiLineCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("JournalEntryPlaybookMultilineAction")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.MultiLine" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, queue = JournalEntryQueueFilter.MultiLine })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("JournalEntriesMultiLine")</a>
                        <a asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-info"
                           hx-get="@Url.Action("FinancialAccounts", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("FinancialAccountsTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@T.T("CreateJournalEntry")</div>
                            <div class="small text-muted mt-1">@T.T("Queue")</div>
                        </div>
                        <span class="@JournalEntryOpsHealthBadgeClass(Model.Summary.TotalCount > 0)">@Model.Summary.TotalCount</span>
                    </div>
                    <div class="small text-muted mt-3">@T.T("JournalEntryPlaybookMultilineDependency")</div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="CreateJournalEntry" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-primary"
                           hx-get="@Url.Action("CreateJournalEntry", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CreateJournalEntry")</a>
                        <a asp-action="Expenses" asp-route-businessId="@Model.BusinessId" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Expenses", "Billing", new { businessId = Model.BusinessId })"
                           hx-target="#billing-journal-entries-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ExpensesTitle")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("JournalReviewPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-sm @(Model.QueueFilter is null ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId })"
       hx-target="#billing-journal-entries-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("All")</a>
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.Recent" class="btn btn-sm @(Model.QueueFilter == JournalEntryQueueFilter.Recent ? "btn-primary" : "btn-outline-primary")"
       hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, queue = JournalEntryQueueFilter.Recent })"
       hx-target="#billing-journal-entries-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Recent")</a>
    <a asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-queue="@JournalEntryQueueFilter.MultiLine" class="btn btn-sm @(Model.QueueFilter == JournalEntryQueueFilter.MultiLine ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@Url.Action("JournalEntries", "Billing", new { businessId = Model.BusinessId, queue = JournalEntryQueueFilter.MultiLine })"
       hx-target="#billing-journal-entries-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("JournalEntriesMultiLine")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead><tr><th>@T.T("CommonDate")</th><th>@T.T("Description")</th><th>@T.T("Lines")</th><th>@T.T("Debit")</th><th>@T.T("Credit")</th><th class="text-end">@T.T("CommonActions")</th></tr></thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">@T.T("JournalEntriesEmptyState")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.EntryDateUtc.ToLocalTime().ToString("d", CultureInfo.CurrentCulture)</td>
                    <td>@item.Description</td>
                    <td>@item.LineCount</td>
                    <td>@item.Currency @((item.TotalDebitMinor / 100M).ToString("0.00"))</td>
                    <td>@item.Currency @((item.TotalCreditMinor / 100M).ToString("0.00"))</td>
                    <td class="text-end"><a asp-action="EditJournalEntry" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("EditJournalEntry", "Billing", new { id = item.Id })"
                       hx-target="#billing-journal-entries-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("CommonEdit")</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Billing" asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-queue="@Model.QueueFilter" hx-target="#billing-journal-entries-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
