@model Darwin.WebAdmin.ViewModels.Orders.OrderDetailVm
@{
    ViewData["Title"] = "Order " + Model.OrderNumber;
}

<h1 class="mb-2"><i class="fa fa-receipt"></i> Order @Model.OrderNumber</h1>
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3"><strong>Status:</strong> @Model.Status</div>
            <div class="col-md-3"><strong>Total:</strong> @Model.Currency @((Model.GrandTotalGrossMinor / 100.0M).ToString("0.00"))</div>
            <div class="col-md-3">
                <strong>Shipping:</strong>
                @(string.IsNullOrWhiteSpace(Model.ShippingMethodName)
                    ? "Not selected"
                    : $"{Model.ShippingMethodName} ({Model.Currency} {(Model.ShippingTotalMinor / 100.0M):0.00})")
            </div>
            <div class="col-md-3">
                <strong>Carrier/Service:</strong>
                @(string.IsNullOrWhiteSpace(Model.ShippingCarrier)
                    ? "-"
                    : string.IsNullOrWhiteSpace(Model.ShippingService)
                        ? Model.ShippingCarrier
                        : $"{Model.ShippingCarrier} / {Model.ShippingService}")
            </div>
            <div class="col-md-12 text-end">
                <form asp-controller="Orders" asp-action="ChangeStatus" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <select name="WarehouseId" class="form-select form-select-sm d-inline w-auto me-2">
                        <option value="">Warehouse (Auto)</option>
                        @foreach (var warehouse in Model.WarehouseOptions)
                        {
                            <option value="@warehouse.Value" selected="@warehouse.Selected">@warehouse.Text</option>
                        }
                    </select>
                    <select name="NewStatus" class="form-select form-select-sm d-inline w-auto me-2">
                        <!-- Use only valid statuses or only allowed transitions -->
                        @* <option value="Pending">Pending</option> *@
                        <option value="Paid">Paid</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Shipped">Shipped</option>
                    </select>
                    <button class="btn btn-sm btn-outline-primary" type="submit"><i class="fa fa-sync"></i> Change Status</button>
                </form>
                <a asp-controller="Orders"
                   asp-action="AddPayment"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-success"
                   hx-get="@Url.Action("AddPayment", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-credit-card"></i> Add Payment
                </a>
                <a asp-controller="Orders"
                   asp-action="AddShipment"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("AddShipment", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-truck"></i> Add Shipment
                </a>
                <a asp-controller="Orders"
                   asp-action="AddRefund"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-rotate-left"></i> Add Refund
                </a>
                <a asp-controller="Orders"
                   asp-action="CreateInvoice"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("CreateInvoice", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-file-invoice"></i> Create Invoice
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Tax &amp; Price Snapshot</span>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-tax" class="btn btn-sm btn-outline-secondary">Open Tax Settings</a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="text-muted small">Price Mode</div>
                        <div class="fw-semibold mt-1">@(Model.PricesIncludeTax ? "VAT Inclusive" : "VAT Exclusive")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Subtotal Net</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.SubtotalNetMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Tax Total</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.TaxTotalMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Discounts</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.DiscountTotalMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                </div>
                <div class="small text-muted mt-3">
                    Gross totals remain the operational source of truth, while this snapshot exposes the net/tax split currently persisted on the order.
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">Current Tax Policy</div>
            <div class="card-body">
                <div class="small text-muted">VAT Enabled</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.VatEnabled ? "Yes" : "No")</div>
                <div class="small text-muted">Default VAT</div>
                <div class="fw-semibold mb-2">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div>
                <div class="small text-muted">Reverse Charge</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.AllowReverseCharge ? "Allowed" : "Disabled")</div>
                <div class="small text-muted">Issuer</div>
                <div class="fw-semibold">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : "Missing")</div>
            </div>
        </div>
    </div>
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Return Support Baseline</span>
                <a asp-controller="Orders"
                   asp-action="ShipmentsQueue"
                   asp-route-filter="Returned"
                   class="btn btn-sm btn-outline-secondary">
                    Open Returned Queue
                </a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="text-muted small">Returned Shipments</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.ReturnedShipmentCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Returned Without Tracking</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.ReturnedWithoutTrackingCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Carrier Review Rows</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.CarrierReviewShipmentCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">Refund Path</div>
                        <div class="fw-semibold mt-1">@(Model.ReturnSupport.HasRefundablePayment ? "Ready" : "Check payments first")</div>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <button class="btn btn-sm btn-outline-primary"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#shipments">
                        Review Shipments
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#refunds">
                        Review Refunds
                    </button>
                    @if (Model.ReturnSupport.DefaultRefundPaymentId.HasValue)
                    {
                        <a asp-controller="Orders"
                           asp-action="AddRefund"
                           asp-route-orderId="@Model.Id"
                           asp-route-paymentId="@Model.ReturnSupport.DefaultRefundPaymentId"
                           class="btn btn-sm btn-danger"
                           hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.Id, paymentId = Model.ReturnSupport.DefaultRefundPaymentId })"
                           hx-target="#order-operation-shell"
                           hx-swap="innerHTML"
                           hx-push-url="false">
                            <i class="fa fa-rotate-left"></i> Start Return Refund
                        </a>
                    }
                    <a asp-controller="Orders"
                       asp-action="ShipmentsQueue"
                       asp-route-filter="CarrierReview"
                       class="btn btn-sm btn-outline-warning">
                        Carrier Review Queue
                    </a>
                </div>
                <div class="small text-muted mt-3">
                    Phase-1 returns support uses existing shipment and refund records. Returned parcels can be triaged here, while restock and deeper RMA workflow remain later-phase work.
                </div>
            </div>
        </div>
    </div>
</div>

<div id="order-operation-shell" class="mb-3"></div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Inventory Allocation</strong>
        <small class="text-muted">Allocate reserved stock & finalize picking</small>
    </div>
    <div class="card-body">
        <p class="mb-3">
            When allocation succeeds, the order transitions to <code>Shipped</code> (idempotent).
        </p>

        <form asp-controller="Orders" asp-action="ChangeStatus" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="OrderId" value="@Model.Id" />
            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
            <input type="hidden" name="NewStatus" value="Shipped" />
            <select name="WarehouseId" class="form-select d-inline w-auto me-2">
                <option value="">Warehouse (Auto)</option>
                @foreach (var warehouse in Model.WarehouseOptions)
                {
                    <option value="@warehouse.Value" selected="@warehouse.Selected">@warehouse.Text</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-primary">
                <i class="fa fa-dolly"></i> Allocate Now
            </button>
        </form>

    @* Note: If we want to display a condition (for example, only when Status = Paid), we can activate the following condition:
    @if (Model.Status != OrderStatus.Paid) {
       <div class="alert alert-info mt-3 mb-0">Allocation is available once the order is Paid.</div>
    }
    *@
    </div>
</div>

<h5>Lines</h5>
<div class="table-responsive mb-3">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Name</th>
                <th>Warehouse</th>
                <th class="text-end">Qty</th>
                <th class="text-end">Unit</th>
                <th class="text-end">Line</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>@l.Sku</td>
                    <td>@l.Name</td>
                    <td>@(string.IsNullOrWhiteSpace(l.WarehouseName) ? "Auto" : l.WarehouseName)</td>
                    <td class="text-end">@l.Quantity</td>
                    <td class="text-end">@((l.UnitPriceGrossMinor / 100.0M).ToString("0.00"))</td>
                    <td class="text-end">@((l.LineGrossMinor / 100.0M).ToString("0.00"))</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<ul class="nav nav-tabs" id="orderTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="payments-tab" data-bs-toggle="tab" data-bs-target="#payments" type="button" role="tab">Payments</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="shipments-tab" data-bs-toggle="tab" data-bs-target="#shipments" type="button" role="tab">Shipments</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="refunds-tab" data-bs-toggle="tab" data-bs-target="#refunds" type="button" role="tab">Refunds</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="invoices-tab" data-bs-toggle="tab" data-bs-target="#invoices" type="button" role="tab">Invoices</button>
    </li>
</ul>
<div class="tab-content border border-top-0 p-3">
    <div class="tab-pane fade show active" id="payments" role="tabpanel">
        <div id="payments-grid"
             hx-get="@Url.Action("Payments", "Orders", new { orderId = Model.Id })"
             hx-trigger="load"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="shipments" role="tabpanel">
        <div id="shipments-grid"
             hx-get="@Url.Action("Shipments", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="refunds" role="tabpanel">
        <div id="refunds-grid"
             hx-get="@Url.Action("Refunds", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="invoices" role="tabpanel">
        <div id="invoices-grid"
             hx-get="@Url.Action("Invoices", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
