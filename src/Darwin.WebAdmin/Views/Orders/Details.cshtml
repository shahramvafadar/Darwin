@model Darwin.WebAdmin.ViewModels.Orders.OrderDetailVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Order") + " " + Model.OrderNumber;
}

<div id="order-details-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-2">
    <h1 class="mb-0"><i class="fa fa-receipt"></i> @T.T("Order") @Model.OrderNumber</h1>
    <a asp-action="Index"
       hx-get="@Url.Action("Index", "Orders")"
       hx-target="#order-details-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("BackToOrders")</a>
</div>
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3"><strong>@T.T("Status"):</strong> @Model.Status</div>
            <div class="col-md-3"><strong>@T.T("Total"):</strong> @Model.Currency @((Model.GrandTotalGrossMinor / 100.0M).ToString("0.00"))</div>
            <div class="col-md-3">
                <strong>@T.T("Shipping"):</strong>
                @(string.IsNullOrWhiteSpace(Model.ShippingMethodName)
                    ? T.T("NotSelected")
                    : $"{Model.ShippingMethodName} ({Model.Currency} {(Model.ShippingTotalMinor / 100.0M):0.00})")
            </div>
            <div class="col-md-3">
                <strong>@T.T("CarrierService"):</strong>
                @(string.IsNullOrWhiteSpace(Model.ShippingCarrier)
                    ? "-"
                    : string.IsNullOrWhiteSpace(Model.ShippingService)
                        ? Model.ShippingCarrier
                        : $"{Model.ShippingCarrier} / {Model.ShippingService}")
            </div>
            <div class="col-md-12 text-end">
                <form asp-controller="Orders"
                      asp-action="ChangeStatus"
                      method="post"
                      class="d-inline"
                      hx-post="@Url.Action("ChangeStatus", "Orders")"
                      hx-target="#order-details-workspace-shell"
                      hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                    <select name="WarehouseId" class="form-select form-select-sm d-inline w-auto me-2">
                        <option value="">@T.T("WarehouseAuto")</option>
                        @foreach (var warehouse in Model.WarehouseOptions)
                        {
                            <option value="@warehouse.Value" selected="@warehouse.Selected">@warehouse.Text</option>
                        }
                    </select>
                    <select name="NewStatus" class="form-select form-select-sm d-inline w-auto me-2">
                        <!-- Use only valid statuses or only allowed transitions -->
                        @* <option value="Pending">Pending</option> *@
                        <option value="Paid">@T.T("Paid")</option>
                        <option value="Cancelled">@T.T("Cancelled")</option>
                        <option value="Shipped">@T.T("Shipped")</option>
                    </select>
                    <button class="btn btn-sm btn-outline-primary" type="submit"><i class="fa fa-sync"></i> @T.T("ChangeStatus")</button>
                </form>
                <a asp-controller="Orders"
                   asp-action="AddPayment"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-success"
                   hx-get="@Url.Action("AddPayment", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-credit-card"></i> @T.T("AddPayment")
                </a>
                <a asp-controller="Orders"
                   asp-action="AddShipment"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"
                   hx-get="@Url.Action("AddShipment", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-truck"></i> @T.T("AddShipment")
                </a>
                <a asp-controller="Orders"
                   asp-action="AddRefund"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-rotate-left"></i> @T.T("AddRefund")
                </a>
                <a asp-controller="Orders"
                   asp-action="CreateInvoice"
                   asp-route-orderId="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("CreateInvoice", "Orders", new { orderId = Model.Id })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    <i class="fa fa-file-invoice"></i> @T.T("CreateInvoice")
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@T.T("TaxPriceSnapshot")</span>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-tax"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                   hx-target="#order-operation-shell"
                   hx-swap="innerHTML"
                   hx-push-url="false">
                    @T.T("OpenTaxSettings")
                </a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("PriceMode")</div>
                        <div class="fw-semibold mt-1">@(Model.PricesIncludeTax ? T.T("VatInclusive") : T.T("VatExclusive"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("SubtotalNet")</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.SubtotalNetMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("TaxTotal")</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.TaxTotalMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("Discounts")</div>
                        <div class="fw-semibold mt-1">@Model.Currency @((Model.DiscountTotalMinor / 100.0M).ToString("0.00"))</div>
                    </div>
                </div>
                <div class="small text-muted mt-3">
                    @T.T("TaxSnapshotNote")
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">@T.T("CurrentTaxPolicy")</div>
            <div class="card-body">
                <div class="small text-muted">@T.T("VatEnabled")</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.VatEnabled ? T.T("Yes") : T.T("No"))</div>
                <div class="small text-muted">@T.T("DefaultVat")</div>
                <div class="fw-semibold mb-2">@Model.TaxPolicy.DefaultVatRatePercent.ToString("0.##")%</div>
                <div class="small text-muted">@T.T("ReverseCharge")</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div>
                <div class="small text-muted">@T.T("Issuer")</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.IssuerConfigured ? Model.TaxPolicy.InvoiceIssuerLegalName : T.T("Missing"))</div>
                <div class="small text-muted">@T.T("ArchiveReadiness")</div>
                <div class="fw-semibold mb-2">@(Model.TaxPolicy.ArchiveReadinessComplete ? T.T("Ready") : T.T("MissingData"))</div>
                <div class="small text-muted mb-2">@Model.TaxPolicy.ArchiveReadinessLabel</div>
                <div class="small text-muted">@T.T("EInvoiceBaseline")</div>
                <div class="fw-semibold">@(Model.TaxPolicy.EInvoiceBaselineReady ? T.T("Ready") : T.T("NotReady"))</div>
                <div class="small text-muted mt-2">@Model.TaxPolicy.EInvoiceBaselineLabel</div>
                <div class="small text-muted mt-2">@Model.TaxPolicy.ComplianceScopeNote</div>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-controller="SiteSettings"
                       asp-action="Edit"
                       asp-fragment="site-settings-tax"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">
                        @T.T("TaxSettings")
                    </a>
                    @if (!Model.TaxPolicy.ArchiveReadinessComplete)
                    {
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#order-operation-shell"
                           hx-swap="innerHTML"
                           hx-push-url="false">
                            @T.T("CompleteIssuerData")
                        </a>
                    }
                    @if (!Model.TaxPolicy.EInvoiceBaselineReady)
                    {
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" })"
                           hx-target="#order-operation-shell"
                           hx-swap="innerHTML"
                           hx-push-url="false">
                            @T.T("ReviewEInvoiceBaseline")
                        </a>
                    }
                    <button class="btn btn-sm btn-outline-primary"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#invoices">
                        @T.T("ReviewInvoices")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@T.T("ReturnSupportBaseline")</span>
                <a asp-controller="Orders"
                   asp-action="ShipmentsQueue"
                   asp-route-filter="Returned"
                   hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = "Returned" })"
                   hx-target="#order-details-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true"
                   class="btn btn-sm btn-outline-secondary">
                    @T.T("OpenReturnedQueue")
                </a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("ReturnedShipments")</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.ReturnedShipmentCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("ReturnedWithoutTracking")</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.ReturnedWithoutTrackingCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("CarrierReviewRows")</div>
                        <div class="fs-4 fw-semibold mt-1">@Model.ReturnSupport.CarrierReviewShipmentCount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small">@T.T("RefundPath")</div>
                        <div class="fw-semibold mt-1">@(Model.ReturnSupport.HasRefundablePayment ? T.T("Ready") : T.T("CheckPaymentsFirst"))</div>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <button class="btn btn-sm btn-outline-primary"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#shipments">
                        @T.T("ReviewShipments")
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            type="button"
                            data-bs-toggle="tab"
                            data-bs-target="#refunds">
                        @T.T("ReviewRefunds")
                    </button>
                    @if (Model.ReturnSupport.DefaultRefundPaymentId.HasValue)
                    {
                        <a asp-controller="Orders"
                           asp-action="AddRefund"
                           asp-route-orderId="@Model.Id"
                           asp-route-paymentId="@Model.ReturnSupport.DefaultRefundPaymentId"
                           class="btn btn-sm btn-danger"
                           hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.Id, paymentId = Model.ReturnSupport.DefaultRefundPaymentId })"
                           hx-target="#order-operation-shell"
                           hx-swap="innerHTML"
                           hx-push-url="false">
                            <i class="fa fa-rotate-left"></i> @T.T("StartReturnRefund")
                        </a>
                    }
                    <a asp-controller="Orders"
                       asp-action="ShipmentsQueue"
                       asp-route-filter="CarrierReview"
                       class="btn btn-sm btn-outline-warning"
                       hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = "CarrierReview" })"
                       hx-target="#order-details-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        @T.T("CarrierReviewQueue")
                    </a>
                </div>
                <div class="small text-muted mt-3">
                    @T.T("ReturnSupportNote")
                </div>
            </div>
        </div>
    </div>
</div>

<div id="order-operation-shell" class="mb-3"></div>

<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>@T.T("InventoryAllocation")</strong>
        <small class="text-muted">@T.T("InventoryAllocationSubtitle")</small>
    </div>
    <div class="card-body">
        <p class="mb-3">
            @T.T("InventoryAllocationNote")
        </p>

        <form asp-controller="Orders"
              asp-action="ChangeStatus"
              method="post"
              class="d-inline"
              hx-post="@Url.Action("ChangeStatus", "Orders")"
              hx-target="#order-details-workspace-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input type="hidden" name="OrderId" value="@Model.Id" />
            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
            <input type="hidden" name="NewStatus" value="Shipped" />
            <select name="WarehouseId" class="form-select d-inline w-auto me-2">
                <option value="">@T.T("WarehouseAuto")</option>
                @foreach (var warehouse in Model.WarehouseOptions)
                {
                    <option value="@warehouse.Value" selected="@warehouse.Selected">@warehouse.Text</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-primary">
                <i class="fa fa-dolly"></i> @T.T("AllocateNow")
            </button>
        </form>

    @* Note: If we want to display a condition (for example, only when Status = Paid), we can activate the following condition:
    @if (Model.Status != OrderStatus.Paid) {
       <div class="alert alert-info mt-3 mb-0">@T.T("AllocationAvailableAfterPayment")</div>
    }
    *@
    </div>
</div>

<h5>@T.T("Lines")</h5>
<div class="table-responsive mb-3">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Sku")</th>
                <th>@T.T("Name")</th>
                <th>@T.T("Warehouse")</th>
                <th class="text-end">@T.T("Qty")</th>
                <th class="text-end">@T.T("Unit")</th>
                <th class="text-end">@T.T("Line")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.Lines)
            {
                <tr>
                    <td>@l.Sku</td>
                    <td>@l.Name</td>
                    <td>@(string.IsNullOrWhiteSpace(l.WarehouseName) ? "Auto" : l.WarehouseName)</td>
                    <td class="text-end">@l.Quantity</td>
                    <td class="text-end">@((l.UnitPriceGrossMinor / 100.0M).ToString("0.00"))</td>
                    <td class="text-end">@((l.LineGrossMinor / 100.0M).ToString("0.00"))</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<ul class="nav nav-tabs" id="orderTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="payments-tab" data-bs-toggle="tab" data-bs-target="#payments" type="button" role="tab">@T.T("Payments")</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="shipments-tab" data-bs-toggle="tab" data-bs-target="#shipments" type="button" role="tab">@T.T("Shipments")</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="refunds-tab" data-bs-toggle="tab" data-bs-target="#refunds" type="button" role="tab">@T.T("Refunds")</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="invoices-tab" data-bs-toggle="tab" data-bs-target="#invoices" type="button" role="tab">@T.T("Invoices")</button>
    </li>
</ul>
<div class="tab-content border border-top-0 p-3">
    <div class="tab-pane fade show active" id="payments" role="tabpanel">
        <div id="payments-grid"
             hx-get="@Url.Action("Payments", "Orders", new { orderId = Model.Id })"
             hx-trigger="load"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="shipments" role="tabpanel">
        <div id="shipments-grid"
             hx-get="@Url.Action("Shipments", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="refunds" role="tabpanel">
        <div id="refunds-grid"
             hx-get="@Url.Action("Refunds", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
    <div class="tab-pane fade" id="invoices" role="tabpanel">
        <div id="invoices-grid"
             hx-get="@Url.Action("Invoices", "Orders", new { orderId = Model.Id })"
             hx-trigger="revealed"
             hx-swap="innerHTML">
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</div>
