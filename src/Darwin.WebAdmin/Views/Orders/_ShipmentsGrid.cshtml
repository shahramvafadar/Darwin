@model Darwin.WebAdmin.ViewModels.Orders.OrderShipmentsPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var orderCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeShipmentStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string OrderDateTimeText(DateTime? utc) => utc?.ToString("g", orderCulture) ?? "-";
    string OrderShipmentOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string OrderShipmentOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    string AddShipmentUrl(Guid orderId) => Url.Action("AddShipment", "Orders", new { orderId }) ?? string.Empty;
    string OrderRefundsUrl(Guid orderId) => Url.Action("Refunds", "Orders", new { orderId }) ?? string.Empty;
    string AddRefundUrl(Guid orderId, Guid? paymentId) => Url.Action("AddRefund", "Orders", new { orderId, paymentId }) ?? string.Empty;
    string ShippingSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" }) ?? string.Empty;
    string ShippingMethodsUrl(string filter) => Url.Action("Index", "ShippingMethods", new { filter }) ?? string.Empty;
    var orderShipmentAwaitingHandoffCount = Model.Items.Count(item => item.AwaitingHandoff);
    var orderShipmentTrackingOverdueCount = Model.Items.Count(item => item.TrackingOverdue);
    var orderShipmentCarrierReviewCount = Model.Items.Count(item => item.NeedsCarrierReview);
    var orderShipmentReturnFollowUpCount = Model.Items.Count(item => item.NeedsReturnFollowUp || item.Status == Darwin.Domain.Enums.ShipmentStatus.Returned);
    var orderShipmentAttentionCount = orderShipmentAwaitingHandoffCount + orderShipmentTrackingOverdueCount + orderShipmentCarrierReviewCount + orderShipmentReturnFollowUpCount;
}

<div id="shipments-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="fw-semibold">@T.T("ShipmentsQueue")</div>
                        <span class="@OrderShipmentOpsHealthBadgeClass(orderShipmentAttentionCount == 0)">@OrderShipmentOpsHealthBadgeText(orderShipmentAttentionCount == 0)</span>
                    </div>
                    <div class="small text-muted mt-2">
                        @T.T("CarrierReviewQueue")
                        @if (orderShipmentAttentionCount > 0)
                        {
                            <span class="ms-1">@T.T("NeedsAttention"): @orderShipmentAttentionCount</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Orders"
                       asp-action="AddShipment"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-sm btn-outline-primary"
                       hx-get="@AddShipmentUrl(Model.OrderId)"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("AddShipment")</a>
                    <a asp-controller="Orders"
                       asp-action="Refunds"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@OrderRefundsUrl(Model.OrderId)"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("ReviewRefunds")</a>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("AwaitingHandoff")</div>
                                <div class="small text-muted mt-1">@T.T("PendingPacked")</div>
                            </div>
                            <span class="@OrderShipmentOpsHealthBadgeClass(orderShipmentAwaitingHandoffCount == 0)">@orderShipmentAwaitingHandoffCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("ShippingSettings")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="AwaitingHandoff" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.AwaitingHandoff ? "btn-danger" : "btn-outline-danger")">@T.T("AwaitingHandoff")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-shipping" class="btn btn-sm btn-outline-secondary" hx-get="@ShippingSettingsUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("ShippingSettings")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("TrackingOverdue")</div>
                                <div class="small text-muted mt-1">@T.T("Tracking")</div>
                            </div>
                            <span class="@OrderShipmentOpsHealthBadgeClass(orderShipmentTrackingOverdueCount == 0)">@orderShipmentTrackingOverdueCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("Open")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="TrackingOverdue" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.TrackingOverdue ? "btn-danger" : "btn-outline-danger")">@T.T("TrackingOverdue")</a>
                            <a asp-controller="ShippingMethods" asp-action="Index" asp-route-filter="Dhl" class="btn btn-sm btn-outline-secondary" hx-get="@ShippingMethodsUrl("Dhl")" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("ShippingMethods")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("CarrierReview")</div>
                                <div class="small text-muted mt-1">@T.T("CarrierReviewQueue")</div>
                            </div>
                            <span class="@OrderShipmentOpsHealthBadgeClass(orderShipmentCarrierReviewCount == 0)">@orderShipmentCarrierReviewCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("ReviewRefunds")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="CarrierReview" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.CarrierReview ? "btn-danger" : "btn-outline-danger")">@T.T("CarrierReview")</a>
                            <a asp-controller="Orders" asp-action="Refunds" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary" hx-get="@OrderRefundsUrl(Model.OrderId)" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("ReviewRefunds")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("ReturnFollowUp")</div>
                                <div class="small text-muted mt-1">@T.T("Returned")</div>
                            </div>
                            <span class="@OrderShipmentOpsHealthBadgeClass(orderShipmentReturnFollowUpCount == 0)">@orderShipmentReturnFollowUpCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("StartRefund")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="ReturnFollowUp" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.ReturnFollowUp ? "btn-dark" : "btn-outline-dark")">@T.T("ReturnFollowUp")</a>
                            @if (Model.DefaultRefundPaymentId.HasValue)
                            {
                                <a asp-controller="Orders" asp-action="AddRefund" asp-route-orderId="@Model.OrderId" asp-route-paymentId="@Model.DefaultRefundPaymentId" class="btn btn-sm btn-outline-danger" hx-get="@AddRefundUrl(Model.OrderId, Model.DefaultRefundPaymentId)" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("StartRefund")</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-controller="Orders" asp-action="Shipments" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">@T.T("Apply")</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Pending" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Pending ? "btn-warning" : "btn-outline-warning")">@T.T("PendingPacked")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Shipped" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Shipped ? "btn-primary" : "btn-outline-primary")">@T.T("ShippedDelivered")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Returned" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Returned ? "btn-dark" : "btn-outline-dark")">@T.T("Returned")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="CarrierReview" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.CarrierReview ? "btn-danger" : "btn-outline-danger")">@T.T("CarrierReview")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="ReturnFollowUp" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.ReturnFollowUp ? "btn-dark" : "btn-outline-dark")">@T.T("ReturnFollowUp")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="AwaitingHandoff" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.AwaitingHandoff ? "btn-danger" : "btn-outline-danger")">@T.T("AwaitingHandoff")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="TrackingOverdue" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.TrackingOverdue ? "btn-danger" : "btn-outline-danger")">@T.T("TrackingOverdue")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">@T.T("Clear")</a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Carrier")</th>
                    <th>@T.T("Tracking")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("CreatedUtc")</th>
                    <th class="text-end">@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted">@T.T("NoShipments")</td></tr>
                }
                else
                {
                    foreach (var s in Model.Items)
                    {
                        var needsServiceResolution = string.IsNullOrWhiteSpace(s.Service);
                        var needsThresholdReview = s.AwaitingHandoff || s.TrackingOverdue;
                        <tr>
                            <td>
                                @s.Carrier
                                @if (s.IsDhl)
                                {
                                    <div><span class="badge text-bg-info mt-1">@T.T("Dhl")</span></div>
                                }
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(s.TrackingNumber))
                                {
                                    @:-
                                }
                                else if (!string.IsNullOrWhiteSpace(s.TrackingUrl))
                                {
                                    <a href="@s.TrackingUrl" target="_blank" rel="noopener noreferrer">@s.TrackingNumber</a>
                                    <div class="small mt-1">
                                        <a href="@s.TrackingUrl" target="_blank" rel="noopener noreferrer">@T.T("Open")</a>
                                    </div>
                                }
                                else
                                {
                                    @s.TrackingNumber
                                }
                                @if (!string.IsNullOrWhiteSpace(s.ProviderShipmentReference))
                                {
                                    <div class="small text-muted mt-1">@T.T("ProviderShipmentReference"): <code>@s.ProviderShipmentReference</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.LabelUrl))
                                {
                                    <div class="small mt-1">
                                        <a href="@s.LabelUrl" target="_blank" rel="noopener noreferrer">@T.T("CarrierLabel")</a>
                                    </div>
                                }
                                else if (s.ProviderOperationQueued)
                                {
                                    <div><span class="badge text-bg-warning mt-1">@T.T("Pending")</span></div>
                                }
                                else if (s.ProviderOperationFailed)
                                {
                                    <div><span class="badge text-bg-danger mt-1">@T.T("Failed")</span></div>
                                }
                                <div class="small text-muted mt-1">@s.TrackingState</div>
                                @if (s.TrackingOverdue)
                                {
                                    <div><span class="badge text-bg-danger mt-1">@T.T("TrackingOverdueBadge")</span></div>
                                }
                            </td>
                            <td>
                                @LocalizeShipmentStatus(s.Status)
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned)
                                {
                                    <div><span class="badge text-bg-dark mt-1">@T.T("ReturnedParcel")</span></div>
                                }
                                @if (s.AwaitingHandoff)
                                {
                                    <div><span class="badge text-bg-danger mt-1">@T.T("AwaitingHandoff")</span></div>
                                }
                                @if (s.NeedsCarrierReview)
                                {
                                    <div><span class="badge text-bg-warning mt-1">@T.T("CarrierReview")</span></div>
                                }
                                @if (s.NeedsReturnFollowUp)
                                {
                                    <div><span class="badge text-bg-dark mt-1">@T.T("ReturnFollowUp")</span></div>
                                }
                            </td>
                            <td>
                                <div>@OrderDateTimeText(s.CreatedAtUtc)</div>
                                @if (s.LastCarrierEventAtUtc.HasValue)
                                {
                                    <div class="small text-muted mt-1">@T.T("LastEvent") @OrderDateTimeText(s.LastCarrierEventAtUtc)</div>
                                }
                                @if (s.RecentCarrierEvents.Count > 0)
                                {
                                    <div class="small text-muted mt-2">
                                        @foreach (var carrierEvent in s.RecentCarrierEvents)
                                        {
                                            <div class="mt-1">
                                                <span>@OrderDateTimeText(carrierEvent.OccurredAtUtc)</span>
                                                <code>@carrierEvent.CarrierEventKey</code>
                                                @if (!string.IsNullOrWhiteSpace(carrierEvent.ProviderStatus))
                                                {
                                                    <span>(@carrierEvent.ProviderStatus)</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(carrierEvent.ExceptionCode) || !string.IsNullOrWhiteSpace(carrierEvent.ExceptionMessage))
                                                {
                                                    <div class="text-danger">
                                                        @if (!string.IsNullOrWhiteSpace(carrierEvent.ExceptionCode))
                                                        {
                                                            <code>@carrierEvent.ExceptionCode</code>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(carrierEvent.ExceptionMessage))
                                                        {
                                                            <span>@carrierEvent.ExceptionMessage</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(s.LastCarrierEventKey))
                                {
                                    <div class="small text-muted mt-1">@T.T("LastCarrierEventKey") <code>@s.LastCarrierEventKey</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.ExceptionNote))
                                {
                                    <div class="small text-danger mt-1">@s.ExceptionNote</div>
                                }
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned)
                                {
                                    <div class="small text-muted mt-1">@T.T("UseRefundRestockFollowUp")</div>
                                }
                            </td>
                            <td class="text-end">
                                @if (!string.IsNullOrWhiteSpace(s.TrackingUrl))
                                {
                                    <a href="@s.TrackingUrl"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-primary">
                                        @T.T("Tracking")
                                    </a>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.LabelUrl))
                                {
                                    <a href="@s.LabelUrl"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       class="btn btn-sm btn-outline-secondary">
                                        @T.T("CarrierLabel")
                                    </a>
                                }
                                @if (s.IsDhl && string.IsNullOrWhiteSpace(s.LabelUrl) && !s.ProviderOperationQueued)
                                {
                                    <form asp-controller="Orders"
                                          asp-action="GenerateDhlLabel"
                                          method="post"
                                          class="d-inline-block"
                                          hx-post="@Url.Action("GenerateDhlLabel", "Orders")"
                                          hx-target="#shipments-grid-content"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="shipmentId" value="@s.Id" />
                                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                                        <input type="hidden" name="returnToQueue" value="false" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            @T.T("GenerateCarrierLabel")
                                        </button>
                                    </form>
                                }
                                else if (s.IsDhl && s.ProviderOperationQueued)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning" disabled>
                                        @T.T("Pending")
                                    </button>
                                }
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned || s.NeedsCarrierReview)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            type="button"
                                            data-bs-toggle="tab"
                                            data-bs-target="#refunds">
                                        @T.T("ReviewRefunds")
                                    </button>
                                }
                                @if (s.NeedsReturnFollowUp)
                                {
                                    <a asp-controller="Orders"
                                       asp-action="Shipments"
                                       asp-route-orderId="@Model.OrderId"
                                       asp-route-filter="CarrierReview"
                                       class="btn btn-sm btn-outline-dark">
                                        @T.T("CarrierReview")
                                    </a>
                                }
                                @if (needsServiceResolution)
                                {
                                    <a asp-controller="ShippingMethods"
                                       asp-action="Index"
                                       asp-route-filter="Dhl"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@ShippingMethodsUrl("Dhl")"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("ShippingMethods")
                                    </a>
                                }
                                @if (needsThresholdReview)
                                {
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="site-settings-shipping"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@ShippingSettingsUrl()"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("ShippingSettings")
                                    </a>
                                }
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned && Model.DefaultRefundPaymentId.HasValue)
                                {
                                    <a asp-controller="Orders"
                                       asp-action="AddRefund"
                                       asp-route-orderId="@Model.OrderId"
                                       asp-route-paymentId="@Model.DefaultRefundPaymentId"
                                       class="btn btn-sm btn-outline-danger"
                                       hx-get="@AddRefundUrl(Model.OrderId, Model.DefaultRefundPaymentId)"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("StartRefund")
                                    </a>
                                }
                                @if (s.ProviderOperationFailed && !string.IsNullOrWhiteSpace(s.ProviderOperationFailureReason))
                                {
                                    <div class="small text-danger mt-1">@s.ProviderOperationFailureReason</div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Shipments"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#shipments-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
