@model Darwin.WebAdmin.ViewModels.Orders.OrderShipmentsPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T

<div id="shipments-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <form asp-controller="Orders" asp-action="Shipments" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">@T.T("Apply")</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Pending" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Pending ? "btn-warning" : "btn-outline-warning")">@T.T("PendingPacked")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Shipped" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Shipped ? "btn-primary" : "btn-outline-primary")">@T.T("ShippedDelivered")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="Returned" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.Returned ? "btn-dark" : "btn-outline-dark")">@T.T("Returned")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="CarrierReview" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.CarrierReview ? "btn-danger" : "btn-outline-danger")">@T.T("CarrierReview")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="ReturnFollowUp" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.ReturnFollowUp ? "btn-dark" : "btn-outline-dark")">@T.T("ReturnFollowUp")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="AwaitingHandoff" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.AwaitingHandoff ? "btn-danger" : "btn-outline-danger")">@T.T("AwaitingHandoff")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" asp-route-filter="TrackingOverdue" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.ShipmentQueueFilter.TrackingOverdue ? "btn-danger" : "btn-outline-danger")">@T.T("TrackingOverdue")</a>
        <a asp-controller="Orders" asp-action="Shipments" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">@T.T("Clear")</a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Carrier")</th>
                    <th>@T.T("Tracking")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("CreatedUtc")</th>
                    <th class="text-end">@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted">@T.T("NoShipments")</td></tr>
                }
                else
                {
                    foreach (var s in Model.Items)
                    {
                        var needsServiceResolution = string.IsNullOrWhiteSpace(s.Service);
                        var needsThresholdReview = s.AwaitingHandoff || s.TrackingOverdue;
                        <tr>
                            <td>
                                @s.Carrier
                                @if (s.IsDhl)
                                {
                                    <div><span class="badge text-bg-info mt-1">DHL</span></div>
                                }
                            </td>
                            <td>
                                @(string.IsNullOrWhiteSpace(s.TrackingNumber) ? "-" : s.TrackingNumber)
                                <div class="small text-muted mt-1">@s.TrackingState</div>
                                @if (s.TrackingOverdue)
                                {
                                    <div><span class="badge text-bg-danger mt-1">@T.T("TrackingOverdueBadge")</span></div>
                                }
                            </td>
                            <td>
                                @s.Status
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned)
                                {
                                    <div><span class="badge text-bg-dark mt-1">@T.T("ReturnedParcel")</span></div>
                                }
                                @if (s.AwaitingHandoff)
                                {
                                    <div><span class="badge text-bg-danger mt-1">@T.T("AwaitingHandoff")</span></div>
                                }
                                @if (s.NeedsCarrierReview)
                                {
                                    <div><span class="badge text-bg-warning mt-1">@T.T("CarrierReview")</span></div>
                                }
                                @if (s.NeedsReturnFollowUp)
                                {
                                    <div><span class="badge text-bg-dark mt-1">@T.T("ReturnFollowUp")</span></div>
                                }
                            </td>
                            <td>
                                <div>@s.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
                                @if (s.LastCarrierEventAtUtc.HasValue)
                                {
                                    <div class="small text-muted mt-1">@T.T("LastEvent") @s.LastCarrierEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.ExceptionNote))
                                {
                                    <div class="small text-danger mt-1">@s.ExceptionNote</div>
                                }
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned)
                                {
                                    <div class="small text-muted mt-1">@T.T("UseRefundRestockFollowUp")</div>
                                }
                            </td>
                            <td class="text-end">
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned || s.NeedsCarrierReview)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            type="button"
                                            data-bs-toggle="tab"
                                            data-bs-target="#refunds">
                                        @T.T("ReviewRefunds")
                                    </button>
                                }
                                @if (s.NeedsReturnFollowUp)
                                {
                                    <a asp-controller="Orders"
                                       asp-action="Shipments"
                                       asp-route-orderId="@Model.OrderId"
                                       asp-route-filter="CarrierReview"
                                       class="btn btn-sm btn-outline-dark">
                                        @T.T("CarrierReview")
                                    </a>
                                }
                                @if (needsServiceResolution)
                                {
                                    <a asp-controller="ShippingMethods"
                                       asp-action="Index"
                                       asp-route-filter="Dhl"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Index", "ShippingMethods", new { filter = "Dhl" })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("ShippingMethods")
                                    </a>
                                }
                                @if (needsThresholdReview)
                                {
                                    <a asp-controller="SiteSettings"
                                       asp-action="Edit"
                                       asp-fragment="site-settings-shipping"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("ShippingSettings")
                                    </a>
                                }
                                @if (s.Status == Darwin.Domain.Enums.ShipmentStatus.Returned && Model.DefaultRefundPaymentId.HasValue)
                                {
                                    <a asp-controller="Orders"
                                       asp-action="AddRefund"
                                       asp-route-orderId="@Model.OrderId"
                                       asp-route-paymentId="@Model.DefaultRefundPaymentId"
                                       class="btn btn-sm btn-outline-danger"
                                       hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.OrderId, paymentId = Model.DefaultRefundPaymentId })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("StartRefund")
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Shipments"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#shipments-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
