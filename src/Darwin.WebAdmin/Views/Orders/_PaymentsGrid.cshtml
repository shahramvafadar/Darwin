@model Darwin.WebAdmin.ViewModels.Orders.OrderPaymentsPageVm
@{
    // Server renders pager via TagHelper; actions stay on Details page and reload this partial via JS when needed.
}
<div id="payments-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Provider</th>
                    <th>Reference</th>
                    <th>Invoice</th>
                    <th class="text-end">Amount</th>
                    <th>Status</th>
                    <th>Paid (UTC)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted">No payments.</td></tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        <tr>
                            <td>@p.Provider</td>
                            <td>@p.ProviderReference</td>
                            <td>
                                @if (p.InvoiceId.HasValue)
                                {
                                    <code>@p.InvoiceId</code>
                                    @if (p.InvoiceStatus.HasValue)
                                    {
                                        <div class="small text-muted">@p.InvoiceStatus</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div>@p.Currency @((p.AmountMinor / 100.0M).ToString("0.00"))</div>
                                @if (p.RefundedAmountMinor > 0)
                                {
                                    <div class="small text-warning">Refunded: @p.Currency @((p.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                                }
                                <div class="small text-muted">Net: @p.Currency @((p.NetCapturedAmountMinor / 100.0M).ToString("0.00"))</div>
                            </td>
                            <td>@p.Status</td>
                            <td>@(p.PaidAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? p.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss"))</td>
                            <td class="text-end">
                                <a asp-controller="Billing" asp-action="EditPayment" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Open</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Payments"
           asp-route-orderId="@Model.OrderId">
    </pager>
</div>
