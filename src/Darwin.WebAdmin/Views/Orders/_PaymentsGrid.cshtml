@model Darwin.WebAdmin.ViewModels.Orders.OrderPaymentsPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    // Server renders pager via TagHelper; actions stay on Details page and reload this partial via JS when needed.
    var orderCulture = System.Globalization.CultureInfo.CurrentCulture;
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalRefundsUrl() => Url.Action("Refunds", "Billing") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string GlobalBillingWebhooksUrl() => Url.Action("Webhooks", "Billing") ?? string.Empty;
    string AddPaymentUrl(Guid orderId) => Url.Action("AddPayment", "Orders", new { orderId }) ?? string.Empty;
    string CreateInvoiceUrl(Guid orderId) => Url.Action("CreateInvoice", "Orders", new { orderId }) ?? string.Empty;
    string EditPaymentUrl(Guid id) => Url.Action("EditPayment", "Billing", new { id }) ?? string.Empty;
    string AddRefundUrl(Guid orderId, Guid paymentId) => Url.Action("AddRefund", "Orders", new { orderId, paymentId }) ?? string.Empty;
    string LocalizePaymentStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string OrderDateTimeText(DateTime? utc) => utc?.ToString("g", orderCulture) ?? "-";
    string OrderPaymentOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string OrderPaymentOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var orderPaymentFailedCount = Model.Items.Count(item => item.Status == Darwin.Domain.Enums.PaymentStatus.Failed);
    var orderPaymentRefundedCount = Model.Items.Count(item => item.RefundedAmountMinor > 0);
    var orderPaymentUnlinkedInvoiceCount = Model.Items.Count(item => !item.InvoiceId.HasValue);
    var orderPaymentProviderFollowUpCount = Model.Items.Count(item => string.IsNullOrWhiteSpace(item.ProviderReference) || item.Status == Darwin.Domain.Enums.PaymentStatus.Pending);
    var orderPaymentAttentionCount = orderPaymentFailedCount + orderPaymentRefundedCount + orderPaymentUnlinkedInvoiceCount + orderPaymentProviderFollowUpCount;
}
<div id="payments-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="fw-semibold">@T.T("Payment")</div>
                        <span class="@OrderPaymentOpsHealthBadgeClass(orderPaymentAttentionCount == 0)">@OrderPaymentOpsHealthBadgeText(orderPaymentAttentionCount == 0)</span>
                    </div>
                    <div class="small text-muted mt-2">
                        @T.T("Invoice")
                        @if (orderPaymentAttentionCount > 0)
                        {
                            <span class="ms-1">@T.T("NeedsAttention"): @orderPaymentAttentionCount</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Orders"
                       asp-action="AddPayment"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-sm btn-outline-primary"
                       hx-get="@AddPaymentUrl(Model.OrderId)"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("Payment")</a>
                    <a asp-controller="Billing"
                       asp-action="Payments"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@GlobalPaymentsUrl()"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("Payments")</a>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Failed")</div>
                                <div class="small text-muted mt-1">@T.T("Payment")</div>
                            </div>
                            <span class="@OrderPaymentOpsHealthBadgeClass(orderPaymentFailedCount == 0)">@orderPaymentFailedCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("NeedsAttention")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Payments" asp-route-orderId="@Model.OrderId" asp-route-filter="Failed" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.PaymentQueueFilter.Failed ? "btn-danger" : "btn-outline-danger")">@T.T("Failed")</a>
                            <a asp-controller="Billing" asp-action="Payments" class="btn btn-sm btn-outline-secondary" hx-get="@GlobalPaymentsUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Payments")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Refunded")</div>
                                <div class="small text-muted mt-1">@T.T("Refund")</div>
                            </div>
                            <span class="@OrderPaymentOpsHealthBadgeClass(orderPaymentRefundedCount == 0)">@orderPaymentRefundedCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Payments" asp-route-orderId="@Model.OrderId" asp-route-filter="Refunded" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.PaymentQueueFilter.Refunded ? "btn-warning" : "btn-outline-warning")">@T.T("Refunded")</a>
                            <a asp-controller="Billing" asp-action="Refunds" class="btn btn-sm btn-outline-secondary" hx-get="@GlobalRefundsUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Refund")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Invoice")</div>
                                <div class="small text-muted mt-1">@T.T("Unlinked")</div>
                            </div>
                            <span class="@OrderPaymentOpsHealthBadgeClass(orderPaymentUnlinkedInvoiceCount == 0)">@orderPaymentUnlinkedInvoiceCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("ReviewInvoices")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="CreateInvoice" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-primary" hx-get="@CreateInvoiceUrl(Model.OrderId)" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("CreateInvoice")</a>
                            <a asp-controller="Crm" asp-action="Invoices" class="btn btn-sm btn-outline-secondary" hx-get="@GlobalInvoicesUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("ReviewInvoices")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Reference")</div>
                                <div class="small text-muted mt-1">@T.T("Provider")</div>
                            </div>
                            <span class="@OrderPaymentOpsHealthBadgeClass(orderPaymentProviderFollowUpCount == 0)">@orderPaymentProviderFollowUpCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("Open")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Billing" asp-action="Payments" class="btn btn-sm btn-outline-secondary" hx-get="@GlobalPaymentsUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Payments")</a>
            <a asp-controller="Billing" asp-action="Webhooks" class="btn btn-sm btn-outline-secondary" hx-get="@GlobalBillingWebhooksUrl()" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Open")</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-controller="Orders" asp-action="Payments" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">@T.T("Apply")</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Payments" asp-route-orderId="@Model.OrderId" asp-route-filter="Failed" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.PaymentQueueFilter.Failed ? "btn-danger" : "btn-outline-danger")">@T.T("Failed")</a>
        <a asp-controller="Orders" asp-action="Payments" asp-route-orderId="@Model.OrderId" asp-route-filter="Refunded" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.PaymentQueueFilter.Refunded ? "btn-warning" : "btn-outline-warning")">@T.T("Refunded")</a>
        <a asp-controller="Orders" asp-action="Payments" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">@T.T("Clear")</a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Provider")</th>
                    <th>@T.T("Reference")</th>
                    <th>@T.T("Invoice")</th>
                    <th class="text-end">@T.T("Amount")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("PaidUtc")</th>
                    <th class="text-end">@T.T("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted">@T.T("NoPayments")</td></tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        <tr>
                            <td>@p.Provider</td>
                            <td>@p.ProviderReference</td>
                            <td>
                                @if (p.InvoiceId.HasValue)
                                {
                                    <code>@p.InvoiceId</code>
                                @if (p.InvoiceStatus.HasValue)
                                {
                                    <div class="small text-muted">@LocalizeInvoiceStatus(p.InvoiceStatus)</div>
                                }
                            }
                            else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div>@p.Currency @((p.AmountMinor / 100.0M).ToString("0.00"))</div>
                                @if (p.RefundedAmountMinor > 0)
                                {
                                    <div class="small text-warning">@T.T("Refunded"): @p.Currency @((p.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                                }
                                <div class="small text-muted">@T.T("Net"): @p.Currency @((p.NetCapturedAmountMinor / 100.0M).ToString("0.00"))</div>
                            </td>
                            <td>@LocalizePaymentStatus(p.Status)</td>
                            <td>@(p.PaidAtUtc.HasValue ? OrderDateTimeText(p.PaidAtUtc) : OrderDateTimeText(p.CreatedAtUtc))</td>
                            <td class="text-end">
                                <a asp-controller="Billing"
                                   asp-action="EditPayment"
                                   asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@EditPaymentUrl(p.Id)"
                                   hx-target="#order-operation-shell"
                                   hx-swap="innerHTML"
                                   hx-push-url="false">
                                    @T.T("Open")
                                </a>
                                <a asp-controller="Orders"
                                   asp-action="AddRefund"
                                   asp-route-orderId="@Model.OrderId"
                                   asp-route-paymentId="@p.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   hx-get="@AddRefundUrl(Model.OrderId, p.Id)"
                                   hx-target="#order-operation-shell"
                                   hx-swap="innerHTML"
                                   hx-push-url="false">
                                    @T.T("Refund")
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Payments"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#payments-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
