@model Darwin.WebAdmin.ViewModels.Orders.OrderRefundsPageVm

<div id="refunds-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <form asp-controller="Orders" asp-action="Refunds" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">Apply</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Refunds" asp-route-orderId="@Model.OrderId" asp-route-filter="Pending" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.RefundQueueFilter.Pending ? "btn-warning" : "btn-outline-warning")">Pending</a>
        <a asp-controller="Orders" asp-action="Refunds" asp-route-orderId="@Model.OrderId" asp-route-filter="Completed" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.RefundQueueFilter.Completed ? "btn-success" : "btn-outline-success")">Completed</a>
        <a asp-controller="Orders" asp-action="Refunds" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">Clear</a>
    </div>
    @if (Model.ReturnedShipmentCount > 0)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-start gap-3">
            <div>
                <div class="fw-semibold">Returned shipment follow-up is open on this order.</div>
                <div class="small mb-0">Returned shipments: @Model.ReturnedShipmentCount. Use the shipment tab to confirm carrier state, then record the refund from this order.</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="tab" data-bs-target="#shipments">Review Shipments</button>
                @if (Model.DefaultRefundPaymentId.HasValue)
                {
                    <a asp-controller="Orders"
                       asp-action="AddRefund"
                       asp-route-orderId="@Model.OrderId"
                       asp-route-paymentId="@Model.DefaultRefundPaymentId"
                       class="btn btn-sm btn-danger"
                       hx-get="@Url.Action("AddRefund", "Orders", new { orderId = Model.OrderId, paymentId = Model.DefaultRefundPaymentId })"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">
                        Start Return Refund
                    </a>
                }
            </div>
        </div>
    }
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Payment</th>
                    <th>Reason</th>
                    <th class="text-end">Amount</th>
                    <th>Status</th>
                    <th>Created (UTC)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted">No refunds.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.PaymentProvider</div>
                                <div class="small text-muted">@item.PaymentProviderReference</div>
                                <div class="small text-muted">Payment status: @item.PaymentStatus</div>
                            </td>
                            <td>@item.Reason</td>
                            <td class="text-end">@item.Currency @((item.AmountMinor / 100.0M).ToString("0.00"))</td>
                            <td>@item.Status</td>
                            <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="text-end">
                                <a asp-controller="Billing"
                                   asp-action="EditPayment"
                                   asp-route-id="@item.PaymentId"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("EditPayment", "Billing", new { id = item.PaymentId })"
                                   hx-target="#order-operation-shell"
                                   hx-swap="innerHTML"
                                   hx-push-url="false">
                                    Payment
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Refunds"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#refunds-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
