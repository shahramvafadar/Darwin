@model Darwin.WebAdmin.ViewModels.Orders.OrdersListVm
@{
    ViewData["Title"] = "Orders";
}

<h1 class="mb-3"><i class="fa fa-receipt"></i> Orders</h1>

<partial name="~/Views/Shared/_Alerts.cshtml" />

<form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
    <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by order number or currency" />
    <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    <button class="btn btn-outline-secondary" type="submit">
        <i class="fa fa-search"></i> Search
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Index" asp-route-filter="Open" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.Open ? "btn-primary" : "btn-outline-primary")">Open</a>
    <a asp-action="Index" asp-route-filter="PaymentIssues" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.PaymentIssues ? "btn-danger" : "btn-outline-danger")">Payment Issues</a>
    <a asp-action="Index" asp-route-filter="FulfillmentAttention" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.FulfillmentAttention ? "btn-warning" : "btn-outline-warning")">Fulfillment Attention</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear Queue Filters</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Status</th>
                <th>Total</th>
                <th>Ops</th>
                <th>Created (UTC)</th>
                <th class="text-end" style="width:160px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted">No orders.</td></tr>
            }
            else
            {
                foreach (var o in Model.Items)
                {
                    <tr>
                        <td>@o.OrderNumber</td>
                        <td>@o.Status</td>
                        <td>@o.Currency @((o.GrandTotalGrossMinor / 100.0M).ToString("0.00"))</td>
                        <td>
                            <div class="small text-muted d-flex flex-column">
                                <span>Payments: @o.PaymentCount</span>
                                <span>Failed: @o.FailedPaymentCount</span>
                                <span>Shipments: @o.ShipmentCount</span>
                            </div>
                        </td>
                        <td>@o.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td class="text-end">
                            @if (o.FailedPaymentCount > 0 || Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.PaymentIssues)
                            {
                                <a asp-controller="Orders" asp-action="AddPayment" asp-route-orderId="@o.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="fa fa-credit-card"></i> Payment
                                </a>
                            }
                            @if (o.Status == Darwin.Domain.Enums.OrderStatus.Paid || Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.FulfillmentAttention)
                            {
                                <a asp-controller="Orders" asp-action="AddShipment" asp-route-orderId="@o.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-truck"></i> Shipment
                                </a>
                            }
                            @if (o.PaymentCount > 0)
                            {
                                <a asp-controller="Orders" asp-action="CreateInvoice" asp-route-orderId="@o.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-file-invoice"></i> Invoice
                                </a>
                            }
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Orders"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter">
</pager>
