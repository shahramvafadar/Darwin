@model Darwin.WebAdmin.ViewModels.Orders.OrdersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("OrdersTitle");
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalRefundsUrl() => Url.Action("Refunds", "Billing") ?? string.Empty;
    string GlobalShipmentsQueueUrl() => Url.Action("ShipmentsQueue", "Orders") ?? string.Empty;
    string GlobalReturnsQueueUrl() => Url.Action("ReturnsQueue", "Orders") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string GlobalOrdersIndexUrl() => Url.Action("Index", "Orders") ?? string.Empty;
    string OrdersIndexUrl(string? query = null, string? filter = null) => Url.Action("Index", "Orders", new { query, filter }) ?? string.Empty;
    string AddPaymentUrl(Guid orderId) => Url.Action("AddPayment", "Orders", new { orderId }) ?? string.Empty;
    string AddShipmentUrl(Guid orderId) => Url.Action("AddShipment", "Orders", new { orderId }) ?? string.Empty;
    string CreateInvoiceUrl(Guid orderId) => Url.Action("CreateInvoice", "Orders", new { orderId }) ?? string.Empty;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
    var orderCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeOrderStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string OrderDateTimeText(DateTime utc) => utc.ToString("g", orderCulture);
    string OrderQueueOpsHealthBadgeClass(bool healthy) => healthy ? "text-bg-success" : "text-bg-warning";
    string OrderQueueOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var paymentIssueCount = Model.Items.Count(o => o.FailedPaymentCount > 0);
    var fulfillmentAttentionCount = Model.Items.Count(o => o.Status == Darwin.Domain.Enums.OrderStatus.Paid && o.ShipmentCount == 0);
    var invoiceReadyCount = Model.Items.Count(o => o.PaymentCount > 0);
    var activeOrderCount = Model.Items.Count(o => o.Status != Darwin.Domain.Enums.OrderStatus.Completed && o.Status != Darwin.Domain.Enums.OrderStatus.Cancelled);
    var orderQueueAttentionCount = paymentIssueCount + fulfillmentAttentionCount;
}

<div id="orders-workspace-shell">
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><i class="fa fa-receipt"></i> @T.T("OrdersTitle")</h1>
    <a asp-controller="Orders"
       asp-action="ShipmentsQueue"
       hx-get="@GlobalShipmentsQueueUrl()"
       hx-target="#orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("ShipmentsQueue")</a>
    <a asp-controller="Orders"
       asp-action="ReturnsQueue"
       hx-get="@GlobalReturnsQueueUrl()"
       hx-target="#orders-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true"
       class="btn btn-outline-secondary">@T.T("ReturnsQueueTitle")</a>
</div>

<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @OrderQueueOpsHealthBadgeClass(orderQueueAttentionCount == 0)">@OrderQueueOpsHealthBadgeText(orderQueueAttentionCount == 0)</span>
                    <span class="badge @OrderQueueOpsHealthBadgeClass(Model.Items.Count > 0)">@T.T("OpenQueue")</span>
                </div>
                <h2 class="h5 mb-1">@T.T("OrdersTitle")</h2>
                <p class="text-muted mb-0">@T.T("ClearQueueFilters")</p>
            </div>
            <div class="text-md-end">
                <div class="small text-muted">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@orderQueueAttentionCount</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("OpenQueue")</span>
                        <span class="badge @OrderQueueOpsHealthBadgeClass(activeOrderCount == 0)">@activeOrderCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("OrdersTitle")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="Open"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@OrdersIndexUrl(Model.Query, "Open")"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="ShipmentsQueue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalShipmentsQueueUrl()"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ShipmentsQueue")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("PaymentIssues")</span>
                        <span class="badge @OrderQueueOpsHealthBadgeClass(paymentIssueCount == 0)">@paymentIssueCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("Payments") / @T.T("Invoice")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="PaymentIssues"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@OrdersIndexUrl(Model.Query, "PaymentIssues")"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="Billing"
                           asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalPaymentsUrl()"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Payments")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("FulfillmentAttention")</span>
                        <span class="badge @OrderQueueOpsHealthBadgeClass(fulfillmentAttentionCount == 0)">@fulfillmentAttentionCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("Shipment") / @T.T("ShipmentsQueue")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index"
                           asp-route-filter="FulfillmentAttention"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@OrdersIndexUrl(Model.Query, "FulfillmentAttention")"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="ReturnsQueue"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalReturnsQueueUrl()"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReturnsQueueTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("Invoice")</span>
                        <span class="badge @OrderQueueOpsHealthBadgeClass(invoiceReadyCount == 0)">@invoiceReadyCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("CreateInvoice") / @T.T("ReturnsQueueTitle")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Crm"
                           asp-action="Invoices"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalInvoicesUrl()"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Invoice")</a>
                        <a asp-controller="Billing"
                           asp-action="Refunds"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalRefundsUrl()"
                           hx-target="#orders-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Refunds")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<form asp-action="Index" method="get" class="d-flex gap-2 mb-3"
          hx-get="@GlobalOrdersIndexUrl()"
      hx-target="#orders-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchOrdersPlaceholder")" />
    <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    <button class="btn btn-outline-secondary" type="submit">
        <i class="fa fa-search"></i> @T.T("Search")
    </button>
    <a asp-action="Index" hx-get="@GlobalOrdersIndexUrl()" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Reset")</a>
</form>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Index" asp-route-filter="Open" hx-get="@OrdersIndexUrl(Model.Query, "Open")" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.Open ? "btn-primary" : "btn-outline-primary")">@T.T("OpenQueue")</a>
    <a asp-action="Index" asp-route-filter="PaymentIssues" hx-get="@OrdersIndexUrl(Model.Query, "PaymentIssues")" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.PaymentIssues ? "btn-danger" : "btn-outline-danger")">@T.T("PaymentIssues")</a>
    <a asp-action="Index" asp-route-filter="FulfillmentAttention" hx-get="@OrdersIndexUrl(Model.Query, "FulfillmentAttention")" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.FulfillmentAttention ? "btn-warning" : "btn-outline-warning")">@T.T("FulfillmentAttention")</a>
    <a asp-action="Index" hx-get="@OrdersIndexUrl(Model.Query)" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Total")</th>
                <th>@T.T("Ops")</th>
                <th>@T.T("CreatedUtc")</th>
                    <th class="text-end admin-w-160">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted">@T.T("NoOrders")</td></tr>
            }
            else
            {
                foreach (var o in Model.Items)
                {
                    <tr>
                        <td>@o.OrderNumber</td>
                        <td>@LocalizeOrderStatus(o.Status)</td>
                        <td>@o.Currency @((o.GrandTotalGrossMinor / 100.0M).ToString("0.00"))</td>
                        <td>
                            <div class="small text-muted d-flex flex-column">
                                <span>@T.T("PaymentsCount"): @o.PaymentCount</span>
                                <span>@T.T("FailedCount"): @o.FailedPaymentCount</span>
                                <span>@T.T("ShipmentsCount"): @o.ShipmentCount</span>
                            </div>
                        </td>
                        <td>@OrderDateTimeText(o.CreatedAtUtc)</td>
                        <td class="text-end">
                            @if (o.FailedPaymentCount > 0 || Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.PaymentIssues)
                            {
                                <a asp-controller="Orders" asp-action="AddPayment" asp-route-orderId="@o.Id" hx-get="@AddPaymentUrl(o.Id)" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-danger">
                                    <i class="fa fa-credit-card"></i> @T.T("Payments")
                                </a>
                            }
                            @if (o.Status == Darwin.Domain.Enums.OrderStatus.Paid || Model.Filter == Darwin.Application.Orders.DTOs.OrderQueueFilter.FulfillmentAttention)
                            {
                                <a asp-controller="Orders" asp-action="AddShipment" asp-route-orderId="@o.Id" hx-get="@AddShipmentUrl(o.Id)" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-truck"></i> @T.T("Shipment")
                                </a>
                            }
                            @if (o.PaymentCount > 0)
                            {
                                <a asp-controller="Orders" asp-action="CreateInvoice" asp-route-orderId="@o.Id" hx-get="@CreateInvoiceUrl(o.Id)" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">
                                    <i class="fa fa-file-invoice"></i> @T.T("Invoice")
                                </a>
                            }
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" hx-get="@OrderDetailsUrl(o.Id)" hx-target="#orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-eye"></i> @T.T("View")
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Orders"
       asp-action="Index"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#orders-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
