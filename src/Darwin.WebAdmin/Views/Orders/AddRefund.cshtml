@model Darwin.WebAdmin.ViewModels.Orders.RefundCreateVm
@{
    ViewData["Title"] = "Add Refund";
    var header = ViewBag.OrderHeader as Darwin.WebAdmin.ViewModels.Orders.OrderHeaderVm;
}

<h1 class="mb-3"><i class="fa fa-rotate-left"></i> Add Refund</h1>

@if (header is not null)
{
    <div class="alert alert-info">
        <strong>Order:</strong> @header.OrderNumber
    </div>
}

<form asp-action="AddRefund" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="OrderId" />
    <div class="col-md-6">
        <label asp-for="PaymentId" class="form-label"></label>
        <select asp-for="PaymentId" asp-items="Model.PaymentOptions" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="AmountMinor" class="form-label"></label>
        <input asp-for="AmountMinor" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Currency" class="form-label"></label>
        <input asp-for="Currency" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Reason" class="form-label"></label>
        <input asp-for="Reason" class="form-control" />
    </div>
    <div class="col-12">
        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary">Back</a>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
