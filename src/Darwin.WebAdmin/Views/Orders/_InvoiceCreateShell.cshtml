@model Darwin.WebAdmin.ViewModels.Orders.OrderInvoiceCreateVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var header = ViewData["OrderHeader"] as Darwin.WebAdmin.ViewModels.Orders.OrderHeaderVm;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
}

<div id="order-invoice-shell" class="card mb-3">
    <div class="card-body">
        <h2 class="h4 mb-3"><i class="fa fa-file-invoice"></i> @T.T("CreateInvoice")</h2>

        @if (header is not null)
        {
            <div class="alert alert-info">
                <strong>@T.T("Order"):</strong> @header.OrderNumber
            </div>
        }

        <form asp-action="CreateInvoice"
              method="post"
              hx-post="@Url.Action("CreateInvoice", "Orders")"
              hx-target="#order-invoice-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OrderId" />

            <section class="admin-form-section">
                <h2 class="admin-form-section-title">@T.T("OrderInvoiceLinksSection")</h2>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="BusinessId" class="form-label"></label>
                        <field-help title="@T.T("Business")" content="@T.T("OrderInvoiceBusinessHelp")" placement="right"></field-help>
                        <select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label"></label>
                        <field-help title="@T.T("Customer")" content="@T.T("OrderInvoiceCustomerHelp")" placement="right"></field-help>
                        <select asp-for="CustomerId" asp-items="Model.CustomerOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PaymentId" class="form-label"></label>
                        <field-help title="@T.T("Payment")" content="@T.T("OrderInvoicePaymentHelp")" placement="right"></field-help>
                        <select asp-for="PaymentId" asp-items="Model.PaymentOptions" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DueAtUtc" class="form-label"></label>
                        <field-help title="@T.T("DueAtUtc")" content="@T.T("OrderInvoiceDueAtUtcHelp")" placement="right"></field-help>
                        <input asp-for="DueAtUtc" type="datetime-local" class="form-control" />
                        <span asp-validation-for="DueAtUtc" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <div class="d-flex gap-2">
                <a asp-action="Details" asp-route-id="@Model.OrderId" hx-get="@OrderDetailsUrl(Model.OrderId)" hx-target="#order-details-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Back")</a>
                <button type="submit" class="btn btn-primary">@T.T("CreateInvoice")</button>
            </div>
        </form>
    </div>
</div>
