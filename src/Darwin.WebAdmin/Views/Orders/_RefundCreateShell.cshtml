@model Darwin.WebAdmin.ViewModels.Orders.RefundCreateVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var header = ViewData["OrderHeader"] as Darwin.WebAdmin.ViewModels.Orders.OrderHeaderVm;
    string OrderDetailsUrl(Guid id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
}

<div id="order-refund-shell" class="card mb-3">
    <div class="card-body">
        <h2 class="h4 mb-3"><i class="fa fa-rotate-left"></i> @T.T("AddRefund")</h2>

        @if (header is not null)
        {
            <div class="alert alert-info">
                <strong>@T.T("Order"):</strong> @header.OrderNumber
            </div>
        }

        <form asp-action="AddRefund"
              method="post"
              hx-post="@Url.Action("AddRefund", "Orders")"
              hx-target="#order-refund-shell"
              hx-swap="outerHTML">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OrderId" />

            <section class="admin-form-section">
                <h2 class="admin-form-section-title">@T.T("OrderRefundDetailsSection")</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="PaymentId" class="form-label"></label>
                        <field-help title="@T.T("Payment")" content="@T.T("OrderRefundPaymentHelp")" placement="right"></field-help>
                        <select asp-for="PaymentId" asp-items="Model.PaymentOptions" class="form-select"></select>
                        <span asp-validation-for="PaymentId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="AmountMinor" class="form-label"></label>
                        <field-help title="@T.T("AmountMinor")" content="@T.T("OrderRefundAmountMinorHelp")" placement="right"></field-help>
                        <input asp-for="AmountMinor" class="form-control" />
                        <span asp-validation-for="AmountMinor" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Currency" class="form-label"></label>
                        <field-help title="@T.T("Currency")" content="@T.T("OrderRefundCurrencyHelp")" placement="right"></field-help>
                        <input asp-for="Currency" class="form-control" />
                        <span asp-validation-for="Currency" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Reason" class="form-label"></label>
                        <field-help title="@T.T("Reason")" content="@T.T("OrderRefundReasonHelp")" placement="right"></field-help>
                        <input asp-for="Reason" class="form-control" />
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <div class="d-flex gap-2">
                <a asp-action="Details" asp-route-id="@Model.OrderId" hx-get="@OrderDetailsUrl(Model.OrderId)" hx-target="#order-details-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Back")</a>
                <button type="submit" class="btn btn-primary">@T.T("Save")</button>
            </div>
        </form>
    </div>
</div>
