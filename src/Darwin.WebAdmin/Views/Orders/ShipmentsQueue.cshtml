@using Darwin.Application.Orders.DTOs
@model Darwin.WebAdmin.ViewModels.Orders.ShipmentsQueueVm
@{
    ViewData["Title"] = "Shipments";
}

<div id="shipments-queue-workspace-shell">
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-truck me-2"></i>Shipment Queue</h1>
        <p class="text-muted mb-0">Cross-order shipment review for pending packing, shipped items, and carrier/tracking follow-up.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ShipmentsQueue" asp-route-filter="Pending" class="btn btn-outline-warning btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Pending })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Pending/Packed</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Shipped" class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Shipped })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Shipped/Delivered</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="MissingTracking" class="btn btn-outline-info btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.MissingTracking })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Missing Tracking</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Returned" class="btn btn-outline-dark btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Returned })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Returned</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Dhl" class="btn btn-outline-primary btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Dhl })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">DHL</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="MissingService" class="btn btn-outline-warning btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.MissingService })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Missing Service</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="AwaitingHandoff" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.AwaitingHandoff })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Awaiting Handoff</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="TrackingOverdue" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.TrackingOverdue })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Tracking Overdue</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="CarrierReview" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.CarrierReview })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Carrier Review</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="ReturnFollowUp" class="btn btn-outline-dark btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.ReturnFollowUp })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Return Follow-up</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Pending / Packed</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Shipped / Delivered</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ShippedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Tracking</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingTrackingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Returned</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ReturnedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">DHL Rows</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DhlCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Service</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingServiceCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Awaiting Handoff</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AwaitingHandoffCount</div>
            <div class="small text-muted mt-1">Threshold: @Model.Dhl.ShipmentAttentionDelayHours h</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Tracking Overdue</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TrackingOverdueCount</div>
            <div class="small text-muted mt-1">Grace: @Model.Dhl.ShipmentTrackingGraceHours h</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Carrier Review</div>
            <div class="fs-4 fw-semibold">@Model.Summary.CarrierReviewCount</div>
            <div class="small text-muted mt-1">DHL exception follow-up</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Return Follow-up</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ReturnFollowUpCount</div>
            <div class="small text-muted mt-1">Returned parcels needing refund or carrier completion</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>DHL Phase-1 Readiness</span>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-shipping" class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Open Shipping Settings</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Enabled</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.Enabled ? "Yes" : "No")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">API Base URL</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ApiBaseUrlConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">API Credentials</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ApiCredentialsConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Account Number</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.AccountNumberConfigured ? "Configured" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Environment</div>
                    <div class="fw-semibold mt-1">@Model.Dhl.EnvironmentLabel</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Shipper Identity</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ShipperIdentityConfigured ? "Ready" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Handoff Delay</div>
                    <div class="fw-semibold mt-1">@Model.Dhl.ShipmentAttentionDelayHours h</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Tracking Grace</div>
                    <div class="fw-semibold mt-1">@Model.Dhl.ShipmentTrackingGraceHours h</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Phase-1 Shipment Support Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                        <th>Settings Dependency</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                        <td>@item.SettingsDependency</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("ShipmentsQueue", "Orders")"
      hx-target="#shipments-queue-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by order, carrier, service, or tracking" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="pageSize" asp-items="Model.PageSizeItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
        <a asp-action="ShipmentsQueue" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ShipmentsQueue", "Orders")" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>Order</th>
                <th>Carrier / Service</th>
                <th>Tracking</th>
                <th>Weight</th>
                <th>Status</th>
                <th>Timeline</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted py-4">No shipments found.</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var needsServiceResolution = string.IsNullOrWhiteSpace(item.Service);
                var needsThresholdReview = item.AwaitingHandoff || item.TrackingOverdue;
                <tr>
                    <td>
                        <div class="fw-semibold">@item.OrderNumber</div>
                        <div class="small text-muted">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                    </td>
                    <td>
                        @item.Carrier / @(string.IsNullOrWhiteSpace(item.Service) ? "-" : item.Service)
                    </td>
                    <td>
                        @(string.IsNullOrWhiteSpace(item.TrackingNumber) ? "-" : item.TrackingNumber)
                        <div class="small text-muted mt-1">@item.TrackingState</div>
                        @if (item.NeedsCarrierReview)
                        {
                            <div><span class="badge text-bg-warning mt-1">Needs carrier review</span></div>
                        }
                        @if (item.NeedsReturnFollowUp)
                        {
                            <div><span class="badge text-bg-dark mt-1">Return follow-up</span></div>
                        }
                        @if (item.TrackingOverdue)
                        {
                            <div><span class="badge text-bg-danger mt-1">Tracking overdue</span></div>
                        }
                    </td>
                    <td>@item.TotalWeight</td>
                    <td>
                        <span class="badge text-bg-@(item.Status == Darwin.Domain.Enums.ShipmentStatus.Delivered ? "success" : item.Status == Darwin.Domain.Enums.ShipmentStatus.Shipped ? "primary" : "warning")">
                            @item.Status
                        </span>
                        @if (item.IsDhl)
                        {
                            <div><span class="badge text-bg-info mt-1">DHL</span></div>
                        }
                        @if (item.AwaitingHandoff)
                        {
                            <div><span class="badge text-bg-danger mt-1">Awaiting handoff</span></div>
                        }
                    </td>
                    <td>
                        @if (item.DeliveredAtUtc.HasValue)
                        {
                            <span>Delivered @item.DeliveredAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                        else if (item.ShippedAtUtc.HasValue)
                        {
                            <span>Shipped @item.ShippedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                        else
                        {
                            <span class="text-muted">Not yet handed over</span>
                            <div class="small text-muted mt-1">Open for @item.OpenAgeHours h</div>
                            @if (item.AwaitingHandoff)
                            {
                                <div class="small text-danger mt-1">Older than @item.AttentionDelayHours h threshold</div>
                            }
                        }
                        @if (item.InTransitAgeHours.HasValue)
                        {
                            <div class="small text-muted mt-1">In transit for @item.InTransitAgeHours.Value h</div>
                        }
                        @if (item.LastCarrierEventAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">Last event @item.LastCarrierEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (item.TrackingOverdue)
                        {
                            <div class="small text-danger mt-1">Missing tracking beyond @item.TrackingGraceHours h grace</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ExceptionNote))
                        {
                            <div class="small text-danger mt-1">@item.ExceptionNote</div>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="shipments" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                <i class="fa-solid fa-receipt"></i> Order
                            </a>
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Returned || item.NeedsCarrierReview)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                    <i class="fa-solid fa-rotate-left"></i> Refunds
                                </a>
                            }
                            @if (item.NeedsReturnFollowUp)
                            {
                                <a asp-action="ShipmentsQueue"
                                   asp-route-filter="@ShipmentQueueFilter.CarrierReview"
                                   class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.CarrierReview })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-triangle-exclamation"></i> Carrier Review Queue
                                </a>
                            }
                            @if (needsServiceResolution)
                            {
                                <a asp-controller="ShippingMethods"
                                   asp-action="Index"
                                   asp-route-filter="Dhl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "ShippingMethods", new { filter = "Dhl" })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-box"></i> Shipping Methods
                                </a>
                            }
                            @if (needsThresholdReview)
                            {
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-shipping"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-sliders"></i> Shipping Settings
                                </a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Returned && item.DefaultRefundPaymentId.HasValue)
                            {
                                <a asp-controller="Orders"
                                   asp-action="AddRefund"
                                   asp-route-orderId="@item.OrderId"
                                   asp-route-paymentId="@item.DefaultRefundPaymentId"
                                   class="btn btn-sm btn-danger"
                                   hx-get="@Url.Action("AddRefund", "Orders", new { orderId = item.OrderId, paymentId = item.DefaultRefundPaymentId })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-rotate-left"></i> Start Return Refund
                                </a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Pending || item.Status == Darwin.Domain.Enums.ShipmentStatus.Packed)
                            {
                                <a asp-controller="Orders" asp-action="AddShipment" asp-route-orderId="@item.OrderId" class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("AddShipment", "Orders", new { orderId = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                    <i class="fa-solid fa-plus"></i> Add Shipment
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Orders"
       asp-action="ShipmentsQueue"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#shipments-queue-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
