@using Darwin.Application.Orders.DTOs
@model Darwin.WebAdmin.ViewModels.Orders.ShipmentsQueueVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Shipments");
}

<div id="shipments-queue-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1"><i class="fa-solid fa-truck me-2"></i>@T.T("ShipmentQueueTitle")</h1>
        <p class="text-muted mb-0">@T.T("ShipmentQueueIntro")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ShipmentsQueue" asp-route-filter="Pending" class="btn btn-outline-warning btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Pending })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("PendingPacked")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Shipped" class="btn btn-outline-secondary btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Shipped })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("ShippedDelivered")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="MissingTracking" class="btn btn-outline-info btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.MissingTracking })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("MissingTracking")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Returned" class="btn btn-outline-dark btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Returned })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("Returned")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="Dhl" class="btn btn-outline-primary btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.Dhl })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("DhlMethods")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="MissingService" class="btn btn-outline-warning btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.MissingService })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("MissingService")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="AwaitingHandoff" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.AwaitingHandoff })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("AwaitingHandoff")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="TrackingOverdue" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.TrackingOverdue })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("TrackingOverdue")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="CarrierReview" class="btn btn-outline-danger btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.CarrierReview })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("CarrierReview")</a>
        <a asp-action="ShipmentsQueue" asp-route-filter="ReturnFollowUp" class="btn btn-outline-dark btn-sm"
           hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.ReturnFollowUp })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("ReturnFollowUp")</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("PendingPacked")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.PendingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ShippedDelivered")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ShippedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingTracking")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingTrackingCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("Returned")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ReturnedCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("DhlRows")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.DhlCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("MissingService")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingServiceCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("AwaitingHandoff")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.AwaitingHandoffCount</div>
            <div class="small text-muted mt-1">@T.T("Threshold"): @Model.Dhl.ShipmentAttentionDelayHours h</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("TrackingOverdue")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TrackingOverdueCount</div>
            <div class="small text-muted mt-1">@T.T("Grace"): @Model.Dhl.ShipmentTrackingGraceHours h</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("CarrierReview")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.CarrierReviewCount</div>
            <div class="small text-muted mt-1">@T.T("DhlExceptionFollowUp")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">@T.T("ReturnFollowUp")</div>
            <div class="fs-4 fw-semibold">@Model.Summary.ReturnFollowUpCount</div>
            <div class="small text-muted mt-1">@T.T("ReturnedParcelsNeedFollowUp")</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("DhlPhaseOneReadiness")</span>
        <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-shipping" class="btn btn-sm btn-outline-secondary"
           hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("OpenShippingSettings")</a>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Enabled")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.Enabled ? T.T("Yes") : T.T("No"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ApiBaseUrl")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ApiBaseUrlConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ApiCredentials")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ApiCredentialsConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("AccountNumber")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.AccountNumberConfigured ? T.T("Configured") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("Environment")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.EnvironmentLabel == "NotSet" ? T.T("NotSet") : Model.Dhl.EnvironmentLabel)</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("ShipperIdentity")</div>
                    <div class="fw-semibold mt-1">@(Model.Dhl.ShipperIdentityConfigured ? T.T("Ready") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("HandoffDelay")</div>
                    <div class="fw-semibold mt-1">@Model.Dhl.ShipmentAttentionDelayHours h</div>
                </div>
            </div>
            <div class="col-md-1">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("TrackingGrace")</div>
                    <div class="fw-semibold mt-1">@Model.Dhl.ShipmentTrackingGraceHours h</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">@T.T("ShipmentSupportPlaybooks")</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@T.T(item.Title)</td>
                        <td>@T.T(item.ScopeNote)</td>
                        <td>@T.T(item.OperatorAction)</td>
                        <td>@T.T(item.SettingsDependency)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("ShipmentsQueue", "Orders")"
      hx-target="#shipments-queue-workspace-shell"
      hx-swap="outerHTML">
    <div class="col-md-4">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("SearchShipmentsPlaceholder")" />
    </div>
    <div class="col-md-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <select name="pageSize" asp-items="Model.PageSizeItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="fa-solid fa-magnifying-glass"></i> @T.T("Search")
        </button>
        <a asp-action="ShipmentsQueue" class="btn btn-outline-secondary"
           hx-get="@Url.Action("ShipmentsQueue", "Orders")" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">@T.T("Reset")</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th>@T.T("Order")</th>
                <th>@T.T("CarrierService")</th>
                <th>@T.T("Tracking")</th>
                <th>@T.T("Weight")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Timeline")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted py-4">@T.T("NoShipmentsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                var needsServiceResolution = string.IsNullOrWhiteSpace(item.Service);
                var needsThresholdReview = item.AwaitingHandoff || item.TrackingOverdue;
                <tr>
                    <td>
                        <div class="fw-semibold">@item.OrderNumber</div>
                        <div class="small text-muted">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                    </td>
                    <td>
                        @item.Carrier / @(string.IsNullOrWhiteSpace(item.Service) ? "-" : item.Service)
                    </td>
                    <td>
                        @(string.IsNullOrWhiteSpace(item.TrackingNumber) ? "-" : item.TrackingNumber)
                        <div class="small text-muted mt-1">@item.TrackingState</div>
                        @if (item.NeedsCarrierReview)
                        {
                            <div><span class="badge text-bg-warning mt-1">@T.T("NeedsCarrierReview")</span></div>
                        }
                        @if (item.NeedsReturnFollowUp)
                        {
                            <div><span class="badge text-bg-dark mt-1">@T.T("ReturnFollowUp")</span></div>
                        }
                        @if (item.TrackingOverdue)
                        {
                            <div><span class="badge text-bg-danger mt-1">@T.T("TrackingOverdue")</span></div>
                        }
                    </td>
                    <td>@item.TotalWeight</td>
                    <td>
                        <span class="badge text-bg-@(item.Status == Darwin.Domain.Enums.ShipmentStatus.Delivered ? "success" : item.Status == Darwin.Domain.Enums.ShipmentStatus.Shipped ? "primary" : "warning")">
                            @item.Status
                        </span>
                        @if (item.IsDhl)
                        {
                            <div><span class="badge text-bg-info mt-1">@T.T("DhlMethods")</span></div>
                        }
                        @if (item.AwaitingHandoff)
                        {
                            <div><span class="badge text-bg-danger mt-1">@T.T("AwaitingHandoff")</span></div>
                        }
                    </td>
                    <td>
                        @if (item.DeliveredAtUtc.HasValue)
                        {
                            <span>@T.T("Delivered") @item.DeliveredAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                        else if (item.ShippedAtUtc.HasValue)
                        {
                            <span>@T.T("Shipped") @item.ShippedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                        else
                        {
                            <span class="text-muted">@T.T("NotYetHandedOver")</span>
                            <div class="small text-muted mt-1">@T.T("OpenFor") @item.OpenAgeHours h</div>
                            @if (item.AwaitingHandoff)
                            {
                                <div class="small text-danger mt-1">@T.T("OlderThanThreshold") @item.AttentionDelayHours h</div>
                            }
                        }
                        @if (item.InTransitAgeHours.HasValue)
                        {
                            <div class="small text-muted mt-1">@T.T("InTransitFor") @item.InTransitAgeHours.Value h</div>
                        }
                        @if (item.LastCarrierEventAtUtc.HasValue)
                        {
                            <div class="small text-muted mt-1">@T.T("LastEvent") @item.LastCarrierEventAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                        }
                        @if (item.TrackingOverdue)
                        {
                            <div class="small text-danger mt-1">@T.T("MissingTrackingBeyondGrace") @item.TrackingGraceHours h</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.ExceptionNote))
                        {
                            <div class="small text-danger mt-1">@item.ExceptionNote</div>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="shipments" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                <i class="fa-solid fa-receipt"></i> @T.T("Order")
                            </a>
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Returned || item.NeedsCarrierReview)
                            {
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" asp-fragment="refunds" class="btn btn-sm btn-outline-danger"
                                   hx-get="@Url.Action("Details", "Orders", new { id = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                    <i class="fa-solid fa-rotate-left"></i> @T.T("ReviewRefunds")
                                </a>
                            }
                            @if (item.NeedsReturnFollowUp)
                            {
                                <a asp-action="ShipmentsQueue"
                                   asp-route-filter="@ShipmentQueueFilter.CarrierReview"
                                   class="btn btn-sm btn-outline-dark"
                                   hx-get="@Url.Action("ShipmentsQueue", "Orders", new { filter = ShipmentQueueFilter.CarrierReview })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-triangle-exclamation"></i> @T.T("CarrierReviewQueue")
                                </a>
                            }
                            @if (needsServiceResolution)
                            {
                                <a asp-controller="ShippingMethods"
                                   asp-action="Index"
                                   asp-route-filter="Dhl"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Index", "ShippingMethods", new { filter = "Dhl" })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-box"></i> @T.T("ShippingMethods")
                                </a>
                            }
                            @if (needsThresholdReview)
                            {
                                <a asp-controller="SiteSettings"
                                   asp-action="Edit"
                                   asp-fragment="site-settings-shipping"
                                   class="btn btn-sm btn-outline-secondary"
                                   hx-get="@Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-shipping" })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-sliders"></i> @T.T("ShippingSettings")
                                </a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Returned && item.DefaultRefundPaymentId.HasValue)
                            {
                                <a asp-controller="Orders"
                                   asp-action="AddRefund"
                                   asp-route-orderId="@item.OrderId"
                                   asp-route-paymentId="@item.DefaultRefundPaymentId"
                                   class="btn btn-sm btn-danger"
                                   hx-get="@Url.Action("AddRefund", "Orders", new { orderId = item.OrderId, paymentId = item.DefaultRefundPaymentId })"
                                   hx-target="#shipments-queue-workspace-shell"
                                   hx-swap="outerHTML">
                                    <i class="fa-solid fa-rotate-left"></i> @T.T("StartReturnRefund")
                                </a>
                            }
                            @if (item.Status == Darwin.Domain.Enums.ShipmentStatus.Pending || item.Status == Darwin.Domain.Enums.ShipmentStatus.Packed)
                            {
                                <a asp-controller="Orders" asp-action="AddShipment" asp-route-orderId="@item.OrderId" class="btn btn-sm btn-outline-primary"
                                   hx-get="@Url.Action("AddShipment", "Orders", new { orderId = item.OrderId })" hx-target="#shipments-queue-workspace-shell" hx-swap="outerHTML">
                                    <i class="fa-solid fa-plus"></i> @T.T("AddShipment")
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page"
       page-size="Model.PageSize"
       total="Model.Total"
       asp-controller="Orders"
       asp-action="ShipmentsQueue"
       asp-route-query="@Model.Query"
       asp-route-filter="@Model.Filter"
       hx-target="#shipments-queue-workspace-shell"
       hx-swap="outerHTML">
</pager>
</div>
