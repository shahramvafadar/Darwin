@model Darwin.WebAdmin.ViewModels.Orders.OrderInvoicesPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string LocalizeInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
}

<div id="invoices-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <form asp-controller="Orders" asp-action="Invoices" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">@T.T("Apply")</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Outstanding" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Outstanding ? "btn-danger" : "btn-outline-danger")">@T.T("Outstanding")</a>
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Paid" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Paid ? "btn-success" : "btn-outline-success")">@T.T("Paid")</a>
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">@T.T("Clear")</a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Invoice")</th>
                    <th>@T.T("Customer")</th>
                    <th>@T.T("TaxProfile")</th>
                    <th>@T.T("Payment")</th>
                    <th class="text-end">@T.T("Total")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("IssuedUtc")</th>
                    <th>@T.T("DueUtc")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted">@T.T("NoInvoices")</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><code>@item.Id</code></td>
                            <td>
                                @if (item.CustomerId.HasValue)
                                {
                                    <a asp-controller="Crm"
                                       asp-action="EditCustomer"
                                       asp-route-id="@item.CustomerId.Value"
                                       class="text-decoration-none"
                                       hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                    </a>
                                }
                                else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                                {
                                    @item.CustomerDisplayName
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.CustomerTaxProfileType.HasValue)
                                {
                                    <span class="badge @(item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@LocalizeCustomerTaxProfileType(item.CustomerTaxProfileType)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.CustomerVatId))
                                    {
                                        <div class="small text-muted">@item.CustomerVatId</div>
                                    }
                                    else if (item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                                    {
                                        <div class="small text-danger">@T.T("VatIdMissing")</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.PaymentId.HasValue)
                                {
                                    <div class="fw-semibold">@item.PaymentProvider</div>
                                    <div class="small text-muted">@item.PaymentProviderReference</div>
                                    @if (item.PaymentStatus.HasValue)
                                    {
                                        <div class="small text-muted">@LocalizeInvoiceStatus(item.PaymentStatus)</div>
                                    }
                                    <div class="mt-1">
                                        <a asp-controller="Billing"
                                           asp-action="EditPayment"
                                           asp-route-id="@item.PaymentId.Value"
                                           class="btn btn-sm btn-outline-secondary"
                                           hx-get="@Url.Action("EditPayment", "Billing", new { id = item.PaymentId.Value })"
                                           hx-target="#order-operation-shell"
                                           hx-swap="innerHTML"
                                           hx-push-url="false">
                                            @T.T("Payment")
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="small text-muted">@T.T("Net"): @item.Currency @((item.TotalNetMinor / 100.0M).ToString("0.00"))</div>
                                <div class="small text-muted">@T.T("Tax"): @item.Currency @((item.TotalTaxMinor / 100.0M).ToString("0.00"))</div>
                                <div class="fw-semibold">@T.T("Gross"): @item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</div>
                                @if (item.RefundedAmountMinor > 0)
                                {
                                    <div class="small text-warning">@T.T("Refunded"): @item.Currency @((item.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                                }
                                <div class="small text-muted">@T.T("Settled"): @item.Currency @((item.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                                <div class="small @(item.BalanceMinor > 0 ? "text-danger" : "text-success")">
                                    @T.T("Balance"): @item.Currency @((item.BalanceMinor / 100.0M).ToString("0.00"))
                                </div>
                            </td>
                            <td>@LocalizeInvoiceStatus(item.Status)</td>
                            <td>@item.IssuedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                @(item.DueAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")
                                <div class="mt-1">
                                    <a asp-controller="Crm"
                                       asp-action="EditInvoice"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("EditInvoice", "Crm", new { id = item.Id })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("Invoice")
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Invoices"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#invoices-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
