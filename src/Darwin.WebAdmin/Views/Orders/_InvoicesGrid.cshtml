@model Darwin.WebAdmin.ViewModels.Orders.OrderInvoicesPageVm

<div id="invoices-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML">
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Customer</th>
                    <th>Payment</th>
                    <th class="text-end">Total</th>
                    <th>Status</th>
                    <th>Issued (UTC)</th>
                    <th>Due (UTC)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted">No invoices.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><code>@item.Id</code></td>
                            <td>
                                @if (item.CustomerId.HasValue)
                                {
                                    <a asp-controller="Crm" asp-action="EditCustomer" asp-route-id="@item.CustomerId.Value" class="text-decoration-none">
                                        @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                    </a>
                                }
                                else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                                {
                                    @item.CustomerDisplayName
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.PaymentId.HasValue)
                                {
                                    <div class="fw-semibold">@item.PaymentProvider</div>
                                    <div class="small text-muted">@item.PaymentProviderReference</div>
                                    @if (item.PaymentStatus.HasValue)
                                    {
                                        <div class="small text-muted">@item.PaymentStatus</div>
                                    }
                                    <div class="mt-1">
                                        <a asp-controller="Billing" asp-action="EditPayment" asp-route-id="@item.PaymentId.Value" class="btn btn-sm btn-outline-secondary">Payment</a>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">@item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</td>
                            <td>@item.Status</td>
                            <td>@item.IssuedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                @(item.DueAtUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")
                                <div class="mt-1">
                                    <a asp-controller="Crm" asp-action="EditInvoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Invoice</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Invoices"
           asp-route-orderId="@Model.OrderId">
    </pager>
</div>
