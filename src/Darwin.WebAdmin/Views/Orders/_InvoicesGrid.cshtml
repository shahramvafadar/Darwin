@model Darwin.WebAdmin.ViewModels.Orders.OrderInvoicesPageVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var orderCulture = System.Globalization.CultureInfo.CurrentCulture;
    string LocalizeInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string LocalizeCustomerTaxProfileType(object? taxProfileType) => taxProfileType is null ? "-" : T.T(taxProfileType.ToString() ?? string.Empty);
    string OrderDateTimeText(DateTime? utc) => utc?.ToString("g", orderCulture) ?? "-";
    string OrderInvoiceOpsHealthBadgeClass(bool healthy) => healthy
        ? "badge bg-success-subtle text-success-emphasis"
        : "badge bg-warning-subtle text-warning-emphasis";
    string OrderInvoiceOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    var orderInvoiceOutstandingCount = Model.Items.Count(item => item.BalanceMinor > 0);
    var orderInvoiceVatGapCount = Model.Items.Count(item => item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business && string.IsNullOrWhiteSpace(item.CustomerVatId));
    var orderInvoiceRefundedCount = Model.Items.Count(item => item.RefundedAmountMinor > 0);
    var orderInvoiceAttentionCount = orderInvoiceOutstandingCount + orderInvoiceVatGapCount + orderInvoiceRefundedCount;
}

<div id="invoices-grid-content"
     hx-boost="true"
     hx-target="this"
     hx-swap="outerHTML"
     hx-push-url="false">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="fw-semibold">@T.T("ReviewInvoices")</div>
                        <span class="@OrderInvoiceOpsHealthBadgeClass(orderInvoiceAttentionCount == 0)">@OrderInvoiceOpsHealthBadgeText(orderInvoiceAttentionCount == 0)</span>
                    </div>
                    <div class="small text-muted mt-2">
                        @T.T("Invoice")
                        @if (orderInvoiceAttentionCount > 0)
                        {
                            <span class="ms-1">@T.T("NeedsAttention"): @orderInvoiceAttentionCount</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Orders"
                       asp-action="CreateInvoice"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-sm btn-outline-primary"
                       hx-get="@Url.Action("CreateInvoice", "Orders", new { orderId = Model.OrderId })"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("CreateInvoice")</a>
                    <a asp-controller="Billing"
                       asp-action="Payments"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@Url.Action("Payments", "Billing")"
                       hx-target="#order-operation-shell"
                       hx-swap="innerHTML"
                       hx-push-url="false">@T.T("Payments")</a>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Outstanding")</div>
                                <div class="small text-muted mt-1">@T.T("Balance")</div>
                            </div>
                            <span class="@OrderInvoiceOpsHealthBadgeClass(orderInvoiceOutstandingCount == 0)">@orderInvoiceOutstandingCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("Payment")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Outstanding" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Outstanding ? "btn-danger" : "btn-outline-danger")">@T.T("Outstanding")</a>
                            <a asp-controller="Billing" asp-action="Payments" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("Payments", "Billing")" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Payments")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Paid")</div>
                                <div class="small text-muted mt-1">@T.T("Settled")</div>
                            </div>
                            <span class="@OrderInvoiceOpsHealthBadgeClass(Model.Items.Count(item => item.BalanceMinor <= 0) == 0)">@Model.Items.Count(item => item.BalanceMinor <= 0)</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("Invoice")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Paid" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Paid ? "btn-success" : "btn-outline-success")">@T.T("Paid")</a>
                            <a asp-controller="Orders" asp-action="CreateInvoice" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("CreateInvoice", "Orders", new { orderId = Model.OrderId })" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("CreateInvoice")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("VatIdMissing")</div>
                                <div class="small text-muted mt-1">@T.T("TaxProfile")</div>
                            </div>
                            <span class="@OrderInvoiceOpsHealthBadgeClass(orderInvoiceVatGapCount == 0)">@orderInvoiceVatGapCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("TaxSettings")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Billing" asp-action="TaxCompliance" class="btn btn-sm btn-outline-danger" hx-get="@Url.Action("TaxCompliance", "Billing")" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("TaxSettings")</a>
                            <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="MissingVatId" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("Invoices", "Crm", new { filter = "MissingVatId" })" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("ReviewInvoices")</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@T.T("Refunded")</div>
                                <div class="small text-muted mt-1">@T.T("Payment")</div>
                            </div>
                            <span class="@OrderInvoiceOpsHealthBadgeClass(orderInvoiceRefundedCount == 0)">@orderInvoiceRefundedCount</span>
                        </div>
                        <div class="small text-muted mt-3">@T.T("CrmNextStep")</div>
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <a asp-controller="Billing" asp-action="Refunds" class="btn btn-sm btn-outline-warning" hx-get="@Url.Action("Refunds", "Billing")" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Refunded")</a>
                            <a asp-controller="Billing" asp-action="Payments" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("Payments", "Billing")" hx-target="#order-operation-shell" hx-swap="innerHTML" hx-push-url="false">@T.T("Payment")</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form asp-controller="Orders" asp-action="Invoices" method="get" class="d-flex gap-2 mb-3">
        <input type="hidden" name="orderId" value="@Model.OrderId" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select form-select-sm"></select>
        <button class="btn btn-sm btn-outline-secondary" type="submit">@T.T("Apply")</button>
    </form>
    <div class="d-flex gap-2 flex-wrap mb-3">
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Outstanding" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Outstanding ? "btn-danger" : "btn-outline-danger")">@T.T("Outstanding")</a>
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" asp-route-filter="Paid" class="btn btn-sm @(Model.Filter == Darwin.Application.Orders.DTOs.InvoiceQueueFilter.Paid ? "btn-success" : "btn-outline-success")">@T.T("Paid")</a>
        <a asp-controller="Orders" asp-action="Invoices" asp-route-orderId="@Model.OrderId" class="btn btn-sm btn-outline-secondary">@T.T("Clear")</a>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@T.T("Invoice")</th>
                    <th>@T.T("Customer")</th>
                    <th>@T.T("TaxProfile")</th>
                    <th>@T.T("Payment")</th>
                    <th class="text-end">@T.T("Total")</th>
                    <th>@T.T("Status")</th>
                    <th>@T.T("IssuedUtc")</th>
                    <th>@T.T("DueUtc")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted">@T.T("NoInvoices")</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><code>@item.Id</code></td>
                            <td>
                                @if (item.CustomerId.HasValue)
                                {
                                    <a asp-controller="Crm"
                                       asp-action="EditCustomer"
                                       asp-route-id="@item.CustomerId.Value"
                                       class="text-decoration-none"
                                       hx-get="@Url.Action("EditCustomer", "Crm", new { id = item.CustomerId.Value })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @(string.IsNullOrWhiteSpace(item.CustomerDisplayName) ? item.CustomerId.Value.ToString() : item.CustomerDisplayName)
                                    </a>
                                }
                                else if (!string.IsNullOrWhiteSpace(item.CustomerDisplayName))
                                {
                                    @item.CustomerDisplayName
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.CustomerTaxProfileType.HasValue)
                                {
                                    <span class="badge @(item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business ? "text-bg-dark" : "text-bg-secondary")">@LocalizeCustomerTaxProfileType(item.CustomerTaxProfileType)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.CustomerVatId))
                                    {
                                        <div class="small text-muted">@item.CustomerVatId</div>
                                    }
                                    else if (item.CustomerTaxProfileType == Darwin.Domain.Enums.CustomerTaxProfileType.Business)
                                    {
                                        <div class="small text-danger">@T.T("VatIdMissing")</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.PaymentId.HasValue)
                                {
                                    <div class="fw-semibold">@item.PaymentProvider</div>
                                    <div class="small text-muted">@item.PaymentProviderReference</div>
                                    @if (item.PaymentStatus.HasValue)
                                    {
                                        <div class="small text-muted">@LocalizeInvoiceStatus(item.PaymentStatus)</div>
                                    }
                                    <div class="mt-1">
                                        <a asp-controller="Billing"
                                           asp-action="EditPayment"
                                           asp-route-id="@item.PaymentId.Value"
                                           class="btn btn-sm btn-outline-secondary"
                                           hx-get="@Url.Action("EditPayment", "Billing", new { id = item.PaymentId.Value })"
                                           hx-target="#order-operation-shell"
                                           hx-swap="innerHTML"
                                           hx-push-url="false">
                                            @T.T("Payment")
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="small text-muted">@T.T("Net"): @item.Currency @((item.TotalNetMinor / 100.0M).ToString("0.00"))</div>
                                <div class="small text-muted">@T.T("Tax"): @item.Currency @((item.TotalTaxMinor / 100.0M).ToString("0.00"))</div>
                                <div class="fw-semibold">@T.T("Gross"): @item.Currency @((item.TotalGrossMinor / 100.0M).ToString("0.00"))</div>
                                @if (item.RefundedAmountMinor > 0)
                                {
                                    <div class="small text-warning">@T.T("Refunded"): @item.Currency @((item.RefundedAmountMinor / 100.0M).ToString("0.00"))</div>
                                }
                                <div class="small text-muted">@T.T("Settled"): @item.Currency @((item.SettledAmountMinor / 100.0M).ToString("0.00"))</div>
                                <div class="small @(item.BalanceMinor > 0 ? "text-danger" : "text-success")">
                                    @T.T("Balance"): @item.Currency @((item.BalanceMinor / 100.0M).ToString("0.00"))
                                </div>
                            </td>
                            <td>@LocalizeInvoiceStatus(item.Status)</td>
                            <td>@OrderDateTimeText(item.IssuedAtUtc)</td>
                            <td>
                                @OrderDateTimeText(item.DueAtUtc)
                                <div class="mt-1">
                                    <a asp-controller="Crm"
                                       asp-action="EditInvoice"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                       hx-get="@Url.Action("EditInvoice", "Crm", new { id = item.Id })"
                                       hx-target="#order-operation-shell"
                                       hx-swap="innerHTML"
                                       hx-push-url="false">
                                        @T.T("Invoice")
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Orders"
           asp-action="Invoices"
           asp-route-orderId="@Model.OrderId"
           asp-route-filter="@Model.Filter"
           hx-target="#invoices-grid-content"
           hx-swap="outerHTML"
           hx-push-url="false">
    </pager>
</div>
