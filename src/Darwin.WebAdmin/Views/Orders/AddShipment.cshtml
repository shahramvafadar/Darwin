@model Darwin.WebAdmin.ViewModels.Orders.ShipmentCreateVm
@{
    ViewData["Title"] = "Add Shipment";
    var header = ViewBag.OrderHeader as Darwin.WebAdmin.ViewModels.Orders.OrderHeaderVm;
}

<h1 class="mb-3"><i class="fa fa-truck"></i> Add Shipment</h1>

@if (header is not null)
{
    <div class="alert alert-info">
        <strong>Order:</strong> @header.OrderNumber
    </div>
}

<form asp-action="AddShipment" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="OrderId" />
    <div class="col-md-4">
        <label asp-for="Carrier" class="form-label"></label>
        <input asp-for="Carrier" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Service" class="form-label"></label>
        <input asp-for="Service" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="TrackingNumber" class="form-label"></label>
        <input asp-for="TrackingNumber" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="TotalWeight" class="form-label"></label>
        <input asp-for="TotalWeight" class="form-control" />
    </div>
    <div class="col-12">
        <h5>Shipment Lines</h5>
        <div class="table-responsive">
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Order Line</th>
                        <th class="text-end">Quantity</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Lines.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model.Lines[i].Label
                                <input type="hidden" asp-for="Lines[i].OrderLineId" />
                                <input type="hidden" asp-for="Lines[i].Label" />
                            </td>
                            <td class="text-end" style="width:180px">
                                <input asp-for="Lines[i].Quantity" class="form-control text-end" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-12">
        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary">Back</a>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
