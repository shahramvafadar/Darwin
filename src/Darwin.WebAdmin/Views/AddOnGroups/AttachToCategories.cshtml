@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupAttachToCategoriesVm
@{
    ViewData["Title"] = T.T("AddOnAttachCategoriesTitle");

    string AttachAddOnGroupToCategoriesSearchUrl() => Url.Action("AttachToCategories", "AddOnGroups") ?? string.Empty;
    string AttachAddOnGroupToCategoriesUrl(Guid id) => Url.Action("AttachToCategories", "AddOnGroups", new { id }) ?? string.Empty;
    string AddOnGroupsIndexUrl() => Url.Action("Index", "AddOnGroups") ?? string.Empty;
}
<div id="add-on-group-attach-categories-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-2"><i class="fa fa-sitemap"></i> @T.T("AddOnAttachCategoriesTitle") <small class="text-muted">(@Model.AddOnGroupName)</small></h1>
<form method="get" class="row g-2 mb-3" asp-controller="AddOnGroups" asp-action="AttachToCategories" hx-get="@AttachAddOnGroupToCategoriesSearchUrl()" hx-target="#add-on-group-attach-categories-shell" hx-swap="outerHTML" hx-push-url="true">
<input type="hidden" name="id" value="@Model.AddOnGroupId" />
<div class="col-auto"><input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("AddOnSearchCategories")" /></div>
<div class="col-auto"><button class="btn btn-outline-primary"><i class="fa fa-search"></i> @T.T("Search")</button><a asp-controller="AddOnGroups" asp-action="AttachToCategories" asp-route-id="@Model.AddOnGroupId" class="btn btn-outline-secondary" hx-get="@AttachAddOnGroupToCategoriesUrl(Model.AddOnGroupId)" hx-target="#add-on-group-attach-categories-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Reset")</a></div>
</form>
<form asp-controller="AddOnGroups" asp-action="AttachToCategories" method="post" hx-post="@Url.Action("AttachToCategories", "AddOnGroups")" hx-target="#add-on-group-attach-categories-shell" hx-swap="outerHTML">
@Html.AntiForgeryToken()
<input type="hidden" name="AddOnGroupId" value="@Model.AddOnGroupId" />
<input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? "" : Convert.ToBase64String(Model.RowVersion))" />
<input type="hidden" name="Page" value="@Model.Page" />
<input type="hidden" name="PageSize" value="@Model.PageSize" />
<input type="hidden" name="Query" value="@Model.Query" />
<div class="table-responsive" data-addon-selection-scope><table class="table table-sm table-striped align-middle"><thead><tr><th class="text-center admin-w-40"><input type="checkbox" id="toggleAll" data-addon-toggle-all /></th><th>@T.T("Name")</th></tr></thead><tbody>@if (Model.Items is null || Model.Items.Count == 0) { <tr><td colspan="2" class="text-center text-muted">@T.T("AddOnNoCategories")</td></tr> } else { foreach (var c in Model.Items) { <tr><td class="text-center"><input type="checkbox" class="row-check" data-addon-row-check name="SelectedCategoryIds" value="@c.Id" @(c.Selected ? "checked" : "") /></td><td>@c.Display</td></tr> } }</tbody></table></div>
<div class="mt-3"><button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> @T.T("AddOnSaveAttachments")</button><a asp-controller="AddOnGroups" asp-action="Index" class="btn btn-outline-secondary" hx-get="@AddOnGroupsIndexUrl()" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Back")</a></div>
</form>
<div class="pt-3"><pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="AddOnGroups" asp-action="AttachToCategories" asp-route-id="@Model.AddOnGroupId" asp-route-query="@Model.Query" hx-target="#add-on-group-attach-categories-shell" hx-swap="outerHTML" hx-push-url="true"></pager></div>
</div>
