@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupEditorVm

@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var selectionModeOptions = Html.GetEnumSelectList<Darwin.Domain.Enums.AddOnSelectionMode>().Select(option => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Value = option.Value, Text = T.T(option.Text) });
    string AddOnGroupsIndexUrl() => Url.Action("Index", "AddOnGroups") ?? string.Empty;
}
<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="card mb-3">
    <div class="card-body row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Currency" class="form-label"></label>
            <input asp-for="Currency" class="form-control" maxlength="3" data-addon-currency-uppercase />
            <span asp-validation-for="Currency" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="SelectionMode" class="form-label"></label>
            <select asp-for="SelectionMode" class="form-select" asp-items="selectionModeOptions"></select>
            <span asp-validation-for="SelectionMode" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="MinSelections" class="form-label"></label>
            <input asp-for="MinSelections" class="form-control" />
            <span asp-validation-for="MinSelections" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="MaxSelections" class="form-label"></label>
            <input asp-for="MaxSelections" class="form-control" />
            <span asp-validation-for="MaxSelections" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <div class="form-check mt-4 pt-2">
                <input asp-for="IsGlobal" class="form-check-input" />
                <label asp-for="IsGlobal" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check mt-4 pt-2">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
</div>

<partial name="_OptionsEditor" model="Model" />

<div class="mt-3">
    <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
    <a asp-controller="AddOnGroups" asp-action="Index" class="btn btn-outline-secondary"
       hx-get="@AddOnGroupsIndexUrl()"
       hx-target="#add-on-groups-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Back")</a>
</div>
