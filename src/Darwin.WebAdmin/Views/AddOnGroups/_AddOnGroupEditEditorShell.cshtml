@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupEditVm
@{
    ViewData["Title"] = T.T("AddOnEditTitle");
}

<div id="add-on-group-editor-shell">
    <h1 class="mb-3"><i class="fa fa-pen"></i> @T.T("AddOnEditHeading") @Model.Name</h1>
    <div class="text-muted mb-3">@T.T("AddOnEditIntro")</div>

    <form asp-action="Edit"
          method="post"
          class="needs-validation"
          novalidate
          hx-post="@Url.Action("Edit", "AddOnGroups")"
          hx-target="#add-on-group-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        <partial name="_AddOnGroupForm" model="Model" />
    </form>
</div>
