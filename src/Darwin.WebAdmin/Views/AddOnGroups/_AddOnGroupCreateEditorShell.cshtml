@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupCreateVm
@{
    ViewData["Title"] = "Create Add-on Group";
}

<div id="add-on-group-editor-shell">
    <h1 class="mb-3"><i class="fa fa-plus-circle"></i> New Add-on Group</h1>

    <form asp-action="Create"
          method="post"
          class="needs-validation"
          novalidate
          hx-post="@Url.Action("Create", "AddOnGroups")"
          hx-target="#add-on-group-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <partial name="_AddOnGroupForm" model="Model" />
    </form>
</div>

<script>
    (function () {
      const shell = document.getElementById('add-on-group-editor-shell');
      if (!shell) return;

      const currency = shell.querySelector('#Currency');
      if (currency && !currency.dataset.uppercaseBound) {
        currency.dataset.uppercaseBound = 'true';
        currency.addEventListener('input', function () {
          this.value = this.value.toUpperCase();
        });
      }
    })();
</script>
