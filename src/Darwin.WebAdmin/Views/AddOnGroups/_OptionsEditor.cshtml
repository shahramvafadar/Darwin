@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupEditorVm

<div class="card mb-3">
    <div class="card-header">@T.T("AddOnOptionsValues")</div>
    <div class="card-body">

        <div class="alert alert-info mb-3">@T.T("AddOnOptionsEditorHelp")</div>

        <div id="options-editor" data-options-prefix="Options">
            <div id="options-container">
                @if (Model.Options != null && Model.Options.Count > 0)
                {
                    for (var i = 0; i < Model.Options.Count; i++)
                    {
                        var opt = Model.Options[i];
                        <div class="option-item border rounded p-2 mb-2" data-index="@i">
                            <input type="hidden" name="Options[@i].Id" value="@opt.Id" />
                            <div class="row g-2 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label">@T.T("AddOnOptionLabel") <span class="text-danger">*</span></label>
                                    <input class="form-control" name="Options[@i].Label" value="@opt.Label" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">@T.T("SortOrder")</label>
                                    <input type="number" class="form-control" name="Options[@i].SortOrder" value="@opt.SortOrder" />
                                </div>
                                <div class="col-md-3 text-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm" data-remove-option><i class="fa fa-trash"></i> @T.T("AddOnRemoveOption")</button>
                                </div>
                            </div>

                            @if (opt.Translations.Count > 0)
                            {
                                <div class="row g-2 mt-2">
                                    @for (var ti = 0; ti < opt.Translations.Count; ti++)
                                    {
                                        <div class="col-md-6">
                                            <input type="hidden" name="Options[@i].Translations[@ti].Culture" value="@opt.Translations[ti].Culture" />
                                            <label class="form-label">@T.T("AddOnOptionLabel") @opt.Translations[ti].Culture</label>
                                            <input class="form-control" name="Options[@i].Translations[@ti].Label" value="@opt.Translations[ti].Label" />
                                        </div>
                                    }
                                </div>
                            }

                            <div class="mt-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong>@T.T("Values")</strong>
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-add-value><i class="fa fa-plus"></i> @T.T("AddOnAddValue")</button>
                                </div>

                                <div class="values-container">
                                    @if (opt.Values != null && opt.Values.Count > 0)
                                    {
                                        for (var j = 0; j < opt.Values.Count; j++)
                                        {
                                            var val = opt.Values[j];
                                            <div class="value-item border rounded p-2 mb-2" data-vindex="@j">
                                                <input type="hidden" name="Options[@i].Values[@j].Id" value="@val.Id" />
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label">@T.T("AddOnValueLabel") <span class="text-danger">*</span></label>
                                                        <input class="form-control" name="Options[@i].Values[@j].Label" value="@val.Label" required />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label">@T.T("AddOnPriceDeltaMinor") <span class="text-danger">*</span></label>
                                                        <input type="number" class="form-control" name="Options[@i].Values[@j].PriceDeltaMinor" value="@val.PriceDeltaMinor" required />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label">@T.T("SortOrder")</label>
                                                        <input type="number" class="form-control" name="Options[@i].Values[@j].SortOrder" value="@val.SortOrder" />
                                                    </div>
                                                    <div class="col-md-2">
                                                        <label class="form-label d-block">@T.T("Active")</label>
                                                        <div class="form-check mt-2">
                                                            <input type="hidden" name="Options[@i].Values[@j].IsActive" value="false" />
                                                            <input class="form-check-input" type="checkbox" name="Options[@i].Values[@j].IsActive" value="true" @(val.IsActive ? "checked" : "") />
                                                            <label class="form-check-label">@T.T("Yes")</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-12">
                                                        <label class="form-label">@T.T("Hint")</label>
                                                        <input class="form-control" name="Options[@i].Values[@j].Hint" value="@val.Hint" />
                                                    </div>
                                                    @if (val.Translations.Count > 0)
                                                    {
                                                        for (var vti = 0; vti < val.Translations.Count; vti++)
                                                        {
                                                            <div class="col-md-6">
                                                                <input type="hidden" name="Options[@i].Values[@j].Translations[@vti].Culture" value="@val.Translations[vti].Culture" />
                                                                <label class="form-label">@T.T("AddOnValueLabel") @val.Translations[vti].Culture</label>
                                                                <input class="form-control" name="Options[@i].Values[@j].Translations[@vti].Label" value="@val.Translations[vti].Label" />
                                                            </div>
                                                        }
                                                    }
                                                </div>

                                                <div class="text-end mt-2">
                                                    <button type="button" class="btn btn-outline-danger btn-sm" data-remove-value><i class="fa fa-trash"></i> @T.T("AddOnRemoveValue")</button>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="mt-2">
                <button type="button" class="btn btn-outline-primary" id="btnAddOption"><i class="fa fa-plus"></i> @T.T("AddOnAddOption")</button>
            </div>

            <template id="addOnOptionTemplate">
                <div class="option-item border rounded p-2 mb-2" data-index="__i__">
                    <input type="hidden" name="__prefix__[__i__].Id" value="" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label">@T.T("AddOnOptionLabel") <span class="text-danger">*</span></label>
                            <input class="form-control" name="__prefix__[__i__].Label" value="" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@T.T("SortOrder")</label>
                            <input type="number" class="form-control" name="__prefix__[__i__].SortOrder" value="0" />
                        </div>
                        <div class="col-md-3 text-end">
                            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-option><i class="fa fa-trash"></i> @T.T("AddOnRemoveOption")</button>
                        </div>
                    </div>
                    <div class="mt-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>@T.T("Values")</strong>
                            <button type="button" class="btn btn-sm btn-outline-primary" data-add-value><i class="fa fa-plus"></i> @T.T("AddOnAddValue")</button>
                        </div>
                        <div class="values-container">__value__</div>
                    </div>
                </div>
            </template>

            <template id="addOnValueTemplate">
                <div class="value-item border rounded p-2 mb-2" data-vindex="__j__">
                    <input type="hidden" name="__prefix__[__i__].Values[__j__].Id" value="" />
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">@T.T("AddOnValueLabel") <span class="text-danger">*</span></label>
                            <input class="form-control" name="__prefix__[__i__].Values[__j__].Label" value="" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@T.T("AddOnPriceDeltaMinor") <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="__prefix__[__i__].Values[__j__].PriceDeltaMinor" value="0" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@T.T("SortOrder")</label>
                            <input type="number" class="form-control" name="__prefix__[__i__].Values[__j__].SortOrder" value="0" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label d-block">@T.T("Active")</label>
                            <div class="form-check mt-2">
                                <input type="hidden" name="__prefix__[__i__].Values[__j__].IsActive" value="false" />
                                <input class="form-check-input" type="checkbox" name="__prefix__[__i__].Values[__j__].IsActive" value="true" checked />
                                <label class="form-check-label">@T.T("Yes")</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">@T.T("Hint")</label>
                            <input class="form-control" name="__prefix__[__i__].Values[__j__].Hint" value="" />
                        </div>
                    </div>
                    <div class="text-end mt-2">
                        <button type="button" class="btn btn-outline-danger btn-sm" data-remove-value><i class="fa fa-trash"></i> @T.T("AddOnRemoveValue")</button>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>
