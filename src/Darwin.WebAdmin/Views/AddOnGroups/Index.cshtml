@model Darwin.WebAdmin.ViewModels.Catalog.AddOnGroupsListVm
@{
    ViewData["Title"] = T.T("AddOnGroups");
}

<div id="add-on-groups-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3"><i class="fa fa-layer-group"></i> @T.T("AddOnGroups")</h1>

<div class="row g-3 mb-3">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@T.T("Total")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@T.T("Inactive")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.InactiveCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@T.T("Global")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.GlobalCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@T.T("Unattached")</div>
                <div class="fs-4 fw-semibold">@Model.Summary.UnattachedCount</div>
                <div class="small text-muted mt-1">@T.T("AddOnLinkedGroups"): @Model.Summary.VariantLinkedCount</div>
            </div>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "AddOnGroups")"
      hx-target="#add-on-groups-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="col-auto">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("AddOnSearchNameCurrency")" />
    </div>
    <div class="col-auto">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary"><i class="fa fa-search"></i> @T.T("Search")</button>
        <a asp-controller="AddOnGroups" asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "AddOnGroups")"
           hx-target="#add-on-groups-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
    <div class="col-auto ms-auto">
        <a asp-controller="AddOnGroups" asp-action="Create" class="btn btn-primary"
           hx-get="@Url.Action("Create", "AddOnGroups")"
           hx-target="#add-on-groups-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-plus"></i> @T.T("AddOnNewGroup")
        </a>
    </div>
</form>

<div class="card shadow-sm mb-3">
    <div class="card-header">@T.T("AddOnOperationsPlaybooks")</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("WhyItMatters")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var playbook in Model.Playbooks)
                    {
                        <tr>
                            <td class="fw-semibold">@playbook.QueueLabel</td>
                            <td>@playbook.WhyItMatters</td>
                            <td>@playbook.OperatorAction</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Currency")</th>
                <th class="text-center">@T.T("Global")</th>
                <th class="text-center">@T.T("Active")</th>
                <th class="text-center">@T.T("Options")</th>
                <th class="text-center">@T.T("Attachments")</th>
                <th>@T.T("Modified")</th>
                <th class="text-end" style="width:420px">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted">@T.T("AddOnNoGroups")</td></tr>
            }
            else
            {
                foreach (var g in Model.Items)
                {
                    <tr>
                        <td>@g.Name</td>
                        <td>@g.Currency</td>
                        <td class="text-center">
                            <i class="fa @(g.IsGlobal ? "fa-check text-success" : "fa-minus text-muted")"></i>
                        </td>
                        <td class="text-center">
                            <span class="badge @(g.IsActive ? "text-bg-success" : "text-bg-secondary")">@(g.IsActive ? T.T("Yes") : T.T("No"))</span>
                        </td>
                        <td class="text-center">@g.OptionsCount</td>
                        <td class="text-center">@g.AttachmentCount</td>
                        <td>@g.ModifiedAtUtc?.ToLocalTime()</td>
                        <td class="text-end">
                            <a asp-controller="AddOnGroups" asp-action="Edit" asp-route-id="@g.Id" class="btn btn-sm btn-outline-secondary"
                               hx-get="@Url.Action("Edit", "AddOnGroups", new { id = g.Id })"
                               hx-target="#add-on-groups-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-pen"></i> @T.T("Edit")
                            </a>
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="AddOnGroups" asp-action="AttachToVariants" asp-route-id="@g.Id" hx-get="@Url.Action("AttachToVariants", "AddOnGroups", new { id = g.Id })" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true"><i class="fa fa-sitemap"></i> @T.T("Variants")</a>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="AddOnGroups" asp-action="AttachToProducts" asp-route-id="@g.Id" hx-get="@Url.Action("AttachToProducts", "AddOnGroups", new { id = g.Id })" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true"><i class="fa fa-box"></i> @T.T("Products")</a>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="AddOnGroups" asp-action="AttachToCategories" asp-route-id="@g.Id" hx-get="@Url.Action("AttachToCategories", "AddOnGroups", new { id = g.Id })" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true"><i class="fa fa-tags"></i> @T.T("Categories")</a>
                                <a class="btn btn-sm btn-outline-primary" asp-controller="AddOnGroups" asp-action="AttachToBrands" asp-route-id="@g.Id" hx-get="@Url.Action("AttachToBrands", "AddOnGroups", new { id = g.Id })" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true"><i class="fa fa-industry"></i> @T.T("Brands")</a>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal" data-action="@Url.Action("Delete", "AddOnGroups")" data-id="@g.Id" data-name="@g.Name" data-rowversion="@Convert.ToBase64String(g.RowVersion)" data-hx-target="#add-on-groups-workspace-shell" data-hx-swap="outerHTML" data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                                <i class="fa fa-trash"></i> @T.T("Delete")
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="AddOnGroups" asp-action="Index" asp-route-query="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#add-on-groups-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
