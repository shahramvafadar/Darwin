@model Darwin.WebAdmin.ViewModels.CMS.MediaAssetCreateVm
@{
    ViewData["Title"] = "Upload Media";
}

<div id="media-create-editor-shell">
    <h1 class="mb-3">Upload Media</h1>

    <form asp-action="Create"
          method="post"
          enctype="multipart/form-data"
          hx-post="@Url.Action("Create", "Media")"
          hx-encoding="multipart/form-data"
          hx-target="#media-create-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="File" class="form-label">File</label>
            <input asp-for="File" class="form-control" accept=".png,.jpg,.jpeg,.webp,.gif" />
            <span asp-validation-for="File" class="text-danger"></span>
            <div class="form-text">Supported formats: PNG, JPG, WEBP, GIF. Max 5 MB.</div>
        </div>

        <partial name="_MediaAssetUploadForm" model="Model" />

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-upload"></i> Upload
            </button>
            <a asp-action="Index"
               class="btn btn-outline-secondary"
               hx-get="@Url.Action("Index", "Media")"
               hx-target="#media-create-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">Cancel</a>
        </div>
    </form>
</div>
