@model Darwin.WebAdmin.ViewModels.CMS.MediaAssetCreateVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("UploadMedia");
    string MediaIndexUrl() => Url.Action("Index", "Media") ?? string.Empty;
}

<div id="media-create-editor-shell">
    <h1 class="mb-3">@T.T("UploadMedia")</h1>

    <form asp-action="Create"
          method="post"
          enctype="multipart/form-data"
          hx-post="@Url.Action("Create", "Media")"
          hx-encoding="multipart/form-data"
          hx-target="#media-create-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="File" class="form-label">@T.T("File")</label>
            <input asp-for="File" class="form-control" accept=".png,.jpg,.jpeg,.webp,.gif" />
            <span asp-validation-for="File" class="text-danger"></span>
            <div class="form-text">@T.T("MediaSupportedFormatsHelp")</div>
        </div>

        <partial name="_MediaAssetUploadForm" model="Model" />

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-upload"></i> @T.T("Upload")
            </button>
            <a asp-action="Index"
               class="btn btn-outline-secondary"
               hx-get="@MediaIndexUrl()"
               hx-target="#media-create-editor-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Cancel")</a>
        </div>
    </form>
</div>
