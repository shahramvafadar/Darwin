@model Darwin.WebAdmin.ViewModels.CMS.MediaAssetsListVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Media");
    string MediaCreateUrl() => Url.Action("Create", "Media") ?? string.Empty;
    string MediaIndexUrl(string? filter = null) => Url.Action("Index", "Media", string.IsNullOrWhiteSpace(filter) ? null : new { filter }) ?? string.Empty;
    string MediaEditUrl(Guid id) => Url.Action("Edit", "Media", new { id }) ?? string.Empty;
    string MediaPurgeUnusedBatchUrl() => Url.Action("PurgeUnusedBatch", "Media") ?? string.Empty;
}
<div id="media-workspace-shell">
<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
    <div>
        <h1 class="mb-1">@T.T("MediaLibraryTitle")</h1>
        <p class="text-muted mb-0">@T.T("MediaLibraryIntro")</p>
    </div>

    <div class="d-flex gap-2">
        @if (Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.Unused && Model.Summary.UnusedCount > 0)
        {
            <form asp-action="PurgeUnusedBatch" method="post" hx-post="@MediaPurgeUnusedBatchUrl()" hx-target="#media-workspace-shell" hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="fa fa-broom"></i> @T.T("MediaPurgeUnusedBatch")
                </button>
            </form>
        }
        <a asp-action="Create"
           class="btn btn-primary"
           hx-get="@MediaCreateUrl()"
           hx-target="#media-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
            <i class="fa fa-upload"></i> @T.T("UploadMedia")
        </a>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Index" asp-route-filter="MissingAlt" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.MissingAlt ? "btn-warning" : "btn-outline-warning")"
       hx-get="@MediaIndexUrl("MissingAlt")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaMissingAlt")</a>
    <a asp-action="Index" asp-route-filter="MissingTitle" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.MissingTitle ? "btn-dark" : "btn-outline-dark")"
       hx-get="@MediaIndexUrl("MissingTitle")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaMissingTitle")</a>
    <a asp-action="Index" asp-route-filter="EditorAssets" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.EditorAssets ? "btn-info" : "btn-outline-info")"
       hx-get="@MediaIndexUrl("EditorAssets")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaEditorAssets")</a>
    <a asp-action="Index" asp-route-filter="LibraryAssets" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.LibraryAssets ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@MediaIndexUrl("LibraryAssets")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaLibraryAssets")</a>
    <a asp-action="Index" asp-route-filter="UsedInProducts" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.UsedInProducts ? "btn-success" : "btn-outline-success")"
       hx-get="@MediaIndexUrl("UsedInProducts")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaUsedInProducts")</a>
    <a asp-action="Index" asp-route-filter="Unused" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.Unused ? "btn-danger" : "btn-outline-danger")"
       hx-get="@MediaIndexUrl("Unused")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("MediaUnusedAssets")</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"
       hx-get="@MediaIndexUrl()" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="admin-kpi-row mb-3">
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaMissingAlt")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingAltCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaMissingTitle")</div><div class="fs-4 fw-semibold">@Model.Summary.MissingTitleCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaEditorAssets")</div><div class="fs-4 fw-semibold">@Model.Summary.EditorAssetCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaLibraryAssets")</div><div class="fs-4 fw-semibold">@Model.Summary.LibraryAssetCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaUsedInProducts")</div><div class="fs-4 fw-semibold">@Model.Summary.ProductReferencedCount</div></div>
    <div class="admin-kpi-item"><div class="text-muted small">@T.T("MediaUnusedAssets")</div><div class="fs-4 fw-semibold">@Model.Summary.UnusedCount</div></div>
</div>

<details class="admin-playbook mb-3">
    <summary>@T.T("MediaOpsPlaybooksTitle")</summary>
    <div class="admin-playbook-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Queue")</th>
                        <th>@T.T("Scope")</th>
                        <th>@T.T("OperatorAction")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</details>

<form asp-action="Index"
      method="get"
      class="row g-2 mb-3"
      hx-get="@MediaIndexUrl()"
      hx-target="#media-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="col-sm-8 col-lg-5">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="@T.T("MediaSearchPlaceholder")" />
    </div>
    <div class="col-sm-4 col-lg-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-sm-auto">
        <button class="btn btn-outline-secondary" type="submit">
            <i class="fa fa-search"></i> @T.T("Search")
        </button>
    </div>
    <div class="col-sm-auto">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@MediaIndexUrl()"
           hx-target="#media-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </div>
</form>

<div class="row g-3">
    @if (Model.Items.Count == 0)
    {
        <div class="col-12">
            <div class="alert alert-secondary mb-0">@T.T("MediaNoAssetsFound")</div>
        </div>
    }
    else
    {
        foreach (var item in Model.Items)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                    <div class="ratio ratio-16x9 bg-light border-bottom">
                        <img src="@item.Url" alt="@item.Alt" class="w-100 h-100 object-fit-cover" />
                    </div>
                    <div class="card-body d-flex flex-column gap-2">
                        <div>
                            <div class="fw-semibold text-truncate">@(!string.IsNullOrWhiteSpace(item.Title) ? item.Title : item.OriginalFileName)</div>
                            <div class="small text-muted text-truncate">@item.OriginalFileName</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            @if (string.IsNullOrWhiteSpace(item.Alt))
                            {
                                <span class="badge text-bg-warning">@T.T("MediaMissingAlt")</span>
                            }
                            @if (string.IsNullOrWhiteSpace(item.Title))
                            {
                                <span class="badge text-bg-dark">@T.T("MediaMissingTitle")</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Role) && item.Role.Contains("EditorAsset"))
                            {
                                <span class="badge text-bg-info">@T.T("MediaEditorAsset")</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">@T.T("MediaLibraryAsset")</span>
                            }
                            @if (item.ProductReferenceCount > 0)
                            {
                                <span class="badge text-bg-success">@T.T("MediaProductReferences"): @item.ProductReferenceCount</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">@T.T("MediaUnusedAsset")</span>
                            }
                        </div>
                        <div class="small">
                            <div><span class="text-muted">@T.T("AltLabel"):</span> @(string.IsNullOrWhiteSpace(item.Alt) ? T.T("MediaNotSet") : item.Alt)</div>
                            <div><span class="text-muted">@T.T("Role"):</span> @(string.IsNullOrWhiteSpace(item.Role) ? T.T("MediaGeneralRole") : item.Role)</div>
                            <div><span class="text-muted">@T.T("MediaProductReferences"):</span> @item.ProductReferenceCount</div>
                            <div><span class="text-muted">@T.T("Size"):</span> @((item.SizeBytes / 1024.0).ToString("0.0")) KB</div>
                            <div><span class="text-muted">@T.T("Updated"):</span> @(item.ModifiedAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? T.T("MediaUnknownValue"))</div>
                        </div>
                        <div class="input-group input-group-sm mt-auto">
                            <input type="text" value="@item.Url" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary js-copy-media-url" data-copy-media-url data-url="@item.Url" data-copy-label="@T.T("Copy")" data-copied-label="@T.T("Copied")">@T.T("Copy")</button>
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex gap-2 justify-content-end">
                        <a href="@item.Url" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-dark">
                            <i class="fa fa-up-right-from-square"></i> @T.T("Open")
                        </a>
                        @if (string.IsNullOrWhiteSpace(item.Alt))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"
                               hx-get="@MediaEditUrl(item.Id)"
                               hx-target="#media-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-font"></i> @T.T("MediaSetAlt")
                            </a>
                        }
                        @if (string.IsNullOrWhiteSpace(item.Title))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark"
                               hx-get="@MediaEditUrl(item.Id)"
                               hx-target="#media-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-heading"></i> @T.T("MediaSetTitle")
                            </a>
                        }
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@MediaEditUrl(item.Id)"
                           hx-target="#media-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-pen"></i> @T.T("Edit")
                        </a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#confirmDeleteModal"
                                data-action="@Url.Action("Delete", "Media")"
                                data-id="@item.Id"
                                data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                data-name="@(!string.IsNullOrWhiteSpace(item.Title) ? item.Title : item.OriginalFileName)"
                                data-hx-target="#media-workspace-shell"
                                data-hx-swap="outerHTML"
                               >
                            <i class="fa fa-trash"></i> @T.T("Delete")
                        </button>
                        @if (item.ProductReferenceCount == 0)
                        {
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#confirmDeleteModal"
                                    data-action="@Url.Action("PurgeUnused", "Media")"
                                    data-id="@item.Id"
                                    data-rowversion="@Convert.ToBase64String(item.RowVersion)"
                                    data-name="@(!string.IsNullOrWhiteSpace(item.Title) ? item.Title : item.OriginalFileName)"
                                    data-hx-target="#media-workspace-shell"
                                    data-hx-swap="outerHTML">
                                <i class="fa fa-broom"></i> @T.T("MediaPurgeUnused")
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="mt-4">
    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Media"
           asp-action="Index"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#media-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true"></pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
