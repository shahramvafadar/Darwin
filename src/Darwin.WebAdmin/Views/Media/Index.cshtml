@model Darwin.WebAdmin.ViewModels.CMS.MediaAssetsListVm
@{
    ViewData["Title"] = "Media";
}
<div id="media-workspace-shell">
<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
    <div>
        <h1 class="mb-1">Media Library</h1>
        <p class="text-muted mb-0">Manage uploaded editor assets and reusable media files.</p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary"
       hx-get="@Url.Action("Create", "Media")"
       hx-target="#media-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">
        <i class="fa fa-upload"></i> Upload Media
    </a>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="Index" asp-route-filter="MissingAlt" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.MissingAlt ? "btn-warning" : "btn-outline-warning")"
       hx-get="@Url.Action("Index", "Media", new { filter = "MissingAlt" })" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">Missing Alt</a>
    <a asp-action="Index" asp-route-filter="MissingTitle" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.MissingTitle ? "btn-dark" : "btn-outline-dark")"
       hx-get="@Url.Action("Index", "Media", new { filter = "MissingTitle" })" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">Missing Title</a>
    <a asp-action="Index" asp-route-filter="EditorAssets" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.EditorAssets ? "btn-info" : "btn-outline-info")"
       hx-get="@Url.Action("Index", "Media", new { filter = "EditorAssets" })" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">Editor Assets</a>
    <a asp-action="Index" asp-route-filter="LibraryAssets" class="btn btn-sm @(Model.Filter == Darwin.Application.CMS.Media.DTOs.MediaAssetQueueFilter.LibraryAssets ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@Url.Action("Index", "Media", new { filter = "LibraryAssets" })" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">Library Assets</a>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"
       hx-get="@Url.Action("Index", "Media")" hx-target="#media-workspace-shell" hx-swap="outerHTML" hx-push-url="true">Clear Queue Filters</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Alt</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingAltCount</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Missing Title</div>
            <div class="fs-4 fw-semibold">@Model.Summary.MissingTitleCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Editor Assets</div>
            <div class="fs-4 fw-semibold">@Model.Summary.EditorAssetCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Library Assets</div>
            <div class="fs-4 fw-semibold">@Model.Summary.LibraryAssetCount</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Media Ops Playbooks</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Queue</th>
                        <th>Scope</th>
                        <th>Operator Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td>@item.ScopeNote</td>
                        <td>@item.OperatorAction</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form asp-action="Index"
      method="get"
      class="row g-2 mb-3"
      hx-get="@Url.Action("Index", "Media")"
      hx-target="#media-workspace-shell"
      hx-swap="outerHTML"
      hx-push-url="true">
    <div class="col-sm-8 col-lg-5">
        <input type="text" name="query" value="@Model.Query" class="form-control" placeholder="Search by title, alt, filename, role, or URL" />
    </div>
    <div class="col-sm-4 col-lg-3">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-sm-auto">
        <button class="btn btn-outline-secondary" type="submit">
            <i class="fa fa-search"></i> Search
        </button>
    </div>
    <div class="col-sm-auto">
        <a asp-action="Index" class="btn btn-outline-secondary"
           hx-get="@Url.Action("Index", "Media")"
           hx-target="#media-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">Reset</a>
    </div>
</form>

<div class="row g-3">
    @if (Model.Items.Count == 0)
    {
        <div class="col-12">
            <div class="alert alert-secondary mb-0">No media assets found.</div>
        </div>
    }
    else
    {
        foreach (var item in Model.Items)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                    <div class="ratio ratio-16x9 bg-light border-bottom">
                        <img src="@item.Url" alt="@item.Alt" class="w-100 h-100 object-fit-cover" />
                    </div>
                    <div class="card-body d-flex flex-column gap-2">
                        <div>
                            <div class="fw-semibold text-truncate">@(!string.IsNullOrWhiteSpace(item.Title) ? item.Title : item.OriginalFileName)</div>
                            <div class="small text-muted text-truncate">@item.OriginalFileName</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            @if (string.IsNullOrWhiteSpace(item.Alt))
                            {
                                <span class="badge text-bg-warning">Missing Alt</span>
                            }
                            @if (string.IsNullOrWhiteSpace(item.Title))
                            {
                                <span class="badge text-bg-dark">Missing Title</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Role) && item.Role.Contains("EditorAsset"))
                            {
                                <span class="badge text-bg-info">Editor Asset</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Library Asset</span>
                            }
                        </div>
                        <div class="small">
                            <div><span class="text-muted">Alt:</span> @(string.IsNullOrWhiteSpace(item.Alt) ? "Not set" : item.Alt)</div>
                            <div><span class="text-muted">Role:</span> @(string.IsNullOrWhiteSpace(item.Role) ? "General" : item.Role)</div>
                            <div><span class="text-muted">Size:</span> @((item.SizeBytes / 1024.0).ToString("0.0")) KB</div>
                            <div><span class="text-muted">Updated:</span> @(item.ModifiedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "n/a")</div>
                        </div>
                        <div class="input-group input-group-sm mt-auto">
                            <input type="text" value="@item.Url" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary js-copy-media-url" data-url="@item.Url">Copy</button>
                        </div>
                    </div>
                    <div class="card-footer bg-white d-flex gap-2 justify-content-end">
                        <a href="@item.Url" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-dark">
                            <i class="fa fa-up-right-from-square"></i> Open
                        </a>
                        @if (string.IsNullOrWhiteSpace(item.Alt))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"
                               hx-get="@Url.Action("Edit", "Media", new { id = item.Id })"
                               hx-target="#media-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-font"></i> Set Alt
                            </a>
                        }
                        @if (string.IsNullOrWhiteSpace(item.Title))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark"
                               hx-get="@Url.Action("Edit", "Media", new { id = item.Id })"
                               hx-target="#media-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">
                                <i class="fa fa-heading"></i> Set Title
                            </a>
                        }
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@Url.Action("Edit", "Media", new { id = item.Id })"
                           hx-target="#media-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">
                            <i class="fa fa-pen"></i> Edit
                        </a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#confirmDeleteModal"
                                data-action="@Url.Action("Delete", "Media")"
                                data-id="@item.Id"
                                data-name="@(!string.IsNullOrWhiteSpace(item.Title) ? item.Title : item.OriginalFileName)"
                                data-hx-target="#media-workspace-shell"
                                data-hx-swap="outerHTML"
                                data-hx-success="window.darwinAdmin.refreshAlerts(); window.darwinAdmin.hideModal('confirmDeleteModal');">
                            <i class="fa fa-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="mt-4">
    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Media"
           asp-action="Index"
           asp-route-query="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#media-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true"></pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.js-copy-media-url').forEach(function (button) {
            button.addEventListener('click', async function () {
                const url = button.getAttribute('data-url') || '';
                if (!url || !navigator.clipboard) {
                    return;
                }

                await navigator.clipboard.writeText(url);
                button.textContent = 'Copied';
                window.setTimeout(function () {
                    button.textContent = 'Copy';
                }, 1500);
            });
        });
    </script>
}
