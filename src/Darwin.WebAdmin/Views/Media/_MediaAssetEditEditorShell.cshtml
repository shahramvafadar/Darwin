@model Darwin.WebAdmin.ViewModels.CMS.MediaAssetEditVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("MediaEditTitle");
    string MediaIndexUrl() => Url.Action("Index", "Media") ?? string.Empty;
}

<div id="media-edit-editor-shell">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-3">
        <div>
            <h1 class="mb-1">@T.T("MediaEditTitle")</h1>
            <div class="text-muted small">@Model.OriginalFileName</div>
        </div>
        <a href="@Model.Url" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">
            <i class="fa fa-up-right-from-square"></i> @T.T("MediaOpenFile")
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="ratio ratio-16x9 bg-light border-bottom">
                    <img src="@Model.Url" alt="@Model.Alt" class="w-100 h-100 object-fit-cover" />
                </div>
                <div class="card-body small">
                    <div><span class="text-muted">@T.T("Url"):</span> @Model.Url</div>
                    <div><span class="text-muted">@T.T("Size"):</span> @((Model.SizeBytes / 1024.0).ToString("0.0")) KB</div>
                    <div><span class="text-muted">@T.T("Dimensions"):</span> @(Model.Width.HasValue && Model.Height.HasValue ? $"{Model.Width} x {Model.Height}" : T.T("MediaUnknownValue"))</div>
                    <div><span class="text-muted">@T.T("Updated"):</span> @(Model.ModifiedAtUtc?.ToLocalTime().ToString(CultureInfo.CurrentCulture) ?? T.T("MediaUnknownValue"))</div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <form asp-action="Edit"
                  method="post"
                  hx-post="@Url.Action("Edit", "Media")"
                  hx-target="#media-edit-editor-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />

                <partial name="_MediaAssetUploadForm" model="Model" />

                <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save"></i> @T.T("Save")
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary"
                       hx-get="@MediaIndexUrl()"
                       hx-target="#media-edit-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Back")</a>
                </div>
            </form>
        </div>
    </div>
</div>
