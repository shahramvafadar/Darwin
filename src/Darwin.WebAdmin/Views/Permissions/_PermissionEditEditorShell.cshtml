@model Darwin.WebAdmin.ViewModels.Identity.PermissionEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("EditPermission");
    string GlobalBusinessSupportQueueUrl() => Url.Action("SupportQueue", "Businesses") ?? string.Empty;
    string PermissionsIndexUrl() => Url.Action("Index", "Permissions") ?? string.Empty;
    string DelegatedSupportPermissionsUrl() => Url.Action("Index", "Permissions", new { filter = Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport }) ?? string.Empty;
    string UnconfirmedUsersUrl() => Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed }) ?? string.Empty;
    string LockedUsersUrl() => Url.Action("Index", "Users", new { filter = Darwin.Application.Identity.DTOs.UserQueueFilter.Locked }) ?? string.Empty;
}

<div id="permission-editor-shell">
    <h1 class="mb-3"><i class="fa fa-key"></i> @T.T("EditPermission")</h1>

    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="card mb-3 border-info-subtle">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index"
                   asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport"
                   class="btn btn-sm btn-outline-info"
                   hx-get="@DelegatedSupportPermissionsUrl()"
                   hx-target="#permission-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("IdentityFilterDelegatedSupport")</a>
                <a asp-controller="Businesses"
                   asp-action="SupportQueue"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@GlobalBusinessSupportQueueUrl()"
                   hx-target="#permission-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Unconfirmed"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@UnconfirmedUsersUrl()"
                   hx-target="#permission-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterUnconfirmed")</a>
                <a asp-controller="Users"
                   asp-action="Index"
                   asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.Locked"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@LockedUsersUrl()"
                   hx-target="#permission-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("UsersFilterLocked")</a>
            </div>
        </div>
    </div>

    <form asp-action="Edit"
          method="post"
          hx-post="@Url.Action("Edit", "Permissions")"
          hx-target="#permission-editor-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Key" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="IsSystem" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">@T.T("Key")</label>
                    <input class="form-control" value="@Model.Key" readonly />
                    <small class="text-muted">@T.T("ImmutableKeyHelp")</small>
                </div>
                <div class="mb-3">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <field-help title="@T.T("DisplayName")" content="@T.T("AdminDisplayNameHelp")" placement="right"></field-help>
                    <input asp-for="DisplayName" class="form-control" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">@T.T("System")</label>
                    @if (Model.IsSystem)
                    {
                        <span class="badge bg-secondary"><i class="fa fa-lock"></i> @T.T("System")</span>
                    }
                    else
                    {
                        <span class="text-muted">@T.T("No")</span>
                    }
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <div>
                    @if (!Model.IsSystem)
                    {
                        <button type="button"
                                class="btn btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#confirmDeleteModal"
                                data-action="@Url.Action("Delete", "Permissions")"
                                data-id="@Model.Id"
                                data-rowversion="@Convert.ToBase64String(Model.RowVersion)"
                                data-name="@Model.Key"
                                data-hx-target="#permission-editor-shell"
                                data-hx-swap="outerHTML"
                   >
                            <i class="fa fa-trash"></i> @T.T("Delete")
                        </button>
                    }
                </div>
                <div class="text-end">
                    <a asp-action="Index"
                       class="btn btn-outline-secondary"
                       hx-get="@PermissionsIndexUrl()"
                       hx-target="#permission-editor-shell"
                       hx-swap="outerHTML"><i class="fa fa-arrow-left"></i> @T.T("Back")</a>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> @T.T("Save")</button>
                </div>
            </div>
        </div>
    </form>

    <partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
</div>
