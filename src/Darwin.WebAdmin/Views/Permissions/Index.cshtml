@model Darwin.WebAdmin.ViewModels.Identity.PermissionsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("Permissions");
    string PermissionsGlobalIndexUrl() => Url.Action("Index", "Permissions") ?? string.Empty;
    string PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter filter) => Url.Action("Index", "Permissions", new { filter }) ?? string.Empty;
    string CreatePermissionUrl() => Url.Action("Create", "Permissions") ?? string.Empty;
    string EditPermissionUrl(Guid id) => Url.Action("Edit", "Permissions", new { id }) ?? string.Empty;
}

<div id="permissions-workspace-shell">
    <h1 class="mb-3"><i class="fa fa-key"></i> @T.T("Permissions")</h1>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Total")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.All"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.All)"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("System")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.SystemCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.System"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.System)"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterSystem")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("Custom")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.CustomCount</div>
                    <div class="mt-2 d-flex gap-2 flex-wrap">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.Custom"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.Custom)"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterCustom")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreatePermissionUrl()"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML">@T.T("NewPermission")</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">@T.T("DelegatedSupport")</div>
                    <div class="fs-4 fw-semibold">@Model.Summary.DelegatedSupportCount</div>
                    <div class="mt-2">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport"
                           class="btn btn-sm btn-outline-info"
                           hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport)"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("IdentityFilterDelegatedSupport")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3 border-info-subtle">
        <div class="card-body">
            <h2 class="h6 mb-2">@T.T("PermissionOpsPlaybook")</h2>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("PermissionOpsPlaybookSystem")</span>
                    <a asp-action="Index"
                       asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.System"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.System)"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Open")</a>
                </div>
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("PermissionOpsPlaybookDelegatedSupport")</span>
                    <a asp-action="Index"
                       asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport"
                       class="btn btn-sm btn-outline-info"
                       hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.DelegatedSupport)"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Open")</a>
                </div>
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                    <span>@T.T("PermissionOpsPlaybookCustom")</span>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Index"
                           asp-route-filter="@Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.Custom"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@PermissionsIndexUrl(Darwin.WebAdmin.ViewModels.Identity.PermissionQueueFilter.Custom)"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-action="Create"
                           class="btn btn-sm btn-outline-primary"
                           hx-get="@CreatePermissionUrl()"
                           hx-target="#permissions-workspace-shell"
                           hx-swap="outerHTML"><i class="fa fa-plus"></i> @T.T("NewPermission")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="alert alert-info mb-3">
                <strong>@T.T("DelegatedBusinessSupport"):</strong> @T.T("PermissionDelegatedSupportNote")
            </div>
            <form method="get"
                  class="row g-2 align-items-end"
               hx-get="@PermissionsGlobalIndexUrl()"
                  hx-target="#permissions-workspace-shell"
                  hx-swap="outerHTML">
                <div class="col-md-4">
                    <label for="q" class="form-label">@T.T("Search")</label>
                    <field-help title="@T.T("SearchTerm")" content="@T.T("PermissionSearchHelp")" placement="right"></field-help>
                    <input id="q" name="q" value="@Model.Query" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label for="pageSize" class="form-label">@T.T("PageSize")</label>
                    <select id="pageSize" name="pageSize" class="form-select" asp-items="Model.PageSizeItems"></select>
                </div>
                <div class="col-md-3">
                    <label for="filter" class="form-label">@T.T("Queue")</label>
                    <select id="filter" name="filter" class="form-select" asp-items="Model.FilterItems"></select>
                </div>
                <div class="col-md-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="fa fa-search"></i> @T.T("Search")
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary"
       hx-get="@PermissionsGlobalIndexUrl()"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML">@T.T("Reset")</a>
                    <a asp-action="Create"
                       class="btn btn-primary"
                       hx-get="@CreatePermissionUrl()"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML"><i class="fa fa-plus"></i> @T.T("NewPermission")</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@T.T("Key")</th>
                            <th>@T.T("DisplayName")</th>
                            <th>@T.T("Description")</th>
                    <th class="admin-w-120">@T.T("System")</th>
                    <th class="text-end admin-w-180">@T.T("Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted p-4">@T.T("NoPermissionsFound")</td></tr>
                    }
                    else
                    {
                        foreach (var p in Model.Items)
                        {
                            <tr>
                                <td class="text-monospace">@p.Key</td>
                                <td>@p.DisplayName</td>
                                <td>@(string.IsNullOrWhiteSpace(p.Description) ? "-" : p.Description)</td>
                                <td>
                                    @if (p.IsSystem) { <span class="badge bg-secondary"><i class="fa fa-lock"></i> @T.T("System")</span> }
                                    else { <span class="text-muted">@T.T("No")</span> }
                                </td>
                                <td class="text-end">
                                    @if (string.Equals(p.Key, "ManageBusinessSupport", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-info text-dark me-2">@T.T("DelegatedSupport")</span>
                                    }
                                    <a asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary me-1"
                                       hx-get="@EditPermissionUrl(p.Id)"
                                       hx-target="#permissions-workspace-shell"
                                       hx-swap="outerHTML">
                                        <i class="fa fa-pen"></i> @T.T("Edit")
                                    </a>
                                    @if (!p.IsSystem)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#confirmDeleteModal"
                                                data-action="@Url.Action("Delete", "Permissions")"
                                                data-id="@p.Id"
                                                data-name="@p.DisplayName"
                                                data-rowversion="@Convert.ToBase64String(p.RowVersion)"
                                                data-hx-target="#permissions-workspace-shell"
                                                data-hx-swap="outerHTML"
                                   >
                                            <i class="fa fa-trash"></i> @T.T("Delete")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Permissions"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter"
           hx-target="#permissions-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">
    </pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
