@model Darwin.WebAdmin.ViewModels.Identity.PermissionsListVm
@{
    ViewData["Title"] = "Permissions";
}

<div id="permissions-workspace-shell">
    <h1 class="mb-3"><i class="fa fa-key"></i> Permissions</h1>

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Total</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">System</div><div class="fs-4 fw-semibold">@Model.Summary.SystemCount</div></div></div></div>
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Custom</div><div class="fs-4 fw-semibold">@Model.Summary.CustomCount</div></div></div></div>
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Delegated support</div><div class="fs-4 fw-semibold">@Model.Summary.DelegatedSupportCount</div></div></div></div>
    </div>

    <div class="card mb-3 border-info-subtle">
        <div class="card-body">
            <h2 class="h6 mb-2">Permission Ops Playbook</h2>
            <ul class="mb-0">
                <li>Review `System` permissions before changing role bindings.</li>
                <li>Use `Delegated Support` to verify business-support scope stays narrower than `FullAdminAccess`.</li>
                <li>Use `Custom` when cleaning up older permission experiments before completion audit.</li>
            </ul>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="alert alert-info mb-3">
                <strong>Delegated business support:</strong> the built-in <code>ManageBusinessSupport</code> permission is for invitation and member-support workflows only. Approval, suspension, owner overrides, and business lifecycle actions still belong to <code>FullAdminAccess</code>.
            </div>
            <form method="get"
                  class="row g-2 align-items-end"
                  hx-get="@Url.Action("Index", "Permissions")"
                  hx-target="#permissions-workspace-shell"
                  hx-swap="outerHTML">
                <div class="col-md-4">
                    <label for="q" class="form-label">Search</label>
                    <field-help title="Search term" content="Searches in key and display name." placement="right"></field-help>
                    <input id="q" name="q" value="@Model.Query" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label for="pageSize" class="form-label">Page size</label>
                    <select id="pageSize" name="pageSize" class="form-select" asp-items="Model.PageSizeItems"></select>
                </div>
                <div class="col-md-3">
                    <label for="filter" class="form-label">Queue</label>
                    <select id="filter" name="filter" class="form-select" asp-items="Model.FilterItems"></select>
                </div>
                <div class="col-md-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="fa fa-search"></i> Search
                    </button>
                    <a asp-action="Index"
                       class="btn btn-outline-secondary"
                       hx-get="@Url.Action("Index", "Permissions")"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML">Reset</a>
                    <a asp-action="Create"
                       class="btn btn-primary"
                       hx-get="@Url.Action("Create", "Permissions")"
                       hx-target="#permissions-workspace-shell"
                       hx-swap="outerHTML"><i class="fa fa-plus"></i> New Permission</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Key</th>
                            <th>Display Name</th>
                            <th>Description</th>
                            <th style="width:120px;">System</th>
                            <th class="text-end" style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted p-4">No permissions found.</td></tr>
                    }
                    else
                    {
                        foreach (var p in Model.Items)
                        {
                            <tr>
                                <td class="text-monospace">@p.Key</td>
                                <td>@p.DisplayName</td>
                                <td>@(string.IsNullOrWhiteSpace(p.Description) ? "-" : p.Description)</td>
                                <td>
                                    @if (p.IsSystem) { <span class="badge bg-secondary"><i class="fa fa-lock"></i> System</span> }
                                    else { <span class="text-muted">No</span> }
                                </td>
                                <td class="text-end">
                                    @if (string.Equals(p.Key, "ManageBusinessSupport", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-info text-dark me-2">Delegated support</span>
                                    }
                                    <a asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary me-1"
                                       hx-get="@Url.Action("Edit", "Permissions", new { id = p.Id })"
                                       hx-target="#permissions-workspace-shell"
                                       hx-swap="outerHTML">
                                        <i class="fa fa-pen"></i> Edit
                                    </a>
                                    @if (!p.IsSystem)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#confirmDeleteModal"
                                                data-action="@Url.Action("Delete", "Permissions")"
                                                data-id="@p.Id"
                                                data-name="@p.DisplayName"
                                                data-rowversion="@Convert.ToBase64String(p.RowVersion)">
                                            <i class="fa fa-trash"></i> Delete
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <pager page="Model.Page"
           page-size="Model.PageSize"
           total="Model.Total"
           asp-controller="Permissions"
           asp-action="Index"
           asp-route-q="@Model.Query"
           asp-route-filter="@Model.Filter">
    </pager>
</div>

<partial name="~/Views/Shared/_ConfirmDeleteModal.cshtml" />
