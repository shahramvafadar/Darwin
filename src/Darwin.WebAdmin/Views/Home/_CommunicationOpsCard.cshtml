@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    string CommunicationChannelLabel(string channel) => channel switch
    {
        "SMS" => T.T("SMS"),
        "WhatsApp" => T.T("WhatsApp"),
        _ => string.IsNullOrWhiteSpace(channel) ? T.T("CommonUnclassified") : T.T(channel)
    };
}

<div id="communication-ops-card" class="card shadow-sm">
    <div class="card-header bg-white">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="fw-semibold">@T.T("CommunicationOpsTitle")</div>
                <div class="small text-muted">@T.T("CommunicationOpsDashboardIntro")</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        hx-get="@Url.Action("CommunicationOpsFragment", "Home", new { businessId = Model.SelectedBusinessId })"
                        hx-target="#communication-ops-card"
                        hx-swap="outerHTML">
                    @T.T("Refresh")
                </button>
                <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-secondary">@T.T("OpenWorkspaceAction")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-sm btn-outline-secondary">@T.T("SMTP")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-sm btn-outline-secondary">@CommunicationChannelLabel("SMS")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-sm btn-outline-secondary">@CommunicationChannelLabel("WhatsApp")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-secondary">@T.T("AdminAlerts")</a>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("EmailTransport")</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.EmailTransportConfigured ? T.T("Ready") : T.T("NeedsSetup"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("SmsTransport")</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.SmsTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("WhatsAppTransport")</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.WhatsAppTransportConfigured ? T.T("Ready") : T.T("NotReady"))</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("AdminAlertRouting")</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.AdminAlertRoutingConfigured ? T.T("Configured") : T.T("Missing"))</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("BusinessesRequiringEmailSetup")</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.BusinessesRequiringEmailSetupCount</div>
                    <div class="small text-muted mt-2">@T.T("BusinessesRequiringEmailSetupNote")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("MissingSupportEmail")</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.MissingSupportEmailCount</div>
                    <div class="small text-muted mt-2">@T.T("MissingSupportEmailNote")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">@T.T("MissingSenderIdentity")</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.MissingSenderIdentityCount</div>
                    <div class="small text-muted mt-2">@T.T("MissingSenderIdentityNote")</div>
                </div>
            </div>
        </div>

        <div class="small text-muted mt-3">
            @T.T("CommunicationTransactionalEmailEnabledLabel"): <strong>@Model.CommunicationOps.TransactionalEmailBusinessesCount</strong>
            <span class="mx-2">|</span>
            @T.T("CommunicationMarketingEmailEnabledLabel"): <strong>@Model.CommunicationOps.MarketingEmailBusinessesCount</strong>
            <span class="mx-2">|</span>
            @T.T("CommunicationOperationalAlertsEnabledLabel"): <strong>@Model.CommunicationOps.OperationalAlertBusinessesCount</strong>
        </div>

        @if (Model.SelectedBusinessId.HasValue)
        {
            <div class="d-flex flex-wrap gap-2 mt-3">
                <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("CommunicationOpenCurrentBusinessSetupAction")</a>
                <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.SelectedBusinessId" asp-route-filter="Attention" class="btn btn-sm btn-outline-primary">@T.T("CommunicationOpenMemberSupportAction")</a>
                <a asp-controller="BusinessCommunications" asp-action="Details" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("CommunicationInspectProfileAction")</a>
            </div>
        }
    </div>
</div>
