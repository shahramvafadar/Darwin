@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm

<div id="communication-ops-card" class="card shadow-sm">
    <div class="card-header bg-white">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="fw-semibold">Communication Operations</div>
                <div class="small text-muted">Phase-1 email/SMS/WhatsApp readiness across platform and business defaults.</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        hx-get="@Url.Action("CommunicationOpsFragment", "Home", new { businessId = Model.SelectedBusinessId })"
                        hx-target="#communication-ops-card"
                        hx-swap="outerHTML">
                    Refresh
                </button>
                <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-secondary">Open Workspace</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-smtp" class="btn btn-sm btn-outline-secondary">SMTP</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-sms" class="btn btn-sm btn-outline-secondary">SMS</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-whatsapp" class="btn btn-sm btn-outline-secondary">WhatsApp</a>
                <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-admin-routing" class="btn btn-sm btn-outline-secondary">Admin Alerts</a>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Email Transport</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.EmailTransportConfigured ? "Ready" : "Needs setup")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">SMS Transport</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.SmsTransportConfigured ? "Ready" : "Not ready")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">WhatsApp Transport</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.WhatsAppTransportConfigured ? "Ready" : "Not ready")</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Admin Alert Routing</div>
                    <div class="fw-semibold mt-1">@(Model.CommunicationOps.AdminAlertRoutingConfigured ? "Configured" : "Missing")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Businesses Requiring Email Setup</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.BusinessesRequiringEmailSetupCount</div>
                    <div class="small text-muted mt-2">Businesses with email-related toggles enabled but missing support or sender identity fields.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Missing Support Email</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.MissingSupportEmailCount</div>
                    <div class="small text-muted mt-2">Transactional and support-facing flows should not depend only on global sender details.</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Missing Sender Identity</div>
                    <div class="fs-4 fw-semibold">@Model.CommunicationOps.MissingSenderIdentityCount</div>
                    <div class="small text-muted mt-2">Counts businesses missing sender display name or reply-to defaults.</div>
                </div>
            </div>
        </div>

        <div class="small text-muted mt-3">
            Transactional email enabled: <strong>@Model.CommunicationOps.TransactionalEmailBusinessesCount</strong>
            <span class="mx-2">|</span>
            Marketing email enabled: <strong>@Model.CommunicationOps.MarketingEmailBusinessesCount</strong>
            <span class="mx-2">|</span>
            Operational alerts enabled: <strong>@Model.CommunicationOps.OperationalAlertBusinessesCount</strong>
        </div>

        @if (Model.SelectedBusinessId.HasValue)
        {
            <div class="d-flex flex-wrap gap-2 mt-3">
                <a asp-controller="Businesses" asp-action="Setup" asp-route-id="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">Open Current Business Setup</a>
                <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.SelectedBusinessId" asp-route-filter="Attention" class="btn btn-sm btn-outline-primary">Open Member Support</a>
                <a asp-controller="BusinessCommunications" asp-action="Details" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">Inspect Communication Profile</a>
            </div>
        }
    </div>
</div>
