{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "PostgreSql": ""
  },
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Security": {
    "CookieSecurePolicy": "SameAsRequest"
  },
  "Email": {
    "Provider": "SMTP",
    "Brevo": {
      "BaseUrl": "https://api.brevo.com/v3/",
      "ApiKey": "",
      "SenderEmail": "no-reply@darwin.local",
      "SenderName": "Darwin Development",
      "ReplyToEmail": "",
      "ReplyToName": "",
      "WebhookUsername": "",
      "WebhookPassword": "",
      "SandboxMode": true,
      "TimeoutSeconds": 30,
      "DefaultTags": [
        "darwin",
        "development",
        "transactional"
      ]
    },
    "Smtp": {
      "Host": "localhost",
      "Port": 2525,
      "EnableSsl": false,
      "Username": "",
      "Password": "",
      "FromAddress": "no-reply@darwin.local",
      "FromDisplayName": "Darwin Development"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/dev-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Properties": {
      "Application": "Darwin.WebAdmin (Dev)"
    }
  },
  "DataProtection": {
    "KeysPath": "E:\\_Projects\\Darwin\\_shared_keys",
    "ApplicationName": "Darwin",
    "RequireKeyEncryption": false
  }
}
