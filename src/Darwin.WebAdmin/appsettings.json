{
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Darwin.WebAdmin"
    }
  },
  "DataProtection": {
    "KeysPath": "D:\\Darwin\\_shared_keys",
    "ApplicationName": "Darwin",
    "RequireKeyEncryption": true,
    "CertificateThumbprint": "",
    "CertificateStoreName": "My",
    "CertificateStoreLocation": "LocalMachine"
  },
  "Email": {
    "Provider": "Brevo",
    "Brevo": {
      "BaseUrl": "https://api.brevo.com/v3/",
      "ApiKey": "",
      "SenderEmail": "",
      "SenderName": "Darwin",
      "ReplyToEmail": "",
      "ReplyToName": "Darwin Support",
      "WebhookUsername": "",
      "WebhookPassword": "",
      "SandboxMode": false,
      "TimeoutSeconds": 30,
      "DefaultTags": [
        "darwin",
        "transactional"
      ]
    },
    "Smtp": {
      "Host": "smtp.office365.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "",
      "FromDisplayName": "Darwin"
    }
  },
  "BusinessOnboarding": {
    "InvitationMagicLink": {
      "BaseUrl": "darwin-business://InvitationAcceptance"
    }
  },
  "Security": {
    "AuthAntiBot": {
      "Enabled": true,
      "RequireChallengeToken": true,
      "MinimumFormSeconds": 2,
      "ChallengeTokenMaxAgeSeconds": 900
    }
  }
}
