{
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "PostgreSql"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "buffered": false,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "Darwin.WebAdmin"
    }
  },
  "DataProtection": {
    "KeysPath": "D:\\Darwin\\_shared_keys"
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.office365.com",
      "Port": 587,
      "EnableSsl": true,
      "Username": "darwin.test.sender@outlook.com",
      "Password": "SET_TEST_SMTP_PASSWORD_HERE",
      "FromAddress": "darwin.test.sender@outlook.com",
      "FromDisplayName": "Darwin Test"
    }
  },
  "BusinessOnboarding": {
    "InvitationMagicLink": {
      "BaseUrl": "darwin-business://InvitationAcceptance"
    }
  },
  "Security": {
    "AuthAntiBot": {
      "Enabled": true,
      "RequireChallengeToken": true,
      "MinimumFormSeconds": 2,
      "ChallengeTokenMaxAgeSeconds": 900
    }
  }
}
