<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.SessionPage"
    x:DataType="vm:SessionViewModel"
    Title="{x:Static res:AppResources.SessionTitle}">

    <ScrollView x:Name="RootScrollView">
        <VerticalStackLayout Padding="20,16,20,24" Spacing="14">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding OperatorRole, StringFormat='{x:Static res:AppResources.OperatorRoleFormat}'}"
                           Style="{StaticResource CaptionLabelStyle}" />
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Border Grid.Column="0"
                                Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{x:Static res:AppResources.PointsLabel}"
                                       Style="{StaticResource CaptionLabelStyle}" />
                                <Label Text="{Binding PointsBalance}"
                                       Style="{StaticResource MetricValueLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource MutedCardBorderStyle}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{x:Static res:AppResources.CustomerLabel}"
                                       Style="{StaticResource CaptionLabelStyle}" />
                                <Label Text="{Binding CustomerName}"
                                       Style="{StaticResource BodyLabelStyle}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label Text="{Binding SuccessMessage}"
                           Style="{StaticResource SuccessLabelStyle}"
                           IsVisible="{Binding HasSuccess}" />

                    <Label Text="{Binding WarningMessage}"
                           Style="{StaticResource WarningLabelStyle}"
                           IsVisible="{Binding HasWarning}" />

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedAccrual}"
                   Style="{StaticResource WarningLabelStyle}"
                   IsVisible="{Binding HasAccrualPermission, Converter={StaticResource InverseBoolConverter}}" />

            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedRedemption}"
                   Style="{StaticResource WarningLabelStyle}"
                   IsVisible="{Binding HasRedemptionPermission, Converter={StaticResource InverseBoolConverter}}" />

            <Border Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding CanExecuteAccrual}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ConfirmAccrualButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.AccrualHelpText}"
                           Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.PointsPlaceholder}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry x:Name="PointsEntry"
                               Text="{Binding PointsToAccrue}"
                               Keyboard="Numeric"
                               Placeholder="{x:Static res:AppResources.PointsPlaceholder}"
                               Style="{StaticResource FormEntryStyle}"
                               TextColor="{StaticResource BrushOnSurface}" />
                    </inputLayout:SfTextInputLayout>
                    <buttons:SfButton Text="{x:Static res:AppResources.ConfirmAccrualButton}"
                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                      Command="{Binding ConfirmAccrualCommand}"
                                      Clicked="OnActionClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    IsVisible="{Binding CanExecuteRedemption}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ConfirmRedemptionButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.RedemptionHelpText}"
                           Style="{StaticResource SecondaryBodyLabelStyle}" />
                    <buttons:SfButton Text="{x:Static res:AppResources.ConfirmRedemptionButton}"
                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                      Command="{Binding ConfirmRedemptionCommand}"
                                      Clicked="OnActionClicked" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource BrushPrimary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
