<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    Title="{x:Static res:AppResources.SettingsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24,24,24,32"
                             Spacing="18">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.SettingsTitle}"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.SettingsSubtitle}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.ProfileTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SettingsProfileButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Command="{Binding OpenProfileCommand}" />

                    <Button Text="{x:Static res:AppResources.SettingsChangePasswordButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Command="{Binding OpenChangePasswordCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.HomeStatusTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SettingsStaffAccessBadgeButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Command="{Binding OpenStaffAccessBadgeCommand}" />

                    <Button Text="{x:Static res:AppResources.SettingsSubscriptionButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Command="{Binding OpenSubscriptionCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.LegalHubTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                            Style="{StaticResource OutlinedButtonStyle}"
                            Command="{Binding OpenLegalHubCommand}" />

                    <Button Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                            Style="{StaticResource DangerLinkButtonStyle}"
                            HorizontalOptions="Start"
                            Command="{Binding OpenAccountDeletionCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
