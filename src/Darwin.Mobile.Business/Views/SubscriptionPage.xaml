<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.SubscriptionPage"
    x:DataType="vm:SubscriptionViewModel"
    Title="{x:Static res:AppResources.SubscriptionTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="{x:Static res:AppResources.SubscriptionTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="{x:Static res:AppResources.SubscriptionDescription}"
                   Style="{StaticResource SecondaryBodyLabelStyle}" />

            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.SubscriptionStatusSectionTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Label Text="{Binding SubscriptionSummaryText}"
                           Style="{StaticResource BodyLabelStyle}" />

                    <Label Text="{Binding SubscriptionDatesText}"
                           Style="{StaticResource CaptionLabelStyle}"
                           IsVisible="{Binding HasSubscriptionStatus}" />

                    <Label Text="{Binding SubscriptionPolicyNotice}"
                           Style="{StaticResource SecondaryBodyLabelStyle}" />

                    <Button Text="{x:Static res:AppResources.SubscriptionRefreshStatusButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RefreshSubscriptionStatusCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.SubscriptionManagementSectionTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Label Text="{Binding ManagementWebsiteHint}"
                           Style="{StaticResource BodyLabelStyle}" />

                    <Label Text="{Binding ManagementWebsiteDetails}"
                           Style="{StaticResource CaptionLabelStyle}" />

                    <Label Text="{x:Static res:AppResources.SubscriptionManagementWebsiteUrlLabel}"
                           Style="{StaticResource FormLabelStyle}"
                           IsVisible="{Binding IsManagementWebsiteConfigured}" />

                    <Label Text="{Binding ManagementWebsiteUrlText}"
                           Style="{StaticResource CaptionLabelStyle}"
                           IsVisible="{Binding IsManagementWebsiteConfigured}" />

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />

                    <Button Text="{x:Static res:AppResources.SubscriptionOpenManagementWebsiteButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding OpenManagementWebsiteCommand}"
                            IsEnabled="{Binding IsManagementWebsiteConfigured}" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
