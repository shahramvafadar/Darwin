<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.ScannerPage"
    x:DataType="vm:ScannerViewModel"
    Title="{x:Static res:AppResources.ScanTitle}">

    <!-- Named scroll root to reveal feedback when needed -->
    <ScrollView x:Name="RootScrollView">
        <VerticalStackLayout Spacing="16" Padding="24">

            <Button Text="{x:Static res:AppResources.ScanTitle}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding CanStartScan}"
                    HorizontalOptions="Fill" />

            <Label Text="{Binding OperatorRole, StringFormat='Operator role: {0}'}"
                   FontSize="12"
                   Opacity="0.8"
                   TextColor="{StaticResource BrushOnSurface}" />

            <Label Text="{x:Static res:AppResources.LastTokenLabel}"
                   Style="{StaticResource TitleLabelStyle}" />
            <Label Text="{Binding LastScannedToken}"
                   TextColor="{StaticResource BrushPrimary}"
                   FontSize="16"
                   LineBreakMode="CharacterWrap" />

            <Label Text="{x:Static res:AppResources.ScannerSingleOwnerHint}"
                   FontSize="12"
                   Opacity="0.75"
                   TextColor="{StaticResource BrushOnSurface}" />

            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedAccrual}"
                   TextColor="OrangeRed"
                   FontSize="12"
                   IsVisible="{Binding HasAccrualPermission, Converter={StaticResource InverseBoolConverter}}" />

            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedRedemption}"
                   TextColor="OrangeRed"
                   FontSize="12"
                   IsVisible="{Binding HasRedemptionPermission, Converter={StaticResource InverseBoolConverter}}" />

            <Label Text="{x:Static res:AppResources.BusinessNoScannerPermissionWarning}"
                   TextColor="OrangeRed"
                   FontSize="12"
                   IsVisible="{Binding HasAnyProcessingPermission, Converter={StaticResource InverseBoolConverter}}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="14"
                   IsVisible="{Binding HasError}"
                   LineBreakMode="WordWrap" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource BrushPrimary}"
                               HeightRequest="40" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
