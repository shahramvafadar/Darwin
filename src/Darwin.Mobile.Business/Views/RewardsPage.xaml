<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
             xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
             x:Class="Darwin.Mobile.Business.Views.RewardsPage"
             x:DataType="vm:RewardsViewModel"
             Title="{x:Static res:AppResources.RewardsTitle}"
             x:Name="PageRoot">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static res:AppResources.RewardsTitle}"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="{x:Static res:AppResources.RewardsSubtitle}"
                   FontSize="13"
                   Opacity="0.8" />

            <Label Text="{Binding OperatorRole, StringFormat='Operator role: {0}'}"
                   FontSize="12"
                   Opacity="0.8" />

            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedRewardEdit}"
                   TextColor="OrangeRed"
                   IsVisible="{Binding CanManageRewards, Converter={StaticResource InverseBoolConverter}}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="{x:Static res:AppResources.RewardsRefreshButton}"
                        Command="{Binding RefreshCommand}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.RewardsNewTierButton}"
                        IsEnabled="{Binding CanManageRewards}"
                        Command="{Binding CreateNewCommand}" />
            </Grid>

            <Border StrokeThickness="1" Stroke="{StaticResource BrushPrimary}" Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding SaveButtonText}" FontAttributes="Bold" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsPointsPlaceholder}"
                           Keyboard="Numeric"
                           Text="{Binding PointsRequiredInput}" />

                    <Picker Title="{x:Static res:AppResources.RewardsTypePickerTitle}"
                            ItemsSource="{Binding RewardTypeOptions}"
                            SelectedItem="{Binding SelectedRewardType}" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsValuePlaceholder}"
                           Keyboard="Numeric"
                           Text="{Binding RewardValueInput}" />

                    <Editor Placeholder="{x:Static res:AppResources.RewardsDescriptionPlaceholder}"
                            AutoSize="TextChanges"
                            Text="{Binding DescriptionInput}" />

                    <HorizontalStackLayout Spacing="8">
                        <Switch IsToggled="{Binding AllowSelfRedemption}" />
                        <Label Text="{x:Static res:AppResources.RewardsAllowSelfRedemptionLabel}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="{Binding SaveButtonText}"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanManageRewards}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.RewardsDeleteButton}"
                                Command="{Binding DeleteCommand}"
                                IsEnabled="{Binding CanDeleteReward}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="{x:Static res:AppResources.RewardsCurrentTiersLabel}"
                   FontAttributes="Bold" />

            <CollectionView x:Name="RewardTiersCollectionView"
                            ItemsSource="{Binding RewardTiers}"
                            SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:RewardTierEditorItem">
                        <Border StrokeThickness="1" Stroke="#555555" Padding="10" Margin="0,4,0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PointsRequired, StringFormat='{}{0} pts'}"
                                       FontAttributes="Bold"
                                       FontSize="15" />

                                <Label Text="{Binding RewardType}"
                                       FontSize="13"
                                       Opacity="0.85" />

                                <Label Text="{Binding RewardValue, StringFormat='Value: {0}'}"
                                       FontSize="13"
                                       IsVisible="{Binding RewardValue, Converter={StaticResource NullCheckConverter}}" />

                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       IsVisible="{Binding Description, Converter={StaticResource NullCheckConverter}}" />

                                <Label Text="{Binding AllowSelfRedemption, StringFormat='Self redemption: {0}'}"
                                       FontSize="12"
                                       Opacity="0.7" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>


            <Border StrokeThickness="1" Stroke="#666666" Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding CampaignSaveButtonText}" FontAttributes="Bold" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignNamePlaceholder}"
                           Text="{Binding CampaignNameInput}" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignTitlePlaceholder}"
                           Text="{Binding CampaignTitleInput}" />

                    <Editor Placeholder="{x:Static res:AppResources.RewardsCampaignBodyPlaceholder}"
                            AutoSize="TextChanges"
                            Text="{Binding CampaignBodyInput}" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignStartsAtPlaceholder}"
                           Text="{Binding CampaignStartsAtInput}" />

                    <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignEndsAtPlaceholder}"
                           Text="{Binding CampaignEndsAtInput}" />

                    <Picker Title="{x:Static res:AppResources.RewardsCampaignChannelPickerTitle}"
                            ItemsSource="{Binding CampaignChannelOptions}"
                            SelectedItem="{Binding SelectedCampaignChannel}" />

                    <Editor Placeholder="{x:Static res:AppResources.RewardsCampaignTargetingJsonPlaceholder}"
                            AutoSize="TextChanges"
                            Text="{Binding CampaignTargetingJsonInput}" />

                    <Label Text="{x:Static res:AppResources.RewardsCampaignTargetingPresetTitle}"
                           FontSize="12"
                           Opacity="0.75" />

                    <HorizontalStackLayout Spacing="6">
                        <Button Text="{x:Static res:AppResources.RewardsCampaignAudienceJoinedMembers}"
                                Command="{Binding ApplyCampaignTargetingPresetCommand}"
                                CommandParameter="JoinedMembers"
                                FontSize="12" />
                        <Button Text="{x:Static res:AppResources.RewardsCampaignAudienceTierSegment}"
                                Command="{Binding ApplyCampaignTargetingPresetCommand}"
                                CommandParameter="TierSegment"
                                FontSize="12" />
                        <Button Text="{x:Static res:AppResources.RewardsCampaignAudiencePointsThreshold}"
                                Command="{Binding ApplyCampaignTargetingPresetCommand}"
                                CommandParameter="PointsThreshold"
                                FontSize="12" />
                        <Button Text="{x:Static res:AppResources.RewardsCampaignAudienceDateWindow}"
                                Command="{Binding ApplyCampaignTargetingPresetCommand}"
                                CommandParameter="DateWindow"
                                FontSize="12" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding CampaignTargetingHint}"
                           FontSize="11"
                           Opacity="0.75" />

                    <Label Text="{Binding CampaignTargetingSchemaValidationMessage}"
                           FontSize="11"
                           TextColor="OrangeRed"
                           IsVisible="{Binding HasCampaignTargetingSchemaValidationError}" />

                    <Button Text="{x:Static res:AppResources.RewardsCampaignTargetingApplyFixButton}"
                            Command="{Binding ApplyCampaignTargetingSchemaFixCommand}"
                            IsVisible="{Binding HasCampaignTargetingSchemaValidationError}" />

                    <Label Text="{Binding CampaignTargetingFixStatusMessage}"
                           FontSize="11"
                           TextColor="SeaGreen"
                           IsVisible="{Binding HasCampaignTargetingFixStatusMessage}" />

                    <Label Text="{Binding CampaignTargetingFixMetricsSummary}"
                           FontSize="11"
                           Opacity="0.7" />

                    <Label Text="{Binding CampaignTargetingFixMetricsWindowSummary}"
                           FontSize="11"
                           Opacity="0.65" />

                    <Button Text="{x:Static res:AppResources.RewardsCampaignTargetingFixMetricsResetButton}"
                            Command="{Binding ResetCampaignTargetingFixMetricsCommand}"
                            IsVisible="{Binding HasCampaignTargetingFixMetrics}" />

                    <Editor Placeholder="{x:Static res:AppResources.RewardsCampaignPayloadJsonPlaceholder}"
                            AutoSize="TextChanges"
                            Text="{Binding CampaignPayloadJsonInput}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="{Binding CampaignSaveButtonText}"
                                Command="{Binding SaveCampaignCommand}"
                                IsEnabled="{Binding CanManageRewards}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.RewardsCampaignNewButton}"
                                Command="{Binding NewCampaignCommand}"
                                IsEnabled="{Binding CanManageRewards}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="{x:Static res:AppResources.RewardsCampaignsLabel}"
                   FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,Auto,*,*,*" ColumnSpacing="8">
                <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignSearchPlaceholder}"
                       Text="{Binding CampaignSearchQuery}" />

                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.RewardsCampaignClearSearchButton}"
                        Command="{Binding ClearCampaignSearchCommand}"
                        IsEnabled="{Binding HasCampaignSearchQuery}" />

                <Picker Grid.Column="2"
                        Title="{x:Static res:AppResources.RewardsCampaignStateFilterPickerTitle}"
                        ItemsSource="{Binding CampaignStateFilterOptions}"
                        SelectedItem="{Binding SelectedCampaignStateFilter}" />

                <Picker Grid.Column="3"
                        Title="{x:Static res:AppResources.RewardsCampaignAudienceFilterPickerTitle}"
                        ItemsSource="{Binding CampaignAudienceFilterOptions}"
                        SelectedItem="{Binding SelectedCampaignAudienceFilter}" />

                <Picker Grid.Column="4"
                        Title="{x:Static res:AppResources.RewardsCampaignSortPickerTitle}"
                        ItemsSource="{Binding CampaignSortOptions}"
                        SelectedItem="{Binding SelectedCampaignSortOption}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Label Text="{Binding CampaignFilterSummary}"
                       VerticalOptions="Center"
                       Opacity="0.8" />

                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.RewardsCampaignClearFiltersButton}"
                        Command="{Binding ClearCampaignFiltersCommand}"
                        IsEnabled="{Binding HasActiveCampaignFilters}" />
            </Grid>

            <Label Text="{Binding CampaignDiagnosticsSnapshotAtText}"
                   FontSize="11"
                   Opacity="0.75"
                   IsVisible="{Binding HasCampaignDiagnosticsSnapshotAt}" />

            <Label Text="{Binding CampaignDiagnosticsVisibleCampaignsPreview}"
                   FontSize="11"
                   Opacity="0.75" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Text="{x:Static res:AppResources.RewardsCampaignCopyDiagnosticsButton}"
                        Command="{Binding CopyCampaignDiagnosticsCommand}"
                        IsEnabled="{Binding HasCampaigns}" />
                <Button Grid.Column="1"
                        Text="{x:Static res:AppResources.RewardsCampaignClearDiagnosticsStatusButton}"
                        Command="{Binding ClearCampaignDiagnosticsStatusCommand}"
                        IsEnabled="{Binding HasCampaignDiagnosticsCopyStatus}" />
            </Grid>

            <Label Text="{Binding CampaignDiagnosticsCopyStatus}"
                   FontSize="11"
                   TextColor="SeaGreen"
                   IsVisible="{Binding HasCampaignDiagnosticsCopyStatus}" />

            <Label Text="{Binding CampaignStateMetricsSummary}"
                   FontSize="12"
                   Opacity="0.75" />

            <HorizontalStackLayout Spacing="6">
                <Button Text="{Binding AllCampaignMetricText}"
                        Command="{Binding ApplyCampaignStateFilterCommand}"
                        CommandParameter=""
                        FontSize="12" />
                <Button Text="{Binding DraftCampaignMetricText}"
                        Command="{Binding ApplyCampaignStateFilterCommand}"
                        CommandParameter="Draft"
                        FontSize="12" />
                <Button Text="{Binding ScheduledCampaignMetricText}"
                        Command="{Binding ApplyCampaignStateFilterCommand}"
                        CommandParameter="Scheduled"
                        FontSize="12" />
                <Button Text="{Binding ActiveCampaignMetricText}"
                        Command="{Binding ApplyCampaignStateFilterCommand}"
                        CommandParameter="Active"
                        FontSize="12" />
                <Button Text="{Binding ExpiredCampaignMetricText}"
                        Command="{Binding ApplyCampaignStateFilterCommand}"
                        CommandParameter="Expired"
                        FontSize="12" />
            </HorizontalStackLayout>

            <Label Text="{Binding CampaignAudienceMetricsSummary}"
                   FontSize="12"
                   Opacity="0.75" />

            <Label Text="{Binding CampaignChannelMetricsSummary}"
                   FontSize="12"
                   Opacity="0.75" />

            <HorizontalStackLayout Spacing="6">
                <Button Text="{Binding AllCampaignAudienceMetricText}"
                        Command="{Binding ApplyCampaignAudienceFilterCommand}"
                        CommandParameter=""
                        FontSize="12" />
                <Button Text="{Binding JoinedMembersCampaignMetricText}"
                        Command="{Binding ApplyCampaignAudienceFilterCommand}"
                        CommandParameter="JoinedMembers"
                        FontSize="12" />
                <Button Text="{Binding TierSegmentCampaignMetricText}"
                        Command="{Binding ApplyCampaignAudienceFilterCommand}"
                        CommandParameter="TierSegment"
                        FontSize="12" />
                <Button Text="{Binding PointsThresholdCampaignMetricText}"
                        Command="{Binding ApplyCampaignAudienceFilterCommand}"
                        CommandParameter="PointsThreshold"
                        FontSize="12" />
                <Button Text="{Binding DateWindowCampaignMetricText}"
                        Command="{Binding ApplyCampaignAudienceFilterCommand}"
                        CommandParameter="DateWindow"
                        FontSize="12" />
            </HorizontalStackLayout>

            <Label Text="{x:Static res:AppResources.RewardsCampaignsEmptyFiltered}"
                   Opacity="0.8"
                   IsVisible="{Binding HasCampaigns, Converter={StaticResource InverseBoolConverter}}" />

            <CollectionView x:Name="CampaignsCollectionView"
                            ItemsSource="{Binding Campaigns}"
                            SelectionMode="Single"
                            IsVisible="{Binding HasCampaigns}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:BusinessCampaignEditorItem">
                        <Border StrokeThickness="1" Stroke="#444444" Padding="10" Margin="0,4,0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding Name}" Opacity="0.8" FontSize="13" />
                                <Label Text="{Binding CampaignState, StringFormat='State: {0}'}" FontSize="12" Opacity="0.8" />
                                <Label Text="{Binding AudienceSummary}" FontSize="12" Opacity="0.8" />
                                <Label Text="{Binding ChannelSummary}" FontSize="12" Opacity="0.8" />
                                <Label Text="{Binding StartsAtUtc, StringFormat='Start: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" Opacity="0.75" IsVisible="{Binding StartsAtUtc, Converter={StaticResource NullCheckConverter}}" />
                                <Label Text="{Binding EndsAtUtc, StringFormat='End: {0:yyyy-MM-dd HH:mm}'}" FontSize="12" Opacity="0.75" IsVisible="{Binding EndsAtUtc, Converter={StaticResource NullCheckConverter}}" />
                                <Button Text="{Binding ActivationButtonText}"
                                        Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ToggleCampaignActivationCommand}"
                                        CommandParameter="{Binding .}"
                                        IsEnabled="{Binding Source={x:Reference PageRoot}, Path=BindingContext.CanManageRewards}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
