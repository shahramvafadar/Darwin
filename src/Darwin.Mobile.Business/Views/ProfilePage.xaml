<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    Title="{x:Static res:AppResources.ProfileTitle}">

    <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                   IsRefreshing="{Binding IsBusy}"
                                   ProgressColor="{StaticResource BrandGold500}"
                                   ProgressBackground="{StaticResource Neutral0}">
        <pullToRefresh:SfPullToRefresh.PullableContent>
            <ScrollView>
                <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="{x:Static res:AppResources.ProfileTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ProfileSectionTitle}" Style="{StaticResource SectionHeadingLabelStyle}" />

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.EmailLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding Email}" IsReadOnly="True" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.FirstNameLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding FirstName}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.LastNameLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding LastName}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.PhoneLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding PhoneE164}" Keyboard="Telephone" Placeholder="{x:Static res:AppResources.ProfilePhonePlaceholder}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.LocaleLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding Locale}" Placeholder="{x:Static res:AppResources.ProfileLocalePlaceholder}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.TimezoneLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding Timezone}" Placeholder="{x:Static res:AppResources.ProfileTimezonePlaceholder}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.CurrencyLabel}"
                                                   Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                        <Entry Text="{Binding Currency}" Placeholder="{x:Static res:AppResources.ProfileCurrencyPlaceholder}" Style="{StaticResource FormEntryStyle}" />
                    </inputLayout:SfTextInputLayout>

                    <!-- Keep feedback directly above primary action for better visibility while keyboard is open. -->
                    <Label Text="{Binding SuccessMessage}"
                           Style="{StaticResource SuccessLabelStyle}"
                           IsVisible="{Binding HasSuccess}" />

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SaveProfileButton}"
                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                      Command="{Binding SaveCommand}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Clicked="OnAccountDeletionClicked" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </Border>
                </VerticalStackLayout>
            </ScrollView>
        </pullToRefresh:SfPullToRefresh.PullableContent>
    </pullToRefresh:SfPullToRefresh>
</ContentPage>
