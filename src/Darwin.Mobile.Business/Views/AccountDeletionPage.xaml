<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
    x:Class="Darwin.Mobile.Business.Views.AccountDeletionPage"
    x:DataType="vm:AccountDeletionViewModel"
    Title="{x:Static res:AppResources.AccountDeletionTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{x:Static res:AppResources.AccountDeletionTitle}"
                   Style="{StaticResource TitleLabelStyle}" />

            <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.AccountDeletionWarningTitle}"
                           Style="{StaticResource SectionHeadingLabelStyle}"
                           TextColor="{StaticResource Danger500}" />

                    <Label Text="{x:Static res:AppResources.AccountDeletionWarningBody}"
                           Style="{StaticResource BodyLabelStyle}" />

                    <Label Text="{x:Static res:AppResources.AccountDeletionExternalHint}"
                           Style="{StaticResource SecondaryBodyLabelStyle}" />

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />

                    <Button Text="{x:Static res:AppResources.AccountDeletionContinueButton}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ContinueCommand}" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
