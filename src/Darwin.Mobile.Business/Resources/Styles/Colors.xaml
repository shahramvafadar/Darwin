<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Unified Light Theme (Business)
        Design intent:
        - Keep a premium white/gold look aligned with the logo.
        - Maintain high readability with dark text on light surfaces.
        - Use gold as accent, not as a large background.
    -->

    <!-- Core neutrals -->
    <Color x:Key="Neutral0">#FFFFFF</Color>
    <!-- pure white -->
    <Color x:Key="Neutral50">#FFFFFF</Color>
    <!-- app background -->
    <Color x:Key="Neutral100">#FFF8E7</Color>
    <!-- subtle borders/dividers -->
    <Color x:Key="Neutral700">#717182</Color>
    <!-- secondary text -->
    <Color x:Key="Neutral900">#2C2416</Color>
    <!-- primary text -->

    <!-- Brand palette -->
    <Color x:Key="BrandGold500">#F4B223</Color>
    <!-- primary brand accent -->
    <Color x:Key="BrandGold300">#FFD24C</Color>
    <!-- secondary brand accent -->
    <Color x:Key="BrandGold600">#E09F1A</Color>
    <!-- pressed/hover -->
    <Color x:Key="BrandGold700">#C98713</Color>
    <!-- strong accent text -->

    <!-- Semantic -->
    <Color x:Key="Success500">#1F8B4C</Color>
    <Color x:Key="Warning500">#B7791F</Color>
    <Color x:Key="Danger500">#C53030</Color>
    <Color x:Key="Info500">#E09F1A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource Neutral50}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource Neutral0}" />
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource BrandGold500}" />
    <SolidColorBrush x:Key="BrushPrimaryLight" Color="{StaticResource BrandGold300}" />
    <SolidColorBrush x:Key="BrushPrimaryPressed" Color="{StaticResource BrandGold600}" />
    <SolidColorBrush x:Key="BrushOnPrimary" Color="{StaticResource Neutral0}" />
    <SolidColorBrush x:Key="BrushOnSurface" Color="{StaticResource Neutral900}" />
    <SolidColorBrush x:Key="BrushOnSurfaceSecondary" Color="{StaticResource Neutral700}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource Neutral100}" />
</ResourceDictionary>
