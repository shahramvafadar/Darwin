# Copy this file to .env for local Docker Desktop usage.
# Never commit .env because it contains local credentials.

DARWIN_POSTGRES_DB=darwin_dev
DARWIN_POSTGRES_USER=darwin_app
DARWIN_POSTGRES_PASSWORD=change-this-local-postgres-password

DARWIN_PGADMIN_EMAIL=admin@example.test
DARWIN_PGADMIN_PASSWORD=change-this-local-pgadmin-password
