# Copy this file to .env for local Docker Desktop usage.
# Never commit .env because it contains local credentials.

DARWIN_POSTGRES_DB=darwin_dev
DARWIN_POSTGRES_USER=darwin_app
DARWIN_POSTGRES_PASSWORD=change-this-local-postgres-password

DARWIN_PGADMIN_EMAIL=admin@example.test
DARWIN_PGADMIN_PASSWORD=change-this-local-pgadmin-password

# Optional local app overrides. Set these in your shell or user-secrets when running apps.
ConnectionStrings__PostgreSql=Host=localhost;Port=5432;Database=darwin_dev;Username=darwin_app;Password=change-this-local-postgres-password;Include Error Detail=true
ConnectionStrings__DefaultConnection=Data Source=.;Initial Catalog=Darwin_Dev;User ID=darwin_app;Password=change-this-local-sqlserver-password;Encrypt=False;Trust Server Certificate=True

# Use false when running apps with a restricted runtime role after migrations/seed were applied by an owner role.
DatabaseStartup__ApplyMigrations=false
DatabaseStartup__Seed=false
